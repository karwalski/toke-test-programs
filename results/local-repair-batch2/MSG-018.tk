m=ps;i=io:std.io;i=s:std.str;f=matchpat(pat:$str;topic:$str):$bool{let pparts=s.split(pat;"/");let tparts=s.split(topic;"/");let pn=pparts.len();let tn=tparts.len();let i=mut.0;lp(i<pn){let p=pparts.get(i);if(s.equals(p;"#")){<true};if(i>=tn){<false};let t=tparts.get(i);if(!s.equals(p;"*")){if(!s.equals(p;"+")){if(!s.equals(p;t)){<false}}};i=i+1};if(tn>pn){<false};<true};f=main():$i64{let nstr=s.trim(io.readln());let n=s.toint(nstr);let subs=mut.@();let i=mut.0;lp(i<n){subs=subs+@(s.trim(io.readln()));i=i+1};let blank=io.readln();lp(true){let line=io.readln();if(s.len(line)=0){br};let trimmed=s.trim(line);if(s.len(trimmed)=0){br};let parts=s.split(trimmed;"|");let topic=parts.get(0);io.println(s.concat(topic;":"));let j=mut.0;lp(j<subs.len()){if(matchpat(subs.get(j);topic)){io.println(s.concat("  ";subs.get(j)))};j=j+1}};<0}
