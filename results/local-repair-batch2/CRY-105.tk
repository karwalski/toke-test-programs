m=blockstats;i=io:std.io;i=s:std.str;i=math:std.math;f=main():$i64{let line=s.trim(io.readln());let parts=s.split(line;",");let n=parts.len();let times=mut.@(0);times=@();let i=mut.1;lp(i<n){let d=s.toint(s.trim(parts.get(i)))-s.toint(s.trim(parts.get(i-1)));times=times+@(d);i=i+1};let m=times.len();let sum=mut.0;let mn=mut.times.get(0);let mx=mut.times.get(0);let j=mut.0;lp(j<m){let v=times.get(j);sum=sum+v;if(v<mn){mn=v};if(v>mx){mx=v};j=j+1};let avg=s.tofloat(s.fromint(sum))/s.tofloat(s.fromint(m));let vs=mut.0.0;let k=mut.0;lp(k<m){let d=s.tofloat(s.fromint(times.get(k)))-avg;vs=vs+d*d;k=k+1};let sd=math.sqrt(vs/s.tofloat(s.fromint(m)));io.println(s.concat(s.concat(s.concat(s.concat(s.concat(s.concat(s.concat("avg:";s.format(avg;"%.1f"));" min:");s.fromint(mn));" max:");s.fromint(mx));" stddev:");s.format(sd;"%.1f")));<0}
