m=nft;i=io:std.io;i=s:std.str;f=main():$i64{let tokens=mut.@($i64);let owners=mut.@($str);lp(1){let l=io.readln();if(s.len(l)=0){br};let t=s.trim(l);if(s.len(t)=0){br};let parts=s.split(t;" ");let cmd=parts.get(0);let tid=s.toint(parts.get(1));if(cmd="MINT"){let owner=parts.get(2);tokens=tokens+@(tid);owners=owners+@(owner)};if(cmd="TRANSFER"){let from=parts.get(2);let to=parts.get(3);let foundIdx=mut.-1;lp(let i=0;i<tokens.len();i=i+1){if(tokens.get(i)=tid){foundIdx=i}};if(foundIdx>=0){let curOwner=owners.get(foundIdx);let isOwner=mut.false;if(s.len(curOwner)=s.len(from)){if(s.indexof(curOwner;from)=0){if(s.indexof(from;curOwner)=0){isOwner=true}}};if(!isOwner){let err=mut."ERROR: ";err=s.concat(err;from);err=s.concat(err;" does not own token ");err=s.concat(err;s.fromint(tid));io.println(err);<0};owners=owners.set(foundIdx;to)}}};let n=tokens.len();lp(let a=0;a<n-1;a=a+1){lp(let b=0;b<n-a-1;b=b+1){if(tokens.get(b)>tokens.get(b+1)){let tt=tokens.get(b);tokens=tokens.set(b;tokens.get(b+1));tokens=tokens.set(b+1;tt);let to=owners.get(b);owners=owners.set(b;owners.get(b+1));owners=owners.set(b+1;to)}}};let out=mut."{";lp(let i=0;i<n;i=i+1){if(i>0){out=s.concat(out;",")};out=s.concat(out;"\"");out=s.concat(out;s.fromint(tokens.get(i)));out=s.concat(out;"\":\"");out=s.concat(out;owners.get(i));out=s.concat(out;"\"")};out=s.concat(out;"}");io.println(out);<0}
