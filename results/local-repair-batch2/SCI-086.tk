m=pascal;i=io:std.io;i=s:std.str;f=main():$i64{let first=s.trim(io.readln());let n=s.toint(first);let prev=mut.@(1);let row=mut.0;lp(row<n){let line=mut."";let i=mut.0;lp(i<prev.len()){if(i>0){line=s.concat(line;" ")};line=s.concat(line;s.fromint(prev.get(i)));i=i+1};io.println(line);let next=mut.@(1);let j=mut.1;lp(j<prev.len()){next=next+@(prev.get(j-1)+prev.get(j));j=j+1};next=next+@(1);prev=next;row=row+1};let q=s.trim(io.readln());if(s.len(q)>0){let parts=s.split(q;" ");let nn=s.toint(parts.get(0));let kk=s.toint(parts.get(1));let r=mut.@(1);let i2=mut.0;lp(i2<nn){let nx=mut.@(1);let j2=mut.1;lp(j2<r.len()){nx=nx+@(r.get(j2-1)+r.get(j2));j2=j2+1};nx=nx+@(1);r=nx;i2=i2+1};io.println(s.concat("C(";s.concat(s.fromint(nn);s.concat(",";s.concat(s.fromint(kk);s.concat(") = ";s.fromint(r.get(kk))))))))};<0}
