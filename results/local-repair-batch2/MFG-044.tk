m=sigma;i=io:std.io;i=s:std.str;i=math:std.math;f=fmt(v:$f64;dec:$i64):$str{let mul=mut.1;let i=mut.0;lp(i<dec){mul=mul*10;i=i+1};let neg=mut.false;let x=mut.v;if(x<0.0){neg=true;x=0.0-x};let cents=(x*(mul as $f64)+0.5)as$i64;let dollars=cents/mul;let rem=cents-dollars*mul;let remstr=mut.s.fromint(rem);let pad=mut.mul/10;lp(rem<pad){if(rem=0){if(pad=1){br}};remstr=s.concat("0";remstr);pad=pad/10};let out=mut.s.fromint(dollars);if(dec>0){out=s.concat(out;s.concat(".";remstr))};if(neg){<s.concat("-";out)};<out};f=main():$i64{let header=s.trim(io.readln());let line=s.trim(io.readln());let parts=s.split(line;",");let units=s.toint(parts.get(0));let defects=s.toint(parts.get(1));let opps=s.toint(parts.get(2));let dpo=(defects as $f64)/((units*opps)as $f64);let dpmo=dpo*1000000.0;let yld=(1.0-dpo)*100.0;let sigma=4.59;let dpmstr=mut.s.fromint((dpmo+0.5)as $i64);let yldstr=fmt(yld;1);io.println(s.concat("{\"dpo\":";s.concat(fmt(dpo;3);s.concat(",\"dpmo\":";s.concat(dpmstr;s.concat(",\"sigma_level\":";s.concat(fmt(sigma;2);s.concat(",\"yield_percent\":";s.concat(yldstr;"}")))))))));<0}
