m=apv;i=io:std.io;i=s:std.str;i=math:std.math;f=main():$i64{let parts=s.split(s.trim(io.readln());" ");let pmt=s.tofloat(parts.get(0));let r=s.tofloat(parts.get(1));let nP=s.toint(parts.get(2));let onePlusR=1.0+r;let factor=mut.1.0;lp(let i=0;i<nP;i=i+1){factor=factor*onePlusR};let pv=pmt*(1.0-1.0/factor)/r;io.println(s.format(pv;"%.2f"));<0}
