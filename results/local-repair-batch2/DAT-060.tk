m=fc;i=io:std.io;i=s:std.str;f=main():$i64{let vals=mut.@($str);let cnts=mut.@($i64);lp(1){let line=io.readln();if(s.len(line)=0){br};let v=s.trim(line);if(s.len(v)=0){br};let found=mut.-1;lp(let i=0;i<vals.len();i=i+1){if(vals.get(i)=v){found=i}};if(found>=0){cnts=cnts.set(found;cnts.get(found)+1)}el{vals=vals+@(v);cnts=cnts+@(1)}};let n=vals.len();lp(let a=0;a<n-1;a=a+1){lp(let b=0;b<n-a-1;b=b+1){let cb=cnts.get(b);let cn=cnts.get(b+1);let vb=vals.get(b);let vn=vals.get(b+1);let swap=mut.false;if(cn>cb){swap=true};if(cn=cb){if(vn<vb){swap=true}};if(swap){cnts=cnts.set(b;cn);cnts=cnts.set(b+1;cb);vals=vals.set(b;vn);vals=vals.set(b+1;vb)}}};lp(let i=0;i<n;i=i+1){let out=mut.vals.get(i);out=s.concat(out;"\t");out=s.concat(out;s.fromint(cnts.get(i)));io.println(out)};<0}
