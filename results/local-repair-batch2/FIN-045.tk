m=variance;i=io:std.io;i=s:std.str;f=fget(a:@$f64;idx:$i64):$f64{<a.get(idx)};f=main():$i64{let line=s.trim(io.readln());let parts=s.split(line;",");let n=parts.len();let arr=mut.@($f64);lp(let i=0;i<n;i=i+1){arr=arr+@(s.tofloat(parts.get(i)))};let sum=mut.0.0;lp(let i=0;i<n;i=i+1){sum=sum+fget(arr;i)};let nf=s.tofloat(s.fromint(n));let mean=sum/nf;let sq=mut.0.0;lp(let i=0;i<n;i=i+1){let d=fget(arr;i)-mean;sq=sq+d*d};let pop=sq/nf;let samp=sq/s.tofloat(s.fromint(n-1));io.println(s.format(pop;"%.4f"));io.println(s.format(samp;"%.4f"));<0}
