m=cc;i=io:std.io;i=s:std.str;i=math:std.math;f=main():$i64{let line=s.trim(io.readln());let p=s.split(line;",");let n=p.len();let counts=mut.@(0);counts=@();let i=mut.0;let sm=mut.0;lp(i<n){let v=s.toint(s.trim(p.get(i)));counts=counts+@(v);sm=sm+v;i=i+1};let cbar=s.tofloat(s.fromint(sm))/s.tofloat(s.fromint(n));let ucl=cbar+3.0*math.sqrt(cbar);let lcl=mut.cbar-3.0*math.sqrt(cbar);if(lcl<0.0){lcl=0.0};let ooc=mut.@(0);ooc=@();let j=mut.0;lp(j<n){let v=s.tofloat(s.fromint(counts.get(j)));if(v>ucl){ooc=ooc+@(j)};if(v<lcl){ooc=ooc+@(j)};j=j+1};let oocs=mut."[";let k=mut.0;lp(k<ooc.len()){if(k>0){oocs=s.concat(oocs;",")};oocs=s.concat(oocs;s.fromint(ooc.get(k)));k=k+1};oocs=s.concat(oocs;"]");let out=mut."{\"c_bar\":";out=s.concat(out;s.format(cbar;"%.1f"));out=s.concat(out;",\"ucl\":");out=s.concat(out;s.format(ucl;"%.2f"));out=s.concat(out;",\"lcl\":");out=s.concat(out;s.format(lcl;"%.1f"));out=s.concat(out;",\"out_of_control\":");out=s.concat(out;oocs);out=s.concat(out;"}");io.println(out);<0}
