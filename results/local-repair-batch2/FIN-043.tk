m=mode;i=io:std.io;i=s:std.str;f=main():$i64{let line=s.trim(io.readln());let parts=s.split(line;",");let n=parts.len();let nums=mut.@(0);nums=@();let i=mut.0;lp(i<n){nums=nums+@(s.toint(parts.get(i)));i=i+1};let maxfreq=mut.1;let j=mut.0;lp(j<n){let cnt=mut.0;let k=mut.0;lp(k<n){if(nums.get(k)=nums.get(j)){cnt=cnt+1};k=k+1};if(cnt>maxfreq){maxfreq=cnt};j=j+1};if(maxfreq=1){io.println("NO_MODE")}el{let modes=mut.@(0);modes=@();let m=mut.0;lp(m<n){let cnt=mut.0;let kk=mut.0;lp(kk<n){if(nums.get(kk)=nums.get(m)){cnt=cnt+1};kk=kk+1};if(cnt=maxfreq){let v=nums.get(m);let already=mut.false;let z=mut.0;lp(z<modes.len()){if(modes.get(z)=v){already=true};z=z+1};if(!already){modes=modes+@(v)}};m=m+1};let mn=modes.len();let a=mut.0;lp(a<mn){let b=mut.a+1;lp(b<mn){if(modes.get(a)>modes.get(b)){let tmp=modes.get(a);modes=modes.set(a;modes.get(b));modes=modes.set(b;tmp)};b=b+1};a=a+1};let out=mut."";let q=mut.0;lp(q<mn){if(q>0){out=s.concat(out;",")};out=s.concat(out;s.fromint(modes.get(q)));q=q+1};io.println(out)};<0}
