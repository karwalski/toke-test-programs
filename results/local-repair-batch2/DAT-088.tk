m=adjmat;i=io:std.io;i=s:std.str;f=main():$i64{let lines=mut.@();lp(true){let line=io.readln();if(s.len(line)=0){br};let trimmed=mut.line;if(s.endswith(trimmed;"\n")){trimmed=s.slice(trimmed;0;s.len(trimmed)-1)};if(s.len(trimmed)=0){br};lines=lines+@(trimmed)};if(lines.len()<2){<0};let header=s.split(lines.get(0);",");let n=header.len()-1;let names=mut.@();let h=mut.1;lp(h<header.len()){names=names+@(header.get(h));h=h+1};let edges=mut.@();let i=mut.1;lp(i<lines.len()){let parts=s.split(lines.get(i);",");if(parts.len()=n+1){let from=parts.get(0);let j=mut.0;lp(j<n){let w=s.toint(parts.get(j+1));if(w!=0){edges=edges+@(s.concat(from;s.concat(",";s.concat(names.get(j);s.concat(",";s.fromint(w))))))};j=j+1}};i=i+1};let m=edges.len();let p=mut.0;lp(p<m){let q=mut.p+1;lp(q<m){if(edges.get(q)<edges.get(p)){let tmp=edges.get(p);let nx=edges.get(q);let neu=mut.@();let k=mut.0;lp(k<m){if(k=p){neu=neu+@(nx)}el{if(k=q){neu=neu+@(tmp)}el{neu=neu+@(edges.get(k))}};k=k+1};edges=neu};q=q+1};p=p+1};let oi=mut.0;lp(oi<m){let e=s.split(edges.get(oi);",");io.println(s.concat(e.get(0);s.concat(" ";s.concat(e.get(1);s.concat(" ";e.get(2))))));oi=oi+1};<0}
