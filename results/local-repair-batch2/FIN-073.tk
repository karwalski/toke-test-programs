m=balance;i=io:std.io;i=s:std.str;f=main():$i64{let atotal=mut.0.0;let ltotal=mut.0.0;let etotal=mut.0.0;let done=mut.0;lp(done<1){let line=io.readln();if(s.len(line)=0){done=1}el{let trimmed=s.trim(line);if(s.len(trimmed)=0){done=1}el{let parts=s.split(trimmed;" ");if(parts.len()<3){done=1}el{let etype=parts.get(0);let amt=s.tofloat(parts.get(2));if(s.equals(etype;"ASSET")){atotal=atotal+amt}el{if(s.equals(etype;"LIABILITY")){ltotal=ltotal+amt}el{if(s.equals(etype;"EQUITY")){etotal=etotal+amt}}}}}}};io.println(s.concat("ASSETS: ";s.format(atotal;"%.2f")));io.println(s.concat("LIABILITIES: ";s.format(ltotal;"%.2f")));io.println(s.concat("EQUITY: ";s.format(etotal;"%.2f")));let diff=mut.atotal-(ltotal+etotal);if(diff<0.0){diff=0.0-diff};if(diff<0.01){io.println("BALANCED")}el{io.println("NOT BALANCED")};<0}
