m=phi;i=io:std.io;i=s:std.str;f=gcd(a:$i64;b:$i64):$i64{let x=mut.a;let y=mut.b;lp(y>0){let t=y;y=x-(x/y)*y;x=t};<x};f=phi(n:$i64):$i64{if(n=1){<1};let count=mut.0;lp(let i=1;!(i>n);i=i+1){if(gcd(i;n)=1){count=count+1}};<count};f=main():$i64{let n=s.toint(s.trim(io.readln()));let result=phi(n);io.println(s.fromint(result));<0}
