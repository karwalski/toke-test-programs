m=lin;i=io:std.io;i=s:std.str;i=math:std.math;f=main():$i64{let line=mut.io.readln();let header=mut.true;let xs=mut.@(0.0);xs=@();let ys=mut.@(0.0);ys=@();let empties=mut.0;lp(empties<2){let t=s.trim(line);if(s.len(t)>0){empties=0;if(header){header=false}el{let p=s.split(t;",");xs=xs+@(s.tofloat(p.get(0)));ys=ys+@(s.tofloat(p.get(1)))}}el{empties=empties+1};line=io.readln()};let n=xs.len();let nf=s.tofloat(s.fromint(n));let sx=mut.0.0;let sy=mut.0.0;let sxy=mut.0.0;let sxx=mut.0.0;let syy=mut.0.0;let i=mut.0;lp(i<n){let x=xs.get(i);let y=ys.get(i);sx=sx+x;sy=sy+y;sxy=sxy+x*y;sxx=sxx+x*x;syy=syy+y*y;i=i+1};let slope=(nf*sxy-sx*sy)/(nf*sxx-sx*sx);let intercept=(sy-slope*sx)/nf;let num=nf*sxy-sx*sy;let den=math.sqrt((nf*sxx-sx*sx)*(nf*syy-sy*sy));let r=num/den;let r2=r*r;let lin=mut.false;if(slope>=0.9){if(slope<=1.1){if(r2>0.99){lin=true}}};let out=mut."{\"slope\":";out=s.concat(out;s.format(slope;"%.2f"));out=s.concat(out;",\"intercept\":");out=s.concat(out;s.format(intercept;"%.2f"));out=s.concat(out;",\"r_squared\":");out=s.concat(out;s.format(r2;"%.1f"));out=s.concat(out;",\"linear\":");if(lin){out=s.concat(out;"true")}el{out=s.concat(out;"false")};out=s.concat(out;"}");io.println(out);<0}
