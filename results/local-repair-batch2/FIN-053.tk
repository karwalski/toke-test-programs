m=lr;i=io:std.io;i=s:std.str;f=fget(a:@$f64;idx:$i64):$f64{<a.get(idx)};f=main():$i64{let xl=s.trim(io.readln());let yl=s.trim(io.readln());let xp=s.split(xl;",");let yp=s.split(yl;",");let n=xp.len();let xs=mut.@($f64);let ys=mut.@($f64);lp(let i=0;i<n;i=i+1){xs=xs+@(s.tofloat(xp.get(i)));ys=ys+@(s.tofloat(yp.get(i)))};let xsum=mut.0.0;let ysum=mut.0.0;lp(let i=0;i<n;i=i+1){xsum=xsum+fget(xs;i);ysum=ysum+fget(ys;i)};let nf=s.tofloat(s.fromint(n));let xm=xsum/nf;let ym=ysum/nf;let num=mut.0.0;let den=mut.0.0;lp(let i=0;i<n;i=i+1){let dx=fget(xs;i)-xm;let dy=fget(ys;i)-ym;num=num+dx*dy;den=den+dx*dx};let slope=num/den;let intc=ym-slope*xm;let ssr=mut.0.0;let sst=mut.0.0;lp(let i=0;i<n;i=i+1){let yp=slope*fget(xs;i)+intc;let dr=fget(ys;i)-yp;let dt=fget(ys;i)-ym;ssr=ssr+dr*dr;sst=sst+dt*dt};let r2=1.0-ssr/sst;io.println(s.format(slope;"%.4f"));io.println(s.format(intc;"%.4f"));io.println(s.format(r2;"%.4f"));<0}
