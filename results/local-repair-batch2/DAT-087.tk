m=adj;i=io:std.io;i=s:std.str;f=main():$i64{let nodeLine=io.readln();let nodes=s.split(nodeLine;" ");let n=nodes.len;let matrix=mut.@();let i=mut.0;lp(i<n*n){matrix=matrix+@(0);i=i+1};lp(1=1){let line=io.readln();if(s.len(line)=0){br};let p=s.split(line;" ");let from=p.get(0);let to=p.get(1);let w=s.toint(p.get(2));let fromIdx=mut.0-1;let toIdx=mut.0-1;let k=mut.0;lp(k<n){if(s.equals(nodes.get(k);from)){fromIdx=k};if(s.equals(nodes.get(k);to)){toIdx=k};k=k+1};if(fromIdx>=0){if(toIdx>=0){matrix=matrix.set(fromIdx*n+toIdx;w)}}};let hdr=mut."";let j=mut.0;lp(j<n){hdr=s.concat(s.concat(hdr;",");nodes.get(j));j=j+1};io.println(hdr);let r=mut.0;lp(r<n){let lineout=mut.nodes.get(r);let c=mut.0;lp(c<n){lineout=s.concat(s.concat(lineout;",");s.fromint(matrix.get(r*n+c)));c=c+1};io.println(lineout);r=r+1};<0}
