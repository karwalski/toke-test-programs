m=maxrect;i=io:std.io;i=s:std.str;f=main():$i64{let hdr=s.split(s.trim(io.readln());" ");let rows=s.toint(hdr.get(0));let cols=s.toint(hdr.get(1));let mat=mut.@($i64);let total=rows*cols;lp(let r=0;r<rows;r=r+1){let line=s.trim(io.readln());let parts=s.split(line;" ");lp(let c=0;c<cols;c=c+1){mat=mat+@(s.toint(parts.get(c)))}};let maxSum=mut.-1000000000;let fT=mut.0;let fB=mut.0;let fL=mut.0;let fR=mut.0;lp(let left=0;left<cols;left=left+1){let temp=mut.@($i64);lp(let i=0;i<rows;i=i+1){temp=temp+@(0)};lp(let right=left;right<cols;right=right+1){lp(let i=0;i<rows;i=i+1){temp=temp.set(i;temp.get(i)+mat.get(i*cols+right))};let curSum=mut.0;let topIdx=mut.0;let tempStart=mut.0;let bestSum=mut.-1000000000;let bTop=mut.0;let bBot=mut.0;lp(let k=0;k<rows;k=k+1){curSum=curSum+temp.get(k);if(curSum>bestSum){bestSum=curSum;bTop=tempStart;bBot=k};if(curSum<0){curSum=0;tempStart=k+1}};if(bestSum>maxSum){maxSum=bestSum;fT=bTop;fB=bBot;fL=left;fR=right}}};io.println(s.concat("Max sum: ";s.fromint(maxSum)));let out=mut."Rectangle: top_left=(";out=s.concat(out;s.fromint(fT));out=s.concat(out;",");out=s.concat(out;s.fromint(fL));out=s.concat(out;") bottom_right=(");out=s.concat(out;s.fromint(fB));out=s.concat(out;",");out=s.concat(out;s.fromint(fR));out=s.concat(out;")");io.println(out);<0}
