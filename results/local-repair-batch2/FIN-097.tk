m=lcmc;i=io:std.io;i=s:std.str;f=gcd(a:$i64;b:$i64):$i64{let x=mut.a;let y=mut.b;lp(y!=0){let t=y;y=x-(x/y)*y;x=t};<x};f=lcm(a:$i64;b:$i64):$i64{<(a/gcd(a;b))*b};f=main():$i64{let line=s.trim(io.readln());let parts=s.split(line;",");let res=mut.s.toint(s.trim(parts.get(0)));let i=mut.1;lp(i<parts.len()){res=lcm(res;s.toint(s.trim(parts.get(i))));i=i+1};io.println(s.fromint(res));<0}
