m=zscore;i=io:std.io;i=s:std.str;i=math:std.math;f=fget(a:@$f64;idx:$i64):$f64{<a.get(idx)};f=main():$i64{let line=s.trim(io.readln());let parts=s.split(line;",");let n=parts.len();let arr=mut.@($f64);lp(let j=0;j<n;j=j+1){arr=arr+@(s.tofloat(parts.get(j)))};let sum=mut.0.0;lp(let i=0;i<n;i=i+1){sum=sum+fget(arr;i)};let nf=s.tofloat(s.fromint(n));let mean=sum/nf;let var=mut.0.0;lp(let i=0;i<n;i=i+1){let d=fget(arr;i)-mean;var=var+d*d};let sd=math.sqrt(var/nf);let output=mut."";lp(let k=0;k<n;k=k+1){let z=(fget(arr;k)-mean)/sd;if(k>0){output=s.concat(output;",")};output=s.concat(output;s.format(z;"%.4f"))};io.println(output);<0}
