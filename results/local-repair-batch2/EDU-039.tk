m=ps;i=io:std.io;i=s:std.str;f=fmtmin(t:$i64):$str{let h=t/60;let m=t%60;let hs=mut.s.fromint(h);if(h<10){hs=s.concat("0";hs)};let ms=mut.s.fromint(m);if(m<10){ms=s.concat("0";ms)};<s.concat(s.concat(hs;":");ms)};f=main():$i64{let line=io.readln();let p=s.split(line;" ");let w=s.toint(p.get(0));let b=s.toint(p.get(1));let total=s.toint(p.get(2));let cur=mut.0;let isWork=mut.true;lp(cur<total){let dur=mut.w;if(!isWork){dur=b};let nxt=mut.cur+dur;if(nxt>total){nxt=total};let kind=mut."WORK";if(!isWork){kind="BREAK"};io.println(s.concat(s.concat(s.concat(s.concat(fmtmin(cur);"-");fmtmin(nxt));" ");kind));cur=nxt;isWork=!isWork};<0}
