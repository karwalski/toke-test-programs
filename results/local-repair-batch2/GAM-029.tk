m=tetris;i=io:std.io;i=s:std.str;f=main():$i64{let board=mut.@();lp(true){let line=io.readln();if(s.len(line)=0){br};let trimmed=mut.line;if(s.endswith(trimmed;"\n")){trimmed=s.slice(trimmed;0;s.len(trimmed)-1)};if(s.len(trimmed)=0){br};board=board+@(trimmed)};let cleared=mut.0;let kept=mut.@();let i=mut.0;lp(i<board.len()){let row=board.get(i);let full=mut.true;let j=mut.0;lp(j<s.len(row)){if(s.slice(row;j;j+1)="."){full=false;br};j=j+1};if(full){cleared=cleared+1}el{kept=kept+@(row)};i=i+1};let empty=mut."";let w=mut.10;if(board.len()>0){w=s.len(board.get(0))};let q=mut.0;lp(q<w){empty=s.concat(empty;".");q=q+1};io.println(s.fromint(cleared));let blanks=mut.@();let b=mut.0;lp(b<cleared){blanks=blanks+@(empty);b=b+1};let out=blanks+kept;let p=mut.0;lp(p<out.len()){io.println(out.get(p));p=p+1};<0}
