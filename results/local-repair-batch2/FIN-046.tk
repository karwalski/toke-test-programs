m=pct;i=io:std.io;i=s:std.str;f=main():$i64{let p=s.tofloat(s.trim(io.readln()));let line=s.trim(io.readln());let parts=s.split(line;",");let n=parts.len();let arr=mut.@(0.0);arr=@();let i=mut.0;lp(i<n){arr=arr+@(s.tofloat(s.trim(parts.get(i))));i=i+1};let a=mut.0;lp(a<n){let b=mut.a+1;lp(b<n){if(arr.get(a)>arr.get(b)){let t=arr.get(a);arr=arr.set(a;arr.get(b));arr=arr.set(b;t)};b=b+1};a=a+1};let idx=(p/100.0)*s.tofloat(s.fromint(n-1));let li=idx as $i64;let ui=li+1;let res=mut.0.0;if(ui>=n){res=arr.get(n-1)}el{let lv=arr.get(li);let uv=arr.get(ui);let frac=idx-s.tofloat(s.fromint(li));res=lv+frac*(uv-lv)};io.println(s.format(res;"%.4f"));<0}
