m=toposort;i=io:std.io;i=s:std.str;f=main():$i64{let line=s.trim(io.readln());let parts=s.split(line;" ");let v=s.toint(parts.get(0));let e=s.toint(parts.get(1));let froms=mut.@();let tos=mut.@();lp(let i=0;i<e;i=i+1){let eline=s.trim(io.readln());let ep=s.split(eline;" ");froms=froms+@(s.toint(ep.get(0)));tos=tos+@(s.toint(ep.get(1)))};let indeg=mut.@();lp(let i=0;i<v;i=i+1){indeg=indeg+@(0)};lp(let i=0;i<e;i=i+1){let t=tos.get(i);indeg=indeg.set(t;indeg.get(t)+1)};let order=mut.@();let processed=mut.0;lp(processed<v){let found=mut.-1;lp(let i=0;i<v;i=i+1){if(found<0){if(indeg.get(i)=0){found=i}}};if(found<0){br};order=order+@(found);indeg=indeg.set(found;-1);lp(let i=0;i<e;i=i+1){if(froms.get(i)=found){let t=tos.get(i);indeg=indeg.set(t;indeg.get(t)-1)}};processed=processed+1};if(processed<v){io.println("CYCLE")}el{let result=mut."";lp(let i=0;i<order.len();i=i+1){if(i>0){result=s.concat(result;" ")};result=s.concat(result;s.fromint(order.get(i)))};io.println(s.concat("Topological order: ";result))};<0}
