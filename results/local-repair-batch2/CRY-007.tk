m=hexenc;i=io:std.io;i=s:std.str;f=hexd(n:$i64):$str{if(n<10){<s.fromint(n)};if(n=10){<"a"};if(n=11){<"b"};if(n=12){<"c"};if(n=13){<"d"};if(n=14){<"e"};<"f"};f=main():$i64{let line=io.readln();let trimmed=s.trim(line);let n=s.len(trimmed);let idx=mut.0;let out=mut."";lp(idx<n){let ch=s.slice(trimmed;idx;idx+1);let code=s.charcode(ch;0);let hi=code/16;let lo=code-hi*16;out=s.concat(out;s.concat(hexd(hi);hexd(lo)));idx=idx+1};io.println(out);<0}
