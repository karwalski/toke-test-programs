m=chess;i=io:std.io;i=s:std.str;f=cnt(fen:$str;letter:$str):$i64{let count=mut.0;let pos=mut.0;let n=s.len(fen);lp(pos<n){let idx=s.indexof(s.slice(fen;pos;n);letter);if(idx<0){br};count=count+1;pos=pos+idx+1};<count};f=main():$i64{let fen=s.trim(io.readln());let wp=cnt(fen;"P");let wr=cnt(fen;"R");let wn=cnt(fen;"N");let wb=cnt(fen;"B");let wq=cnt(fen;"Q");let bp=cnt(fen;"p");let brk=cnt(fen;"r");let bn=cnt(fen;"n");let bb=cnt(fen;"b");let bq=cnt(fen;"q");let score=wp+wr*5+wn*3+wb*3+wq*9-bp-brk*5-bn*3-bb*3-bq*9;io.println(s.fromint(score));<0}
