m=crt;i=io:std.io;i=s:std.str;f=gcd(a:$i64;b:$i64):$i64{if(b=0){<a};let r=a-a/b*b;<gcd(b;r)};f=modinv(a:$i64;m:$i64):$i64{let x=mut.1;lp(x<m){if((a*x-(a*x)/m*m)=1){<x};x=x+1};<0};f=main():$i64{let k=s.toint(s.trim(io.readln()));let rems=mut.@();let mods=mut.@();lp(let i=0;i<k;i=i+1){let line=s.trim(io.readln());let parts=s.split(line;" ");rems=rems+@(s.toint(parts.get(0)));mods=mods+@(s.toint(parts.get(1)))};let coprime=mut.1;lp(let i=0;i<k;i=i+1){lp(let j=i+1;j<k;j=j+1){if(gcd(mods.get(i);mods.get(j))!=1){coprime=0}}};if(coprime=0){io.println("NO SOLUTION (moduli not coprime with inconsistent remainders)");<0};let mm=mut.mods.get(0);lp(let i=1;i<k;i=i+1){let g=gcd(mm;mods.get(i));mm=mm*mods.get(i)/g};let x=mut.0;lp(let i=0;i<k;i=i+1){let mmi=mm/mods.get(i);let yi=modinv(mmi;mods.get(i));x=x+rems.get(i)*mmi*yi};x=x-x/mm*mm;if(x<0){x=x+mm};io.println(s.concat(s.concat(s.concat(s.concat("x = ";s.fromint(x));" (mod ");s.fromint(mm));")"));<0}
