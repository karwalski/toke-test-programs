m=li;i=io:std.io;i=s:std.str;f=main():$i64{let l1=io.readln();let l2=io.readln();let p1=s.split(l1;" ");let p2=s.split(l2;" ");let x1=s.tofloat(p1.get(0));let y1=s.tofloat(p1.get(1));let x2=s.tofloat(p1.get(2));let y2=s.tofloat(p1.get(3));let x3=s.tofloat(p2.get(0));let y3=s.tofloat(p2.get(1));let x4=s.tofloat(p2.get(2));let y4=s.tofloat(p2.get(3));let denom=(x1-x2)*(y3-y4)-(y1-y2)*(x3-x4);if(denom=0.0){let cross=(x3-x1)*(y2-y1)-(y3-y1)*(x2-x1);if(cross=0.0){io.println("COLLINEAR")}el{io.println("PARALLEL")};<0};let t=((x1-x3)*(y3-y4)-(y1-y3)*(x3-x4))/denom;let u=0.0-(((x1-x2)*(y1-y3)-(y1-y2)*(x1-x3))/denom);if(t>=0.0){if(t<=1.0){if(u>=0.0){if(u<=1.0){let px=x1+t*(x2-x1);let py=y1+t*(y2-y1);io.println(s.concat(s.concat(s.concat(s.concat("INTERSECT at (";s.format(px;"%.6f"));", ");s.format(py;"%.6f"));")"));<0}}}};io.println("NO INTERSECT");<0}
