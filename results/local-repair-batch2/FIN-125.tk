m=tlh;i=io:std.io;i=s:std.str;f=fget(a:@$f64;idx:$i64):$f64{<a.get(idx)};f=main():$i64{let tickers=mut.@($str);let losses=mut.@($f64);lp(1){let l=io.readln();if(s.len(l)=0){br};let t=s.trim(l);if(s.len(t)=0){br};let parts=s.split(t;" ");if(parts.len()<5){br};let tkr=parts.get(0);let bp=s.tofloat(parts.get(2));let cp=s.tofloat(parts.get(3));let qty=s.tofloat(parts.get(4));let loss=(cp-bp)*qty;if(loss<0.0){tickers=tickers+@(tkr);losses=losses+@(loss)}};let n=tickers.len();lp(let a=0;a<n-1;a=a+1){lp(let b=0;b<n-a-1;b=b+1){if(fget(losses;b)>fget(losses;b+1)){let tl=fget(losses;b);losses=losses.set(b;fget(losses;b+1));losses=losses.set(b+1;tl);let tt=tickers.get(b);tickers=tickers.set(b;tickers.get(b+1));tickers=tickers.set(b+1;tt)}}};lp(let i=0;i<n;i=i+1){io.println(s.concat(s.concat(tickers.get(i);" ");s.format(fget(losses;i);"%.2f")))};<0}
