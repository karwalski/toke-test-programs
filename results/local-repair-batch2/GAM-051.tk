m=dp;i=io:std.io;i=s:std.str;f=fget(a:@$f64;idx:$i64):$f64{<a.get(idx)};f=main():$i64{let parts=s.split(s.trim(io.readln());" ");let nDice=s.toint(parts.get(0));let nSides=s.toint(parts.get(1));let minS=nDice;let maxS=nDice*nSides;let nCounts=maxS+1;let dist=mut.@($f64);lp(let i=0;i<=maxS;i=i+1){dist=dist+@(0.0)};dist=dist.set(0;1.0);lp(let d=0;d<nDice;d=d+1){let newDist=mut.@($f64);lp(let i=0;i<=maxS;i=i+1){newDist=newDist+@(0.0)};lp(let sum=0;sum<=maxS;sum=sum+1){let cur=fget(dist;sum);if(cur>0.0){lp(let face=1;face<=nSides;face=face+1){if(sum+face<=maxS){newDist=newDist.set(sum+face;fget(newDist;sum+face)+cur)}}}};dist=newDist};let total=mut.1.0;lp(let i=0;i<nDice;i=i+1){total=total*s.tofloat(s.fromint(nSides))};lp(let s2=minS;s2<=maxS;s2=s2+1){let prob=fget(dist;s2)/total*100.0;let outl=mut.s.fromint(s2);outl=s.concat(outl;": ");outl=s.concat(outl;s.format(prob;"%.2f"));outl=s.concat(outl;"%");io.println(outl)};<0}
