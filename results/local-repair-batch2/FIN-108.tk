m=payback;i=io:std.io;i=s:std.str;i=math:std.math;f=payback(inv:$f64;cfs:@($f64)):$str{let cum=mut.0.0;let n=cfs.len();let i=mut.0;let res=mut."NEVER_RECOVERED";let found=mut.false;lp(i<n){if(!found){let prev=cum;let cf=cfs.get(i);cum=cum+cf;if(cum>=inv){let yrs=mut.s.tofloat(s.fromint(i+1));if(cf!=0.0){yrs=s.tofloat(s.fromint(i))+(inv-prev)/cf};res=s.format(yrs;"%.2f");found=true}};i=i+1};<res};f=main():$i64{let l1=s.trim(io.readln());let p1=s.split(l1;" ");let inv=s.tofloat(p1.get(0));let r=s.tofloat(p1.get(1));let l2=s.trim(io.readln());let parts=s.split(l2;",");let cfs=mut.@(0.0);cfs=@();let i=mut.0;lp(i<parts.len()){cfs=cfs+@(s.tofloat(parts.get(i)));i=i+1};let dcfs=mut.@(0.0);dcfs=@();let j=mut.0;lp(j<cfs.len()){let t=s.tofloat(s.fromint(j+1));let denom=math.pow(1.0+r;t);dcfs=dcfs+@(cfs.get(j)/denom);j=j+1};io.println(payback(inv;cfs));io.println(payback(inv;dcfs));<0}
