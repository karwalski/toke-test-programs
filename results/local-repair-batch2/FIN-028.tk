m=inv;i=io:std.io;i=s:std.str;f=main():$i64{let subtotal=mut.0.0;let tax=mut.0.0;lp(1=1){let line=io.readln();if(s.len(line)=0){br};let parts=s.split(line;" ");if(parts.len<4){br};let qty=s.tofloat(parts.get(1));let price=s.tofloat(parts.get(2));let rate=s.tofloat(parts.get(3));let lineTotal=qty*price;subtotal=subtotal+lineTotal;tax=tax+(lineTotal*rate)};let total=subtotal+tax;io.println(s.format(subtotal;"%.2f"));io.println(s.format(tax;"%.2f"));io.println(s.format(total;"%.2f"));<0}
