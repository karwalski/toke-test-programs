m=dft;i=io:std.io;i=s:std.str;i=math:std.math;f=main():$i64{let n=s.toint(s.trim(io.readln()));let line=s.trim(io.readln());let parts=s.split(line;" ");let x=mut.@(0.0);x=@();let i=mut.0;lp(i<n){x=x+@(s.tofloat(parts.get(i)));i=i+1};let pi=3.141592653589793;let out=mut."Magnitudes:";let k=mut.0;lp(k<n){let re=mut.0.0;let im=mut.0.0;let jj=mut.0;lp(jj<n){let ang=0.0-2.0*pi*s.tofloat(s.fromint(k*jj))/s.tofloat(s.fromint(n));re=re+x.get(jj)*math.cos(ang);im=im+x.get(jj)*math.sin(ang);jj=jj+1};let mag=math.sqrt(re*re+im*im);out=s.concat(out;" ");out=s.concat(out;s.format(mag;"%.4f"));k=k+1};io.println(out);<0}
