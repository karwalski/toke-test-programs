m=movavg;i=io:std.io;i=s:std.str;f=fget(a:@$f64;idx:$i64):$f64{<a.get(idx)};f=main():$i64{let window=s.toint(s.trim(io.readln()));let line=s.trim(io.readln());let parts=s.split(line;",");let n=parts.len();let values=mut.@($f64);lp(let idx=0;idx<n;idx=idx+1){values=values+@(s.tofloat(parts.get(idx)))};let output=mut."";let i=mut.0;lp(i<=n-window){let sum=mut.0.0;let j=mut.0;lp(j<window){sum=sum+fget(values;i+j);j=j+1};let avg=sum/s.tofloat(s.fromint(window));if(i>0){output=s.concat(output;",")};output=s.concat(output;s.format(avg;"%.2f"));i=i+1};io.println(output);<0}
