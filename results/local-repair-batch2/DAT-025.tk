m=csort;i=io:std.io;i=s:std.str;f=main():$i64{let line=s.trim(io.readln());let parts=s.split(line;" ");let n=parts.len();let nums=mut.@(0);nums=@();let i=mut.0;let mx=mut.0;lp(i<n){let v=s.toint(parts.get(i));nums=nums+@(v);if(v>mx){mx=v};i=i+1};let cnt=mut.@(0);cnt=@();let k=mut.0;lp(k<=mx){cnt=cnt+@(0);k=k+1};let j=mut.0;lp(j<n){let v=nums.get(j);cnt=cnt.set(v;cnt.get(v)+1);j=j+1};let cs=mut."Counts:";let q=mut.0;lp(q<=mx){if(cnt.get(q)>0){cs=s.concat(cs;" ");cs=s.concat(cs;s.fromint(q));cs=s.concat(cs;":");cs=s.concat(cs;s.fromint(cnt.get(q)))};q=q+1};io.println(cs);let so=mut."Sorted:";let r=mut.0;lp(r<=mx){let c=cnt.get(r);let z=mut.0;lp(z<c){so=s.concat(so;" ");so=s.concat(so;s.fromint(r));z=z+1};r=r+1};io.println(so);<0}
