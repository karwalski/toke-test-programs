m=tb;i=io:std.io;i=s:std.str;f=main():$i64{let drTotal=mut.0;let crTotal=mut.0;let lines=mut.@();lp(1=1){let line=io.readln();if(s.len(line)=0){br};lines=lines+@(line);let parts=s.split(line;" ");let amt=s.toint(parts.get(1));let side=parts.get(2);if(side="DR"){drTotal=drTotal+amt}el{crTotal=crTotal+amt}};let idx=mut.0;lp(idx<lines.len){io.println(lines.get(idx));idx=idx+1};io.println(s.concat(s.concat(s.concat("TOTAL DR: ";s.fromint(drTotal));" CR: ");s.fromint(crTotal)));if(drTotal=crTotal){io.println("BALANCED")}el{let diff=mut.drTotal-crTotal;if(diff<0){diff=0-diff};io.println(s.concat("UNBALANCED ";s.fromint(diff)))};<0}
