m=cc;i=io:std.io;i=s:std.str;f=main():$i64{let shift=s.toint(s.trim(io.readln()));let upper="ABCDEFGHIJKLMNOPQRSTUVWXYZ";let lower="abcdefghijklmnopqrstuvwxyz";let normShift=mut.shift;lp(normShift<0){normShift=normShift+26};normShift=normShift-normShift/26*26;lp(1){let l=io.readln();if(s.len(l)=0){br};let t=s.trim(l);let out=mut."";let n=s.len(t);lp(let i=0;i<n;i=i+1){let ch=s.slice(t;i;i+1);let uidx=s.indexof(upper;ch);if(uidx>=0){if(s.len(ch)=1){let newIdx=mut.uidx+normShift;newIdx=newIdx-newIdx/26*26;out=s.concat(out;s.slice(upper;newIdx;newIdx+1))}el{out=s.concat(out;ch)}}el{let lidx=s.indexof(lower;ch);if(lidx>=0){if(s.len(ch)=1){let newIdx=mut.lidx+normShift;newIdx=newIdx-newIdx/26*26;out=s.concat(out;s.slice(lower;newIdx;newIdx+1))}el{out=s.concat(out;ch)}}el{out=s.concat(out;ch)}}};io.println(out)};<0}
