m=cpx;i=io:std.io;i=s:std.str;f=parsecpx(str:$str;real:@($i64);imag:@($i64)):$i64{let n=s.len(str);let pi=mut.-1;let mi=mut.-1;let j=mut.1;lp(j<n){let ch=s.slice(str;j;j+1);if(ch="+"){pi=j;br};if(ch="-"){mi=j;br};j=j+1};let r=mut.0;let im=mut.0;if(pi>0){r=s.toint(s.slice(str;0;pi));let istr=s.slice(str;pi+1;n-1);im=s.toint(istr)}el{if(mi>0){r=s.toint(s.slice(str;0;mi));let istr=s.slice(str;mi+1;n-1);im=0-s.toint(istr)}el{r=s.toint(s.slice(str;0;n-1));im=0}};let nr=real+@(r);let ni=imag+@(im);<0};f=fmt(re:$i64;im:$i64):$str{if(im>=0){<s.concat(s.fromint(re);s.concat("+";s.concat(s.fromint(im);"i")))};<s.concat(s.fromint(re);s.concat(s.fromint(im);"i"))};f=main():$i64{let line=s.trim(io.readln());let parts=s.split(line;" ");if(parts.len()<3){io.println("error");<0};let lhs=parts.get(0);let op=parts.get(1);let rhs=parts.get(2);let pi1=mut.-1;let mi1=mut.-1;let j=mut.1;lp(j<s.len(lhs)){let ch=s.slice(lhs;j;j+1);if(ch="+"){pi1=j;br};if(ch="-"){mi1=j;br};j=j+1};let lr=mut.0;let li=mut.0;if(pi1>0){lr=s.toint(s.slice(lhs;0;pi1));li=s.toint(s.slice(lhs;pi1+1;s.len(lhs)-1))}el{if(mi1>0){lr=s.toint(s.slice(lhs;0;mi1));li=0-s.toint(s.slice(lhs;mi1+1;s.len(lhs)-1))}};let pi2=mut.-1;let mi2=mut.-1;let k=mut.1;lp(k<s.len(rhs)){let ch=s.slice(rhs;k;k+1);if(ch="+"){pi2=k;br};if(ch="-"){mi2=k;br};k=k+1};let rr=mut.0;let ri=mut.0;if(pi2>0){rr=s.toint(s.slice(rhs;0;pi2));ri=s.toint(s.slice(rhs;pi2+1;s.len(rhs)-1))}el{if(mi2>0){rr=s.toint(s.slice(rhs;0;mi2));ri=0-s.toint(s.slice(rhs;mi2+1;s.len(rhs)-1))}};let nr=mut.0;let ni=mut.0;if(op="+"){nr=lr+rr;ni=li+ri}el{if(op="-"){nr=lr-rr;ni=li-ri}el{if(op="*"){nr=lr*rr-li*ri;ni=lr*ri+li*rr}}};io.println(fmt(nr;ni));<0}
