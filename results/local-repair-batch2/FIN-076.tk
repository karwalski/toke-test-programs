m=risk;i=io:std.io;i=s:std.str;f=main():$i64{let tot=mut.0.0;let tw=mut.0.0;let line=mut.io.readln();lp(s.len(line)>0){let t=s.trim(line);if(s.len(t)>0){let p=s.split(t;" ");let val=s.tofloat(p.get(1));let wt=s.tofloat(p.get(2));tot=tot+val*wt;tw=tw+wt};line=io.readln()};let cs=tot/tw;io.println(s.format(cs;"%.1f"));if(cs<30.0){io.println("LOW")}el{if(cs<70.0){io.println("MEDIUM")}el{io.println("HIGH")}};<0}
