m=radix;i=io:std.io;i=s:std.str;f=main():$i64{let line=s.trim(io.readln());let parts=s.split(line;" ");let n=parts.len();let arr=mut.@();let i=mut.0;lp(i<n){arr=arr+@(s.toint(parts.get(i)));i=i+1};let mx=mut.0;let j=mut.0;lp(j<n){if(arr.get(j)>mx){mx=arr.get(j)};j=j+1};let passes=mut.0;let div=mut.1;lp(mx/div>0){let b0=mut.@();let b1=mut.@();let b2=mut.@();let b3=mut.@();let b4=mut.@();let b5=mut.@();let b6=mut.@();let b7=mut.@();let b8=mut.@();let b9=mut.@();let k=mut.0;lp(k<n){let v=arr.get(k);let d=(v/div)-(v/(div*10))*10;if(d=0){b0=b0+@(v)};if(d=1){b1=b1+@(v)};if(d=2){b2=b2+@(v)};if(d=3){b3=b3+@(v)};if(d=4){b4=b4+@(v)};if(d=5){b5=b5+@(v)};if(d=6){b6=b6+@(v)};if(d=7){b7=b7+@(v)};if(d=8){b8=b8+@(v)};if(d=9){b9=b9+@(v)};k=k+1};arr=b0+b1+b2+b3+b4+b5+b6+b7+b8+b9;div=div*10;passes=passes+1};let sorted=mut."Sorted: ";let p=mut.0;lp(p<n){if(p>0){sorted=s.concat(sorted;" ")};sorted=s.concat(sorted;s.fromint(arr.get(p)));p=p+1};io.println(sorted);io.println(s.concat("Passes: ";s.fromint(passes)));<0}
