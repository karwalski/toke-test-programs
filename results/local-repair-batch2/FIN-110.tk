m=syd;i=io:std.io;i=s:std.str;f=main():$i64{let line=s.trim(io.readln());let parts=s.split(line;" ");let cost=s.tofloat(parts.get(0));let salvage=s.tofloat(parts.get(1));let n=s.toint(parts.get(2));let syd=(n*(n+1))/2;let dep=cost-salvage;let bv=mut.cost;lp(let y=1;y<n+1;y=y+1){let factor=s.tofloat(s.fromint(n-y+1))/s.tofloat(s.fromint(syd));let d=factor*dep;bv=bv-d;io.println(s.concat(s.concat(s.concat(s.concat(s.fromint(y);",");s.format(d;"%.2f"));",");s.format(bv;"%.2f")))};<0}
