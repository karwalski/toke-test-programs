m=tsa;i=io:std.io;i=s:std.str;i=math:std.math;f=main():$i64{let line=mut.io.readln();let header=mut.true;let totnom=mut.0.0;let tottol=mut.0.0;let sumsq=mut.0.0;let empties=mut.0;lp(empties<2){let t=s.trim(line);if(s.len(t)>0){empties=0;if(header){header=false}el{let p=s.split(t;",");let nom=s.tofloat(p.get(1));let tol=s.tofloat(p.get(2));totnom=totnom+nom;tottol=tottol+tol;sumsq=sumsq+tol*tol}}el{empties=empties+1};line=io.readln()};let rss=math.sqrt(sumsq);let wmin=totnom-tottol;let wmax=totnom+tottol;let out=mut."{\"total_nominal\":";out=s.concat(out;s.format(totnom;"%.1f"));out=s.concat(out;",\"worst_case_min\":");out=s.concat(out;s.format(wmin;"%.2f"));out=s.concat(out;",\"worst_case_max\":");out=s.concat(out;s.format(wmax;"%.2f"));out=s.concat(out;",\"rss_tolerance\":");out=s.concat(out;s.format(rss;"%.2f"));out=s.concat(out;"}");io.println(out);<0}
