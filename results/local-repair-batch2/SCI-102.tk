m=bo;i=io:std.io;i=s:std.str;f=popcount(n:$i64):$i64{let v=mut.n;let c=mut.0;lp(v>0){if(v%2=1){c=c+1};v=v/2};<c};f=lowestbit(n:$i64):$i64{let v=mut.n;let b=mut.1;lp(v>0){if(v%2=1){<b};v=v/2;b=b*2};<0};f=highestbit(n:$i64):$i64{let v=mut.n;let b=mut.1;let last=mut.0;lp(v>0){if(v%2=1){last=b};v=v/2;b=b*2};<last};f=ispow2(n:$i64):$bool{if(n<=0){<false};let v=mut.n;lp(v>1){if(v%2=1){<false};v=v/2};<true};f=parity(n:$i64):$i64{<popcount(n)%2};f=main():$i64{lp(1=1){let line=io.readln();if(s.len(line)=0){br};let parts=s.split(line;" ");let op=parts.get(0);let n=s.toint(parts.get(1));if(op="popcount"){io.println(s.fromint(popcount(n)))};if(op="lowest_bit"){io.println(s.fromint(lowestbit(n)))};if(op="highest_bit"){io.println(s.fromint(highestbit(n)))};if(op="is_pow2"){if(ispow2(n)){io.println("true")}el{io.println("false")}};if(op="parity"){if(parity(n)=1){io.println("odd")}el{io.println("even")}}};<0}
