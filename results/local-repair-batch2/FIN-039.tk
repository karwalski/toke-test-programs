m=cv;i=io:std.io;i=s:std.str;f=unitexp(u:$str):$i64{if(u="B"){<0};if(u="KB"){<1};if(u="MB"){<2};if(u="GB"){<3};if(u="TB"){<4};if(u="PB"){<5};<0};f=main():$i64{let line=io.readln();let parts=s.split(line;" ");let val=s.tofloat(parts.get(0));let src=parts.get(1);let dst=parts.get(2);let conv=parts.get(3);let base=mut.1024.0;if(conv="si"){base=1000.0};let se=unitexp(src);let de=unitexp(dst);let diff=se-de;let factor=mut.1.0;let i=mut.0;if(diff>0){lp(i<diff){factor=factor*base;i=i+1}}el{let absDiff=0-diff;lp(i<absDiff){factor=factor/base;i=i+1}};let result=val*factor;io.println(s.format(result;"%.4f"));<0}
