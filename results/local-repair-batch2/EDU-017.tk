m=exam;i=io:std.io;i=s:std.str;f=fmt2(n:$i64):$str{if(n<10){<s.concat("0";s.fromint(n))};<s.fromint(n)};f=main():$i64{let first=s.trim(io.readln());let parts=s.split(first;" ");let total=s.toint(parts.get(0));let nsec=s.toint(parts.get(1));let dur=total/nsec;let secs=mut.@();let i=mut.0;lp(i<nsec){let nm=s.trim(io.readln());secs=secs+@(nm);i=i+1};let idx=mut.0;let start=mut.0;lp(idx<nsec){let endt=start+dur;let h1=start/60;let m1=start-h1*60;let h2=endt/60;let m2=endt-h2*60;let out=mut."Section ";out=s.concat(out;s.fromint(idx+1));out=s.concat(out;": ");out=s.concat(out;secs.get(idx));out=s.concat(out;" | start ");out=s.concat(out;fmt2(h1));out=s.concat(out;":");out=s.concat(out;fmt2(m1));out=s.concat(out;" | end ");out=s.concat(out;fmt2(h2));out=s.concat(out;":");out=s.concat(out;fmt2(m2));out=s.concat(out;" | duration ");out=s.concat(out;s.fromint(dur));out=s.concat(out;"min");io.println(out);start=endt;idx=idx+1};<0}
