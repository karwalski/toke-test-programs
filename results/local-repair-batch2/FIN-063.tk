m=rb;i=io:std.io;i=s:std.str;f=main():$i64{let totalLine=io.readln();let total=s.tofloat(totalLine);lp(1=1){let line=io.readln();if(s.len(line)=0){br};let parts=s.split(line;" ");let asset=parts.get(0);let cur=s.tofloat(parts.get(1));let tgt=s.tofloat(parts.get(2));let diff=tgt-cur;let amt=(diff*total)/100.0;let absAmt=mut.amt;if(absAmt<0.0){absAmt=0.0-absAmt};let action=mut."HOLD";if(diff>0.0){action="BUY"};if(diff<0.0){action="SELL"};io.println(s.concat(s.concat(s.concat(s.concat(asset;" ");action);" ");s.format(absAmt;"%.2f")))};<0}
