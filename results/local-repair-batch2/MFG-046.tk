m=pchart;i=io:std.io;i=s:std.str;i=math:std.math;f=fmt(v:$f64;dec:$i64):$str{let mul=mut.1;let i=mut.0;lp(i<dec){mul=mul*10;i=i+1};let neg=mut.false;let x=mut.v;if(x<0.0){neg=true;x=0.0-x};let cents=(x*(mul as $f64)+0.5)as$i64;let dollars=cents/mul;let rem=cents-dollars*mul;let remstr=mut.s.fromint(rem);let pad=mut.mul/10;lp(rem<pad){if(rem=0){if(pad=1){br}};remstr=s.concat("0";remstr);pad=pad/10};let out=mut.s.fromint(dollars);if(dec>0){out=s.concat(out;s.concat(".";remstr))};if(neg){<s.concat("-";out)};<out};f=main():$i64{let header=s.trim(io.readln());let sums=mut.@();let defects=mut.@();lp(true){let line=io.readln();if(s.len(line)=0){br};let trimmed=s.trim(line);if(s.len(trimmed)=0){br};let parts=s.split(trimmed;",");if(parts.len()<2){br};sums=sums+@(s.toint(parts.get(0)));defects=defects+@(s.toint(parts.get(1)))};let n=sums.len();let totd=mut.0;let totn=mut.0;let i=mut.0;lp(i<n){totd=totd+defects.get(i);totn=totn+sums.get(i);i=i+1};let pbar=(totd as $f64)/(totn as $f64);let nbar=(totn as $f64)/(n as $f64);let stddev=math.sqrt(pbar*(1.0-pbar)/nbar);let ucl=pbar+3.0*stddev;let lcl=mut.pbar-3.0*stddev;if(lcl<0.0){lcl=0.0};let oos=mut.@();let j=mut.0;lp(j<n){let p=(defects.get(j)as $f64)/(sums.get(j)as $f64);if(p>ucl){oos=oos+@(j)};if(p<lcl){oos=oos+@(j)};j=j+1};let oosstr=mut."[";let k=mut.0;lp(k<oos.len()){if(k>0){oosstr=s.concat(oosstr;",")};oosstr=s.concat(oosstr;s.fromint(oos.get(k)));k=k+1};oosstr=s.concat(oosstr;"]");io.println(s.concat("{\"p_bar\":";s.concat(fmt(pbar;3);s.concat(",\"ucl\":";s.concat(fmt(ucl;2);s.concat(",\"lcl\":";s.concat(fmt(lcl;1);s.concat(",\"out_of_control\":";s.concat(oosstr;"}")))))))));<0}
