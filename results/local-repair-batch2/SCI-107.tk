m=pqueue;i=io:std.io;i=s:std.str;f=findminidx(keys:@$i64):$i64{if(keys.len()=0){<-1};let minidx=mut.0;let minval=mut.keys.get(0);lp(let i=1;i<keys.len();i=i+1){if(keys.get(i)<minval){minval=keys.get(i);minidx=i}};<minidx};f=main():$i64{let keys=mut.@();let vals=mut.@();let count=mut.0;lp(count<200){let line=io.readln();let trimmed=mut.line;let nl=s.len(trimmed);if(nl>0){if(s.equals(s.slice(trimmed;nl-1;nl);"\n")){trimmed=s.slice(trimmed;0;nl-1)}};if(s.len(trimmed)=0){count=count+1;if(count>3){br}}el{count=0;let parts=s.split(trimmed;" ");let cmd=parts.get(0);if(s.equals(cmd;"INSERT")){let k=s.toint(parts.get(1));let v=parts.get(2);keys=keys+@(k);vals=vals+@(v)};if(s.equals(cmd;"EXTRACT_MIN")){let idx=findminidx(keys);if(idx>=0){io.println(s.concat(s.concat(s.concat("key=";s.fromint(keys.get(idx)));" value=");vals.get(idx)));let newk=mut.@();let newv=mut.@();lp(let i=0;i<keys.len();i=i+1){if(i!=idx){newk=newk+@(keys.get(i));newv=newv+@(vals.get(i))}};keys=newk;vals=newv}};if(s.equals(cmd;"PEEK")){let idx=findminidx(keys);if(idx>=0){io.println(s.concat(s.concat(s.concat("key=";s.fromint(keys.get(idx)));" value=");vals.get(idx)))}};if(s.equals(cmd;"DELETE")){let k=s.toint(parts.get(1));let newk=mut.@();let newv=mut.@();lp(let i=0;i<keys.len();i=i+1){if(keys.get(i)!=k){newk=newk+@(keys.get(i));newv=newv+@(vals.get(i))}};keys=newk;vals=newv};if(s.equals(cmd;"DECREASE_KEY")){let k=s.toint(parts.get(1));let v=parts.get(2);lp(let i=0;i<keys.len();i=i+1){if(keys.get(i)=k){vals=vals.set(i;v)}}};if(s.equals(cmd;"SIZE")){io.println(s.fromint(keys.len()))}}};<0}
