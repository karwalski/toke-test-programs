m=gas;i=io:std.io;i=s:std.str;f=parsejson(json:$str;key:$str):$i64{let pat=s.concat("\"";s.concat(key;"\":"));let idx=s.indexof(json;pat);if(idx<0){<0};let start=idx+s.len(pat);let n=s.len(json);let endp=mut.start;let k=mut.start;let done=mut.0;lp(k<n){if(done=0){let c=s.slice(json;k;k+1);let isend=mut.0;if(c=","){isend=1};let endbrace=s.slice("xxx}xxx";3;4);if(c=endbrace){isend=1};if(isend=1){endp=k;done=1}};k=k+1};if(done=0){endp=n};let numstr=s.trim(s.slice(json;start;endp));<s.toint(numstr)};f=main():$i64{let limstr=s.trim(io.readln());let limit=s.toint(limstr);let json=s.trim(io.readln());let total=mut.0;let opnamenum=mut.0;let oog=mut.0;let oogat=mut.0;let stopname=mut.0;lp(stopname<1){let opname=s.trim(io.readln());if(s.len(opname)=0){stopname=1}el{opnamenum=opnamenum+1;if(oog=0){let cost=parsejson(json;opname);total=total+cost;if(total>limit){oog=1;oogat=opnamenum}}}};io.println(s.fromint(total));if(oog=1){io.println(s.concat("OUT_OF_GAS at operation ";s.fromint(oogat)))}el{io.println("SUCCESS")};<0}
