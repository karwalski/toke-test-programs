m=cross;i=io:std.io;i=s:std.str;f=ma(prices:@($f64);i:$i64;p:$i64):$f64{let sum=mut.0.0;let j=mut.0;lp(j<p){sum=sum+prices.get(i-p+1+j);j=j+1};<sum/(p as$f64)};f=main():$i64{let l1=io.readln();let params=s.split(l1;" ");let shortp=s.toint(params.get(0));let longp=s.toint(params.get(1));let l2=io.readln();let pstr=s.split(l2;",");let prices=mut.@();let pi=mut.0;lp(pi<pstr.len()){prices=prices+@(s.tofloat(pstr.get(pi)));pi=pi+1};let n=prices.len();let prevstate=mut.0;let savedstate=mut.0;let savedidx=mut.0;let results=mut.@();let i=mut.0;lp(i<n){if(i+1>=longp){let sm=ma(prices;i;shortp);let lm=ma(prices;i;longp);let state=mut.prevstate;if(sm>lm){state=1}el{if(sm<lm){state=2}};if(prevstate=0){savedstate=state;savedidx=i}el{if(prevstate=2){if(state=1){results=results+@(s.concat(s.fromint(i-1);" GOLDEN_CROSS"))}};if(prevstate=1){if(state=2){results=results+@(s.concat(s.fromint(i-1);" DEATH_CROSS"))}}};prevstate=state};i=i+1};if(results.len()=0){if(savedstate=1){io.println(s.concat(s.fromint(savedidx);" GOLDEN_CROSS"))};if(savedstate=2){io.println(s.concat(s.fromint(savedidx);" DEATH_CROSS"))}}el{let k=mut.0;lp(k<results.len()){io.println(results.get(k));k=k+1}};<0}
