m=lu;i=io:std.io;i=s:std.str;f=fabs(x:$f64):$f64{if(x<0.0){<0.0-x};<x};f=main():$i64{let nline=io.readln();let n=s.toint(s.trim(nline));let u=mut.@(0.0);let i=mut.1;lp(i<n*n){u=u+@(0.0);i=i+1};let r=mut.0;lp(r<n){let row=io.readln();let parts=s.split(s.trim(row);" ");let c=mut.0;lp(c<n){u=u.set(r*n+c;s.tofloat(parts.get(c)));c=c+1};r=r+1};let l=mut.@(0.0);let a=mut.1;lp(a<n*n){l=l+@(0.0);a=a+1};let d=mut.0;lp(d<n){l=l.set(d*n+d;1.0);d=d+1};let p=mut.@();let pi=mut.0;lp(pi<n){p=p+@(pi);pi=pi+1};let k=mut.0;lp(k<n){let maxv=mut.fabs(u.get(k*n+k));let pivot=mut.k;let ii=mut.k+1;lp(ii<n){let v=fabs(u.get(ii*n+k));if(v>maxv){maxv=v;pivot=ii};ii=ii+1};if(pivot!=k){let j=mut.0;lp(j<n){let t=u.get(k*n+j);u=u.set(k*n+j;u.get(pivot*n+j));u=u.set(pivot*n+j;t);j=j+1};let tp=p.get(k);p=p.set(k;p.get(pivot));p=p.set(pivot;tp);let jl=mut.0;lp(jl<k){let tl=l.get(k*n+jl);l=l.set(k*n+jl;l.get(pivot*n+jl));l=l.set(pivot*n+jl;tl);jl=jl+1}};let ukk=u.get(k*n+k);if(ukk!=0.0){let ie=mut.k+1;lp(ie<n){let factor=u.get(ie*n+k)/ukk;l=l.set(ie*n+k;factor);let je=mut.k;lp(je<n){let nv=u.get(ie*n+je)-factor*u.get(k*n+je);u=u.set(ie*n+je;nv);je=je+1};ie=ie+1}};k=k+1};let rr=mut.0;lp(rr<n){let line=mut."";let cc=mut.0;lp(cc<n){if(cc>0){line=s.concat(line;" ")};line=s.concat(line;s.format(l.get(rr*n+cc);"%.6f"));cc=cc+1};io.println(line);rr=rr+1};io.println("");let rr2=mut.0;lp(rr2<n){let line=mut."";let cc=mut.0;lp(cc<n){if(cc>0){line=s.concat(line;" ")};line=s.concat(line;s.format(u.get(rr2*n+cc);"%.6f"));cc=cc+1};io.println(line);rr2=rr2+1};io.println("");let pline=mut."";let pp=mut.0;lp(pp<n){if(pp>0){pline=s.concat(pline;" ")};pline=s.concat(pline;s.fromint(p.get(pp)));pp=pp+1};io.println(pline);<0}
