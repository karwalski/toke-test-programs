m=tagquestion;f=tagquestion(question:$str):$str{let hasverb=mut.false;let hasnoun=mut.false;let hasadj=mut.false;let hasadv=mut.false;let words=question.split(" ");lp(let i=0;i<words.len;i=i+1){let w=words.get(i);if(w="is"){hasverb=true}el{if(w="are"){hasverb=true}el{if(w="was"){hasverb=true}el{if(w="were"){hasverb=true}el{if(w="be"){hasverb=true}el{if(w="do"){hasverb=true}el{if(w="does"){hasverb=true}el{if(w="did"){hasverb=true}el{if(w="have"){hasverb=true}el{if(w="has"){hasverb=true}el{if(w="had"){hasverb=true}el{if(w="can"){hasverb=true}el{if(w="could"){hasverb=true}el{if(w="will"){hasverb=true}el{if(w="would