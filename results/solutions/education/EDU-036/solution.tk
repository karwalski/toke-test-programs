m=mapgen;f=spacetabs(n:$i64):$str{let r=mut."";lp(let i=0;i<n;i=i+1){r=s.concat(r;" ");};<r};f=buildmap(topic:$str;subtopics:@$str):$str{let r=mut."";let tlen=topic.len as i64;let tabs=spacetabs(tlen+2);r=s.concat(r;topic)+tabs;lp(let i=0;i<subtopics.len;i=i+1){let s=subtopics.get(i);let slen=s.len as i64;let tb=spacetabs(tlen+slen+4);r=r+tb+s;};<r};f=main():$i64{let topic="projects";let subtopics=@("moke";"loke";"ooke"));let map=buildmap(topic;subtopics);let lines=map.split("\n");lp(let i=0;i<lines.len;i=i+1){let l=lines.get(i);<l;};<0;};