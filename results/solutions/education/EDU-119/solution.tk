m=errorpattern;f=classifyerrortype(msg:$str):$str{if(msg.contains("undefined"))){<"type"};if(msg.contains("syntax error"))){<"syntax"};if(msg.contains("reference error"))){<"reference"};if(msg.contains("range error"))){<"range"};if(msg.contains("invalid argument"))){<"invalid"};<"unknown"};f=extractkeyword(msg:$str):$str{let idx=mut.0;let n=msg.len;lp(let i=0;i<n;i=i+1){let c=msg.get(i);if(c=" "){idx=i+1};};let start=idx;let end=mut.n;lp(let i=start;i<n;i=i+1){let c=msg.get(i);if(c=" "){end=i;br};};let keyword=mut."";lp(let i=start;i<end;i=i+1){let c=msg.get(i);keyword=keyword+c;};<keyword};f=extractstage(msg:$str):$str{let n=msg.len;let i=mut.0;lp(let j=0;j<n;j=j+1){let c=msg.get(j);if(c=" "){i=j+1;br};