m=histogram;i=io:std.io;i=s:std.str;f=main():$i64{let line=io.readln();let grades=s.split(line;" ");let a=mut.0;let b=mut.0;let c=mut.0;let d=mut.0;let gradef=mut.0;let idx=mut.0;lp(idx<grades.len()){let grade=grades.get(idx);if(grade="A"){a=a+1}el{if(grade="B"){b=b+1}el{if(grade="C"){c=c+1}el{if(grade="D"){d=d+1}el{if(grade="F"){gradef=gradef+1}}}}};idx=idx+1};let ahash=mut."";let hashidx=mut.0;lp(hashidx<a){ahash=s.concat(ahash;"#");hashidx=hashidx+1};let bhash=mut."";hashidx=0;lp(hashidx<b){bhash=s.concat(bhash;"#");hashidx=hashidx+1};let chash=mut."";hashidx=0;lp(hashidx<c){chash=s.concat(chash;"#");hashidx=hashidx+1};let dhash=mut."";hashidx=0;lp(hashidx<d){dhash=s.concat(dhash;"#");hashidx=hashidx+1};let fhash=mut."";hashidx=0;lp(hashidx<gradef){fhash=s.concat(fhash;"#");hashidx=hashidx+1};io.println(s.concat(s.concat(s.concat("A: ";ahash);" (");s.concat(s.fromint(a);")")));io.println(s.concat(s.concat(s.concat("B: ";bhash);" (");s.concat(s.fromint(b);")")));io.println(s.concat(s.concat(s.concat("C: ";chash);" (");s.concat(s.fromint(c);")")));io.println(s.concat(s.concat(s.concat("D: ";dhash);" (");s.concat(s.fromint(d);")")));io.println(s.concat(s.concat(s.concat("F: ";fhash);" (");s.concat(s.fromint(gradef);")")));<0}