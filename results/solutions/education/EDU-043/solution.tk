m=grade;i=io:std.io;i=s:std.str;i=math:std.math;f=main():$i64{let line1=io.readln();let params=s.split(line1;" ");let target=s.tofloat(params.get(0));let stddev=s.tofloat(params.get(1));let line2=io.readln();let parts=s.split(line2;" ");let grades=mut.@();let idx=mut.0;lp(idx<parts.len()){let grade=s.tofloat(parts.get(idx));grades=grades+@(grade);idx=idx+1};let sum=mut.0.0;let i=mut.0;lp(i<grades.len()){sum=sum+grades.get(i);i=i+1};let mean=sum/s.tofloat(s.fromint(grades.len()));let variance=mut.0.0;let j=mut.0;lp(j<grades.len()){let diff=grades.get(j)-mean;variance=variance+diff*diff;j=j+1};variance=variance/s.tofloat(s.fromint(grades.len()));let currentstd=math.sqrt(variance);if(currentstd=0.0){let k=mut.0;lp(k<grades.len()){io.println(s.format(target;"%.1f"));k=k+1}}el{let k=mut.0;lp(k<grades.len()){let zscore=(grades.get(k)-mean)/currentstd;let adjusted=target+zscore*stddev;io.println(s.format(adjusted;"%.1f"));k=k+1}};<0}