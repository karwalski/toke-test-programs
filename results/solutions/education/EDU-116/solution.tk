m=audit;f=issubstr(haystack:$str;needle:$str):$bool{let n=needle.len;let m=haystack.len;if(!(n>m)){let result=mut.false;lp(let i=0;i<m-n+1;i=i+1){let j=mut.0;let match=mut.true;lp(let k=0;k<n;k=k+1){let c1=haystack.get(i+k);let c2=needle.get(k);if(!(c1=c2)){match=false}};if(match){result=true}}};<result};f=countcovered(curriculum:$str;lessonplans:@$str):$i64{let count=mut.0;lp(let i=0;i<lessonplans.len;i=i+1){let lp=lessonplans.get(i);let iscovered=issubstr(curriculum;lp);if(iscovered){count=count+1}};<count};f=main():$i64{let curriculum="data science machine learning statistics programming";let lessonplans=@("data science";"machine learning";"statistics";"programming"));let covered=countcovered(curriculum;lessonplans);<0};