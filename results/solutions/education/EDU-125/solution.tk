m=acdp;f=makepledge(name:$str;studentid:$str):$str{let line1="I, ";let line2=", student id ";let line3=", pledge to uphold academic integrity at ";let line4="University of Technology Sydney. I will not cheat, plagiarise, or assist others in doing so. I understand that any breach of this pledge will result in disciplinary action, up to and including expulsion. I sign this pledge on ";let line5=". I have read and understood the University's policies on academic integrity. I agree to comply with these policies at all times. I understand that any breach of these policies