m=quizexport;f=buildrow(parts:@$str):$str{let out=mut."";let n=parts.len;lp(let i=0;i<n;i=i+1){let part=parts.get(i);if(i>0){out=s.concat(out;"|")};out=out+part};<out};f=exportquiz(results:@$quizresult):$str{let header="name|score|grade";let rows=mut.@();lp(let i=0;i<results.len;i=i+1){let r=results.get(i);let parts=@(r.name;r.score as$str;r.grade);let row=buildrow(parts);rows=rows+@(row)};let out=s.concat(s.concat(header;"\n");rows.join("\n"));<out};