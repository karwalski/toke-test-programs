m=studentreport;f=buildreport(name:$str;score:$i64;grade:$str):$str{let result=mut."";result=s.concat(result;"Student Name: ");result=s.concat(result;name);result=s.concat(result;"\nScore: ");let scorestr=score as$str;result=result+scorestr;result=s.concat(result;"\nGrade: ");result=s.concat(result;grade);result=s.concat(result;"\n");<result};f=main():$void{let name="Alice";let score=95;let grade="A";let report=buildreport(name;score;grade);<report};