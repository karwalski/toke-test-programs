m=iqband;i=io:std.io;i=s:std.str;f=iqband(score:$i64):$str{if(score>=130){<"Very Superior"};if(score>=120){<"Superior"};if(score>=110){<"High Average"};if(score>=90){<"Average"};if(score>=80){<"Low Average"};if(score>=70){<"Borderline"};if(score>=55){<"Extremely Low"};<"Profound"};f=main():$i64{let line=io.readln();while(line!=""){let score=s.toint(line);let result=iqband(score);io.println(s.concat(s.fromint(score);": ")+result);line=io.readln()};<0};