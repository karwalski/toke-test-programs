m=report;f=buildreport(name:$str;score:$i64;grade:$str):$str{let header="Student Report\n---------------------\n";let body=s.concat(s.concat(s.concat("Name: ";name);"\nScore: ");score) as$str+s.concat(s.concat("\nGrade: ";grade);"\n");let footer="---------------------\nEnd of Report";<s.concat(s.concat(header;body);footer)};f=main():$void{let report=buildreport("Alice Johnson";95;"A");<report};