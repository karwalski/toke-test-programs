m=gradecheck;i=io:std.io;i=s:std.str;f=wordcount(text:$str):$i64{let words=s.split(text;"_");let count=mut.0;let idx=mut.0;lp(idx<words.len()){let word=s.trim(words.get(idx));if(s.len(word)>0){count=count+1};idx=idx+1};<count};f=avgwordlen(text:$str):$i64{let words=s.split(text;"_");let totallen=mut.0;let wordcnt=mut.0;let idx=mut.0;lp(idx<words.len()){let word=s.trim(words.get(idx));if(s.len(word)>0){totallen=totallen+s.len(word);wordcnt=wordcnt+1};idx=idx+1};if(wordcnt>0){<totallen/wordcnt};<0};f=gradelevel(text:$str):$i64{let wc=wordcount(text);let awl=avgwordlen(text);if(awl<=3){<1}el{if(awl<=4){<2}el{if(awl<=5){<5}el{if(awl<=6){<8}el{if(awl<=7){<10}el{<14}}}}}};f=main():$i64{let targetgrade=s.toint(io.readln());let text=io.readln();let grade=gradelevel(text);if(grade<targetgrade){io.println(s.concat(s.concat("_";s.fromint(grade));"_"))}el{if(grade=targetgrade){io.println("_")}el{io.println(s.concat(s.concat("_";s.fromint(grade));"_"))}};<0}