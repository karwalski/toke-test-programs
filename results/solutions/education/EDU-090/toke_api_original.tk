m=gradecheck;i=io:std.io;i=s:std.str;f=wordcount(text:$str):$i64{let words=s.split(text;" ");let count=mut.0;let idx=mut.0;lp(idx<words.len()){let word=s.trim(words.get(idx));if(s.len(word)>0){count=count+1};idx=idx+1};<count};f=avgwordlen(text:$str):$i64{let words=s.split(text;" ");let totallen=mut.0;let wordcount=mut.0;let idx=mut.0;lp(idx<words.len()){let word=s.trim(words.get(idx));if(s.len(word)>0){totallen=totallen+s.len(word);wordcount=wordcount+1};idx=idx+1};if(wordcount>0){<totallen/wordcount};<0};f=gradelevel(text:$str):$i64{let wc=wordcount(text);let awl=avgwordlen(text);if(wc<=5){if(awl<=3){<1}el{<2}}el{if(wc<=10){if(awl<=4){<3}el{<4}}el{if(awl<=5){<5}el{<6}}}};f=main():$i64{let targetgrade=s.toint(io.readln());let text=io.readln();let grade=gradelevel(text);if(grade<targetgrade){io.println("TOO EASY (grade "+s.fromint(grade)+")")}el{if(grade=targetgrade){io.println("APPROPRIATE")}el{io.println("TOO HARD (grade "+s.fromint(grade)+")")}};<0}