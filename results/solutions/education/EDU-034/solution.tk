m=outline;f=extractpoints(text:$str):$str{let lines=text.split("\n");let result=mut."";let depth=mut.0;lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);let spaces=line.len-line.trim().len;let currentdepth=spaces/2;if(currentdepth>depth){result=s.concat(s.concat(result;line.trim());"\n");depth=currentdepth;}el{if(currentdepth<depth){let tmp=mut."";lp(let j=0;j<currentdepth;j=j+1){tmp=s.concat(tmp;"  ");};result=s.concat(s.concat(tmp;line.trim());"\n");depth=currentdepth;}el{result=s.concat(s.concat(result;line.trim());"\n");};};};<result};f=main():$void{let input="Introduction to Programming\n  Variables and Types\n  Operators and Expressions\n  Control Structures\n    Conditional Statements\n    Loops\n      For Loops\n      While Loops\n  Functions\n  Data Structures\n  File I/O\n  Networking\n  Error Handling\n  Best Practices";let output=extractpoints(input);<output};