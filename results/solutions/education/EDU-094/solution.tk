m=topicfinder;
i=io:std.io;
i=s:std.str;
f=findtopic(interests:@$str):$str{let maxcount=mut.0;let maxtopic=mut."";lp(let i=0;i<interests.len;i=i+1){let topic=interests.get(i);let count=mut.0;lp(let j=0;j<interests.len;j=j+1){if(interests.get(j)=topic){count=count+1};};if(count>maxcount){maxcount=count;maxtopic=topic};};<maxtopic};
f=main():$i64{let input=io.readln();let allinterests=@$str.new();let parts=s.split(input;"interests\":[\"");lp(let i=1;i<parts.len;i=i+1){let part=parts.get(i);let topicpart=s.split(part;"\"]")[0];let topics=s.split(topicpart;"\";\"");lp(let j=0;j<topics.len;j=j+1){allinterests.add(topics.get(j));}};let topicmap=@[@$str;$i64].new();lp(let i=0;i<allinterests.len;i=i+1){let topic=allinterests.get(i);let found=false;lp(let j=0;j<topicmap.len;j=j+1){if(topicmap.get(j).get(0).get(0)=topic){topicmap.get(j).set(1;topicmap.get(j).get(1)+1);found=true;}};if(!found){let entry=@$str.new();entry.add(topic);let newentry=[@$str;$i64].new();newentry.set(0;entry);newentry.set(1;1);topicmap.add(newentry);}};lp(let i=0;i<topicmap.len-1;i=i+1){lp(let j=0;j<topicmap.len-1-i;j=j+1){if(topicmap.get(j).get(1)<topicmap.get(j+1).get(1)){let temp=topicmap.get(j);topicmap.set(j;topicmap.get(j+1));topicmap.set(j+1;temp);}}};let total=allinterests.len;lp(let i=0;i<topicmap.len;i=i+1){let rank=i+1;let topic=topicmap.get(i).get(0).get(0);let votes=topicmap.get(i).get(1);let percent=(votes*100)/total;io.println(s.concat(s.fromint(rank);". ")+topic+s.concat(s.concat(s.concat(s.concat(": ";s.fromint(votes));" votes (");s.fromint(percent));"%)"));};< 0}