m=learning_summary;f=extract_keyword(line:$str):$str{let idx=mut.0;lp(let i=0;i<line.len;i=i+1){let ch=line.get(i);if(ch=":"){idx=i+1}};let keyword=line.substr(idx;line.len-idx);<keyword};f=classify_learning_area(keyword:$str):$str{if(keyword="math"){<keyword};if(keyword="science"){<keyword};if(keyword="programming"){<keyword};if(keyword="data"){<keyword};if(keyword="visualization"){<keyword};<keyword};f=count_keyword_occurrences(lines:@$str;keyword:$str):i64{let count=mut.0;lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);if(line.contains(keyword)){count=count+1}};<count};f=summarise_area(area:$str;count:i64):$str{let summary=mut."";summary=s.concat(summary;area);summary=s.concat(summary;" has ");summary=s.concat(summary;count) as$str;summary=s.concat(summary;" notes.");if(count>0){summary=s.concat(summary;" Let's review these.")}el{summary=s.concat(summary;" No notes in this area)