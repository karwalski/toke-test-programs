m=gradecalc;f=grade(score:$i64):$str{if(score<60){<"f"};if(score<70){<"d"};if(score<80){<"c"};if(score<90){<"b"};<"a"};f=applyextra(grade:$str;extra:$i64):$str{if(extra<0){<grade};let newgrade=grade;let newextra=extra;let finalgrade=mut.newgrade;lp(let idx=0;idx<newextra;idx=idx+1){let currentgrade=finalgrade;if(currentgrade="a"){finalgrade="a";}el{if(currentgrade="b"){finalgrade="a";}el{if(currentgrade="c"){finalgrade="b";}el{if(currentgrade="d"){finalgrade="c";}el{if(currentgrade="f"){finalgrade="d";}el{}}}}}};<finalgrade};