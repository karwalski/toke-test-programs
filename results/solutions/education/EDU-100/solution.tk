m=ranking;i=io:std.io;i=s:std.str;f=main():$i64{let input=io.readln();let clean=s.slice(input;1;s.len(input)-1);let entries=s.split(clean;"},");let scores=mut.@();let names=mut.@();let idx=mut.0;lp(idx<entries.len()){let entry=mut.entries.get(idx);if(idx<entries.len()-1){entry=entry+"}"};let namestart=s.split(entry;"\"student\":\"");if(namestart.len()>=2){let namepart=namestart.get(1);let nameend=s.split(namepart;"\",\"score\":");if(nameend.len()>=1){let name=nameend.get(0);let scorepart=s.split(entry;"\"score\":");if(scorepart.len()>=2){let scorestr=scorepart.get(1);let scoreclean=s.split(scorestr;"}");if(scoreclean.len()>=1){let score=s.toint(scoreclean.get(0));scores=scores+@(score);names=names+@(name)}}}};idx=idx+1};let n=scores.len();let sidx=mut.0;lp(sidx<n-1){let jidx=mut.sidx+1;lp(jidx<n){if(scores.get(sidx)<scores.get(jidx)){let tempscore=scores.get(sidx);let tempname=names.get(sidx);scores=scores.set(sidx;scores.get(jidx));names=names.set(sidx;names.get(jidx));scores=scores.set(jidx;tempscore);names=names.set(jidx;tempname)};jidx=jidx+1};sidx=sidx+1};let rank=mut.1;let oidx=mut.0;lp(oidx<n){if(oidx>0){if(scores.get(oidx)!=scores.get(oidx-1)){rank=oidx+1}};let output=s.concat(s.fromint(rank);". ")+names.get(oidx)+s.concat(" - ";s.fromint(scores.get(oidx)));io.println(output);oidx=oidx+1};<0}