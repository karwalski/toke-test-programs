m=debate;f=solve(p0:$str;p1:$str;p2:i64):$str{let students=std.json.parse(p0);let motion=p1;let seed=p2;let n=students.len;let teama=mut.@();let teamb=mut.@();lp(let i=0;i<n;i=i+1){let s=students.get(i);let hash=mut.0;let name=s.str;lp(let j=0;j<name.len;j=j+1){let c=name.get(j);hash=hash+c as i64;};let idx=hash as i64;let mod=idx-(idx/2)*2;if(mod=0){teama=teama+@(s)}el{teamb=teamb+@(s)}};let result=mut."";let aidx=mut.0;lp(let i=0;i<teama.len;i=i+1){let s=teama.get(i);let name=s.str;let idx=aidx;let line=mut."";line=s.concat(line;"A");line=s.concat(line;".");line=line+name;result=s.concat(result;line);aidx=aidx+1;};let bidx=mut.0;lp(let i=0;i<teamb.len;i=i+1){let s=teamb.get(i);let name=s.str;let idx=bidx;let line=mut."";line=s.concat(line;"B)