m=quizleaderboard;f=sortbypts(arr:@($str;$i64))):@$str{let n=arr.len;let sorted=mut.@();lp(let i=0;i<n;i=i+1){sorted=sorted+@(arr.get(i))};lp(let i=0;i<n;i=i+1){lp(let j=0;j<n-i-1;j=j+1){let a=sorted.get(j);let b=sorted.get(j+1);let ap=arr.get(j);let bp=arr.get(j+1);if(b>a){let tmp=sorted.get(j);sorted.get(j)=sorted.get(j+1);sorted.get(j+1)=tmp;};};};<sorted};f=topnwinners(quizid:$str;n:$i64):@$str{let winners=sortbypts(@($str;$i64))));let result=mut.@();let m=n as u64;let i=mut.0 as u64;lp(let j=0;j<winners.len;j=j+1){if(i<m){result=result+@(winners.get(j)));i=i+1;};};<result};