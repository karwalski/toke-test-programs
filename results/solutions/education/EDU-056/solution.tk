m=topicgraph;f=solve(p0:@$str;p1:@$str):$str{let topicmap=mut.@();lp(let i=0;i<p0.len;i=i+1){let topic=p0.get(i);let found=mut.false;let idx=mut.0;lp(let j=0;j<topicmap.len;j=j+1){let entry=topicmap.get(j);if(entry.topic=topic){found=true;idx=j;};};if(found){let entry=topicmap.get(idx);entry.confidence=entry.confidence+1;};if(!(found)){let newentry=$topicentry{topic:topic;confidence:1};topicmap=topicmap+@(newentry);};};let result=mut."";lp(let i=0;i<topicmap.len;i=i+1){let entry=topicmap.get(i);let line=entry.topic+" ["+entry.confidence as$str+"]";result=result+line;if(!(i=(topicmap.len-1)))){result=s.concat(result;"\n")};};<result};t=$topicentry{topic:$str;confidence:$i64};f=main():$i64{let topics=@("privacy";"security";"