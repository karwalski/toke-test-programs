m=socratic;f=solve(p:$str;q:$str):$str{let topic=p;let question=q;let followup=mut."";let keywords=mut.@();let idx=mut.0;lp(let i=0;i<question.len;i=i+1){let ch=question.get(i);if(ch=" "){idx=idx+1;if(idx=1){keywords=keywords+@(question.get(0)));};}el{keywords=keywords+@(ch);};};let first=keywords.get(0);if(first="w"){if(keywords.get(1)="h"){if(keywords.get(2)="a"){if(keywords.get(3)="t"){if(keywords.get(4)="e"){if(keywords.get(5)="?"){followup="What is the answer to the question?";};};};};};};};};};};};};};};};};};};};};};};};};}