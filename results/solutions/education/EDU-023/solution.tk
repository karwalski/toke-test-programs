m=assign;f=assignreviewers(n:$i64;m:$i64):@$str{let authors=mut.@();lp(let i=0;i<n;i=i+1){authors=authors+@(s.concat("author";i) as$str)}};let reviewers=mut.@();lp(let i=0;i<m;i=i+1){reviewers=reviewers+@(s.concat("rev";i) as$str)}};let assignments=mut.@();lp(let ai=0;ai<authors.len;ai=ai+1){let author=authors.get(ai);let found=mut.false;let assignedreviewer=mut."";lp(let ri=0;ri<reviewers.len;ri=ri+1){let rev=reviewers.get(ri);let isassigned=mut.false;if(ai=ri){isassigned=true};if(!(isassigned)){if(!(found)){assignedreviewer=rev;found=true}}}};if(found){assignments=assignments+@(author+s.concat("→";assignedreviewer)))}el{assignments=assignments+@(author+s.concat("→";"none")))}};let result=mut."";lp(let i=0;i<assignments.len;i=i+1){let line=assignments.get(i);result=result+line