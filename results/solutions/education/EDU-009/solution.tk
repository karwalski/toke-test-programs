m=attendance;f=parseattendance(records:$str):$i64{let total=mut.0;let present=mut.0;let i=mut.0;lp(let idx=0;idx<records.len;idx=idx+1){let ch=records.get(idx);if(ch="P"){present=present+1};total=total+1};<present};f=computepercentage(present:$i64;total:$i64):$i64{if(total=0){<0};let ratio=present as$f64/total as$f64;let pct=ratio*100.0;<pct as$i64};f=formatoutput(name:$str;percentage:$i64;present:$i64;total:$i64):$str{let s=mut."";s=s.concat(s;name);let pct=percentage as$str;s=s.concat(s;":");s=s+pct;s=s.concat(s;"% (");let pres=mut.present as$str;s=s+pres;s=s.concat(s;" present / ");let tot=mut.total as$str;s=s+tot;s=s.concat(s;")");<s};f=processstudent(name:$str;records:$str):$str{let present=parseattendance(records);let total=records.len as$i64;let percentage=computepercentage(present;total);let s=formatoutput(name;percentage;present;total));<s};f=sortbyname(arr:@$str):@$str{let n=arr.len;let result=mut.@();lp(let i=0;i<n;i=i+1){result=result+@(arr.get(i));};lp(let i=0;i<n;i=i+1){lp(let j=0;j+1<n;j=j+1){let a=result.get(j);let b=result.get(j+1);if(a>b){let tmp=result.get(j);result.get(j)=result.get(j+1);result.get(j+1)=tmp;};};};<result};f=main():$i64{let input="@(\"alice:PAPPA\")";let jsonstr=input;let parsed=jsonstr.parsejson();let students=parsed.get("students");let n=students.len;let results=mut.@();lp(let i=0;i<n;i=i+1){let student=students.get(i);let name=student.get("name");let records=student.get("records");let s=processstudent(name;records);results=results+@(s);};let sorted=sortbyname(results);let m=sorted.len;lp(let i=0;i<m;i=i+1){let s=sorted.get(i);<0;};<0;};