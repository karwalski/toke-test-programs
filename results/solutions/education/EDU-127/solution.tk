m=awards;f=calculateawards(scores:@$i64):@$str{let result=mut.@();lp(let i=0;i<scores.len;i=i+1){let score=scores.get(i);let award=mut."";if(score>90){award="gold"}el{if(score>80){award="silver"}el{if(score>70){award="bronze"}el{award="none"}}}};result=result+@(award)};};<result};f=main():$void{let scores=@(95;85;75;65;55));let awards=calculateawards(scores);lp(let i=0;i<awards.len;i=i+1){let award=awards.get(i);let output=mut."";if(award="gold"){output="Gold Award"}el{if(award="silver"){output="Silver Award"}el{if(award="bronze"){output="Bronze Award"}el{output="No Award"}}}};let idx=i as$str;let msg=output+@" for student #";let fullmsg=msg+idx;let finalmsg=fullmsg+@".";let finalfinalmsg=finalmsg