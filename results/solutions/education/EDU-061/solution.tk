m=classavg;f=parseinput(input:$str):$str{let parts=input.split(" ");let studentid=parts.get(0);let grades=parts.slice(1;parts.len());<studentid};f=computeaverages(grades:$str):$str{let lines=grades.split("\n");let totals=mut.@();let counts=mut.@();lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);let studentid=parseinput(line);let score=studentid.toi64();let idx=totals.len as i64;let tmp=totals.get(idx as u64);tmp=score;totals=tmp;let cnt=counts.get(idx as u64);cnt=cnt+1;counts=counts;};let result=mut."";lp(let i=0;i<totals.len;i=i+1){let score=totals.get(i);let count=counts.get(i);let avg=score/count as i64;let line=avg as$str+"\n";result=result+line;};<result};f=main():$void{let input="100 90 80 70