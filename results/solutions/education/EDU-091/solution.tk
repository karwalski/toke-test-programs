m=scoretracker;f=scoreboard(n:$i64;m:$i64):$i64{let total=mut.0;total=n+m;<total};f=recordevent(score:$i64;event:$str):$i64{let newscore=mut.0;if(event="correct"){newscore=score+1}el{if(event="incorrect"){newscore=score-1}el{newscore=score}}};<newscore};f=main():$i64{let s1=scoreboard(10;5));let s2=recordevent(s1;"correct");let s3=recordevent(s2;"incorrect");let finalscore=scoreboard(s3;0);<finalscore};