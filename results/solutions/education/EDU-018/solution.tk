m=score;f=score(rubric:$str;response:$str):$i64{let score=mut.0;let rubricsplit=rubric.split("\n");let n=rubricsplit.len;lp(let i=0;i<n;i=i+1){let line=rubricsplit.get(i);let parts=line.split(":");let m=parts.len;if(m>2){let criterion=parts.get(0);let weight=parts.get(1).trim().replace("%";"");let weightval=weight.parsei64();let maxscore=100;let minscore=0;let diff=maxscore-minscore;let weighteddiff=diff*weightval/100;let minscoreval=weighteddiff;let maxscoreval=weighteddiff+diff;let rubricscore=mut.0