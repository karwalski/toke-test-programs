m=knn;f=knn(k:$i64;train:$str;trainlabels:$str;test:$str):$str{let result=mut."";let len=train.len();let kval=k;if(kval<1){let kval=1};if(kval>len){let kval=len};let testlen=test.len();let trainlen=len;let closest=mut.@();let labels=mut.@();lp(let i=0;i<kval;i=i+1){closest=closest+@(0.0);labels=labels+@("");};lp(let i=0;i<trainlen;i=i+1){let dist=mut.0.0;lp(let j=0;j<testlen;j=j+1){let diff=train.get(i).get(j)-test.get(j);dist=dist+diff*diff;};let found=mut.false;let minidx=mut.0;lp(let j=0;j<kval;j=j+1){if(!found){if(j=0){minidx=j;found=true;}el{if(dist<train.get(i).get(j))){minidx=j;found=true;};};};};};};};};};};};};};};};