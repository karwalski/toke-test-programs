m=confusion;f=buildconfusion(p:$str;q:$str):$str{let res=mut."";let hit=mut.0;let total=mut.0;lp(let i=0;i<p.len;i=i+1){let pi=p.get(i);let qi=q.get(i);if(pi=qi){hit=hit+1};total=total+1;};res=s.concat(s.concat(res;"TP: ");hit) as$str+"\n";res=s.concat(res;"FP: ")+(total-hit)as$str+"\n";res=s.concat(res;"FN: ")+(total-hit)as$str+"\n";res=s.concat(res;"TN: ")+(total-2*hit)as$str+"\n";<res};f=main():$str{let p=$str.fromarray(@("y";"n";"y";"n";"y")));let q=$str.fromarray(@("y";"n";"y";"m";"y")));let r=buildconfusion(p;q);<r};