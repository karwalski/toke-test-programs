m=warranty;f=parseinput(input:$str):$str{let parts=input.split(" ");let model=parts.get(0);let failures=parts.get(1);let volume=parts.get(2);<model};f=computeexpectedfailures(model:$str;volume:$i64):$i64{let base=10;let exp=base-volume;let failures=exp;if(failures<0){<0};<failures};f=estimatetotalfailures(model:$str;volume:$i64):$i64{let expected=computeexpectedfailures(model;volume);let safetyfactor=1.5;let adjusted=safetyfactor*expected;let result=adjusted as$i64;if(result<0){<0};<result};f=buildoutput(model:$str;totalfailures:$i64):$str{let line1=model;let line2="total estimated failures:";let failurestr=totalfailures as$str;let result=line1+s.concat(s.concat("\n";line2);"\n")+failurestr;<result};f=main(input:$str):$str{let model=parseinput(input);let totalfailures=estimatetotalfailures