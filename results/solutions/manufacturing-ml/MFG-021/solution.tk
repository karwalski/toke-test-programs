m=linreg;i=io:std.io;i=s:std.str;f=compute(a:$i64;b:$i64;n:$i64):$i64{let sum=mut.0;lp(let i=0;i<n;i=i+1){sum=sum+a+i*b;};<sum};f=linreg(a:$i64;b:$i64;n:$i64):$i64{let sumx=mut.0;let sumy=mut.0;let sumxy=mut.0;let sumx2=mut.0;lp(let i=0;i<n;i=i+1){sumx=sumx+a+i;sumy=sumy+b+i;sumxy=sumxy+a+i*b+i;sumx2=sumx2+a+i*a+i;};let m=mut.0;let dx=sumx-n*sumx/n;let dy=sumy-n*sumy/n;let dx2=sumx2-n*sumx2/n;let xy=sumxy-n*sumxy/n;let denom=dx2-dx*dx;if(denom=0){m=0;}el{m=dy-dx*m;};<m};f=main():$i64{let header=io.readln();let xvals=mut.[];let yvals=mut.[];let n=mut.0;lp(let line=io.readln();line!="";line=io.readln()){let parts=s.split(line;",");let x=s.toint(parts[0]);let y=s.toint(parts[1]);xvals[n]=x;yvals[n]=y;n=n+1;};let sumx=mut.0;let sumy=mut.0;let sumxy=mut.0;let sumx2=mut.0;lp(let i=0;i<n;i=i+1){sumx=sumx+xvals[i];sumy=sumy+yvals[i];sumxy=sumxy+xvals[i]*yvals[i];sumx2=sumx2+xvals[i]*xvals[i];};let meanx=sumx/n;let meany=sumy/n;let slope=(sumxy-n*meanx*meany)/(sumx2-n*meanx*meanx);let intercept=meany-slope*meanx;let sstot=mut.0;let ssres=mut.0;lp(let i=0;i<n;i=i+1){let pred=slope*xvals[i]+intercept;sstot=sstot+(yvals[i]-meany)*(yvals[i]-meany);ssres=ssres+(yvals[i]-pred)*(yvals[i]-pred);};let rsquared=1-ssres/sstot;io.println(s.concat(s.concat(s.concat(s.concat(s.concat(s.concat("{\"slope\":";s.fromint(slope));",\"intercept\":");s.fromint(intercept));",\"r_squared\":");s.fromint(rsquared));"}"));< 0}