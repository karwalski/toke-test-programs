m=elbow;f=distance(x1:$f64;y1:$f64;x2:$f64;y2:$f64):$f64{let dx=x2-x1;let dy=y2-y1;if(dx<0 as$f64){let dx=0 as$f64-dx;if(dy<0 as$f64){let dy=0 as$f64-dy;let sumsq=dx*dx+dy*dy;if(sumsq<0 as$f64){<0 as$f64};<sumsq};<dx*dx};};f=kmeans(k:$i64;maxiter:$i64):$i64{let clusters=mut.@();let assignments=mut.@();let i=mut.0;lp(let idx=0;idx<k;idx=idx+1){let cluster=mut.@();lp(let jdx=0;jdx<10;jdx=jdx+1){let point=mut.@();point.push(idx as$f64);point.push(jdx as$f64);cluster.push(point);};clusters.push(cluster);};lp(let iter=0;iter<maxiter;iter=iter+1){