m=mostsimilar;f=cosinesim(a:@$i64;b:@$i64):$f64{let dot=mut.0;let maga=mut.0;let magb=mut.0;lp(let i=0;i<a.len;i=i+1){dot=dot+(a.get(i)*b.get(i)));maga=maga+(a.get(i)*a.get(i)));magb=magb+(b.get(i)*b.get(i)));};let result=dot/(maga*magb));<result};f=mostsimilar(batches:@$str;newbatch:$str):$str{let maxsim=mut.0.0;let bestbatch=mut."";lp(let i=0;i<batches.len;i=i+1){let sim=cosinesim(batches.get(i).chars;batches.get(i).chars);if(sim>maxsim){maxsim=sim;bestbatch=batches.get(i);};};<bestbatch};