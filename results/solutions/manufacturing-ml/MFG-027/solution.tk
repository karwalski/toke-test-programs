m=outlier;f=outlier(arr:@$i64):@$i64{let n=arr.len;let sorted=mut.@();lp(let i=0;i<n;i=i+1){sorted=sorted+@(arr.get(i));};lp(let i=0;i<n;i=i+1){let lhs=sorted.get(i);let rhs=arr.get(i);if(lhs=rhs){<@};};let q1=mut.0;let q3=mut.0;let iqr=mut.0;let minval=mut.0;let maxval=mut.0;let range=mut.0;let median=mut.0;let lower=mut.0;let upper=mut.0;let count=mut.0;let idx=mut.0;let val=mut.0;let tmp=mut.0;let result=mut.@()