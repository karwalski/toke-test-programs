m=estimatelife;f=extractdegradation(data:$str):$f64{let lines=data.split("\n");let last=lines.get(lines.len-1));let parts=last.split("=");<parts.get(1).trim().parsef64()}f=estimatetrend(degradation:$f64;days:$i64):$f64{let trend=mut.0.0;if(days>0){trend=degradation/(days as$f64))};<trend};f=estimatelife(degradation:$f64;days:$i64):$i64{let trend=estimatetrend(degradation;days);let projecteddays=mut.0;let currentdays=mut.days;lp(let i=0;i<1000;i=i+1){let remainingdegradation=degradation-(trend*(currentdays as$f64)));if(remainingdegradation<0.0){projecteddays=currentdays;br;};currentdays=currentdays+1;};<projecteddays>;