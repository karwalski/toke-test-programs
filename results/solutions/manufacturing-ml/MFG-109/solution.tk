m=lotdisp;f=classify(p:$i64;q:$i64):$str{let r=mut."";if(p<q){r="PASS";}el{r="FAIL";};<r};f=checklot(results:@$str):$str{let allpass=mut.true;let n=results.len;lp(let i=0;i<n;i=i+1){let r=results.get(i);if(!(r="PASS"))){allpass=false;};};if(allpass){<"PASS";}el{let failcount=mut.0;lp(let i=0;i<n;i=i+1){let r=results.get(i);if(r="FAIL"){failcount=failcount+1;};};let failrate=failcount as$f64/n as$f64;let threshold=0.20 as$f64;if(failrate>threshold){<"FAIL";}el{<"WARN";};};