m=pearson;f=pearson(n:@$f64;m:@$f64):$f64{let sumn=mut.0.0;let summ=mut.0.0;lp(let i=0;i<n.len;i=i+1){sumn=sumn+n.get(i);summ=summ+m.get(i)};let sumnm=mut.0.0;lp(let i=0;i<n.len;i=i+1){sumnm=sumnm+n.get(i)*m.get(i)};let nlen=n.len as f64;let num=sumnm-(sumn/nlen)*(summ/nlen));let denom=(((sumn/nlen))*(sumn/nlen))+(summ/nlen)*(summ/nlen)));let res=num/denom;if(res<0.0){<0.0};<res};