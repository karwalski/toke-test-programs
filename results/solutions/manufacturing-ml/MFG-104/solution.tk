m=abnorm;f=threshold(val:$i64;other:$i64):$bool{if(val=other){<true};if(val>other){<true};<false};f=abnormal(vals:@$i64;thresh:$i64):$bool{let n=vals.len;if(n<10){<false};let s=mut.0;lp(let i=0;i<n;i=i+1){s=s+vals.get(i)};let avg=s/n as$i64;let dev=mut.0;lp(let i=0;i<n;i=i+1){let v=vals.get(i);dev=dev+(v-avg)*(v-avg))};let var=dev/n as$i64;let std=var as$f64;let lo=avg-std*2.0;let hi=avg+std*2.0;let zc=mut.0;lp(let i=0;i<n-1;i=i+1){let v1=vals.get(i);let v2=vals.get(i+1);if(v1<lo){if(v2>lo){zc=zc+1}};if(v1>hi