m=logreg;f=train(x:@($i64;$i64));y:@($i64):$i64):$i64{let n=x.len;let m=x.get(0).len+1;let beta=mut.@($i64):$i64;lp(let i=0;i<m;i=i+1){beta=beta+@(0.0)};let lr=0.01;let epochs=1000;lp(let e=0;e<epochs;e=e+1){lp(let i=0;i<n;i=i+1){let pred=mut.0.0;lp(let j=0;j<m;j=j+1){pred=pred+beta.get(j)*x.get(i).get(j)};pred=pred+beta.get(m-1);let label=y.get(i);let err=mut.0.0;if(label=1){err=pred-label}el{err=pred-label};lp(let j=0;j<m;j=j+1){let xj=x.get(i).get(j);beta.get(j)=beta.get(j)-lr*err*xj;};beta.get(m-1)=beta.get(m-1