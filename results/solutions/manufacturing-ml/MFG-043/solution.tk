m=shapiro;f=shapiro(arr:@$f64):$f64{let n=arr.len;if(n<2){<0.0};if(n>20){<0.0};let m=mut.0;lp(let i=0;i<n;i=i+1){m=m+arr.get(i);};let mu=m/n;let s=mut.0;lp(let i=0;i<n;i=i+1){let diff=arr.get(i)-mu;s=s+diff*diff;};let v=n-1;let inv=mut.1;lp(let i=0;i<v;i=i+1){inv=inv*(n-i)/(i+1));};let sh=inv*s/v;let crit=mut.0;if(n=2){crit=0.14};if(n=3){crit=0.28};if(n=4){crit=0.40};if(n=5){crit=0.52};if(n=6){crit=0.64};if(n=7){crit=0.76};if(n=8){crit=0.88};if(n=9){crit=0