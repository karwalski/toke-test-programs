m=reliability;i=io:std.io;i=s:std.str;i=math:std.math;f=main():$i64{let header=io.readln();let dataline=io.readln();let parts=s.split(dataline;",");let th=s.tofloat(parts.get(0));let nf=s.tofloat(parts.get(1));let mtime=s.tofloat(parts.get(2));let failrate=nf/th;let mtbf=th/nf;let expo=0.0-failrate*mtime;let rel=math.pow(2.718281828459045;expo);let frstr=s.format(failrate;"%.4f");let mtbfstr=s.fromint(mtbf as$i64);let relstr=s.format(rel;"%.2f");let out=mut."{\"failure_rate\":";out=s.concat(out;frstr);out=s.concat(out;",\"mtbf\":");out=s.concat(out;mtbfstr);out=s.concat(out;",\"reliability_at_mission\":");out=s.concat(out;relstr);out=s.concat(out;"}");io.println(out);<0};