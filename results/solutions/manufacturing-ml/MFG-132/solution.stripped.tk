m=reliability;i=io:std.io;i=s:std.str;i=math:std.math;f=main():$i64{let header=io.readln();let dataline=io.readln();let parts=s.split(dataline;"_");let th=s.tofloat(parts.get(0));let nf=s.tofloat(parts.get(1));let mtime=s.tofloat(parts.get(2));let failrate=nf/th;let mtbf=th/nf;let expo=0.0-failrate*mtime;let rel=math.pow(2.718281828459045;expo);let frstr=s.format(failrate;"_");let mtbfstr=s.fromint(mtbf as$i64);let relstr=s.format(rel;"_");let out=mut."_"failure_rate\"_";out=s.concat(out;frstr);out=s.concat(out;"_"mtbf\"_");out=s.concat(out;mtbfstr);out=s.concat(out;"_"reliability_at_mission\"_");out=s.concat(out;relstr);out=s.concat(out;"_");io.println(out);<0};