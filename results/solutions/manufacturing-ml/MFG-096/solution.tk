m=changepoint;i=io:std.io;i=s:std.str;f=main():$i64{let line=s.trim(io.readln());let parts=s.split(line;",");let n=parts.len();let vals=mut.@();lp(let idx=0;idx<n;idx=idx+1){vals=vals+@(s.tofloat(s.trim(parts.get(idx))))};let bestcp=mut.0;let bestcost=mut.0.0;let first=mut.0.0;lp(let idx=0;idx<n;idx=idx+1){first=first+vals.get(idx)};let initmean=first/s.tofloat(s.fromint(n));let initcost=mut.0.0;lp(let idx=0;idx<n;idx=idx+1){let d=vals.get(idx)-initmean;initcost=initcost+d*d};bestcost=initcost;let found=mut.0;lp(let cp=1;cp<n;cp=cp+1){let suma=mut.0.0;lp(let idx=0;idx<cp;idx=idx+1){suma=suma+vals.get(idx)};let meana=suma/s.tofloat(s.fromint(cp));let sumb=mut.0.0;lp(let idx=cp;idx<n;idx=idx+1){sumb=sumb+vals.get(idx)};let meanb=sumb/s.tofloat(s.fromint(n-cp));let cost=mut.0.0;lp(let idx=0;idx<cp;idx=idx+1){let da=vals.get(idx)-meana;cost=cost+da*da};lp(let idx=cp;idx<n;idx=idx+1){let db=vals.get(idx)-meanb;cost=cost+db*db};if(cost<bestcost){bestcost=cost;bestcp=cp;found=1}};if(found=1){let cpval=bestcp;let suma=mut.0.0;lp(let idx=0;idx<cpval;idx=idx+1){suma=suma+vals.get(idx)};let meana=suma/s.tofloat(s.fromint(cpval));let sumb=mut.0.0;lp(let idx=cpval;idx<n;idx=idx+1){sumb=sumb+vals.get(idx)};let meanb=sumb/s.tofloat(s.fromint(n-cpval));let out=mut."";out=s.concat(out;"{\"change_points\":[");out=s.concat(out;s.fromint(cpval));out=s.concat(out;"],\"segment_means\":[");out=s.concat(out;s.format(meana;"%.1f"));out=s.concat(out;",");out=s.concat(out;s.format(meanb;"%.1f"));out=s.concat(out;"]}");io.println(out)}el{io.println("{\"change_points\":[],\"segment_means\":[]}")};<0}