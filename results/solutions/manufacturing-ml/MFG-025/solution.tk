m=kmeans;f=kmeans(vals:@$f64;k:$i64):@$f64{let n=vals.len;let centroids=mut.@();lp(let i=0;i<k;i=i+1){let idx=i*(n/k as u64);centroids=centroids+@(vals.get(idx))};lp(let iter=0;iter<100;iter=iter+1){let newcents=mut.@();lp(let i=0;i<k;i=i+1){let sum=mut.0.0;let cnt=mut.0;lp(let j=0;j<n;j=j+1){let v=vals.get(j);let ci=i as u64;let cz=v.get(ci);let diff=cz-sum;if(diff<0){let diff=0-diff;sum=sum+diff;}el{sum=sum+diff;};cnt=cnt+1;};let avg=sum as f64/cnt as f64;newcents=newcents+@(avg));};lp(let j=0;j<n;j=j+1){let v=vals.get(j);let bestidx=mut.0;let bestdist=mut.0.0;lp