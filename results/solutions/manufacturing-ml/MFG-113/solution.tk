m=cpkmonitor;f=runningcpk(cpkvals:@$f64):$f64{let total=mut.0.0;lp(let i=0;i<cpkvals.len;i=i+1){total=total+cpkvals.get(i);};<total/cpkvals.len as$f64};f=iscpksufficient(cpkval:$f64;targetcpk:$f64):$bool{let result=mut.false;if(cpkval>targetcpk){result=true;};<result};f=monitorcpk(cpkvals:@$f64;targetcpk:$f64):$bool{let currentcpk=runningcpk(cpkvals);let isgood=iscpksufficient(currentcpk;targetcpk);<isgood};f=main():$i64{let cpkvals=@(1.2;1.3;1.4;1.5;1.6));let targetcpk=1.4;let degradationdetected=!monitorcpk(cpkvals;targetcpk);<0};