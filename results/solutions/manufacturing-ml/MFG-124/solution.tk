m=yieldcalc;f=calcstageyield(total:$i64;defective:$i64):$f64{let totalf=total as$f64;let defectf=defective as$f64;let yield=1.0-(defectf/totalf));<yield};f=propagateyield(yields:@$f64):$f64{let total=mut.0.0;lp(let i=0;i<yields.len;i=i+1){let y=yields.get(i);total=total+y;};let finalyield=total/yields.len;<finalyield};f=main():$i64{let yields=@(0.95;0.98;0.92;0.97));let final=propagateyield(yields);<0};