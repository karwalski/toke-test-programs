m=multiplelinreg;f=multiplelinreg(x:$i64;y:$i64):$i64{let n=x.len;let m=y.len;let beta0=mut.0.0;let beta1=mut.0.0;let beta2=mut.0.0;let sumx=mut.0.0;let sumy=mut.0.0;let sumxy=mut.0.0;let sumx2=mut.0.0;lp(let i=0;i<n;i=i+1){let xi=x.get(i);let yi=y.get(i);sumx=sumx+xi;sumy=sumy+yi;sumxy=sumxy+xi*yi;sumx2=sumx2+xi*xi};let denom=sumx2;beta1=sumxy/denom;beta0=sumy-beta1*sumx;let result=mut.0.0;lp(let i=0;i<m;i=i+1){let xi=x.get(i);let yi=y.get(i);let pred=beta0+beta1*xi;result=result+pred-yi;};let mse=result/m as$f64;let finalbeta0=