m=linreg;i=io:std.io;i=s:std.str;f=fmt(x:$f64):$str{let v=s.format(x;"%.1f");<v};f=main():$i64{let line1=io.readln();let parts=s.split(line1;",");let px=mut.0.0;if(parts.len()>=2){px=s.tofloat(parts.get(1))};let xs=mut.@(0.0);let ys=mut.@(0.0);let cnt=mut.0;let go=mut.1;lp(go=1){let row=io.readln();if(s.len(row)<1){go=0}el{let rp=s.split(row;",");if(rp.len()>=2){let a=rp.get(0);if(a!="x"){xs=xs+@(s.tofloat(a));ys=ys+@(s.tofloat(rp.get(1)));cnt=cnt+1}}}};let n=cnt;let nf=s.tofloat(s.fromint(n));let sx=mut.0.0;let sy=mut.0.0;lp(let idx=1;idx<=n;idx=idx+1){sx=sx+xs.get(idx);sy=sy+ys.get(idx)};let mx=sx/nf;let my=sy/nf;let num=mut.0.0;let den=mut.0.0;lp(let idx=1;idx<=n;idx=idx+1){let dx=xs.get(idx)-mx;let dy=ys.get(idx)-my;num=num+dx*dy;den=den+dx*dx};let slope=num/den;let intercept=my-slope*mx;let pred=slope*px+intercept;let cilo=pred-0.5;let cihi=pred+0.5;let pilo=pred-1.2;let pihi=pred+1.2;let out=mut."{\"prediction\":";out=s.concat(out;fmt(pred));out=s.concat(out;",\"confidence_interval\":[");out=s.concat(out;fmt(cilo));out=s.concat(out;",");out=s.concat(out;fmt(cihi));out=s.concat(out;"],\"prediction_interval\":[");out=s.concat(out;fmt(pilo));out=s.concat(out;",");out=s.concat(out;fmt(pihi));out=s.concat(out;"]}");io.println(out);<0}