m=chart;f=buildchart(data:@$str):$str{let counts=mut.@();let labels=mut.@();let n=data.len;lp(let i=0;i<n;i=i+1){let item=data.get(i);let found=mut.false;let m=counts.len;lp(let j=0;j<m;j=j+1){if(labels.get(j)=item)){found=true;};};if(!(found)){counts=counts+@(0);labels=labels+@(item);};let idx=mut.0;let m2=labels.len;lp(let j=0;j<m2;j=j+1){if(labels.get(j)=item)){idx=j;};};let current=counts.get(idx);counts=counts+@(0);let newcounts=mut.@();let newlabels=mut.@();let m3=labels.len;lp(let j=0;j<m3;j=j+1){if(!(labels.get(j)=item))){newcounts=newcounts+@(counts.get(j));newlabels=newlabels+@(labels.get(j));};};newcounts=newcounts+@(current+1);newlabels=newlabels+@(item);<newlabels.len as$str+s.concat(":";"\"")+newlabels.join