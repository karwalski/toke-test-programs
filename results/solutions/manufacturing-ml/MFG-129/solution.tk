m=entropy;f=calc_entropy(defects:@($str):i64):$str{let total=defects.len;let entropy=mut.0.0;lp(let i=0;i<total;i=i+1){let defect=defects.get(i);let count=defect.count;let prob=count as f64/total as f64;entropy=entropy+prob*log2(prob);};let result=entropy as$str;<result;};f=log2(n:f64):f64{let result=mut.0.0;let current=mut.n;lp(let i=0;i<100;i=i+1){if(current>1.0){result=result+1.0;current=current/2.0;}el{br;}};<result;};