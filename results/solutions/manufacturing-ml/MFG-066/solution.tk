m=featureimportance;f=buildforest(traindata:$str;labels:$str;ntrees:$i64):$str{let forest=mut."";lp(let i=0;i<ntrees;i=i+1){let treeid=i as$str;let tree=mut."";let header=mut."";let rowcount=mut.0;let colcount=mut.0;let datalines=mut.@();let labellines=mut.@();let alllines=mut.@();let isheader=mut.true;lp(let lineidx=0;lineidx<traindata.len;lineidx=lineidx+1){let line=traindata.get(lineidx);if(isheader){header=line;isheader=false;}el{datalines=datalines+@(line);};};lp(let lineidx=0;lineidx<labels.len;lineidx=lineidx+1){let line=labels.get(lineidx);labellines=labellines+@(line);};lp(let i=0;i<datalines.len;i=i+1){alllines=alllines+@(datalines.get(i)));};let rowstart=mut.0;let rowend=mut.0;let colstart=mut.0;let colend=mut.