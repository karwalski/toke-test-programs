m=graddesc;t=$str;f=clamp(val:$f64;lo:$f64;hi:$f64):$f64{if(val<lo){<lo};if(val>hi){<hi};<val};f=linearinterp(x:$f64;xa:$f64;xb:$f64;ya:$f64;yb:$f64):$f64{let dx=x-xa;let dy=yb-ya;let t=dx/(xb-xa);let result=ya+t*dy;<result};f=abs(val:$f64):$f64{if(val<0.0){<-val};<val};f=relui(x:$f64):$f64{if(x>0.0){<x};<0.0};f=dot3(lhs:@$f64;rhs:@$f64):$f64{let result=mut.0.0;lp(let idx=0;idx<3;idx=idx+1){result=result+lhs.get(idx)*rhs.get(idx)};<result};f=gdstep(gain:$f64;grad:$