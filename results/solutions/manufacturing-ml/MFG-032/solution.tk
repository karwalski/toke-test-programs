m=sensor;f=solve(p0:$str):$str{let lines=p0.split("\n");let threshold=lines.get(0).split(",").get(1).trim().parsefloat();let values=mut.@();let timestamps=mut.@();lp(let i=1;i<lines.len;i=i+1){let line=lines.get(i);let cols=line.split(",");let ts=cols.get(0).trim();let v=cols.get(1).trim().parsefloat();timestamps=timestamps+@(ts);values=values+@(v)};let rates=mut.@();lp(let i=0;i<values.len-1;i=i+1){let v0=values.get(i);let v1=values.get(i+1));let t0=timestamps.get(i);let t1=timestamps.get(i+1));let dt=t1-t0;let dv=v1-v0;let rate=dv/dt;rates=rates+@(rate)};let maxrate=mut.0;lp(let i=0;i<rates.len;i=i+1){let r=rates.get(i);if(r>maxrate){maxrate=r}};let minrate=mut.maxrate