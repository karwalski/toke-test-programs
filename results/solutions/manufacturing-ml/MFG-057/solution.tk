m=feature;f=mean(arr:@$f64):$f64{let sum=mut.0.0;lp(let i=0;i<arr.len;i=i+1){sum=sum+arr.get(i);};<sum/(arr.len as$f64))};f=variance(arr:@$f64):$f64{let m=mean(arr);let sum=mut.0.0;lp(let i=0;i<arr.len;i=i+1){let diff=arr.get(i)-m;sum=sum+diff*diff;};<sum/(arr.len as$f64))};f=stddev(arr:@$f64):$f64{<variance(arr)};f=normalise(arr:@$f64):@f64{let m=mean(arr);let s=stddev(arr);let result=mut.@();lp(let i=0;i<arr.len;i=i+1){let z=(arr.get(i)-m)/s;result=result+@(z);};<result};