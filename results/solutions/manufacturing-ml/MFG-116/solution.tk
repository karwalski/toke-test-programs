m=healthcheck;f=calchealth(noise:$i64;drift:$i64;dropout:$i64):$i64{let score=mut.100;if(noise>50){score=noise*2}el{if(noise>25){score=noise*1.5}el{score=100-noise}};if(drift>50){score=score-drift}el{if(drift>25){score=score-drift/2}el{score=score}};if(dropout>5){score=score-dropout}el{if(dropout>2){score=score-dropout/2}el{score=score}};<score};f=assignpriority(score:$i64):$str{if(score<20){<"critical"};if(score<50){<"high"};if(score<80){<"medium"};<"low"};f=processsensorrow(row:$str):$str{let cols=row.split(",");let sensorid=cols.get(0);let noise=cols.get(1).parsei64();let drift=cols.get(2).parsei64();let dropout=cols.get(3).parsei64();let health=calchealth(noise;drift;dropout);let priority=assignpriority(health);let result=sensorid+"\";result=result+"\"health_score\":";result=result+health.asstr();result=s.concat(result;",\"maintenance_priority\":\"");result=result+priority;result=s.concat(result;"\"}");<result};f=main():$void{let input=std.io.readstd();let rows=input.split("\n");let header=rows.get(0);let result=mut."";let i=mut.1;lp(let idx=1;idx<rows.len;idx=idx+idx){let row=rows.get(idx);let sensorid=processsensorrow(row);if(i=1){result=sensorid}el{result=s.concat(result;"\n")+sensorid};i=i+1};let output=result;<output};