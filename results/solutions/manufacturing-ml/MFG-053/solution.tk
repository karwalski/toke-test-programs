m=weightedavg;f=computeavg(readings:@$f64;weights:@$f64):$f64{let total=mut.0.0;let sumweights=mut.0.0;let n=readings.len;lp(let i=0;i<n;i=i+1){let r=readings.get(i);let w=weights.get(i);total=total+r*w;sumweights=sumweights+w};if(sumweights=0.0){<0.0};<total/sumweights};f=main():$i64{let readings=@(1.2;3.4;5.6;7.8));let weights=@(0.5;1.0;1.5;2.0));let avg=computeavg(readings;weights);<0 as$i64};