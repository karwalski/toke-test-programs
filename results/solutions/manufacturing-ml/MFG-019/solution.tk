m=we;f=iswe(data:@$i64):$bool{let len=data.len;if(len<20){<false};let avg=mut.0;lp(let i=0;i<len;i=i+1){avg=avg+data.get(i)};avg=avg/(len as$i64));let std=mut.0;lp(let i=0;i<len;i=i+1){let diff=data.get(i)-avg;std=std+diff*diff};std=std/(len as$i64)-1 as$i64);let lo=avg-3*std;let hi=avg+3*std;let count=mut.0;lp(let i=0;i<len;i=i+1){let v=data.get(i);if(v<lo){count=count+1};if(v>hi){count=count+1}};if(count>0){<true};<false};