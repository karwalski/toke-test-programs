m=traceability;f=checkbatch(batch:$str):$bool{let valid=mut.false;if(batch.len=10){let first=batch.charat(0);let second=batch.charat(1);if(first="B"){if(second="T"){valid=true}}}};<valid};f=findbybatch(productlist:@$str;batch:$str):$str{let result=mut."";let found=mut.false;lp(let idx=0;idx<productlist.len;idx=idx+1){let item=productlist.get(idx);let batchstart=item.indexof("batch:");if(!(batchstart<0)){let batchpos=batchstart+6;let batchend=item.indexof("}";batchpos);if(!(batchend<0)){let extracted=item.substring(batchpos;batchend);if(extracted=batch){result=item;found=true}}}};<result};f=buildtrace(productlist:@$str;batch:$str):$str{let valid=checkbatch(batch);if(valid){let founditem=findbybatch(productlist;batch);if(founditem.len>0){let trace="Traceability: batch ";trace=s.concat(trace;batch);trace=s.concat(trace;" found in product: ");trace=trace