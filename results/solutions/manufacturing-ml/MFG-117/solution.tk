m=nuisance;i=io:std.io;i=s:std.str;f=fmtavg(avg:$f64):$str{let r=s.format(avg;"%.1f");<r};f=main():$i64{let header=io.readln();let ids=mut.@();let counts=mut.@();let durs=mut.@();let nids=mut.0;let line=mut.io.readln();lp(s.len(s.trim(line))>0){let parts=s.split(line;",");if(parts.len()>=3){let aid=s.trim(parts.get(0));let dur=s.toint(s.trim(parts.get(2)));let found=mut.0-1;let j=mut.0;lp(j<nids){if(ids.get(j)=aid){found=j};j=j+1};if(found<0){ids=ids.push(aid);counts=counts.push(1);durs=durs.push(dur);nids=nids+1}el{counts=counts.set(found;counts.get(found)+1);durs=durs.set(found;durs.get(found)+dur)}};line=io.readln()};let out=mut."{\"alarms\":[";let k=mut.0;lp(k<nids){if(k>0){out=s.concat(out;",")};let cnt=counts.get(k);let totaldur=durs.get(k);let avg=s.tofloat(s.fromint(totaldur))/s.tofloat(s.fromint(cnt));let nuis=mut."false";if(cnt>3){nuis="true"};out=s.concat(out;"{\"alarm_id\":\"");out=s.concat(out;ids.get(k));out=s.concat(out;"\",\"count\":");out=s.concat(out;s.fromint(cnt));out=s.concat(out;",\"avg_duration\":");out=s.concat(out;fmtavg(avg));out=s.concat(out;",\"nuisance\":");out=s.concat(out;nuis);out=s.concat(out;"}");k=k+1};out=s.concat(out;"]}");io.println(out);<0}