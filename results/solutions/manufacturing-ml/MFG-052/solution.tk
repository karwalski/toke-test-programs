m=drift;f=measure(p:$i64):$i64{let q=mut.0;lp(let i=0;i<p;i=i+1){q=q+1};<q};f=driftdetect(vals:@$i64):$bool{let n=vals.len;if(n<2){<false};let a=mut.0;let b=mut.0;lp(let i=0;i<n-1;i=i+1){a=a+vals.get(i);b=b+vals.get(i+1)};let avgab=a/(n-1 as u64);let avgb=b/(n-1 as u64));let diff=avgb-avgab;if(diff<0){diff=0-diff};let threshold=10;if(diff>threshold){<true};<false};f=main():$i64{let readings=@(100;98;97;96;95;94;93;92;91));let drift=driftdetect(readings);if(drift){<1}el{<0}};