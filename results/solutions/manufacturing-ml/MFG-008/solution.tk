m=rangechart;f=buildchart(vals:@$i64):$str{let n=vals.len;if(n=0){<"No data"};let minv=mut.vals.get(0);let maxv=mut.vals.get(0);lp(let i=0;i<n;i=i+1){let v=vals.get(i);if(v<minv){minv=v};if(v>maxv){maxv=v}};let range=maxv-minv;let bins=mut.10;if(range<10){bins=1}el{if(range<50){bins=5}};let binwidth=range/bins;let counts=mut.@($i64);lp(let i=0;i<bins;i=i+1){counts=counts+@(0)};lp(let i=0;i<n;i=i+1){let v=vals.get(i);let binidx=(v-minv)/binwidth;if(binidx=bins){let lastidx=bins-1;if(counts.get(lastidx)<counts.get(binidx))){let tmp=counts.get(binidx);counts.get(binidx)=counts.get(lastidx);counts.get(lastidx)=tmp}}el{if(bin