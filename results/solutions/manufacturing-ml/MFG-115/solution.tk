m=spa;i=io:std.io;i=s:std.str;f=fabs(x:$f64):$f64{if(x<0.0){<0.0-x};<x};f=main():$i64{let l1=io.readln();let l2=io.readln();let l3=io.readln();let p1=s.split(l1;",");let target=s.tofloat(p1.get(1));let p2=s.split(l2;",");let deadband=s.tofloat(p2.get(1));let parts=s.split(l3;",");let n=parts.len() as i64;let sum=mut.0.0;lp(let i=0;i<n;i=i+1){sum=sum+s.tofloat(parts.get(i as u64))};let nf=s.tofloat(s.fromint(n));let mean=sum/nf;let offset=mean-target;let needed=mut.false;if(fabs(offset)>deadband){needed=true};let adj=0.0-offset;let meanstr=s.format(mean;"%.2f");let offstr=s.format(offset;"%.2f");let adjstr=s.format(adj;"%.2f");let nstr=mut."false";if(needed){nstr="true"};io.println("{\"current_mean\":\(meanstr),\"offset\":\(offstr),\"adjustment_needed\":\(nstr),\"adjustment_amount\":\(adjstr)}");<0}
