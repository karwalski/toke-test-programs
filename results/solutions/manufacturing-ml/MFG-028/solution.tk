m=iforest;f=isqrt(n:$i64):$i64{let r=mut.0;lp(let i=0;i<64;i=i+1){let sq=mut.0;lp(let j=0;j<r;j=j+1){sq=sq+2*r+1;};if(sq>n){r=r-1;};r=r+1;};<r};f=buildtree(points:@($point);k:$i64):$tree{let n=points.len;if(n=0){<emptytree()};let m=n-1;let medianidx=isqrt(n)*2;if(medianidx<n){let medianval=points.get(medianidx).val;if(medianval<0){let medianval=0-medianval;};};let leftpoints=mut.@($point);let rightpoints=mut.@($point);lp(let i=0;i<n;i=i+1){let p=points.get(i);if(p.val<medianval){leftpoints=leftpoints+@(p);}el{rightpoints=rightpoints+@(p);};};let lefttree=buildtree(leftpoints;k);let righttree=buildtree(rightpoints;k);