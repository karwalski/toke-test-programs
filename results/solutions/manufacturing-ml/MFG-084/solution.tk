m=decompose;f=decompose(vals:@$i64;period:$i64):@$i64{let n=vals.len;let trend=mut.@($i64);let seasonal=mut.@($i64);let residual=mut.@($i64);let sum=mut.0;lp(let i=0;i<n;i=i+1){let v=vals.get(i);sum=sum+v;if(i<period){trend=trend+@(v);seasonal=seasonal+@(v);residual=residual+@(0);}el{let idx=i-i/period*period;let base=i/period*period;let s=mut.0;lp(let j=0;j<period;j=j+1){let k=base+j;if(k<n){s=s+vals.get(k);};};let avg=s/period;let diff=v-avg;let tidx=i-i/period*period;let tbase=i/period*period;let sidx=i-i/period*period;let sbase=i/period*period;let ridx=i-i/period*period;let rbase=i/period*period;let t=trend.get(tidx);