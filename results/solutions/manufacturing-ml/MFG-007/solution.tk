m=rangechart;f=buildchart(data:@$i64):$str{let n=data.len;if(n=0){<"No data";};let total=mut.0;lp(let i=0;i<n;i=i+1){let v=data.get(i);total=total+v;};let avg=total as f64/n as f64;let var=mut.0.0;lp(let i=0;i<n;i=i+1){let v=data.get(i)as f64;var=var+(v-avg)*(v-avg));};let sd=var/n as f64;let lo=avg-2.0*sd;let hi=avg+2.0*sd;let out=mut."Range Chart: ";out=s.concat(out;"Min=");out=s.concat(out;lo) as$str;out=s.concat(out;" Max=");out=s.concat(out;hi) as$str;out=s.concat(out;" Avg=");out=s.concat(out;avg) as$str;out=s.concat(out;" SD=");out=s.concat(out;sd) as$str;<out};