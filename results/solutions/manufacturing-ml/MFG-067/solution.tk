m=silhouette;f=silhouette(vals:@$f64;labels:@$i64):$f64{let n=vals.len;let clusters=mut.@();lp(let i=0;i<n;i=i+1){let label=labels.get(i);let found=mut.false;lp(let j=0;j<clusters.len;j=j+1){if(clusters.get(j)=label)){found=true};};if(!(found)){clusters=clusters+@(label)};};let s=mut.0.0;lp(let i=0;i<n;i=i+1){let val=vals.get(i);let label=labels.get(i);let a=mut.0.0;let b=mut.0.0;let minab=mut.0.0;lp(let j=0;j<n;j=j+1){let otherlabel=labels.get(j);if(!(otherlabel=label)){}el{let otherval=vals.get(j);let diff=otherval-val;if(diff<0){let tmp=diff;diff=0-diff;};a=a+diff;};}