m=hotellings;f=mean2d(arr:@($i64;$i64))):$i64{let n=arr.len;let m=mut.0;lp(let i=0;i<n;i=i+1){let v=arr.get(i);m=m+v;};<m};f=var2d(arr:@($i64;$i64));m:$i64):$i64{let n=arr.len;let s=mut.0;lp(let i=0;i<n;i=i+1){let v=arr.get(i);let diff=v-m;s=s+diff*diff;};<s/n as$f64};f=hotellings(arr:@($i64;$i64))):$f64{let n=arr.len;let m=mean2d(arr);let s=var2d(arr;m);let xbar=0 as$f64;let diff=m-xbar;let result=diff*diff/s;<result};