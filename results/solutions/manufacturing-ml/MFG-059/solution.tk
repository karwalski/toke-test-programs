m=rankfeatures;f=rankfeatures(input:$str):$str{let lines=input.split("\n");let headers=lines.get(0).split(",");let n=headers.len();let scores=mut.@();lp(let i=0;i<n;i=i+1){scores=scores.push(0.0);};let linecount=mut.0;lp(let i=1;i<lines.len();i=i+1){let line=lines.get(i);let cols=line.split(",");let valid=mut.true;lp(let j=0;j<cols.len();j=j+1){let col=cols.get(j);if(col.len=0){valid=false;};};if(valid){let k=0