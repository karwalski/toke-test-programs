m=biasdetect;f=absval(x:$f64):$f64{if(x<0.0){<0.0-x};<x}};f=compare(val:$f64;other:$f64):$i64{if(val=other){<0};if(val>other){<1};<-1};f=classifybias(difference:$f64;stddev:$f64):$str{let zscore=difference/stddev;if(zscore<-1.96){<"systematic"};if(zscore>-1.96){if(zscore<1.96){if(zscore>-1.96){<"random"};};};<"systematic"};<"random"};f=detectbias(measurements:@$f64;reference:$f64;stddev:$f64):$str{let avg=mut.0.0;let n=measurements.len;lp(let i=0;i<n;i=i+1){avg=avg+measurements.get(i)};avg=avg/n as$f64;let difference=reference-avg;let bias=classifybias(difference;stddev);<bias