m=roc;f=roc(p:$@($f64);n:$i64;m:$i64):$@($f64):$f64{let thresholds=mut.@();let minp=mut.1.0;lp(let i=0;i<n;i=i+1){let v=p.get(i);if(v<minp){minp=v};};let step=mut.0.01;lp(let t=0.0;t<1.0;t=t+step){thresholds=thresholds+@(t)};let points=mut.@();lp(let i=0;i<thresholds.len;i=i+1){let t=thresholds.get(i);let tp=mut.0;let fp=mut.0;let fn=mut.0;lp(let j=0;j<n;j=j+1){let v=p.get(j);if(v<t){if(v=1){tp=tp+1}el{fp=fp+1}}el{if(v=1){tp=tp+1}el{fn=fn+1}}}};let x=fp/(fp+tp);let y=tp/(tp+fn);points=points+