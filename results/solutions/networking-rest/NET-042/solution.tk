m=httpreverseproxy;f=proxyhandle(req:i64;upstreamurl:$str):i64{let upstream=mut.upstreamurl;let method=req.method;let path=req.path;let fullpath=upstream+path;let headers=req.headers;let body=req.body;let sendurl=fullpath;let sendheaders=headers;let sendbody=body;let response=mut.proxyfetch(method;sendurl;sendheaders;sendbody));let respheaders=response.headers;let respbody=response.body;let finalresp=mut.proxybuildresponse(respheaders;respbody));<finalresp};f=proxyfetch(method:$str;url:$str;headers:i64;body:$str):i64{let result=mut.http:sendrequest(method;url;headers;body));<result};f=proxybuildresponse(headers:i64;body:$str):i64{let response=mut.http:buildresponse(headers;body));<response};f=proxysendrequest(client:i64