m=httpserver;f=main():$void{let port=8080;let msg="Server started on port 8080";<};f=handlepost(body:$str):$str{let dataset=@(1;"alice";30;true);(2;"bob";25;false);(3;"charlie";35;true));let fields=@("id";"name");let filterfield="age";let filtervalue=30;let result=mut.@();lp(let idx=0;idx<dataset.len;idx=idx+1){let item=dataset.get(idx);let id=item.get(0);let name=item.get(1);let age=item.get(2);let isactive=item.get(3);if(age=filtervalue){let entry=@(id;name);result=result+@(entry);};};<result};