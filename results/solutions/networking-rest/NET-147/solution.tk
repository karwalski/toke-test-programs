m=httpclient;f=fetch(url:$str):$str{let body=std.http.get(url);<body};f=fetchcached(url:$str):$str{let cachedpath="/tmp/httpcache/";let urlhash=std.crypto.sha256(url);let cachepath=cachedpath+urlhash;let cachefound=std.file.exists(cachepath);if(cachefound){let cachedcontent=std.file.read(cachepath);<cachedcontent}el{let fetched=fetch(url);let fetchedok=std.http.isok(fetched);if(fetchedok){let responsebody=std.http.body(fetched);let responsehash=std.crypto.sha256(responsebody);let expectedpath=cachedpath+responsehash;let expecteddir="/tmp/httpcache/";let dircreated=std.file.exists(expecteddir);if(dircreated){let writestatus=std.file.write(expectedpath;responsebody);let cachestored=std.file.exists(expectedpath);if(cachestored){<responsebody}el{<""}}el{<""}}el{<""}}};f=main():$void{let url=std.io.readline();let result=fetchcached(url);<result};