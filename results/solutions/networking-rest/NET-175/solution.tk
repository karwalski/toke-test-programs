m=schemafetcher;f=fetchschema(url:$str):$str{let body=mut."";let schema=mut."";let idx=mut.0;let n=url.len;lp(let i=0;i<n;i=i+1){let c=url.get(i);if(c=":"){idx=i+1;br;};};lp(let i=idx;i<n;i=i+1){let c=url.get(i);if(c="/"){idx=i+1;br;};};let endpoint=mut."";lp(let i=idx;i<n;i=i+1){let c=url.get(i);endpoint=endpoint+c;};let result=mut."";let i=mut.0;let len=endpoint.len;lp(let j=0;j<len;j=j+1){let ch=endpoint.get(j);result=result+ch;i=i+1;};let finalresult=mut."";lp(let k=0;k<result.len;k=k+1){let ch=result.get(k);finalresult=finalresult+ch;};<finalresult};