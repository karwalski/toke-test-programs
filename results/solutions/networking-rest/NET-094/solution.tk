m=httpserver;f=main():$void{let port=8080;let baseurl="http://localhost:8080";let docurl=s.concat(baseurl;"/docs");let msg=mut."Server running on port ";msg=s.concat(msg;port) as$str;msg=s.concat(msg;"\nOpen API docs at ");msg=s.concat(msg;docurl);msg=s.concat(msg;"\n");let out=mut.baseurl;out=out+"\n";out=out+docurl;out=out+"\n";out=out+msg;out=out+"\n";let body=out as$str;let headers=mut."HTTP/1.1 200 OK\n";headers=s.concat(headers;"Content-Type: text/plain\n");headers=s.concat(headers;"Content-Length: ");let len=body.len as$str;headers=headers+len;headers=s.concat(headers;"\n\n");let result=mut.headers;result=result+body;result=result+"\n";let final=result as$str;let output=mut.final;output=output+"\n";let disp=mut.output;disp=disp+"\n";let show=mut.disp;show=show+"\n";let present=mut.show;present=present+"\n";let visible=mut.present;visible=visible+"\n";let rendered=mut.visible