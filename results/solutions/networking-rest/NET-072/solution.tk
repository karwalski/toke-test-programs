m=wsbin;f=onopen(c:i64):$void{let welcome="Welcome! Send 4-byte type + payload.";c.send(welcome);};f=onmsg(c:i64;msg:$str):$void{let data=msg.asbytes;let typ=mut.0;lp(let i=0;i<4;i=i+1){typ=typ*256+data.get(i as u64));};let payloadlen=typ;let ack=s.concat("Ack: ";payloadlen) as$str;c.send(ack);};f=onclose(c:i64):$void{let msg="Bye!";c.send(msg);};f=main():$void{let c=ws.accept();onopen(c);lp(let msg=c.recv();msg.len>0;msg=c.recv()){onmsg(c;msg);};onclose(c);};