m=httpserver;f=main():$void{let port=8080;let baseurl="http://localhost:8080";let msg="Server listening on port ";let fullmsg=s.concat(msg;port) as$str;let logresult=mut.log(fullmsg);let handlerresult=mut.maphandlers(baseurl);let mainloopresult=mut.mainloop();};f=log(msg:$str):$void{let result=mut.print(msg);};f=maphandlers(baseurl:$str):$void{let result=mut.print(baseurl);};f=mainloop():$void{let result=mut.print("mainloop");};