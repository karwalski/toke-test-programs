m=main;f=baseport():$i64{<7000};f=startservice(port:$i64):$bool{<true};f=startapiserver(base:$i64):$bool{<true};f=waitforhealth(port:$i64):$bool{<true};f=registeruser(name:$str;email:$str):$str{<""};f=addproduct(name:$str;price:$f64):$str{<""};f=placeorder(user:$str;products:$str):$str{<""};f=verifyorder(orderid:$str;user:$str):$bool{<true};f=runtest(base:$i64):$bool{let reg=registeruser("alice";"alice@example.com");let added=addproduct("widget";19.99);let placed=placeorder(reg;added);let verified=verifyorder(placed;reg);<verified};f=main():$void{let port=baseport();let srv=startservice(port);let apsrv=startapiserver(port);let healthy=waitforhealth(port);let testpassed=runtest(port);if(testpassed){<void}el{<void}};