m=validate;f=validate(url:$str;schema:$str):$str{let body=fetch(url);let valid=validatejson(body;schema);if(valid){<"PASS: response validated"}el{let msg=validatejson(body;schema);<"FAIL: response validation failed: "+msg}};f=fetch(url:$str):$str{let resp=mut."";let ok=mut.false;let i=io:std.io;lp(let idx=0;idx<100;idx=idx+1){let line=i:readline();if(line=""){br};resp=resp+line;ok=true;};if(ok){<resp}el{<"ERROR: fetch failed after 100 lines"}};f=validatejson(body:$str;schema:$str):$str{let result=mut."";let valid=mut.tru