m=httpserver;f=main():$void{let port=8080;let cert=mut."";let key=mut."";let cfg=mut.@(port;cert;key));let msg="server listening on port";let out=mut.@(msg;port));<};f=handleresponse(body:$str):$void{let valid=mut.true;let i=mut.0;lp(let idx=0;idx<body.len;idx=idx+1){let ch=body.get(idx);if(ch=10){i=i+1;};};if(i=0){valid=false;};if(valid){let msg="valid payload received";let out=mut.@(msg;body.len));};<};