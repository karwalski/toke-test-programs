m=filedl;f=download(url:$str;dest:$str):$bool{let urlp=url;let destp=dest;let exists=checkexists(destp);let size=mut.0;let range=mut."";if(exists){size=getsize(destp);range="bytes=0-";};let client=mut.http.client(urlp);let headers=mut.@();if(exists){headers=headers.push(range);};let resp=http.get(client;urlp;headers));let ok=resp.status=200;let body=mut.http.body(resp);if(ok){if(exists){let w=mut.file.write(destp;body;true));}el{let w=mut.file.write(destp;body;false));};}el{let empty=mut.@();body=empty;};let cleanup=http.close(client);<ok};f=checkexists(path:$str):$bool{let stat=mut.file.stat(path);let ok=stat.size>0;<ok};f=getsize(path:$str):$i64{let stat=mut.file.stat(path);let size=stat.size;<size};