m=httpproxy;f=proxyconnect(req:$str):$str{let parts=req.split(" ");let method=parts.get(0);let target=parts.get(1);let protocol=target.split(":").get(0);let host=target.split(":").get(1);let port=target.split(":").get(2);let conndata=s.concat(s.concat(s.concat(s.concat(s.concat(s.concat(s.concat(s.concat("CONNECT ";host);":");port);" HTTP/1.1\r\nHost: ");host);":");port);"\r\nProxy-Connection: keep-alive\r\n\r\n");let response=sendtcp(protocol;host;port;conndata);let lines=response.split("\r\n");let httpline=lines.get(0);let is200=httpline.contains("200");if(!(is200)){<""};let tunnelstart=lines.get(1);let fullresponse=tunnelstart+response.substring(2);<fullresponse};f=sendtcp(proto:$str;host:$str;port:$str;data:$str):$str{let conn=mut."";if(proto="https"){conn="tls1.2"}el{if(proto="ssh"){conn="ssh2"}el{conn=proto}}};let result=mut."";let attempt=mut