m=httpserver;f=main():$void{let port=8080;let certpath="";let keypath="";let cfg=makeconfig(port;certpath;keypath));let srv=makehttpserver(cfg);let logpath="access.log";let logcfg=makeauditconfig(logpath);let withlog=auditmiddleware(srv;logcfg);let handler=withlog;let result=servehttp(handler);};f=servehttp(handler:httphandler):$void{let conn=mut.acceptconn();lp(let lv=0;true;lv=lv+1){if(conn=none){br};let req=mut.readreq(conn);if(req.method="shutdown"){conn=none;br};let resp=handler(req);writeresp(conn;resp);};};f=httpmethod(name:$str):$str{<name};f=httpstatus(code:i64):$str{if(code=200){<"OK"};if(code=201){<"Created"};if(code=204){<"NoContent"};if(code=301){<"MovedPermanently"};if(code=302){<"Found"};if(code=304){<"