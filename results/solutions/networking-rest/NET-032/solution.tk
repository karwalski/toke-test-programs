m=httpserver;f=main():$void{let port=8080;let baseurl="http://localhost:8080";let shutdownkey="SHUTDOWN";let eventpath="/events";let webhooks=mut.@();let currentkey=mut."";let currentvalue=mut."";let readingkey=mut.true;lp(let idx=0;idx<1000;idx=idx+1){let char=std.stdin.readchar();if(char=shutdownkey){<0};if(char="\n"){if(readingkey){currentkey=currentvalue;}el{let webhookurl=currentvalue;webhooks=webhooks+@(webhookurl);};currentkey="";currentvalue="";readingkey=true;}el{if(readingkey){currentvalue=currentvalue+char;}el{currentvalue=currentvalue+char;};};};let server=std.http.server.create(port);let basepath=std.http.server.basepath(server);let eventurl=basepath+eventpath;std.http.server.start(server);lp(let idx=0;idx<1000;idx=idx+1){let req=std.http.server.nextrequest(server);if(req=shutdownkey){<0};