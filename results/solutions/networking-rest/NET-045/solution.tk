m=httpserver;f=main():$void{let port=8080;let cert=mut."";let key=mut."";let index=indexhtml();let notfound=notfoundhtml();let server=mut.httpserver.new(port;cert;key));httpserver.serve(server;index;notfound));};f=indexhtml():$str{let html=mut."<!DOCTYPE html><html><head><title>RPC Server</title></head><body><h1>RPC Server</h1><p>Call methods via JSON-RPC 2.0.</p></body></html>";<html>;};f=notfound