m=ctlog;f=queryapi(url:$str):$str{let result=mut."";let ch=mut.url;lp(let i=0;i<ch.len;i=i+1){let c=ch.get(i);result=result+c;};<result};f=fetchcerts(domain:$str):$str{let apiurl="https://crt.sh/api?output=json&q=";let fullurl=s.concat(apiurl;domain);let response=queryapi(fullurl);<response};f=main():$void{let input=mut."";let ch=mut.stdin;lp(let i=0;i<ch.len;i=i+1){let c=ch.get(i);input=input+c;};let domain=input;let certs=fetchcerts(domain);<certs};