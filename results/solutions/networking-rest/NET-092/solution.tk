m=httpserver;f=extracttenantid(req:$str):$str{let lines=req.split("\n");let tenantid=mut."";lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);if(line.contains("Host:"))){let parts=line.split("Host:");let subdomain=parts.get(1).trim();if(subdomain.contains(".")){let tenant=subdomain.split(".").get(0);tenantid=tenant;}el{if(!(subdomain.len=0 as u64))){tenantid=subdomain;}}}}el{if(line.contains("X-Tenant-ID:"))){let parts=line.split("X-Tenant-ID:");tenantid=parts.get(1).trim();}}}};if(!(tenantid.len=0 as u64))){<tenantid};<""};f=sendresponse(conn:$str;status:$i64;body:$str):$void{let response=mut."";response=s.concat(response;status) as$str;response=s.concat(response;" ");response=s.concat(response;body.len) as$str;response=s.concat(response;"\n");response=s.concat(s.concat(response;body);"\n");<conn.write(response)};f=handlerequest(conn:$str;req:$str