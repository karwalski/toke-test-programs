m=urlparse;f=solve(p0:$str):$str{let url=p0;let scheme=mut."";let host=mut."";let port=mut."";let path=mut."";let query=mut."";let fragment=mut."";let i=mut.0;let n=url.len;lp(let idx=0;idx<n;idx=idx+1){let c=url.get(idx);if(c=":"){scheme=url.sub(i;idx);i=idx+1;}el{if(c="/"){if(i=0){host=url.sub(i+1;idx);i=idx+1;}el{if(i<idx){port=url.sub(i;idx);i=idx+1;};};path=url.sub(i;idx);i=idx+1;}el{if(c="?"){query=url.sub(i;idx);i=idx+1;}el{if(c="#"){fragment=url.sub(i;idx);i=idx+1;};};};};};};};};};};};};};};};};};};};};};};};};}