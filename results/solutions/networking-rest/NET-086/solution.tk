m=main;i=http:std.http;i=json:std.json;i=crypto:std.crypto;i=str:std.str;f=validate(req:i64;secret:$str):$bool{let sigheader=req.headers.get("x-signature");let computed=crypto.hmacsha256(secret;req.body);let valid=crypto.constanttimeequal(computed;sigheader);if(valid){let nowts=str.toint(str.fromint(str.nowms()as$str))));let expiryts=str.toint(req.headers.get("x-expiry")));let ok=nowts<expiryts;if(ok){<true}el{<false}}el{<false}};f=main():$void{let port=8080;let secret="mysecretkey";let handler=http.handler();let sighandler=http.handler();let validator=http.handler();let routes=@(http.route{method:"POST";path:"/sign";handler:handler};http.route{method:"GET";path:"/resource";handler:validator};http.route{method:"POST";path:"/sign";handler:sig