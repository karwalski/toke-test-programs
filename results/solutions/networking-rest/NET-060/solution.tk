m=httpget;f=main():$void{let port=8080;let msg="Server started on port ";let fullmsg=s.concat(msg;port) as$str;let printresult=fullmsg;let body="Hello, world!";let ok="HTTP/1.1 200 OK\r\nContent-Length: ";let totallen=body.len as$str;let response=ok+totallen+s.concat("\r\n\r\n";body);let responsesent=response;let shutdownmsg="Server shut down";let finalmsg=responsesent+s.concat("\n";shutdownmsg);printresult=finalmsg};