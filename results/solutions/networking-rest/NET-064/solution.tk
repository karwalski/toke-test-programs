m=digestauth;f=main():$void{let port=8080;let realm="Restricted";let users=@("user1:password1";"user2:password2");let server=std.http.server(port);let auth=std.auth.digest(realm);lp(let i=0;i<users.len;i=i+1){let u=users.get(i);let parts=u.split(":");let username=parts.get(0);let password=parts.get(1);let entry=std.auth.digest.userentry(auth;username);password);};let handler=std.http.handler();let authhandler=std.auth.digest.handler(auth);let pipeline=std.http.pipeline(server;handler;authhandler));};