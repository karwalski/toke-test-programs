m=api;f=fetchall(baseurl:$str):$str{let items=mut.@();let cursors=mut.@(baseurl);let seen=mut.@();lp(let idx=0;idx<1000;idx=idx+1){if(cursors.len=0){br};let current=mut.cursors.get(0);let resp=mut.http.get(current);let data=mut.resp.json();let itemsarr=mut.data.get("items");let itemcount=mut.itemsarr.len;lp(let j=0;j<itemcount;j=j+1){let item=mut.itemsarr.get(j);let itemstr=mut.item.tojson();items=mut.items.push(itemstr);};let nexturl=mut.data.get("nextCursor");if(nexturl.isnull){cursors=mut.@()}el{cursors=mut.@(nexturl)};};<items.join("\n")>};f=main():$void{let baseurl=mut.http.stdinread();let result=mut.fetchall(baseurl);http.stdoutwrite(result);};