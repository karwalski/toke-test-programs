m=ws;f=main():$void{let srv=ws.srv.new(9443);let res=ws.srv.listen(srv);let con=ws.srv.accept(srv);let req=ws.srv.recv(con);let rep=ws.srv.process(req);ws.srv.send(con;rep);};f=process(req:i64):i64{let action=req.action;let topic=req.topic;let message=req.message;let rtopic=mut.topic;if(action="subscribe"){let found=mut.false;lp(let i=0;i<subscribers.len;i=i+1){let s=subscribers.get(i);if(s.topic=topic){found=true}};if(!found){subscribers=subscribers+@(req)}};if(action="publish