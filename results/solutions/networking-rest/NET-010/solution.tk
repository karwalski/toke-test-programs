m=http;f=main():$void{let port=8080;let msg="Server started on port 8080";<msg};f=handlepost(req:$str):$str{if(req="login"){let sid=generatesid();setsession(sid;"user");<sid};if(req="logout"){let sid=getcookie("sid");setsession(sid;"");<""};<""};f=handleget(req:$str):$str{if(req="profile"){let sid=getcookie("sid");let user=getsession(sid);if(user=""){<""};<user};<""};f=generatesid():$str{let chars="0123456789abcdef";let len=chars.len;let sid="";lp(let idx=0;idx<32;idx=idx+1){let rand=mut.0;lp(let jdx=0;jdx<1000;jdx=jdx+1){rand=rand+1};let mod=rand-rand/len*len;let ch=chars.get(mod as u64);let newsid=sid+ch;let sid=newsid;};<sid};f=setsession