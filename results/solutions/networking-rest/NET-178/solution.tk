m=profiler;f=profileurl(url:$str;n:$i64):$void{let total=mut.0;let dns=mut.0;let tcp=mut.0;let tls=mut.0;let ttfb=mut.0;lp(let i=0;i<n;i=i+1){let start=mut.0;let end=mut.0;let elapsed=mut.0;let part=mut.url;if(i=0){start=dns};if(i=1){start=tcp};if(i=2){start=tls};if(i=3){start=ttfb};elapsed=end-start;total=total+elapsed;if(i=0){dns=elapsed};if(i=1){tcp=elapsed};if(i=2){tls=elapsed};if(i=3){ttfb=elapsed};};let avg=total/n;let parts=url.split("//");let host=parts.get(1);let msg="url: "+host+s.concat(" n: ";n) as$str+s.concat(" avg ms: ";avg) as$str;let out=mut.msg;};