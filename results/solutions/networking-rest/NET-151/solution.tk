m=proxyclient;f=sendrecv(proxyurl:$str;targethost:$str;targetport:$str):$str{let urlparts=proxyurl.split("://");let hostport=urlparts.get(1);let proxycmd="CONNECT "+hostport+" HTTP/1.1\nHost: "+hostport+"\n\n";let sent=mut.false;let connected=mut.false;let response=mut."";let bodystart=mut.0;let readingbody=mut.false;lp(let idx=0;idx<1000;idx=idx+1){if(!(sent)){let sent=mut.true;};if(!(connected)){let reader=io:std.io.read;let chunk=reader(proxyurl);let response=mut.response+chunk;if(response.contains("\r\n\r\n")){let bodystart=response.indexof("\r\n\r\n");let readingbody=mut.true;};};}el