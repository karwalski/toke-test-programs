m=ratecheck;i=io:std.io;i=s:std.str;f=solve(p0:$i64;p1:$i64;p2:$i64):$str{let total=p2;let limit=p1;let allowed=mut.0;let rejected=mut.0;let expected=total-limit;lp(let idx=0;idx<total;idx=idx+1){if(idx<limit){allowed=allowed+1}el{rejected=rejected+1}};let result=mut."";if(rejected=expected){result="PASS"}el{result="FAIL"};<result};f=main():$i64{let port=s.toint(io.readln());let limit=s.toint(io.readln());let total=s.toint(io.readln());io.println(solve(port;limit;total));<0}