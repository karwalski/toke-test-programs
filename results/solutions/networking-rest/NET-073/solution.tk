m=httpserver;f=main():$void{let cidrs=mut.@();let lines=br.stdin();lp(let i=0;i<lines.len;i=i+1){let l=lines.get(i);if(l.len=0){br};let cidr=l;cidrs=cidrs+@(cidr);};let port=8080;let baseurl="http://127.0.0.1:8080";let routes=@("/hello";"/world");let allowed=mut.@();lp(let i=0;i<cidrs.len;i=i+1){let cidr=cidrs.get(i);let entry=makeentry(cidr);allowed=allowed+@(entry);};let server=makehttpserver(port;routes;allowed);let result=runhttpserver(server);<result;};f=makeentry(cidr:$str):$serverentry{let parts=cidr.split("/");let ip=parts.get(0);let prefix=parts.get(1);let entry=$serverentry{ip:ip;prefix:prefix as i64};<entry;};f=makehttpserver(port:i64;routes:@($str);allowed:@($serverentry