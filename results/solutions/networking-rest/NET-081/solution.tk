m=httpbatch;f=httpbatch(port:$i64):$void{let server=std.http.server(port);let body=std.http.body();let requests=std.json.parsearray(body);let n=requests.len;let responses=mut.@();lp(let idx=0;idx<n;idx=idx+1){let req=requests.get(idx);let method=std.json.str(req;"method");let path=std.json.str(req;"path");let query=std.json.str(req;"query");let body=std.json.str(req;"body");let resp=std.http.client(method;path;query;body);responses=responses+resp;};let resp=std.http.response(200;"OK";responses);std.http.send(server;resp);std.http.shutdown(server)};f=main():$void{httpbatch(8080);};f=stdhttpget(url:$str):$str{let resp=std.http.client("GET";url;"";"";0);<resp};f=stdhttpgetjson