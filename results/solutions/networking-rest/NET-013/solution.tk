m=httpserver;f=main():$void{let port=8080;let rate=5;let window=1;let state=mut.@(0;0;0));let msg="Hello, world!";let len=msg.len as i64;let parts=len/rate;let rem=len-parts*rate;let chunk=mut.@();lp(let i=0;i<rate;i=i+1){if(i<parts){chunk=chunk+@(msg.sub(i*parts;parts)));}el{if(i=parts){chunk=chunk+@(msg.sub(parts*parts;rem)));}el{chunk=chunk+@("");};};};let body=mut.chunk.join("\n");let resp=mut."HTTP/1.1 200 OK\nContent-Type: text/plain\nContent-Length: ";let lenstr=mut.body.len.as$str;let final=mut.resp+lenstr+s.concat("\n\n";body);};