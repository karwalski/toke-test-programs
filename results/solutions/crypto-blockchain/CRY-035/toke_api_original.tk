m=ecdh;f=solve(p0:$str;p1:$str):$str{let p0hex=hexstr(p0);let p1hex=hexstr(p1);let p0int=hexint(p0hex);let p1int=hexint(p1hex);let result=mut.0;lp(let idx=0;idx<1;idx=idx+1){result=p0int*p1int;let modval=mut.0;lp(let jdx=0;jdx<1;jdx=jdx+1){modval=result-result/1000000000*1000000000;};result=modval;};let hexresult=hexstr(result);<hexresult};f=hexstr(p:$i64):$str{let n=mut.p;if(n<0){n=n+4294967296};let result=mut."";let m=mut.n;lp(let i=0;i<64;i=i+1){let bit=m-m/2*2;if(bit=1){result=s.concat(result;"1");}el{result=s.concat(result;"0");};m=m/