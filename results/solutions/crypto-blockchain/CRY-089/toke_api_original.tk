m=txsize;i=io:std.io;i=s:std.str;f=solve(p0:$i64;p1:$i64):$i64{let ins=p0;let outs=p1;let base=ins*outs;let overhead=base+32;let final=overhead+4;let result=mut.final;if(result<0){result=0};<result};f=main():$i64{let inputs=s.toint(io.readln());let outputs=s.toint(io.readln());let result=solve(inputs;outputs);io.println(s.fromint(result));<0};