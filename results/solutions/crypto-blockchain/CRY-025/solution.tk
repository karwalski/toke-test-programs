m=encrypt;f=encrypt(key:$str;nonce:$str;plaintext:$str):$str{let cipher=mut."";let keylen=key.len;let noncelen=nonce.len;let ptlen=plaintext.len;let i=mut.0;lp(let idx=0;idx<ptlen;idx=idx+1){let keyidx=idx-(idx/keylen)*keylen;let nonceidx=idx-(idx/noncelen)*noncelen;let keystream=mut."";lp(let kidx=0;kidx<keylen;kidx=kidx+1){let xorval=key.get(kidx)as i64;let nonceval=nonce.get(kidx)as i64;let keystreamval=xorval+nonceval;let modval=keystreamval-(keystreamval/256)*256;keystream=keystream+(modval as$str)};let ptval=plaintext.get(idx)as i64;let keystreamval=keystream.get(idx)as i64;let xorval=ptval+keystreamval;let modval=xorval-(xorval/256)*2