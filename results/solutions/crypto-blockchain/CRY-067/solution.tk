m=blockheader;f=solve(p0:$i64;p1:$str;p2:$str;p3:$i64;p4:$str;p5:$i64):$str{let version=p0;let prevhash=p1;let merkle=p2;let timestamp=p3;let bits=p4;let nonce=p5;let result=mut."";let versionhex=version as$str;result=result+versionhex;result=result+prevhash;result=result+merkle;let timestamphex=timestamp as$str;result=result+timestamphex;result=result+bits;let noncehex=nonce as$str;result=result+noncehex;let finalresult=mut."";lp(let idx=0;idx<80;idx=idx+1){let ch=result.get(idx);finalresult=finalresult+ch;};<finalresult};