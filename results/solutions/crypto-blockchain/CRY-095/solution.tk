m=il;i=io:std.io;i=s:std.str;f=mysqrt(x:$f64):$f64{let g=mut.x;let i=mut.0;lp(i<60){g=(g+x/g)/2.0;i=i+1};<g};f=main():$i64{let l1=io.readln();let l2=io.readln();let p0=s.tofloat(l1);let p1=s.tofloat(l2);let r=p1/p0;let il=2.0*mysqrt(r)/(1.0+r)-1.0;let pct=mut.il*100.0;if(pct<0.0){pct=0.0-pct};io.println(s.format(pct;"%.2f"));<0}
