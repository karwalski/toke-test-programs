m=flashloan;i=io:std.io;i=s:std.str;f=extractreturn(line:$str):$i64{let parts=s.split(line;"\"return\":");if(parts.len()>=2){let after=parts.get(1);let nums=s.split(after;"}");let numstr=s.trim(nums.get(0));<s.toint(numstr)};<0};f=main():$i64{let liquidity=io.readln();let borrowstr=io.readln();let borrowed=s.toint(borrowstr);let feestr=io.readln();let feepct=s.tofloat(feestr);let json=io.readln();let returned=extractreturn(json);let bf=s.tofloat(borrowstr);let feef=bf*feepct/100.0;let feefstr=s.format(feef;"%.0f");let fee=s.toint(feefstr);let torepay=borrowed+fee;let profit=returned-torepay;io.println(s.fromint(profit));if(returned>=torepay){io.println("SUCCESS")}el{io.println("FAILED: insufficient repayment")};<0}