m=secretsharing;f=sharergen(secret:$i64;threshold:$i64;total:$i64):@$i64{let shares=mut.@();let val=secret as$f64;let other=1.0 as$f64;let v=mut.val;lp(let i=0;i<total;i=i+1){let r=v*other;let s=r as$i64;let delta=s as$f64-v*other;if(!(i<total-1)){let adj=mut.0;if(delta<0.0){adj=1}el{if(delta>0.0){adj=-1}};let news=s+adj;shares=shares+@(news)}el{shares=shares+@(s)}};<shares};f=verify(shares:@$i64;threshold:$i64;total:$i64):$bool{let sum=mut.0;lp(let i=0;i<total;i=i+1){sum=sum+shares.get(i as$u64));};let val=sum as$f64;let other=1.0 as$f64;let v=val*other;let s=v as$i