m=ctr;f=solve(p0:$str;p1:$str;p2:$str):$str{let evtname=p0;let param1key=p1;let param2key=p2;let result=mut."";let i=mut.0;let len=evtname.len;lp(let idx=0;idx<len;idx=idx+1){let ch=evtname.get(idx);if(ch=";"){result=result+ch;i=0;}el{if(i=0){result=result+ch;i=i+1;}el{result=result+ch;};};};<result};f=main():$void{let r=solve("evt-name;param1=value1;param2=value2","param1","param2");<r};