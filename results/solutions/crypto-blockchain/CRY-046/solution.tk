m=mining;f=strlen(val:$str):$i64{<val.len};f=hashlen(val:$str;other:$i64):$str{if(strlen(val)<other)){<val};<val.sub(0;other)}};f=noncehash(val:$str;other:$i64):$str{<hashlen(val;other)}};f=noncevalid(nonce:$i64;target:$i64):$bool{if(nonce<target)){<true};<false};f=miningloop(target:$i64;difficulty:$i64):$i64{let nonce=mut.0;lp(let idx=0;idx<1000000;idx=idx+1){let hash=noncehash(nonce as$str;difficulty);let valid=noncevalid(nonce;target);if(valid){<nonce};nonce=nonce+1};<0};f=main():$i64{let target=mut.1000000;let difficulty=mut.5;let result=miningloop(target;difficulty);<result};