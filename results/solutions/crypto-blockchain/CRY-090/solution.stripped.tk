m=txsize;i=io:std.io;i=s:std.str;f=solve(p0:$i64;p1:$i64):$i64{let legacy=p0;let witness=p1;let weight=legacy*4+witness;let vbytes=mut.weight/4;let rem=weight-vbytes*4;if(!(rem=0)){vbytes=vbytes+1};<vbytes};f=main():$i64{let legacy=s.toint(io.readln());let witness=s.toint(io.readln());let weight=legacy*4+witness;let vbytes=solve(legacy;witness);io.println(s.fromint(weight));io.println(s.fromint(vbytes));<0}