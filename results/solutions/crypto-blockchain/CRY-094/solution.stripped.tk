m=liquidity;i=io:std.io;i=s:std.str;f=mintlp(reservea:$i64;deposit:$i64;total:$i64):$i64{<deposit*total/reservea};f=main():$i64{let line1=io.readln();let reserves=s.split(line1;"_");let reservea=s.toint(reserves.get(0));let total=s.toint(io.readln());let depline=io.readln();let dep=s.split(depline;"_");let deposita=s.toint(dep.get(0));let lpmint=mintlp(reservea;deposita;total);io.println(s.fromint(lpmint));<0}