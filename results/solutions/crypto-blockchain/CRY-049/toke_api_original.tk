m=verify;f=verify(leaf:$str;root:$str;path:$str):$str{let valid=mut.true;let leafhash=mut.leaf;if(path.len=0){if(leafhash=root){<VALID}el{<INVALID}};let i=mut.0;lp(let idx=0;idx<path.len;idx=idx+1){let dir=path.get(idx);if(dir="L"){let tmp=mut.leafhash;tmp=tmp+path.get(idx+1));tmp=tmp.lower();leafhash=tmp;}el