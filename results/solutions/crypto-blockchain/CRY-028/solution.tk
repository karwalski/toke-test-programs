m=rsa;i=io:std.io;i=s:std.str;f=modpow(base:$i64;exp:$i64;m:$i64):$i64{let result=mut.1;let basecopy=mut.base;let expcopy=mut.exp;lp(let i=0;expcopy>0;expcopy=expcopy-1){let odd=expcopy-expcopy/2*2;if(odd=1){result=result*basecopy;let r=result-result/2*2;if(r=0){result=result/2}el{result=result/2+1}};basecopy=basecopy*basecopy;let b=basecopy-basecopy/2*2;if(b=0){basecopy=basecopy/2}el{basecopy=basecopy/2+1}};<result};f=rsaencrypt(n:$i64;e:$i64;msg:$i64):$i64{let c=modpow(msg;e;n);<c};f=main():$i64{let nline=io.readln();let eline=io.readln();let msgline=io.readln();let n=s.toint(nline);let e=s.toint(eline);let msg=s.toint(msgline);let ciphertext=rsaencrypt(n;e;msg);io.println(s.fromint(ciphertext));<0};