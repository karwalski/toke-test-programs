m=metadata;f=validatefield(fieldname:$str;value:$str):$bool{let isvalid=mut.true;if(value.len=0){isvalid=false};<isvalid};f=validatejson(jsonstr:$str):$bool{let isvalid=mut.true;let fields=@("name";"description";"image";"attributes"));lp(let idx=0;idx<fields.len;idx=idx+1){let fieldname=fields.get(idx);let value=jsonstr;let found=mut.false;let startidx=mut.0;let endidx=mut.0;let keylen=fieldname.len;let i=mut.0;lp(let j=0;j<value.len;j=j+1){let ch=value.get(j);if(ch=":"){if(j-i=keylen){found=true;startidx=i;endidx=j};i=j+1}};if(found){let extracted=value.sub(startidx;endidx);let isvalid=validatefield(fieldname;extracted);if(!(isvalid=true)){isvalid=false}};if(!(isvalid=true)){isvalid=false}}