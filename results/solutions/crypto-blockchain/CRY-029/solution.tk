m=decrypt;f=solve(n:$str;d:$str;ciphertext:$str):$i64{let key=mut.0;let klen=n.len;lp(let idx=0;idx<klen;idx=idx+1){let ch=n.get(idx);let val=ch as$i64;if(val>96){if(val<123){let offset=val-97;key=key+offset;};};};let dlen=d.len;lp(let idx=0;idx<dlen;idx=idx+1){let ch=d.get(idx);let val=ch as$i64;if(val>96){if(val<123){let offset=val-97;key=key-offset;};};};let ct=mut.ciphertext as$i64;let klen=key as$i64