m=balance;f=balance(ledger:$str;address:$str):$i64{let sum=mut.0;let lines=ledger.split("\n");lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);let is_sender=line.contains(s.concat(address;" sent"));let is_receiver=line.contains(s.concat(address;" received"));let has_address=is_sender||is_receiver;if(has_address){let amount=line.split(" ")[0];let is_debit=amount.contains("-");let debit_amount=mut.0;if(is_debit){let num=amount.split("-")[1];debit_amount=num.to_i64();}let is_credit=!(is_debit);let credit_amount=mut.0;if(is_credit){let num=amount.split("+")[1];credit_amount=num.to_i64();}let net_amount=mut.0;if(is_debit){net_amount=debit_amount;}el{net_amount=credit_amount;};sum=sum+net_amount;}el{if(line.contains(s.concat(address;" sent")))