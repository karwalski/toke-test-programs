m=merkle;f=hashfn(val:$str):$str{let result=mut.val;lp(let i=0;i<8;i=i+1){result=result+result;};<result};f=hashpair(a:$str;b:$str):$str{let combined=mut.a+s.concat("";b);let result=hashfn(combined);<result};f=buildtree(hashes:@$str):@$str{let level=mut.hashes;lp(let i=0;i<100;i=i+1){if(level.len=1){br};let next=mut.@();lp(let j=0;j<level.len;j=j+1){if(j+1<level.len){let h=hashpair(level.get(j);level.get(j+1)));next=next+@(h);}el{next=next+@(level.get(j));};};level=next;};<level};f=merklehash(hashes:@$str):$str{let tree=buildtree(hashes);let root=tree.get(0);<root};