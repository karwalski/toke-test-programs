m=match;f=matchorders(buy:$str;sell:$str):$str{let buyarr=buy.split("\n");let sellarr=sell.split("\n");let result=mut."";let i=mut.0;let j=mut.0;lp(let idx=0;idx<buyarr.len;idx=idx+1){let buyline=buyarr.get(idx);let buyid=buyline.split(" ")[0];let buyprice=buyline.split(" ")[1];let buyqty=buyline.split(" ")[2];let matched=mut.false;let matchedid=mut."";let matchedprice=mut."";let matchedqty=mut."";lp(let jdx=0;jdx<sellarr.len;jdx=jdx+1){let sellline=sellarr.get(jdx);let sellid=sellline.split(" ")[0];let sellprice=sellline.split(" ")[1];let sellqty=sellline.split(" ")[2];if(buyprice=sellprice){matched=true;matchedid=buyid;matchedprice=sellprice;matchedqty=sellqty;};};if(matched){let trade=s.concat(s.concat(s.concat(s.concat("TRADE ";matchedid);" ");matchedprice);" ")+