m=decrypt;f=solve(p0:$str;p1:$str;p2:$str):$str{let hexkey=p0;let hexiv=p1;let hexct=p2;let keylen=hexkey.len;let ivlen=hexiv.len;let ctlen=hexct.len;let valid=mut.true;if(!(keylen=32)){valid=false};if(!(ivlen=16)){valid=false};if(!(ctlen=64)){valid=false};if(!(valid)){<""};let key=hexkey.toi64();let iv=hexiv.toi64();let ct=hexct.toi64();let plen=ctlen;let pt=mut.@();lp(let idx=0;idx<plen;idx=idx+1){let byte=ct.get(idx);pt=pt+@(byte)};let result=pt.tostr();<result};f=main():$void{let p0=$str.read();let p1=$str.read();let p2=$str.read();let result=solve(p0;p1;p2));<result};