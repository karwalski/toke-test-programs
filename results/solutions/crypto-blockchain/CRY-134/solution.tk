m=golomb;f=buildgolomb(arr:@$i64):$i64{let n=arr.len;let m=mut.0;lp(let i=0;i<n;i=i+1){let v=arr.get(i);if(v>m){m=v};};let s=mut.1;lp(let i=0;i<64;i=i+1){if(!(m<s)){s=s+1};};let result=mut.0;lp(let i=0;i<n;i=i+1){let v=arr.get(i);let q=v/s;let r=v-q*s;result=result+q;if(!(r=0)){result=result+1};};<result};f=isgolomb(g:$i64;n:$i64):$bool{let m=mut.0;lp(let i=0;i<n;i=i+1){let v=i+1;let q=v/g;let r=v-q*g;if(r=0){m=m+q}el{m=m+q+1}};<m=n};f=main():$i64{let arr=@(1;2;3;4;5;6;7;8