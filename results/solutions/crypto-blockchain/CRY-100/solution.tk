m=chaincompare;f=findfork(chain1:@$str;chain2:@$str):$str{let len1=chain1.len;let len2=chain2.len;let minlen=mut.len1;if(!(len2<len1)){}el{minlen=len2};let forkhash=mut."";lp(let idx=0;idx<minlen;idx=idx+1){if(chain1.get(idx)=chain2.get(idx)){}el{forkhash=chain1.get(idx);<forkhash};};<forkhash};f=comparechains(chain1:@$str;chain2:@$str):$str{let fork=findfork(chain1;chain2);let len1=chain1.len;let len2=chain2.len;let maxlen=mut.len1;if(!(len2>len1)){}el{maxlen=len2};let result=mut."";if(fork.len=0)){result="equal";}el{if(maxlen=len1)){result="chain1";}el{result="chain2";}}};<result};f=main():$void{let chain1=@("a";"b";"c";"d"));let chain2=@("a";"