m=verify;f=verifyproof(sourcechain:$str;transfer:$str):$bool{let valid=mut.true;if(sourcechain.len=0){valid=false};if(transfer.len=0){valid=false};if(valid){let hash=hashlock(sourcechain);let proof=transfer;let verified=verifyproofhash(proof;hash);if(!verified){valid=false};};<valid};f=hashlock(chainid:$str):$str{let msg=s.concat(chainid;"lock");let hash=hashfn(msg);<hash};f=verifyproofhash(proof:$str;hash:$str):$bool{let msg=s.concat(proof;hash);let computed=hashfn(msg);let valid=mut.false;if(computed=hash){valid=true};<valid};f=hashfn(input:$str):$str{let len=input.len;let sum=mut.0;lp(let i=0;i<len;i=i+1){let ch=input.get(i);let code=chartocode(ch);sum=sum+code;};let result=mut."";let x=sum;let y=0;result=s.concat(result;x) as$str;result=s.concat(result;"=");result=s.concat(result;y) as$str;<result};f=chartocode(ch:$str