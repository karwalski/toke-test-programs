m=nonce;f=readtxs(path:$str):$str{let data=std.io:readfile(path);<data};f=extractnonce(tx:$str):$i64{let start=tx.indexof("nonce=");let end=tx.indexof("&";start);let noncestr=tx.substring(start+6;end);<noncestr.toi64()};f=getnextnonce(accountid:$str;datadir:$str):$i64{let txspath=s.concat(datadir;"/txs");let txdata=readtxs(txspath);let maxnonce=mut.0;let lines=txdata.split("\n");lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);if(line.len=0){<maxnonce};let ismatch=line.indexof(accountid);if(ismatch<0){<maxnonce};let nonce=extractnonce(line);if(nonce>maxnonce){maxnonce=nonce};};<maxnonce+1};f=main():$i64{let accid="acc_001";let datadir="data";let nonce=getnextnonce(accid;datadir);<nonce};