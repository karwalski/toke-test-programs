m=txreceipt;f=extracttransferlogs(receipt:$str):$str{let logs=mut."";let start=mut.0;let end=mut.0;let len=receipt.len;lp(let i=0;i<len;i=i+1){let ch=receipt.get(i);if(ch="\""){if(start=0){start=i+1;}el{end=i;let slice=receipt.slice(start;end);let istransfer=mut.false;if(slice.len>10){let suffix=slice.slice(slice.len-10;slice.len));if(suffix="Transfer"){istransfer=true;};};if(istransfer){let event=slice;let found=mut.false;let result=mut."";let eventlen=event.len;lp(let j=0;j<eventlen;j=j+1){let ch=event.get(j);if(ch=":"){found=true;let keylen=j;let valstart=j+1;let vallen=eventlen-valstart;let key=event.slice(0;keylen));let val=event.slice(valstart;vallen);if(key="\"from\""){result=val;};};};if(found){logs=logs+event+"\n";};};};};};};};