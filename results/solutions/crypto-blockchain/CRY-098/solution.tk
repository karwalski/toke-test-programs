m=priceoracle;i=io:std.io;i=s:std.str;f=median(arr:@$i64;n:$i64):$i64{let sorted=mut.@();lp(let k=0;k<n;k=k+1){sorted=sorted+@(arr.get(k))};lp(let k=0;k<n;k=k+1){let minidx=mut.k;lp(let j=k+1;j<n;j=j+1){if(sorted.get(j)<sorted.get(minidx)){minidx=j}};let tmp=sorted.get(k);sorted=sorted.set(k;sorted.get(minidx));sorted=sorted.set(minidx;tmp)};let mid=n/2;<sorted.get(mid)};f=main():$i64{let line=io.readln();let parts=s.split(line;"\"price\":");let n=parts.len();let prices=mut.@();let names=mut.@();let nameparts=s.split(line;"\"source\":\"");lp(let k=1;k<n;k=k+1){let seg=parts.get(k);let comma=s.split(seg;",");let pv=s.toint(comma.get(0));prices=prices+@(pv)};lp(let k=1;k<nameparts.len();k=k+1){let seg=nameparts.get(k);let q=s.split(seg;"\"");names=names+@(q.get(0))};let cnt=prices.len();let med=median(prices;cnt);io.println(s.fromint(med));let out=mut."";lp(let k=0;k<cnt;k=k+1){let p=prices.get(k);let diff=mut.0;if(p>med){diff=p-med}el{diff=med-p};if(diff>10){out=out+names.get(k)}};io.println(out);<0}