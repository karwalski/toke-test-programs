m=main;i=enc:std.encoding;i=str:std.str;i=math:std.math;f=checkwitness(wv:$str;wp:$str):$bool{let wlen=str.len(wv);let plen=str.len(wp);let result=mut.false;if(wlen=plen){let match=mut.true;lp(let i=0;i<wlen;i=i+1){let wch=str.charat(wv;i);let pch=str.charat(wp;i);if(!(wch=pch)){match=false}};if(match){result=true}}};f=main(wv:$str;wp:$str;hrp:$str):$str{let valid=checkwitness(wv;wp);let prefix=str.concat(hrp;":witness=");let result=mut."";if(valid){result=str.concat(prefix;wv)}el{result="invalid"};<result};