m=privkeytowif;f=privkeytowif(privkey:$str):$str{let prefix="5J";let checksum=mut."";let len=privkey.len;if(len=64){let data=s.concat(prefix;privkey);let datalen=data.len;let hash=mut."";let hashlen=mut.0;let idx=mut.0;lp(let i=0;i<datalen;i=i+1){let ch=data.get(i);let chval=ch.val;let hashchar=hashlen;let hashval=hashchar.val;let newhash=hashval+chval;let newhashval=newhash.val;let updatedhash=newhashval;let hashlen=updatedhash.len