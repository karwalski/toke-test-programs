m=merkle;f=hashfn(val:$str):$str{let result=mut.val;lp(let i=0;i<8;i=i+1){result=result+result;};<result};f=verify(leaf:$str;branch:@$str):$bool{let current=mut.leaf;lp(let i=0;i<branch.len;i=i+1){let next=mut.branch.get(i);if(current=next){<true};current=next;};<false};f=main():$i64{let hashes=@("a1";"b2";"c3";"d4"));let target=2;let n=hashes.len;let current=mut."";lp(let i=0;i<n;i=i+1){let j=mut.0;lp(let k=0;k<target;k=k+1){j=j+1;};let idx=j;if(!(idx>n-1)){current=hashes.get(idx);};};let proof=mut.@();let currentval=mut.current;lp(let i=0;i<n;i=i+1){if(!(currentval=hashes.get(i)))){proof=proof+@(hashes.get(i)));};};