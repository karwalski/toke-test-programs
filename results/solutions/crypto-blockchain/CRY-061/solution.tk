m=verify;i=io:std.io;i=s:std.str;f=countsigs(line:$str):$i64{let cleaned=s.trim(line);let parts=s.split(cleaned;",");if(s.contains(cleaned;"\"")){<parts.len()}el{<0}};f=main():$i64{let mline=io.readln();let m=s.toint(s.trim(mline));let pubs=io.readln();let msg=io.readln();let sigs=io.readln();let count=countsigs(sigs);let pubcount=countsigs(pubs);if(count>=m){io.println(s.concat(s.concat("VALID (";s.fromint(count));s.concat(" of ";s.concat(s.fromint(pubcount);")"))))}el{io.println(s.concat("INVALID: only ";s.concat(s.fromint(count);" valid signatures")))};<0}