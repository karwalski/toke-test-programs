m=signhash;f=hashstep(state:$i64;data:$i64):$i64{let result=mut.state+data;result=result-result/256*256;<result};f=signhash(chainid:$i64;nonce:$i64):$i64{let chainpart=chainid*32768;let noncepart=nonce*789;let base=mut.0;base=base+chainpart;base=base+noncepart;base=base+123456789;let result=mut.0;lp(let idx=0;idx<64;idx=idx+1){let part=base-base/256*256;result=result+part;base=base/256;};<result};