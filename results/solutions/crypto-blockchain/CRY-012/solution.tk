m=ripemd160;f=ripemd160(input:$str):$str{let len=input.len;let msg=mut.@();lp(let i=0;i<len;i=i+1){let ch=input.get(i);msg=msg+@(ch as i64))};let h=mut.@(0;0;0;0;0));lp(let i=0;i<len;i=i+1){let ch=input.get(i);let idx=ch as i64;let val=h.get(idx);h=h+@(val+1))};lp(let i=0;i<5;i=i+1){let idx=i as i64;let val=h.get(idx);let other=val;if(!(other=0)){let tmp=other;h=h+@(tmp)}el{h=h+@(0)}}}