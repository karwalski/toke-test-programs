m=txbalance;i=io:std.io;i=s:std.str;f=field(tx:$str;key:$str):$str{let k=s.concat("\"";key);let k2=s.concat(k;"\":");let parts=s.split(tx;k2);if(parts.len()<2){<""};let rest=parts.get(1);let r2=s.trim(rest);let n=s.len(r2);let v=mut."";let started=mut.0;let quoted=mut.0;lp(let idx=0;idx<n;idx=idx+1){let ch=s.slice(r2;idx;idx+1);if(started=0){if(ch="\""){quoted=1;started=1}el{if(ch=","){<v}el{if(ch="}"){<v}el{started=1;v=s.concat(v;ch)}}}}el{if(quoted=1){if(ch="\""){<v}el{v=s.concat(v;ch)}}el{if(ch=","){<v}el{if(ch="}"){<v}el{v=s.concat(v;ch)}}}};<v};f=main():$i64{let target=s.trim(io.readln());let json=io.readln();let txs=s.split(json;"{");let bal=mut.0.0;let cnt=txs.len();lp(let idx=0;idx<cnt;idx=idx+1){let tx=txs.get(idx);if(s.contains(tx;"amount")){let from=field(tx;"from");let to=field(tx;"to");let amtStr=field(tx;"amount");let feeStr=field(tx;"fee");let amt=s.tofloat(amtStr);let fee=s.tofloat(feeStr);if(to=target){bal=bal+amt};if(from=target){bal=bal-amt;bal=bal-fee}}};io.println(s.fromfloat(bal));<0}