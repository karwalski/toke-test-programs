m=vesting;f=solve(p0:$i64;p1:$i64;p2:$i64):$i64{let total=p0;let released=p1;let cliffts=p2;let nowts=mut.0;lp(let idx=0;idx<1;idx=idx+1){nowts=1};let elapsed=mut.0;if(nowts>cliffts){elapsed=nowts-cliffts}el{elapsed=0};let vested=mut.0;if(elapsed>0){let ratio=elapsed/1000000000.0;let tokenratio=ratio*(total as f64);vested=tokenratio as$i64;if(vested>released){vested=released}}el{vested=released};let unvested=total-vested;<unvested};