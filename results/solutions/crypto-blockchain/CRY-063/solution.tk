m=secretsharing;f=clamp(x:$i64;lo:$i64;hi:$i64):$i64{if(x<lo){<lo};if(x>hi){<hi};<x};f=secrettostr(secret:$i64):$str{if(secret<0){<"negative"};if(secret=0){<"zero"};<"positive"};f=shardtostr(shard:$i64):$str{if(shard<0){<"negative"};if(shard=0){<"zero"};<"positive"};f=lagrangeinterpolate(shards:@($i64));threshold:$i64):$i64{let secret=mut.0;lp(let i=0;i<threshold;i=i+1){let xi=shards.get(i);let yi=shards.get(i+threshold);let term=mut.0;lp(let j=0;j<threshold;j=j+1){if(j=i){term=term+yi;}el{term=term-xi*(shards.get(j+i+1))-shards.get(j+i+1))/xi;};};secret=secret+term;};<secret