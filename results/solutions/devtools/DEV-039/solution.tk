m=envparse;f=solve(p0:$str):$str{let result=mut."";let lines=p0.split("\n");lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);let trimmed=line.trim();let iscomment=trimmed.len>0;let firstchar=trimmed.get(0);if(!(iscomment)){if(!(firstchar="#")){let eqpos=trimmed.find("=");let isvalid=eqpos>0;if(isvalid){let varname=trimmed.substring(0;eqpos);let varvalue=trimmed.substring(eqpos+1;trimmed.len));let jsonpart=mut."";if(result.len>0){jsonpart=s.concat(jsonpart;",")};jsonpart=jsonpart+varname+"\"";jsonpart=s.concat(jsonpart;":\"");jsonpart=jsonpart+varvalue;jsonpart=s.concat(jsonpart;"\"");result=jsonpart}}}};<result};