m=licensecheck;f=checklicense(content:$str):$str{let lines=content.split("\n");let first=lines.get(0);let second=lines.get(1);let isapache=first.contains("Apache License");let ismit=first.contains("MIT License");let isbsd=first.contains("BSD");let isgpl=first.contains("GNU General Public License");let found=mut.false;let result=mut."";if(isapache){found=true;result="Apache License"}};if(ismit){found=true;result="MIT License"}};if(isbsd){found=true;result="BSD License"}};if(isgpl){found=true;result="GNU General Public License"}};if(found){<result};<""};f=processfile(path:$str):$str{let content=mut."";let result=mut."";let found=mut.false;let idx=mut.0;let len=mut.0;let line=mut."";let char=mut."";let space=mut.false;let digit=mut.false;let letter=mut.false;let valid=mut.false;let license=mut."";let ext=mut.path.split(".").get(1);if