m=hotspot;f=rankbycomplexity(churns:@($str;$i64));limit:$i64):@$str{let sorted=mut.churns;lp(let i=0;i<sorted.len;i=i+1){lp(let j=i+1;j<sorted.len;j=j+1){if(sorted.get(i).1>sorted.get(j).1){let tmp=sorted.get(i);sorted.get(i)=sorted.get(j);sorted.get(j)=tmp;};};};let result=mut.@();lp(let i=0;i<limit;i=i+1){if(i<sorted.len){result=result+@(sorted.get(i).0));};};<result};f=rankbychurn