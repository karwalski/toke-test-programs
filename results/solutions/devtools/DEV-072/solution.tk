m=flaky;f=classify(runs:@($str;$str;$str)):$str{let counts=mut.@();let names=mut.@();lp(let i=0;i<runs.len;i=i+1){let r=runs.get(i);let found=mut.false;lp(let j=0;j<names.len;j=j+1){if(names.get(j)=r.test_name)){found=true;let oldcount=counts.get(j);counts.get(j)=oldcount+1;};};if(!(found)){names=names+@(r.test_name);counts=counts+@(1);};};let maxfail=mut.0;lp(let i=0;i<counts.len;i=i+1){if(counts.get(i)>maxfail)){maxfail=counts.get(i);};};let result=mut."";lp(let i=0;i<counts.len;i=i+1){let c=counts.get(i);let n=names.get(i);if(c=maxfail){let line="FLAKY: "+n+" ("+c+" passes, "+(maxfail-c)+" fails)";result=s.concat(result;line);};};<result};f=main():$i64{let runs=@(@("r1";"t1";"pass");@("r2";"t1";"fail");@("r3";"t1";"fail");@("r4";"t2";"pass")));let flakies=classify(runs);<0};