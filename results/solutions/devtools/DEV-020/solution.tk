m=circdep;f=splitby(s:$str;delim:$str):@$str{let parts=mut.@();let p=mut."";let i=mut.0;lp(let idx=0;idx<s.len;idx=idx+1){let c=s.get(idx);if(c=delim){parts=parts+@(p);p="";i=0;}el{p=p+c;i=i+1;};};parts=parts+@(p);<parts};f=reversearr(arr:@$str):@$str{let n=arr.len;let m=mut.@();lp(let idx=0;idx<n;idx=idx+1){let i=n-1-idx;m=m+@(arr.get(i)));};<m};f=buildgraph(lines:@$str):@$str{let n=lines