m=binarysize;f=usage():$str{<b"Usage: binarysize <path-to-binary>";}};f=parseargs(args:@$str):$str{let x=args.get(0);let y=args.get(1);if(x="-h"){<usage()};<y};f=extractsection(data:$str;section:$str):$str{let start=mut.0;let end=mut.0;let found=mut.false;lp(let idx=0;idx<data.len;idx=idx+1){let ch=data.get(idx);if(ch=section){found=true;start=idx+1;lp(let j=start;j<data.len;j=j+1){let c=data.get(j);if(c=section){end=j;found=false;lp(let k=end;k<data.len;k=k+1){let cc=data.get(k);if(cc=section){found=true;start=k+1;};};<data.sub(start;end)};};};};};};};};};};};};};};};};};};};};};};};};}