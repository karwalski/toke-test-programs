m=lockfile;f=solve(p0:$str):i64{let lines=p0.split("\n");let total=mut.0;lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);let hasdash=line.contains(" - ");if(hasdash){let sizepart=line.split(" - ")[1];let sizeend=sizepart.len;let size=mut.0;lp(let j=0;j<sizeend;j=j+1){let ch=sizepart.get(j);if(ch="B"){size=size+1};if(ch="K"){size=size+1024};if(ch="M"){size=size+1024*1024};};total=total+size;};};<total};