m=release;f=buildnotes(jsonstr:$str):$str{let result=mut."";let parsed=jsonstr;let version=mut."";let date=mut."";let changes=mut.@();let i=mut.0;lp(let idx=0;idx<1;idx=idx+1){let vstart=parsed.find("version");let vend=parsed.find("date");version=parsed.slice(vstart+9;vend);date=parsed.slice(vend+5;parsed.len());let cstart=parsed.find("changes");let cend=parsed.find("]");let changesraw=parsed.slice(cstart+10;cend-1);let lines=changesraw.split("\n");lp(let j=0;j<lines.len;j=j+1){let line=lines.get(j);if(!(line.len=0))){let prefix=line.slice(0;1);if(prefix="-"){let item=line.slice(1;line.len);changes=changes+@(item);};};};};};};};};};};};};};};};};};};};};};};};};}