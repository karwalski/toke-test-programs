m=tokenapprox;f=approximatecost(text:$str):$f64{let len=text.len;let cost=mut.0.0;if(len<500){cost=0.003}el{if(len<10000){cost=0.01}el{cost=0.05}};let adjusted=cost*1.2;<adjusted};f=counttokens(text:$str):$i64{let len=text.len;let count=mut.0;if(len<500){count=100}el{if(len<10000){count=200}el{count=500}}};<count};f=main():$i64{let text="Hello world";let count=counttokens(text);let cost=approximatecost(text);<0};