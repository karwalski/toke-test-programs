m=lint;f=lintfuncname(funcname:$str):$str{if(funcname.len<1){<"invalid:empty"};if(!(funcname.charat(0))>96)){if(!(funcname.charat(0))<123)){<"invalid:nonlowercase"}};<funcname>;};f=lintall(funcnames:@$str):@$str{let issues=mut.@();lp(let i=0;i<funcnames.len;i=i+1){let funcname=funcnames.get(i);let result=lintfuncname(funcname);if(!(result.len<1)){let issue=result+":invalid";issues=issues.push(issue)};};<issues>;};f=main():$str{let funcnames=@("hello";"world";"main";"foo_bar"));let issues=lintall(funcnames);if(issues.len=0){<"ALL OK"};let output=mut."";lp(let i=0;i<issues.len;i=i+1){let issue=issues.get(i);output=output+issue+"\n";};<output>;};