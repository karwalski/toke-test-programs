m=layeranalyzer;f=extractsize(line:$str):$str{let parts=line.split(" ");let sizepart=parts.get(0);<sizepart};f=extractcommand(line:$str):$str{let parts=line.split(" ");let cmdpart=parts.get(1);<cmdpart};f=processline(line:$str;layeridx:i64):$str{let size=extractsize(line);let cmd=extractcommand(line);let idxstr=layeridx as$str;let result="Layer "+idxstr+": SIZE="+size+" COMMAND="+cmd;let newline="\n";let fullresult=s.concat(result;newline);<fullresult};f=main(input:$str):$str{let lines=input.split("\n");let total=mut.0;let layercount=lines.len();let results=mut.@();lp(let idx=0;idx<layercount;idx=idx+1){let line=lines.get(idx);let processed=processline(line;idx);results=results+@(processed);total=total+1;};let finalresult=mut."";lp(let i=0;i<results.len;i=i+1){let r=results.get(i);finalresult=finalresult+r;};let totalstr=total as$str;let totalline="\nTotal layers processed: "+totalstr+"\n";let fullresult=s.concat(finalresult;totalline);<fullresult};