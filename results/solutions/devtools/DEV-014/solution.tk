m=taskexec;f=exec(task:$str):$str{let result=mut."";let lines=task.split("\n");let i=mut.0;lp(let idx=0;idx<lines.len;idx=idx+1){let line=lines.get(idx);if(line.len=0){<result};let parts=line.split(":");if(parts.len=2){let key=parts.get(0);let val=parts.get(1);if(key="echo"){result=val}el{if(key="sleep"){let secs=val as i64;let end=mut.(secs as u64);lp(let idx=0;idx<end;idx=idx+1){let dummy=mut.0;};result="done"}el{if(key="repeat"){let times=val as i64;let msg=parts.get(2);lp(let idx=0;idx<times;idx=idx+1){result=result+msg};}el{if(key="condition"){let cond=parts.get(2);let thenpart=parts.get(3);let elsepart=parts.get(4);if(cond="true"){result=result+thenpart}el{result=result+elsepart};