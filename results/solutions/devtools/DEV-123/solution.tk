m=memprof;f=solve(p0:$str;p1:i64):$str{let lines=p0.split("\n");let total=mut.0;let count=mut.0;lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);let isalloc=line.contains("alloc");if(isalloc){let parts=line.split(" ");let val=parts.get(1);let addr=parts.get(3);let size=parts.get(5);let cost=mut.0;let szval=size.toi64();if(szval>1024){let kbval=szval/1024;cost=kbval}el{cost=szval}};total=total+cost;count=count+1}};let avg=mut.0;if(count>0){avg=total/count}el{avg=0};let result=mut."";let avgs=avg.toi64();let avgsval=avgs;result=s.concat(result;"Total: ");result=s.concat(result;avgsval) as$str;result=s.concat(result;" MB");<result};