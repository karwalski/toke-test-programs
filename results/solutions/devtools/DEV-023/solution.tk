m=buildlog;f=parsephase(line:$str):$str{let parts=line.split(" ");let phase=parts.get(3);<phase};f=extractduration(line:$str):i64{let parts=line.split(" ");let duration=parts.get(1);let num=duration.split("m").get(0);<num.to_i64()};f=buildlogparser(input:$str):$str{let lines=input.split("\n");let durations=mut.@();let phases=mut.@();lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);let isphase=line.contains("phase_name:");let isduration=line.contains("HH:MM:SS.mmm");if(isphase){let phase=parsephase(line);phases=phases+@(phase);};if(isduration){let duration=extractduration(line);durations=durations+@(duration);};};let result=mut."";let n=phases.len;lp(let i=0;i<n;i=i+1){let phase=phases.get(i);let duration=durations.get(i);let line=phase+": "+duration+"ms";result=s.concat(s.concat(result;line);"\n");};<result};f=main():$void{let input="HH:MM:SS.mmm phase_name: build";let output=buildlogparser(input);<output};