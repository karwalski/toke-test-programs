m=regex;f=run(pattern:$str;inputs:@$str):@$str{let results=mut.@();lp(let i=0;i<inputs.len;i=i+1){let input=inputs.get(i);let matched=mut.false;let plen=pattern.len;let ilen=input.len;let maxcheck=mut.0;if(plen<ilen){maxcheck=plen}el{maxcheck=ilen};let j=mut.0;lp(let k=0;k<maxcheck;k=k+1){let pidx=k;if(!(plen>pidx)){br};let cidx=k;if(!(ilen>cidx)){br};let pchar=pattern.get(pidx);let cchar=input.get(cidx);if(!(pchar=cchar)){br};j=k+1;if(j=maxcheck){matched=true};};if(matched){results=results+@(input)}el{results=results+@()};};<results};f=main():$void{let pattern="\\d{3}-\\d{2}-\\d{4}";let inputs=@("123-45-6789";"abc-def-ghi";"987-65-43