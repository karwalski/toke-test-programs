m=extract;f=extractsig(code:$str):$str{let lines=code.split("\n");let result=mut."";lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);let trimmed=line.trim();let isfunc=mut.false;if(trimmed.len>2){let first=trimmed.get(0);let second=trimmed.get(1);if(first="f"){if(second="u"){isfunc=true}}}};if(isfunc){let openidx=mut.-1;let closeidx=mut.-1;lp(let j=0;j<trimmed.len;j=j+1){let ch=trimmed.get(j);if(ch="("){openidx=j};if(ch=")"){closeidx=j}};if(!(openidx<0)){if(!(closeidx<0)){if(!(openidx>closeidx)){let funcname=trimmed.substring(1;openidx);let params=trimmed.substring(openidx+1;closeidx));let rettype=trimmed.substring(closeidx+1;trimmed.len));let sig="f="+funcname+"(params="+params+"):rettype="+rettype;result=sig}}}};};<result};f=main():$