m=deadcode;f=analyze(code:$str):$str{let lines=code.split("\n");let result=mut."";let n=lines.len;lp(let i=0;i<n;i=i+1){let line=lines.get(i);let trimmed=line.trim();let isassignment=mut.false;if(trimmed.len>0){let firstchar=trimmed.get(0);if(firstchar="a"){if(trimmed.len>1){let secondchar=trimmed.get(1);if(secondchar="s"){if(trimmed.len>2){let thirdchar=trimmed.get(2);if(thirdchar="i"){if(trimmed.len>3){let fourthchar=trimmed.get(3);if(fourthchar="g"){isassignment=true;};};};};};};};};};};};};};};};};};};};};};};};};}