m=commentratio;f=extractfilename(path:$str):$str{let lastslash=mut.0-1;lp(let idx=0;idx<path.len;idx=idx+1){let ch=path.get(idx);if(ch=47){lastslash=idx};};if(lastslash<0){<path};let start=lastslash+1;<path.sub(start;path.len-start))};f=countcommentlines(code:$str):$i64{let lines=code.split(10);let count=mut.0;lp(let idx=0;idx<lines.len;idx=idx+1){let line=lines.get(idx);let trimmed=line.trim();let iscomment=mut.false;if(trimmed.len>0){let firstchar=trimmed.get(0);if(firstchar=35){iscomment=true};};if(iscomment){count=count+1};};<count};f=countcode