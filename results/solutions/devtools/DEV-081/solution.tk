m=sqlprof;f=analyzequery(query:$str):$str{let msg=mut."query ok: ";let len=query.len;let hasjoin=mut.false;let haslike=mut.false;let hasgroup=mut.false;let hasorder=mut.false;lp(let i=0;i<len;i=i+1){let ch=query.get(i);if(ch="j"){if(i+5<len){let next=query.get(i+5);if(next="n"){if(i+6<len){let next2=query.get(i+6);if(next2="e"){hasjoin=true;};};};};};};};};};};};};};};};};};};};};};};};};}