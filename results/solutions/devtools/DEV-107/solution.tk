m=artifacttracker;t=artifact{name:$str;size:$i64;checksum:$str}};t=artifactlist{items:@($artifact)};f=hashfile(filepath:$str):$str{let data=br.read(filepath);let hash=mut."";let len=data.len;lp(let i=0;i<len;i=i+1){let ch=data.get(i);let code=br.charcode(ch);let hex=br.tohex(code);hash=hash+hex;};<hash};f=storeartifact(name:$str;size:$i64;checksum:$str):$artifact{let art=mut.$artifact{name:name;size:size;checksum:checksum}};<art};f=validateartifact(artifact:$artifact;expectedchecksum:$str):$bool{let computed=hashfile(artifact.name);let valid=mut.false;if(computed=expectedchecksum){valid=true};<valid};f=main():$i64{let artifacts=@($artifact);let count=mut.0;let i=0;lp(let idx=0;idx<10;idx=idx+1){let name="artifact_"+br.tonum(idx);let size=br.tonum(idx)*1