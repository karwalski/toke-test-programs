m=deadcode;f=usage():$str{<"Usage: toke detect-dead-code <file>">};f=detectdeadcode(file:$str):@$str{let lines=file.split("\n");let result=mut.@();let funcstart=mut.false;let infunc=mut.false;let funcname=mut."";let bracecount=mut.0;lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);if(!(funcstart=false)){if(!(infunc=false)){if(!(bracecount=0)){if(line.contains("{")){bracecount=bracecount+1;};};if(line.contains("}")){bracecount=bracecount-1;};};};};};};};};};};};};};};};};};};};};};};};};}