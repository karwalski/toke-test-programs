m=errrate;f=counterrors(logpath:$str):$i64{let count=mut.0;let lines=br.logread(logpath);lp(let idx=0;idx<lines.len;idx=idx+1){let line=lines.get(idx);if(br.strcontains(line;"error"))){count=count+1;};};<count};f=computeerrrate(logpath:$str):$str{let total=br.logcount(logpath);if(total=0){<"0.00"};let errors=counterrors(logpath);let rate=errors as$f64/total as$f64;let result=rate*100.0;<br.strformat("{}.{}";result as$i64;((result as$f64)-(result as$i64)as$f64)*100.0 as$i64))};