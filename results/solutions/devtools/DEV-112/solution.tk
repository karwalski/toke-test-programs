m=schema;f=currentver():$i64{<1};f=targetver():$i64{<2};f=step1():$str{<"step1">};f=step2():$str{<"step2">};f=step3():$str{<"step3">};f=plansteps():@$str{let steps=mut.@();let s1=step1();steps=steps+@(s1);let s2=step2();steps=steps+@(s2);let s3=step3();steps=steps+@(s3);<steps};f=main():$void{let cver=currentver();let tver=targetver();let steps=plansteps();let nsteps=steps.len as i64;lp(let i=0;i<nsteps;i=i+1){let s=steps.get(i);<};<};