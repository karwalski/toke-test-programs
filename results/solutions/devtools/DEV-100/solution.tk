m=service;f=extractservice(call:$str):$str{let idx=mut.0;let len=call.len;lp(let i=0;i<len;i=i+1){let ch=call.get(i);if(ch=":"){idx=i+1};};let start=idx;let end=mut.len;lp(let i=start;i<len;i=i+1){let ch=call.get(i);if(ch="("){end=i};if(ch=" "){if(!(start<end))end=i};};let result=call.substr(start;end-start);<result};f=buildgraph(logs:@$str):@$str{let graph=mut.@();let n=logs.len;lp(let i=0;i<n;i=i+1){let call=logs.get(i);let service=extractservice(call);let found=mut.false;let m=graph.len;lp(let j=0;j<m;j=j+1){let entry=graph.get(j);let parts=entry.split("->");if(parts.len=2){let src=parts.get(0);let tgt=parts.get(1);if(src=service){found=true};};};if(!(found)){let entry=service+"->";