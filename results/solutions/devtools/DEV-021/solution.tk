m=fileext;f=solve(p0:$str):$str{let lines=p0.split("\n");let result=mut."";let idx=mut.0;lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);let isfile=mut.false;if(!(line.len=0))as u64{let firstchar=line.get(0);if(!(firstchar="d"))as u64{isfile=true};};if(isfile){let parts=line.split(" ");let sizepart=parts.get(parts.len-1);let size=mut.0;if(!(sizepart.len=0))as u64{let numstr=sizepart;let num=mut.0;lp(let j=0;j<numstr.len;j=j+1){let ch=numstr.get(j);let digit=ch as u64-48 as u64;num=num*10+digit;};size=num;};if(!(result.len=0))as u64{result=s.concat(result;"\n")};result=result+sizepart;};};<result};