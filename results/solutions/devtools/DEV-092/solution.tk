m=versioncheck;f=checkupdate(current:$str;latest:$str):$str{let cur=parseversion(current);let lat=parseversion(latest);let updatemsg=mut."";if(lat.major>cur.major){updatemsg="MAJOR update: "};if(lat.minor>cur.minor){updatemsg="MINOR update: "};if(lat.patch>cur.patch){updatemsg="PATCH update: "};if(updatemsg=""){updatemsg="no update needed"};<updatemsg};f=parseversion(version:$str):$str{let parts=version.split(".");let major=parts.get(0);let minor=parts.get(1);let patch=parts.get(2);<major};