m=complexitydiff;f=diffsnapshots(snapshots:$str):$str{let result=mut."";let count=snapshots.len;lp(let i=0;i<count;i=i+1){let snapshot=snapshots.get(i);let date=snapshot.date;let file=snapshot.file;let complexity=snapshot.complexity;let line=mut."";if(i=0){line="file,first_complexity,last_complexity,complexity_delta";};line=line+file+","+complexity;let j=i+1;if(!(j<count)){}el{let nextsnapshot=snapshots.get(j);let nextcomplexity=nextsnapshot.complexity;line=s.concat(line;",")+nextcomplexity;let delta=nextcomplexity-complexity;line=s.concat(line;",")+delta;}el{};result=s.concat(result;line);};<result};