m=upgrade;f=advice(old:$i64;new:$i64):$str{if(old=new){<"no change"};if(old<new){<"upgrade"};if(old>new){<"downgrade"};<"unknown"};f=script(old:$i64;new:$i64):$str{let adv=advice(old;new);if(adv="no change"){<"echo 'No change needed.'"};if(adv="upgrade"){<"cat upgrade.md"};if(adv="downgrade"){<"echo 'Downgrade not yet supported.'"};<"echo 'Unknown advice.'"};f=main():$void{let old=1;let new=2;let adv=advice(old;new);let s=script(old;new);<s};