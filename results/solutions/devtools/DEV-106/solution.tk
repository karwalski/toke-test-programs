m=versioncheck;f=solve(p0:@$str;p1:@$str):bool{let result=mut.true;lp(let i=0;i<p0.len;i=i+1){let pkgname=p0.get(i);let requiredversion=p1.get(i);let found=mut.false;let installedversion=mut."";lp(let j=0;j<p0.len;j=j+1){if(p0.get(j)=pkgname)){found=true;installedversion=p1.get(j);};};if(found){let reqmaj=mut.0;let reqmin=mut.0;let instmaj=mut.0;let instmin=mut.0;let idx=mut.0;lp(let k=0;k<requiredversion.len;k=k+1){let ch=requiredversion.get(k);if(ch="." as u8){idx=k+1;reqmaj=mut.0;reqmin=mut.0;lp(let m=0;m<idx;m=m+1){let digit=requiredversion.get(m);if(!(digit<"0"as u8)){if(!(digit>"9"as u8)){let val=digit as u8-"0"as u8;reqmaj=reqmaj