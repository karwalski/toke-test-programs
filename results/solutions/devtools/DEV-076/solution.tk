m=releasecheck;f=validatechecklist(checklist:$str):$str{let result=mut."";let lines=checklist.split("\n");lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);let ischecked=line.contains("[x]");let isempty=line.len=0;let iscomment=mut.false;if(!(isempty)){let firstchar=line.get(0);if(firstchar="#"){iscomment=true}}};if(!(ischecked)){if(!(iscomment)){if(!(isempty)){result=result+line+"\n"}}}}};if(result.len=0){<"All checks pass"}el{<result}};f=main():$void{let checklist="[x] Schema migration\n[ ] Code refactoring\n# Skip tests for now\n";let result=validatechecklist(checklist);<result};