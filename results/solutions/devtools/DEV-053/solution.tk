m=extract;f=extractendpoints(file:$str):@$str{let lines=file.split("\n");let endpoints=mut.@();lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);let hasget=line.contains("get(");let haspost=line.contains("post(");let hassrc=line.contains("src=");if(hasget){let start=line.find("get(");let end=line.find(")");let ep=line.slice(start+4;end);endpoints=endpoints+@(ep);};if(haspost){let start=line.find("pos