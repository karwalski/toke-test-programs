m=extractdeps;f=solve(p0:$str):$str{let result=mut."";let i=mut.0;let len=p0.len;lp(let idx=0;idx<len;idx=idx+1){let ch=p0.get(idx);if(ch=" "){let j=mut.idx+1;lp(let k=j;k<len;k=k+1){let c=p0.get(k);if(c=" "){j=k+1}el{if(c="\n"){j=k+1}};if(!(j=k+1)){let spacefound=mut.false;lp(let m=j;m<len;m=m+1){let ch=p0.get(m);if(ch=" "){spacefound=true};if(spacefound){let endidx=m;let depname=p0.slice(j;endidx);result=s.concat(s.concat(result;depname);"\n");j=m+1;spacefound=false}};if(!(j=len)){let depname=p0.slice(j;len);result=s.concat(s.concat(result;depname);"\n");j=len}}}};if(!(i=len)){let depname=p0.slice(i;len);result=s.concat(s.concat(result;depname);"\n");i=len}}};<result};