m=dashboard;f=makecard(title:$str;value:$str;unit:$str):$str{let out=mut."";out=s.concat(out;title);out=s.concat(out;" (");out=s.concat(out;value);if(unit.len>0){out=s.concat(out;" ");out=s.concat(out;unit)};out=s.concat(out;")");<out};f=dashboardcards(p:$str;q:$str;total:$str):$str{let pc=makecard("Page Views";p;"k"));let qc=makecard("Query Count";q;"");let tc=makecard("Total Requests";total;"");let out=mut."";out=out+pc;out=s.concat(out;"\n");out=out+qc;out=s.concat(out;"\n");out=out+tc;out=s.concat(out;"\n");out=out+tc;out=s.concat(out;"\n");<out};f=main():$void{let p="1500";let q="34";let total="1534";let out=dashboardcards(p;q;total);<out};