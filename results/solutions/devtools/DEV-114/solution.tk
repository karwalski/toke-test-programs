m=traffic;f=extractmethod(line:$str):$str{let idx=mut.0;let n=line.len;lp(let i=0;i<n;i=i+1){let c=line.get(i);if(c=" "){idx=i;br};};let start=idx+1;let end=mut.n;lp(let i=start;i<n;i=i+1){let c=line.get(i);if(c=" "){end=i;br};};let result=mut."";lp(let i=start;i<end;i=i+1){let c=line.get(i);result=result+c;};<result};f=extractpath