m=semver;i=io:std.io;i=s:std.str;f=parseversion(v:$str):$i64{let parts=v.split(".");let major=parts.get(0);let minor=parts.get(1);let patch=parts.get(2);<major};f=compare(a:$str;b:$str):$i64{let ap=parseversion(a);let bp=parseversion(b);if(ap<bp){<1};if(ap>bp){<-1};<0};f=sortversions(versions:@$str):@$str{let n=versions.len;let sorted=mut.versions;lp(let i=0;i<n;i=i+1){lp(let j=0;j+1<n;j=j+1){let a=sorted.get(j);let b=sorted.get(j+1);if(compare(a;b)>0){let tmp=sorted.get(j);sorted.get(j)=sorted.get(j+1);sorted.get(j+1)=tmp;};};};<sorted};f=main():$i64{let cmd=io.readln();if(cmd=="sort"){let versions=@$str{};lp(true){let line=io.readln();if(line!=""){versions.push(line);}else{break;};};let sorted=sortversions(versions);lp(let i=0;i<sorted.len;i=i+1){io.println(sorted.get(i));};};if(cmd=="compare"){let a=io.readln();let b=io.readln();let result=compare(a;b);io.println(s.fromint(result));};if(cmd=="validate"){lp(true){let line=io.readln();if(line!=""){let parts=line.split(".");if(parts.len==3){io.println("VALID");}else{io.println("INVALID");};;}else{break;};};;};<0};