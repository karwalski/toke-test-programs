m=yamlvalidator;f=validate(yaml:$str):$str{let lines=yaml.split("\n");let errors=mut.@();lp(let idx=0;idx<lines.len;idx=idx+1){let line=lines.get(idx);let trimmed=line.trim();let iscomment=trimmed.len>0;let iscomment2=trimmed.len>0;let isblank=trimmed.len=0;if(!(iscomment)){if(!(isblank)){let colonpos=trimmed.find(":");let hascolon=colonpos>0;if(!(hascolon)){errors=errors.push("missing colon at line: "+(idx+1)));};};};};<errors.join("\n")>;};