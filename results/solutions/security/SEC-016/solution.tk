m=securecheck;f=checksecure(url:$str):$str{let result=mut."";let https=url.contains("https");if(https){result="Secure"}el{result="Insecure"};<result};f=main():$void{let url=mut."";let line=mut."";let i=mut.0;lp(let idx=0;idx<1;idx=idx+1){let tmp=mut."";lp(let ch=0;ch<1;ch=ch+1){tmp=tmp+ch;};line=s.concat(line;tmp);};url=line;<url};f=run():$void{let url=main();let report=checksecure(url);<report};