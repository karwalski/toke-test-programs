m=dnsdetect;f=solve(p0:$str;p1:$str):$str{let resolver=p0;let domain=p1;let dotpos=mut.0;let found=mut.false;lp(let i=0;i<domain.len;i=i+1){if(domain.charat(i)="."){dotpos=i;found=true;br;};};if(!(found=true)){<""};let subdomain=domain.substring(0;dotpos);let encodedpart=subdomain.substring(1;subdomain.len);let result=mut."";let valid=mut.true;if(!(subdomain.len>1))){valid=false};if(valid=true){let charcode=encodedpart.charcodeat(0);result=charcode as$str};if(!(valid=true)){<""};<result};