m=certchain;f=extractfield(cert:$str;field:$str):$str{let lines=cert.split("\n");let result=mut."";lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);if(line.contains(field)){let parts=line.split(":");if(parts.len>1){let val=parts.get(1);result=val.trim();};};};<result};f=checkexpiry(cert:$str):$str{let notafter=extractfield(cert;"Not After";0);let days=mut.0;let months=mut.0;let years=mut.0;let isvalid=mut.true;if(notafter.contains("days"))){let parts=notafter.split(" ");if(parts.len>0){let num=parts.get(0);days=num.toi64();};};if(notafter.contains("month