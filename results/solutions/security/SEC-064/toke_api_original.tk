m=urlchecker;f=checkurl(url:$str):$str{let result=mut."safe";let len=url.len;let schemeend=mut.0;let i=mut.0;lp(i=0;i<len;i=i+1){let ch=url.get(i);if(ch=":"){schemeend=i;br};};if(schemeend=0){<result};let hoststart=schemeend+1;let hostend=mut.len;lp(i=hoststart;i<len;i=i+1){let ch=url.get(i);if(ch="/"){hostend=i;br};};if(hostend=hoststart){<result};let tld=url.substr(hostend;len);let tldlen=tld.len;if(tldlen<2){<result};let ch1=tld.get(0);let ch2=tld.get(1);let isxyz=mut.false;if(ch1="x"){if(ch2="y"){isxyz=true}}};let isnewtld=mut.false;if(tld="techcrunch"){isnewtld=true};if(tld="theverge"){isnewtld=true};if(tld="cnet"){isnewtld=true};if(tld="pc