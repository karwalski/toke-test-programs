m=certpin;f=trim(s:$str):$str{let len=s.len;let start=mut.0;lp(let i=0;i<len;i=i+1){let c=s.get(i);if(!(c=32 as u8))el{start=i+1};};let end=mut.len;lp(let i=len-1;!(i<0);i=i-1){let c=s.get(i);if(!(c=32 as u8))el{end=i};};let result=mut."";lp(let i=start;i<end;i=i+1){let c=s.get(i);result=result+c;};<result};f=extractfield(line:$str;field:$str):$str{let parts=line.split(field);if(parts.len<2){<""};let val=parts.get(1);let endidx=val.len;lp(let i=0;i<endidx;i=i+1){let c=val.get(i);if(c=10 as u8){endidx=i;br};};let result=mut."";lp(let i=0;i<endidx;i=i+1){let c=val.get(i);result=result+c;};<trim(result)};f