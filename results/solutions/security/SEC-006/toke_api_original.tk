m=ipreputation;f=classifyreputation(ip:$str):$str{if(ip.len=0){<"unknown"};let islocal=mut.false;if(ip.startswith("10.")){islocal=true};if(ip.startswith("172.")){let secondpart=ip.split(".").get(1);let secval=secondpart.parsei64();if(!(secval<16)){if(!(secval>31))){islocal=true}}};if(ip.startswith("192.168.")){islocal=true};if(islocal){<"local"};let isrfc1918=mut.false;if(ip.startswith("10.")){isrfc1918