m=ssrf;f=extractparam(line:$str;param:$str):$str{let start=line.find(s.concat(param;"="));if(start<0){<""};let eqpos=s.concat(start;s.concat(param.len();"="));let end=line.find("&";eqpos);if(end<0){<line.sub(eqpos;line.len())};<line.sub(eqpos;end-eqpos))};f=checkurl(line:$str):$str{let found=line.find("http");if(found<0){<"NO_URL"};<"URL_FOUND"};f=classifyrisk(line:$str):$str{let hasinternal=line.find("127.0.0.1");let hasintra=line.find("localhost");let hasintra2=line.find("192.168.");let hasintra3=line.find("172.");if(hasinternal>0){<"POTENTIAL_SSRF"};if(hasintra>0){<"POTENTIAL_SSRF"};if(hasintra2>0){<"POTENTIAL_SSRF"};if(hasintra3>0){<"POTENTIAL_SSRF"};<"SAFE"};f=main():$void{let line=std.read.readline();let urlcheck=checkurl(line);if(urlcheck="NO_URL"){<"NO_URL"};let risk=classifyrisk(line);if(risk="POTENTIAL_SSRF"){<"POTENTIAL_SSRF"};<"SAFE"};