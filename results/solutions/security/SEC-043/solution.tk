m=main;f=solve(p0:$str):bool{let len=p0.len;let found=mut.false;lp(let i=0;i<len;i=i+1){let ch=p0.get(i);if(ch=" "){let j=i+1;lp(let k=j;k<len;k=k+1){let c=p0.get(k);if(!(c=" ")){if(!(c="\n")){if(!(c="\r")){found=true}}}}}}};<found};f=main():$void{let input=mut."";let c=mut.std.io.stdin.read();lp(let i=0;!(c=0);i=i+1){input=input+std.io.stdin.read();c=std.io.stdin.read();};let output=solve(input);if(output){std.io.stdout.write("sensitive data detected");}el{std.io.stdout.write("no sensitive data detected");};};