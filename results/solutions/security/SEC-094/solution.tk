m=smtpcheck;f=checkemail(s:$str):bool{let atcount=mut.0;let dotafterat=mut.false;let atpos=mut.0 as i64;let n=s.len as i64;lp(let i=0;i<n;i=i+1){let c=s.get(i);if(c=64){atcount=atcount+1;atpos=i}el{if(c=46){if(!(atcount=0))){if(i>atpos){dotafterat=true}}}}}};if(atcount=1){if(dotafterat){<true}}};<false};f=safesend(s:$str):$str{let len=s.len;if(len=0){<""};let ch=s.get(0);if(ch=64){<""}};<s};f=main():$void{let input=br();let output=safesend(input);let result=checkemail(output);if(result){<br()}el{<br()}}};