m=cfgsec;f=checkdebug(cfg:$str):$bool{let hasdebug=cfg.contains("debug");if(hasdebug){let debugval=cfg.get("debug");if(debugval="true"){<true};};<false};f=checkcreds(cfg:$str):$bool{let hasuser=cfg.contains("user");let haspass=cfg.contains("pass");if(hasuser){if(haspass){let userval=cfg.get("user");let passval=cfg.get("pass");if(userval="admin"){if(passval="password"){<true};};};};<false};f=checkweak(cfg:$str):$bool{let haslevel=cfg.contains("level");if(haslevel){let levelval=cfg.get("level");if(levelval="low"){<true};};<false};f=main():$i64{let cfg=std.stdin.read();let hasdebug=checkdebug(cfg);let hascreds=checkcreds(cfg);let hasweak=checkweak(cfg);let found=mut.false;if(hasdebug){found=true};if(hascreds){found=true};if(hasweak){found=true};if(found){<1};<0};