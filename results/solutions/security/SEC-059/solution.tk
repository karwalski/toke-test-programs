m=rank;f=rank(cipher:$str):$i64{let score=mut.0;if(cipher.contains("PSK"))){score=score-50};if(cipher.contains("SRP"))){score=score-50};if(cipher.contains("DHE"))){score=score+50};if(cipher.contains("ECDHE"))){score=score+100};if(cipher.contains("AES"))){score=score+50};if(cipher.contains("SHA256"))){score=score+50};if(cipher.contains("RSA"))){score=score+50};if(score<0){score=0};<score};f=isdeprecated(cipher:$str):$bool{let result=mut.false;if(cipher.contains("DES"))){result=true};if(cipher.contains("RC4"))){result=true};if(cipher.contains("MD5"))){result=true};<result};f=suggestmodern(cipher:$str):$str{let result=mut."";if(cipher.contains("DES"))){result="AES_256"};if(cipher.contains("RC4"))){result="AES_256"};