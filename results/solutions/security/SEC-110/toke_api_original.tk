m=loganalyser;f=extractfield(line:$str;field:$i64):$str{let parts=line.split(" ");if(field<parts.len){<parts.get(field)}el{<""}};f=extracttimestamp(line:$str):$str{<extractfield(line;0)}};f=extractseqnum(line:$str):$i64{<extractfield(line;1)|{Ok(n):$str{n.to_i64};Err(e):$str{0}}}};f=validateorder(timestamps:@$str):$bool{lp(let i=0;i<timestamps.len-1;i=i+1){let ts1=timestamps.get(i);let ts2=timestamps.get(i+1);if(ts1>ts2){<false}};<true};f=validategap(seqnums:@$i64):$bool{lp(let i=0;i<seqnums.len-1;i=i+1){let num1=seqnums.get(i);let num2=seqnums.get(i+1);let diff=num2-num1;if(!(diff=1)){if(!(diff=0)){}el{<false};}el{<false};}};<true};f=check