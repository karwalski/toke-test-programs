m=desyncprobe;f=probeurl(url:$str):$str{let result=mut."";let frontend=mut."";let backend=mut."";let i=mut.0;lp(let idx=0;idx<url.len;idx=idx+1){let ch=url.get(idx);if(ch="/"){i=idx};};if(i>0){frontend=url.sub(0;i);backend=url.sub(i+1;url.len);}el{frontend="";backend=url};result=s.concat(s.concat(s.concat(s.concat("frontend: ";frontend);"\nbackend: ");backend);"\n");<result};f=simulatefrontend(state:$str):$str{let result=mut."";if(state="ready"){result="frontend ready, sending request...\n";};<result};f=simulatebackend(reqid:$str):$str{let result=mut."";result="backend processing request...\n";<result};f=simulatepipeline(state:$str):$str{let frontend=mut.simulatefrontend(state);let backend=mut.simulatebackend("req_1");let result=mut."";result=s.concat(s.concat(result;"frontend:\n");frontend);result=s.concat(s.concat(result;"backend:\n");backend);result=s.concat(result;"pipeline complete\n");<result