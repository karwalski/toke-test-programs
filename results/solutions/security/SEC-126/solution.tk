m=exploitcheck;f=checkpatch(cveid:$str):$str{let result=mut."unknown";let knownvulnerabilities=@("CVE-2021-44719";"CVE-2022-2362";"CVE-2022-2363");let patchstatus=@("patched";"patched";"patched"));lp(let idx=0;idx<knownvulnerabilities.len;idx=idx+1){if(knownvulnerabilities.get(idx)=cveid){result=patchstatus.get(idx)}};<result};f=exploitactive(cveid:$str):$bool{let active=mut.false