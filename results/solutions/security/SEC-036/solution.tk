m=httpheader;f=checkheader(url:$str):$str{let result=mut."none";let http=std.http;let resp=http.get(url);let headers=resp.headers;let n=headers.len;lp(let i=0;i<n;i=i+1){let hdr=headers.get(i);let key=hdr.key;let val=hdr.value;if(key="X-Frame-Options"){if(val="SAMEORIGIN"){result="X-Frame-Options: SAMEORIGIN"}};if(key="Content-Security-Policy"){let idx=val.find("frame-ancestors");if(idx>0){let rem=val.substr(idx+21);if(rem="none"){result="CSP: frame-ancestors none"}el{if(rem="*"){result="CSP: frame-ancestors *"}el{if(rem="self"){result="CSP: frame-ancestors self"}el{if(rem="https://example.com"){result="CSP: frame-ancestors https://example.com"}el{}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}}