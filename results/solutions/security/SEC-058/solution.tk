m=webfinger;f=extractname(headers:$str):$str{let lines=headers.split("\n");let name=mut."";lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);let colonidx=line.find(":");if(!(colonidx<0)){let key=line.substr(0;colonidx);let val=line.substr(colonidx+1;line.len-colonidx-1);if(key="X-Application-Name"){name=val}}}};<name};f=checkhtmlresp(resp:$str):$str{let ishtml=mut.false;let lowerresp=resp.tolower();let htmlidx=lowerresp.find("html");if(!(htmlidx<0)){ishtml=true};if(ishtml){<resp}el{<""}};f=checkhtmlurl(url:$str):$str{let result=mut."";let htmlcheck=checkhtmlresp(result);if(htmlcheck.len>0){<htmlcheck}el{<""}};f=webfingerprint