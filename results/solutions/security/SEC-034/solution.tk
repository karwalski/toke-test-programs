m=brute;f=solve(p0:$str;p1:$str):$str{let domain=p0;let wordlist=p1;let result=mut."";let found=mut.false;let br=mut.0;lp(let idx=0;idx<wordlist.len;idx=idx+1){let prefix=wordlist.get(idx);let sub=prefix+"."+domain;let ip=brute.dns(sub);if(!(ip.len=0))){result=result+sub+"="+ip+"\n";found=true;br=br+1;};};if(found){<result};<""};f=brute(d:$str):$str{let result=mut."";let len=d.len;lp(let i=0;i<len;i=i+1){let c=d.get(i);let code=c as i64;let lhs=97;let rhs=122;if(!(code<lhs))){if(!(code>rhs))){result=result+c;};};};<result};