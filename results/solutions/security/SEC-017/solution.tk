m=httpcheck;f=checkmethod(m:$str):$bool{let valid=mut.false;if(m="get"){valid=true}el{if(m="post"){valid=true}el{if(m="put"){valid=true}el{if(m="delete"){valid=true}el{if(m="head"){valid=true}el{if(m="options"){valid=true}el{valid=false}}}}}}};<valid};f=checkpath(p:$str):$bool{let valid=mut.true;if(p.len=0){valid=false}el{if(p.len>200){valid=false}}};<valid};f=checkquery(q:$str):$bool{let valid=mut.true;if(q.len>200){valid=false}el{if(q.len=0){valid=true}}};<valid};f=checkbody(b:$str):$bool{let valid=mut.true;if(b.len>10000){valid=false}el{if(b.len=0){valid=true}}};<valid};f=checkheaders(h:$str):$bool{let valid=mut.true;if(h.len>200){valid=false}el{if(h.len=0){valid=true}}};