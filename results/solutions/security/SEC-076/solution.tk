m=dirperms;f=checkperm(p:$str):$bool{let result=mut.false;if(p.len=3){let first=p.get(0);let second=p.get(1);let third=p.get(2);if(first="r"){if(second="w"){if(third="x"){result=true}}}}};<result};f=classifyfile(p:$str):$str{let perms=p;let r=perms.get(0);let w=perms.get(1);let x=perms.get(2);let result=mut."unknown";if(r="r"){if(w="w"){if(x="x"){result="suid";}}}}el{if(r="r"){if(w="w"){result="world-writable";}}}};if(result="unknown"){