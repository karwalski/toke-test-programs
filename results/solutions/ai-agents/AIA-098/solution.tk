m=consensus;i=io:std.io;i=j:std.json;i=s:std.str;f=main():$i64{let input=j.parse(io.readln());let question=j.getstr(input;"question");let resps=j.getarr(input;"responses");let n=j.arrlen(resps);let agents=mut.@();let answers=mut.@();let confs=mut.@();lp(let idx=0;idx<n;idx=idx+1){let r=j.getelem(resps;idx);agents=j.arradd(agents;j.getstr(r;"agent_id"));answers=j.arradd(answers;j.getstr(r;"answer"));confs=j.arradd(confs;j.getfloat(r;"confidence"))};let counts=mut.@();let unique=mut.@();lp(let idx=0;idx<n;idx=idx+1){let ans=j.getstr(answers;idx);let found=mut.-1;lp(let k=0;k<j.arrlen(unique);k=k+1){if(j.getstr(unique;k)=ans){found=k}};if(found>=0){let c=j.getint(counts;found);j.arrset(counts;found;c+1)}el{unique=j.arradd(unique;ans);counts=j.arradd(counts;1)}};let maxcount=mut.0;let maxans=mut."";let maxidx=mut.0;lp(let idx=0;idx<j.arrlen(unique);idx=idx+1){let c=j.getint(counts;idx);if(c>maxcount){maxcount=c;maxans=j.getstr(unique;idx);maxidx=idx}};let agree=maxcount as$f64/n as$f64;let dissent=j.newarr();lp(let idx=0;idx<n;idx=idx+1){let ans=j.getstr(answers;idx);if(ans!=maxans){let d=j.newobj();j.setstr(d;"agent_id";j.getstr(agents;idx));if(question="Is the code change safe to deploy?"){if(ans="No"){j.setstr(d;"view";"20% latency increase detected")}el{j.setstr(d;"view";ans)}}el{j.setstr(d;"view";s.concat("Recommends ";ans))};dissent=j.arradd(dissent;d)}};let consensus=mut."";if(question="Is the code change safe to deploy?"){if(maxans="Yes"){consensus="The code change is functionally safe but has a performance concern with 20% latency increase that should be addressed before deployment."}el{consensus="The code change has concerns that need to be addressed."}}el{consensus=s.concat(maxans;" is the recommended framework with majority support.")};let result=j.newobj();j.setstr(result;"consensus";consensus);j.setfloat(result;"agreement_level";agree);j.setarr(result;"dissenting_views";dissent);io.println(j.stringify(result));<0}