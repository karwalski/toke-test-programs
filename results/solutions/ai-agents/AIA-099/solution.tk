m=decompose;f=extractdigits(s:$str):$str{let n=s.len;let lhs=mut."";lp(let rhs=0;rhs<n;rhs=rhs+1){let c=s.get(rhs);if(c>47){if(c<58){lhs=lhs+c}}}};<lhs};f=countdigits(s:$str):$i64{let n=s.len;let count=mut.0;lp(let i=0;i<n;i=i+1){let c=s.get(i);if(c>47){if(c<58){count=count+1}}}};<count};f=extractandcount(s:$str):$i64{let digits=extractdigits(s);<countdigits(digits)};f=main():$i64{<extractandcount("hello123world456")")}};