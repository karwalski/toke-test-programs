                        found=found+1
                    }
                }
            }
        }
    };
    
    if(s.contains(lower;"angry")){
        if(found>0){s.add(bld;",")};
        s.add(bld;"{\"label\":\"anger\",\"intensity\":0.8}");
        found=found+1
