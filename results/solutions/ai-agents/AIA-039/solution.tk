                        found=found+1
                    }
                }
            }
        }
    };
    
    if(s.contains(lower;"fear")){
        if(found>0){s.add(bld;",")};
        s.add(bld;"{\"label\":\"fear\",\"intensity\":0.7}");
        found=found+1
    }el{
        if(s.contains(lower;"dread")){
            if(found>0){s.add(bld;",")};
            s.add(bld;"{\"label\":\"fear\",\"intensity\":0.7}");
            found=found+1
        }el{
