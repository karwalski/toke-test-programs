m=emotdetect;
i=io:std.io;
i=s:std.str;

f=detectemotions(text:$str):$str{
    let lower=text;
    let bld=s.builder();
    let found=mut.0;
    
    if(s.contains(lower;"happy")){
        if(found>0){s.add(bld;",")};
        s.add(bld;"{\"label\":\"joy\",\"intensity\":0.8}");
        found=found+1
    }el{
        if(s.contains(lower;"joy")){
            if(found>0){s.add(bld;",")};
