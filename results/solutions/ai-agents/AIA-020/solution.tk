m=filter;i=io:std.io;i=s:std.str;i=j:std.json;f=main():$i64{let input=io.readln();let data=j.parse(input);let chunks=data.get("chunks");let minscore=data.get("min_score");let maxredundancy=data.get("max_redundancy");let filtered=mut.@();let idx=mut.0;lp(idx<chunks.len){let chunk=chunks.get(idx);let score=chunk.get("score");if(score>=minscore){let chunktext=chunk.get("text");let redundant=mut.false;let k=mut.0;lp(k<filtered.len){let existingid=filtered.get(k);let existingidx=mut.0;lp(existingidx<chunks.len){let c=chunks.get(existingidx);if(c.get("id")=existingid){let existingtext=c.get("text");let similarity=calculatesimilarity(chunktext;existingtext);if(similarity>maxredundancy){redundant=true;br};br};existingidx=existingidx+1};k=k+1};if(!redundant){filtered=filtered+@(chunk.get("id"))}};idx=idx+1};let result=j.stringify(filtered);io.println(result);<0};f=calculatesimilarity(text1:$str;text2:$str):$f64{let words1=s.split(text1;" ");let words2=s.split(text2;" ");let common=mut.0;let i=mut.0;lp(i<words1.len){let word=words1.get(i);let k=mut.0;lp(k<words2.len){if(word=words2.get(k)){common=common+1;br};k=k+1};i=i+1};let total=words1.len+words2.len-common;if(total=0){<1.0};<(common as$f64)/(total as$f64)}