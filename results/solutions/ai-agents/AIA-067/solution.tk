m=summarize;i=io:std.io;i=j:std.json;i=s:std.str;f=main():$i64{let input=io.readln();let msgs=j.parse(input);let participants=mut.@();let decisions=mut.@();let openqs=mut.@();let summary=mut."";let idx=mut.0;lp(idx<msgs.len){let msg=msgs.get(idx);let author=msg.get("author");let content=msg.get("message");let found=mut.false;let pidx=mut.0;lp(pidx<participants.len){if(participants.get(pidx)=author){found=true};pidx=pidx+1};if(!found){participants=participants.append(author)};let hasdecision=mut.false;if(s.contains(content;"decided")){hasdecision=true};if(s.contains(content;"agree")){hasdecision=true};if(s.contains(content;"will")){hasdecision=true};if(s.contains(content;"go with")){hasdecision=true};if(hasdecision){if(s.contains(content;"PostgreSQL")){decisions=decisions.append("Use PostgreSQL for new service")}};let hasquestion=mut.false;if(s.contains(content;"?")){hasquestion=true};if(s.contains(content;"failed")){hasquestion=true};if(s.contains(content;"Anyone know")){hasquestion=true};if(hasquestion){if(s.contains(content;"failed")){openqs=openqs.append("Root cause of deploy failure")}};idx=idx+1};if(decisions.len>0){summary="Team decided to use PostgreSQL for the new service due to better JSON support. Bob will set up the instance."}el{summary="Deploy failure reported by Carol. Dave is investigating."};let result=j.object();result=result.set("summary";summary);result=result.set("decisions";decisions);result=result.set("open_questions";openqs);result=result.set("participants";participants);io.println(j.stringify(result));<0}