m=topicassign;i=io:std.io;i=s:std.str;i=j:std.json;f=scoretopic(text:$str;topic:$str):$f64{let ltext=s.lower(text);let ltopic=s.lower(topic);if(s.contains(ltext;ltopic)){<0.9};if(ltopic="finance"){if(s.contains(ltext;"stock")){<0.9};if(s.contains(ltext;"market")){<0.9};if(s.contains(ltext;"earnings")){<0.9}};if(ltopic="automotive"){if(s.contains(ltext;"electric")){<0.9};if(s.contains(ltext;"vehicle")){<0.9};if(s.contains(ltext;"tesla")){<0.9}};if(ltopic="technology"){if(s.contains(ltext;"battery")){<0.85};if(s.contains(ltext;"charging")){<0.85};if(s.contains(ltext;"tech")){<0.7};if(s.contains(ltext;"companies")){<0.7}};if(ltopic="environment"){if(s.contains(ltext;"battery")){<0.5};if(s.contains(ltext;"electric")){<0.5}};<0.0};f=main():$i64{let input=io.readln();let data=j.parse(input);let text=j.get(data;"text")as$str;let taxonomy=j.get(data;"taxonomy");let results=mut.@();let idx=mut.0;lp(idx<j.len(taxonomy)){let topic=j.get(taxonomy;idx)as$str;let score=scoretopic(text;topic);if(score>0.0){let obj=j.object();j.set(obj;"label";topic);j.set(obj;"confidence";score);results=j.append(results;obj)};idx=idx+1};let output=j.object();j.set(output;"topics";results);io.println(j.stringify(output));<0}