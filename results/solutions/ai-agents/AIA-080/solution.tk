m=plural;i=io:std.io;i=s:std.str;i=j:std.json;f=getplural(n:$i64;lang:$str):$str{if(lang="en"){if(n=1){<"item"}el{<"items"}}el{if(lang="ru"){let lastdigit=n%10;let lasttwo=n%100;if((lasttwo>=11)&(lasttwo<=14)){<"файлов"}el{if(lastdigit=1){<"файл"}el{if((lastdigit>=2)&(lastdigit<=4)){<"файла"}el{<"файлов"}}}}el{<""}}};f=main():$i64{let input=io.readln();let data=j.parse(input);let sourcetext=j.get(data;"source_text");let targetlang=j.get(data;"target_lang");let quantities=j.get(data;"quantities");let result=j.object();lp(let idx=0;idx<j.arraylen(quantities);idx=idx+1){let qty=j.arrayget(quantities;idx);let numval=j.asint(qty);let plural=getplural(numval;j.asstring(targetlang));let text=s.replace(j.asstring(sourcetext);"{count}";s.fromint(numval));let parts=s.split(text;" ");if(parts.len>=2){let finaltext=s.concat(s.concat(parts.get(0);" ");plural);j.set(result;s.fromint(numval);finaltext)}};io.println(j.stringify(result));<0}