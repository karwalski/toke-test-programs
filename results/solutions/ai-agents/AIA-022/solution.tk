m=extract;f=extractmetadata(text:$str):$str{let lines=text.split("\n");let title=mut."";let author=mut."";let date=mut."";let keywords=mut."";lp(let idx=0;idx<lines.len;idx=idx+1){let line=lines.get(idx);if(line.contains("Title:")){title=line.split("Title:")[1].trim()}el{if(line.contains("Author:"))){author=line.split("Author:")[1].trim()}el{if(line.contains("Date:"))){date=line.split("Date:")[1].trim()}el{if(line.contains("Keywords:"))){keywords=line.split("Keywords:")[1].trim()}el{}}}}};let result=s.concat(s.concat(s.concat(s.concat(s.concat(s.concat(s.concat("title=";title);"\nauthor=");author);"\ndate=");date);"\nkeywords=");keywords);<result};