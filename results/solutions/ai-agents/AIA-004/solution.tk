m=toolformat;i=io:std.io;i=s:std.str;i=j:std.json;f=main():$i64{let input=io.readln();let data=j.parse(input);let tool=j.getstring(j.get(data;"tool_name"));let result=j.get(data;"result");if(tool="weather"){let temp=j.getint(j.get(result;"temp_c"));let cond=j.getstring(j.get(result;"condition"));let hum=j.getint(j.get(result;"humidity"));io.println("The weather in Tokyo is currently \(s.fromint(temp))°C and \(cond) with \(s.fromint(hum))% humidity.")}el{if(tool="email_count"){let unread=j.getint(j.get(result;"unread"));let total=j.getint(j.get(result;"total"));io.println("You have \(s.fromint(unread)) unread emails out of \(s.fromint(total)) total.")}};<0}