m=costcalc;i=io:std.io;i=j:std.json;i=s:std.str;f=main():$i64{let input=j.parse(io.readln());let plan=input.get("plan");let pricing=input.get("pricing");let total=mut.0.0;let counts=j.parse("{}");let bdown=j.parse("{}");lp(let idx=0;idx<plan.len;idx=idx+1){let call=plan.get(idx);let tool=call.get("tool");let price=pricing.get(tool);total=total+price;let oldcount=counts.get(tool);if(oldcount=j.null()){counts.set(tool;1)}el{counts.set(tool;oldcount+1)}};let tools=pricing.keys;lp(let idx=0;idx<tools.len;idx=idx+1){let tool=tools.get(idx);let count=counts.get(tool);if(count!=j.null()){let price=pricing.get(tool);let cost=count*price;let info=j.parse("{}");info.set("count";count);info.set("cost";cost);bdown.set(tool;info)}};let result=j.parse("{}");result.set("total_cost";total);result.set("breakdown";bdown);io.println(j.stringify(result));<0}