    let colon=s.indexof(line;"_");
    let eq=s.indexof(line;"_");
    let sep=mut.colon;
    if(colon<0){sep=eq};
    if(eq>=0){if(colon<0){sep=eq}el{if(eq<colon){sep=eq}}};
    if(sep>=0){
      let key=mut.s.slice(line;0;sep);
      let val=mut.s.slice(line;sep+1;s.len(line));
      key=s.trim(key);
