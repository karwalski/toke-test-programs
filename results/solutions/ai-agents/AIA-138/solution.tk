m=costanomaly;f=isoutlier(arr:@$f64;val:$f64):$bool{let len=arr.len;let isin=mut.false;lp(let i=0;i<len;i=i+1){if(arr.get(i)=val)){isin=true;};};<isin};f=median(arr:@$f64):$f64{let len=arr.len;let sorted=mut.@();lp(let i=0;i<len;i=i+1){sorted=sorted+@(arr.get(i));};};let mid=len/2;let iseven=!(len-mid*2=0));let result=mut.0.0;if(iseven){let idx=mid-1;result=sorted.get(idx);};if(!(iseven)){let idx=mid;result=sorted.get(idx);};<result};f=absf(x:$f64):$f64{if(x<0.0){<0.0-x};<x};f=relui(x:$f64):$f64{if(x>0.0){<x};<0.0};f=variance(arr:@$f64):$f