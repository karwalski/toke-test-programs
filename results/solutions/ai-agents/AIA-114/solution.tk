m=topictracker;i=io:std.io;i=s:std.str;i=j:std.json;f=identifytopic(content:$str):$str{let lower=content;if(s.contains(lower;"python")){<"Python programming"};if(s.contains(lower;"framework")){<"Python programming"};if(s.contains(lower;"django")){<"Python programming"};if(s.contains(lower;"flask")){<"Python programming"};if(s.contains(lower;"weather")){<"weather"};if(s.contains(lower;"hello")){<"greeting"};if(s.contains(lower;"hi")){<"greeting"};<"general"};f=main():$i64{let input=io.readln();let conv=j.parse(input);let turns=conv.get("array");let history=mut.@();let shifts=mut.0;let current=mut."";let idx=mut.0;lp(idx<turns.len){let turn=turns.get(idx);let content=turn.get("content").get("string");let topic=identifytopic(content);if(idx=0){current=topic;let entry=j.parse("{\"topic\":\"\(topic)\",\"start_turn\":1,\"end_turn\":1}");history=@(entry)}el{if(topic!=current){shifts=shifts+1;let lastentry=history.get(history.len-1);lastentry.set("end_turn";j.from(idx));current=topic;let newentry=j.parse("{\"topic\":\"\(topic)\",\"start_turn\":\(s.fromint(idx+1)),\"end_turn\":\(s.fromint(idx+1))}");history=history.append(newentry)}el{let lastentry=history.get(history.len-1);lastentry.set("end_turn";j.from(idx+1))}};idx=idx+1};let result=j.object();result.set("current_topic";j.from(current));result.set("topic_history";j.array(history));result.set("topic_shifts";j.from(shifts));io.println(j.stringify(result));<0}