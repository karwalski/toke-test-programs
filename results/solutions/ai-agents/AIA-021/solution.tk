m=reciprocalrank;i=io:std.io;i=s:std.str;i=j:std.json;f=main():$i64{let input=j.parse(io.readln());let kw=input.get("keyword_results");let sem=input.get("semantic_results");let k=s.toint(j.stringify(input.get("k")));let scoremap=mut.@();let itemlist=mut.@();let idx=mut.0;lp(idx<kw.len){let item=j.stringify(kw.get(idx));let score=1.0/(k as$f64+(idx as$f64)+1.0);let found=mut.-1;let p=mut.0;lp(p<itemlist.len){if(itemlist.get(p)=item){found=p};p=p+1};if(found<0){itemlist=itemlist.push(item);scoremap=scoremap.push(score)}el{let oldscore=scoremap.get(found);scoremap=scoremap.set(found;oldscore+score)};idx=idx+1};idx=0;lp(idx<sem.len){let item=j.stringify(sem.get(idx));let score=1.0/(k as$f64+(idx as$f64)+1.0);let found=mut.-1;let p=mut.0;lp(p<itemlist.len){if(itemlist.get(p)=item){found=p};p=p+1};if(found<0){itemlist=itemlist.push(item);scoremap=scoremap.push(score)}el{let oldscore=scoremap.get(found);scoremap=scoremap.set(found;oldscore+score)};idx=idx+1};let n=itemlist.len;let i=mut.0;lp(i<n-1){let j=mut.0;lp(j<n-i-1){if(scoremap.get(j)<scoremap.get(j+1)){let tempscore=scoremap.get(j);scoremap=scoremap.set(j;scoremap.get(j+1));scoremap=scoremap.set(j+1;tempscore);let tempitem=itemlist.get(j);itemlist=itemlist.set(j;itemlist.get(j+1));itemlist=itemlist.set(j+1;tempitem)};j=j+1};i=i+1};let result=mut.@();let x=mut.0;lp(x<itemlist.len){result=result.push(itemlist.get(x));x=x+1};io.println(j.stringify(result));<0}