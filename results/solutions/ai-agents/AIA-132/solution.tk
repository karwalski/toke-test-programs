m=compare;f=compareplans(plana:$str;planb:$str):$str{let a=mut.0;let b=mut.0;let aparts=plana.split(" ");let bparts=planb.split(" ");lp(let i=0;i<aparts.len;i=i+1){let apart=aparts.get(i);if(apart.contains("cost"))){let coststr=apart.split(":")[1];a=a+coststr.toi64();};};lp(let i=0;i<bparts.len;i=i+1){let bpart=bparts.get(i);if(bpart.contains("cost"))){let coststr=bpart.split(":")[1];b=b+coststr.toi64();};};let result=mut."";if(a<b){result="Plan A is cheaper: ";result=s.concat(result;a) as$str;result=s.concat(result;" < ");result=s.concat(result;b) as$str;}el{if(a>b){result="Plan B is cheaper: ";result=s.concat(result;b) as$str;result=s.concat(result;" < ");result=s.concat(result;a) as$str;}el{result="Plans are equally expensive: ";result=s.concat(result;a) as$str;};};result=s.concat(result;" USD");<result};