m=planchecker;t=$str;f=checkfeasibility(tasks:@$str;resources:@$str;dependencies:@$str;deadline:$str):$str{let result=mut."feasible";let n=tasks.len;lp(let i=0;i<n;i=i+1){let task=tasks.get(i);let hasresource=mut.false;let m=resources.len;lp(let j=0;j<m;j=j+1){let res=resources.get(j);if(res=task){hasresource=true};};if(!(hasresource)){result="infeasible";};};if(result="infeasible"){<result};let deadlinetask=mut.false;lp(let i=0;i<n;i=i+1){let task=tasks.get(i);if(task=deadline){deadlinetask=true};};if(!(deadlinetask)){result="infeasible";};<result};