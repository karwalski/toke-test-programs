m=agentdispatcher;
i=io:std.io;
i=s:std.str;
i=j:std.json;
f=main():$i64{
  let input=io.readln();
  let data=j.parse(input);
  let workitems=j.get(data;"work_items");
  let agents=j.get(data;"agents");
  
  let assigns=mut.@();
  let agentloads=mut.@();
  
  let nagents=j.len(agents);
  lp(let idx=0;idx<nagents;idx=idx+1){
    let agent=j.get(agents;idx);
    let agentid=j.getstr(agent;"id");
    let capacity=j.getint(agent;"capacity");
    assigns=assigns+@(@(agentid;@()));
    agentloads=agentloads+@(@(agentid;0));
  };
  
  let nwork=j.len(workitems);
  lp(let widx=0;widx<nwork;widx=widx+1){
    let work=j.get(workitems;widx);
    let workid=j.getstr(work;"id");
    let worktype=j.getstr(work;"type");
    let complexity=j.getint(work;"complexity");
    
    let bestagent=mut."";
    let bestload=mut.1000000;
    
    lp(let aidx=0;aidx<nagents;aidx=aidx+1){
      let agent=j.get(agents;aidx);
      let agentid=j.getstr(agent;"id");
      let capacity=j.getint(agent;"capacity");
      let specialties=j.get(agent;"specialties");
      
      let canhandle=mut.false;
      let nspec=j.len(specialties);
      lp(let sidx=0;sidx<nspec;sidx=sidx+1){
        let spec=j.getstr(specialties;sidx);
        if(spec=worktype){canhandle=true;br;};
      };
      
      if(canhandle){
        let currentload=getload(agentloads;agentid);
        if((currentload+complexity)<=capacity){
          if(currentload<bestload){
            bestagent=agentid;
            bestload=currentload;
          };
        };
      };
    };
    
    if(bestagent!=""){
      assigns=addwork(assigns;bestagent;workid);
      agentloads=updateload(agentloads;bestagent;bestload+complexity);
    };
  };
  
  let output=buildoutput(assigns);
  io.println(output);
  <0
};
f=getload(loads:@(@($str));agentid:$str):$i64{
  let len=loads.len;
  lp(let idx=0;idx<len;idx=idx+1){
    let pair=loads.get(idx);
    if(pair.get(0)=agentid){<pair.get(1) as $i64};
  };
  <0
};
f=updateload(loads:@(@($str));agentid:$str;newload:$i64):@(@($str)){
  let newarr=mut.@();
  let len=loads.len;
  lp(let idx=0;idx<len;idx=idx+1){
    let pair=loads.get(idx);
    if(pair.get(0)=agentid){
      newarr=newarr+@(@(agentid;newload));
    }el{
      newarr=newarr+@(pair);
    };
  };
  <newarr
};
f=addwork(assigns:@(@($str));agentid:$str;workid:$str):@(@($str)){
  let newarr=mut.@();
  let len=assigns.len;
  lp(let idx=0;idx<len;idx=idx+1){
    let pair=assigns.get(idx);
    if(pair.get(0)=agentid){
      let works=pair.get(1);
      let newworks=works+@(workid);
      newarr=newarr+@(@(agentid;newworks));
    }el{
      newarr=newarr+@(pair);
    };
  };
  <newarr
};
f=buildoutput(assigns:@(@($str))):$str{
  let b=s.builder();
  s.add(b;"{");
  let len=assigns.len;
  let first=mut.true;
  lp(let idx=0;idx<len;idx=idx+1){
    let pair=assigns.get(idx);
    let agentid=pair.get(0);
    let works=pair.get(1);
    if(works.len>0){
      if(!first){s.add(b;",")};
      first=false;
      s.add(b;"\"");
      s.add(b;agentid);
      s.add(b;"\":[");
      let wlen=works.len;
      lp(let widx=0;widx<wlen;widx=widx+1){
        if(widx>0){s.add(b;",")};
        s.add(b;"\"");
        s.add(b;works.get(widx));
        s.add(b;"\"");
      };
      s.add(b;"]");
    };
  };
  s.add(b;"}");
  <s.build(b)
};