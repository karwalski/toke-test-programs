m=selectoptimal;f=selectoptimal(tasks:@($str;$str;$str;$str)));$str{let n=tasks.len;let bestidx=mut.0;let bestpri=mut."";let bestdep=mut."";let bestddl=mut."";lp(let i=0;i<n;i=i+1){let t=tasks.get(i);let pri=t.1;let dep=t.2;let ddl=t.3;let isbetter=mut.false;if(pri>bestpri){isbetter=true};if(!(pri>bestpri)){if(dep<bestdep){isbetter=true}};if(isbetter){bestidx=i;bestpri=pri;bestdep=dep;bestddl=ddl}};<tasks.get(bestidx).0)};