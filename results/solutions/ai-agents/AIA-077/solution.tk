m=translator;i=io:std.io;i=s:std.str;i=j:std.json;f=main():$i64{let input=io.readln();let data=j.parse(input);let text=data.get("text");let glossary=data.get("glossary");let words=s.split(text;" ");let bld=s.builder();lp(let idx=0;idx<words.len;idx=idx+1){let word=words.get(idx);let translated=glossary.get(word);if(idx>0){s.add(bld;" ")};if(translated!=""){s.add(bld;translated)}el{s.add(bld;word)}};let result=s.build(bld);let output=j.stringify(@("translated_text";result));io.println(output);<0}