m=timeoutchecker;f=checktimeouts(steps:@$str;durations:@i64;threshold:i64):@$str{let timedout=mut.@();let n=steps.len;lp(let i=0;i<n;i=i+1){let step=steps.get(i);let duration=durations.get(i);if(duration>threshold){timedout=timedout+@(step)}};<timedout};f=main():$void{let steps=@("step1";"step2";"step3";"step4"));let durations=@(1000;500;1500;1000));let threshold=1000;let result=checktimeouts(steps;durations;threshold);let n=result.len;lp(let i=0;i<n;i=i+1){let step=result.get(i);<step>}};