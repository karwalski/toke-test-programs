m=ragconfig;i=io:std.io;i=s:std.str;i=j:std.json;f=main():$i64{let input=io.readln();let config=j.parse(input);let chunksize=config.get("chunk_size")as$i64;let overlap=config.get("overlap")as$i64;let embeddingdim=config.get("embedding_dim")as$i64;let topk=config.get("top_k")as$i64;let maxcontext=config.get("max_context_tokens")as$i64;let model=config.get("model")as$str;let errors=mut.@();let warnings=mut.@();let valid=mut.true;if(overlap>=chunksize){valid=false;let errmsg="overlap (\(s.fromint(overlap)) must be less than chunk_size (\(s.fromint(chunksize))";errors=@(errmsg)};let threshold=maxcontext*8;threshold=threshold/10;if(topk*chunksize>threshold){let warnmsg="top_k of \(s.fromint(topk)) with chunk_size \(s.fromint(chunksize)) may exceed max_context_tokens";warnings=@(warnmsg)};let result=j.parse("{}");result.set("valid";valid);result.set("errors";errors);result.set("warnings";warnings);io.println(j.stringify(result));<0}