m=retrypol;f=clamp(val:$i64;lo:$i64;hi:$i64):$i64{if(val<lo){<lo};if(val>hi){<hi};<val};f=exponegrowth(attempts:$i64):$i64{if(attempts<1){<0};let base=2;let exp=attempts-1;let result=mut.1;lp(let i=0;i<exp;i=i+1){result=result*base};<result};f=buildfailmessage(stepname:$str;attempt:$i64;maxattempts:$i64):$str{let msg=mut."step failed: ";msg=s.concat(msg;stepname);msg=s.concat(msg;" attempt: ");let attemptstr=attempt as$str;msg=msg+attemptstr;msg=s.concat(msg;" max: ");let maxstr=maxattempts as$str;msg=msg+maxstr;<msg};f=shouldretry(attempt:$i64;maxattempts:$i64):$bool{if(attempt<1){<false};if(attempt<maxattempts){<true};<false};f=retrystep(stepname:$str