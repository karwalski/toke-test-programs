m=depcheck;i=io:std.io;i=s:std.str;i=j:std.json;f=compareversions(v1:$str;v2:$str):$i64{let p1=s.split(v1;".");let p2=s.split(v2;".");let idx=mut.0;lp(idx<p1.len){if(idx>=p2.len){<1};let n1=s.toint(p1.get(idx));let n2=s.toint(p2.get(idx));if(n1<n2){<-1}el{if(n1>n2){<1}};idx=idx+1};if(p2.len>p1.len){<-1};<0};f=main():$i64{let input=j.parse(io.readln());let imports=input.get("imports");let vulns=input.get("known_vulnerabilities");let issues=mut.@();let idx=mut.0;lp(idx<imports.len){let imp=imports.get(idx);let name=imp.get("name") as $str;let version=imp.get("version") as $str;let usedin=imp.get("used_in");let vidx=mut.0;let found=mut.false;lp(vidx<vulns.len){let vuln=vulns.get(vidx);let vname=vuln.get("package") as $str;if(vname=name){let affected=vuln.get("affected_versions") as $str;if(s.contains(affected;"<")){let minver=s.slice(affected;1;s.len(affected));if(compareversions(version;minver)<0){let issue=@("package";name;"type";"vulnerability";"severity";"high";"detail";"Version \(version) is affected, upgrade to \(minver)+");issues=issues.append(issue);found=true}}};vidx=vidx+1};if(usedin.len=0){if(found=false){let issue=@("package";name;"type";"unused";"severity";"low";"detail";"Imported but not used in any file");issues=issues.append(issue)}};idx=idx+1};let result=@("issues";issues);io.println(j.stringify(result));<0}