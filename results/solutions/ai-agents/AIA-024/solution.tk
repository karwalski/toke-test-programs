m=scoreprog;f=score(doc:$str;query:$str):$i64{let words=query.split(" ");let score=mut.0;lp(let i=0;i<words.len;i=i+1){let w=words.get(i);let found=doc.contains(w);if(found){score=score+1};};let total=words.len;let matched=score;let ratio=matched as$f64/total as$f64;let adjusted=score*2;let final=adjusted;if(final<0){<0};if(final>100){<100};<final};f=main():$i64{let doc="the quick brown fox jumps over the lazy dog";let query="the quick brown fox";let s=score(doc;query);<0};