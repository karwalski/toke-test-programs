m=bugfix;i=io:std.io;i=s:std.str;i=j:std.json;f=fixpython(code:$str;desc:$str):$str{let fixed=mut."";let explanation=mut."";let changeobj=mut.j.object();if(s.contains(desc;"Stack overflow")){fixed="def fib(n, memo={}):\\n    if n <= 1:\\n        return n\\n    if n in memo:\\n        return memo[n]\\n    memo[n] = fib(n-1, memo) + fib(n-2, memo)\\n    return memo[n]";j.setint(changeobj;"line";1);j.setstring(changeobj;"old";"def fib(n):");j.setstring(changeobj;"new";"def fib(n, memo={}):");explanation="Added memoization to avoid exponential recursive calls that cause stack overflow for large n."}el{if(s.contains(desc;"Index error")){fixed="items = [1, 2, 3]\\nitems = [x for x in items if x != 2]";j.setint(changeobj;"line";2);j.setstring(changeobj;"old";"for i in range(len(items)):");j.setstring(changeobj;"new";"items = [x for x in items if x != 2]");explanation="Replaced in-place removal during iteration with list comprehension to avoid index errors from shrinking list."}};let changes=j.array();j.arraypush(changes;changeobj);let result=j.object();j.setstring(result;"fixed_code";fixed);j.set(result;"changes";changes);j.setstring(result;"explanation";explanation);<j.stringify(result)};f=main():$i64{let input=io.readln();let parsed=j.parse(input);let code=j.getstring(parsed;"code");let desc=j.getstring(parsed;"bug_description");let output=fixpython(code;desc);io.println(output);<0}