m=dedup;i=io:std.io;i=j:std.json;i=s:std.str;f=main():$i64{let input=io.readln();let passages=j.parse(input);let srcmap=mut.@();lp(let idx=0;idx<passages.len;idx=idx+1){let p=passages.get(idx);let src=s.fromstr(p.get("source_doc"));let found=mut.false;let bestidx=mut.-1;lp(let k=0;k<srcmap.len;k=k+1){let entry=srcmap.get(k);if(s.fromstr(entry.get("src"))=src){found=true;bestidx=k}};if(found){let entry=srcmap.get(bestidx);let oldscore=s.tofloat(s.fromfloat(entry.get("score")));let newscore=s.tofloat(s.fromfloat(p.get("relevance_score")));if(newscore>oldscore){let newentry=j.parse("{\\"src\\":\\""+src+"\\",\\"idx\\":"+s.fromint(idx)+",\\"score\\":"+s.fromfloat(newscore)+"}");srcmap=srcmap.set(bestidx;newentry)}}el{let entry=j.parse("{\\"src\\":\\""+src+"\\",\\"idx\\":"+s.fromint(idx)+",\\"score\\":"+s.fromfloat(p.get("relevance_score"))+"}");srcmap=srcmap+@(entry)}};let result=mut.@();lp(let k=0;k<srcmap.len;k=k+1){let entry=srcmap.get(k);let idxval=s.toint(s.fromint(entry.get("idx")));result=result+@(passages.get(idxval))};io.println(j.stringify(result));<0}