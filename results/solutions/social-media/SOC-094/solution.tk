m=notif;f=notify(title:$str;body:$str):$void{let id=genid();let ts=now();let read=mut.false;let disp=mut."popup";let prio=mut.1;let store=mut.@(id;title;body;ts;prio;read;disp));};f=markread(id:$str):$void{let n=store.len;lp(let i=0;i<n;i=i+1){let v=store.get(i);if(v=id){store.set(i;"read")}}}};f=notiflist(limit:$i64;offset:$i64):$str{let total=store.len;let start=offset;let end=mut.limit;if(start<total){if(end>total-start){end=total-start}};let out=mut."";lp(let i=start;i<start+end;i=i+1){let v=store.get(i);out=out+v+"\n"}};f=init():$void{let s1=notiflist(5;0);let s2=notiflist(5;5);let s3=notiflist(5;10);let s4=notiflist(5;1