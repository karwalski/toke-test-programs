m=main;f=main():$void{let req=std.http.readrequest();let action=req.body.action;let token=req.body.token;let message_id=req.body.message_id;let emoji=req.body.emoji;let resp=std.http.writeresponse();let ok=std.http.writeok(resp);let reaction=std.json.encodestr(emoji);let msg="Reaction added: ";let fullmsg=msg+reaction;let out=std.http.writebody(resp;fullmsg);let done=std.http.writeclose(resp);};