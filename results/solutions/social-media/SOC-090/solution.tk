m=filterusers;f=filterusers(rows:i64;filter:$str):i64{let result=mut.@();let cols=rows;lp(let i=0;i<cols.len;i=i+1){let row=cols.get(i);let verified=row.verified;let followers=row.followers;let loc=row.loc;let name=row.name;let age=row.age;let bio=row.bio;if(filter="verified"){if(verified){result=result+@(row)}}el{if(filter="followers"){let minfollowers=10;let maxfollowers=100;if(!(followers<minfollowers)){if(!(followers>maxfollowers)){result=result+@(row)}}}}el{if(filter="location"){if(loc="us"){result=result+@(row)}}}}};<result};f=main():$void{let query="select * from users";let rows=std.db.query(query);let filter="verified";let filtered=filterusers(rows;filter);let out="filtered";<std.db.query(out)};