m=topics;f=topichash(tag:$str):$i64{let hash=mut.0;let len=tag.len;lp(let i=0;i<len;i=i+1){let char=tag.get(i)as:i64;hash=hash*33+char;hash=hash-hash/2*2;};<hash};f=extractkeywords(text:$str):$str{let words=text.split(" ");let keywords=mut."";lp(let i=0;i<words.len;i=i+1){let word=words.get(i);let hashed=topichash(word);let ispositive=hashed>0;if(ispositive){let iskeyword=word.len>3;if(iskeyword){keywords=keywords+word+" ";};};};<keywords};f=countuniquewords(text:$str):$i64{let words=text.split(" ");let unique=mut.@()