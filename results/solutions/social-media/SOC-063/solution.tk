    "std.time": "time"
  },
  "t": {
    "comment": {
      "id": "str",
      "content": "str",
      "author_id": "str",
      "post_id": "str",
      "created_at": "i64",
      "updated_at": "i64",
      "likes": "i32",
      "dislikes": "i32",
      "is_deleted": "bool"
    }
