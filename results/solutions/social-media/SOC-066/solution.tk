m=comments;f=processcomment(action:$str;commentid:$str;postid:$str;token:$str):$str{if(action="create"){<processcreatecomment(commentid;postid;token))};if(action="delete"){<processdeletecomment(commentid)};if(action="edit"){<processeditcomment(commentid)};if(action="list"){<processlistcomments(postid)};if(action="pin"){<processpincomment(commentid)};if(action="unpin"){<processunpincomment(commentid)};if(action="rate"){<processratecomment(commentid)};if(action="report"){<processreportcomment(commentid)};if(action="approve"){<processapprovecomment(commentid)};if(action="deny"){<processdenycomment(commentid)};<"unknown action"};f=processcreatecomment(commentid:$str;postid:$str;token:$str):$str{<commenttojson(commentid;postid;token))};f=processdeletecomment(commentid:$str):$str{<commenttojson(commentid;"deleted";""))>};f=processeditcomment(commentid:$str):$str{<commenttojson(commentid;"edited";""))>};f=processlistcomments(postid:$str):$str{<commentstojson("all";postid))>};f=processpincomment(commentid:$str):$str{<commenttojson(commentid;"pinned";""))>};f=processunpincomment(commentid:$str):$str{<commenttojson(commentid;"unpinned";""))>};f=processra