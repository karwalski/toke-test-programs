m=groupnotifs;f=groupnotifs(notifs:@$str):@$str{let seen=mut.@();let result=mut.@();lp(let i=0;i<notifs.len;i=i+1){let n=notifs.get(i);let isnew=mut.true;lp(let j=0;j<seen.len;j=j+1){if(seen.get(j)=n){isnew=false}};if(isnew){seen=seen+@(n);let count=mut.1;lp(let k=i+1;k<notifs.len;k=k+1){let m=notifs.get(k);if(m=n){count=count+1;k=k-1}};let suffix=mut."";if(count>1){suffix=" and "+count+" others"};result=result+@(n+suffix))}};<result};