m=profile;f=renderprofile(user:$str;posts:@$str;pinnedidx:$i64):$str{let out=mut."";let n=posts.len;lp(let i=0;i<n;i=i+1){let idx=i as$str;let line=s.concat(user;": post ")+idx;out=s.concat(s.concat(out;line);"\n");};let pidx=pinnedidx as$str;let pline="Pinned: post "+pidx;out=s.concat(s.concat(out;pline);"\n");<out};f=main():$void{let user="alice";let posts=@("hello world";"toke programming";"data science"));let pinned=2;let html=renderprofile(user;posts;pinned);<html};