m=main;i=io;f=processlist(items:@$str):@$str{let result=mut.@();lp(let idx=0;idx<items.len;idx=idx+1){let item=items.get(idx);result=result+@(item);};<result};f=main():$void{let items=@("apple";"banana";"cherry"));let filtered=processlist(items);lp(let idx=0;idx<filtered.len;idx=idx+1){let item=filtered.get(idx);io.println(item);};};