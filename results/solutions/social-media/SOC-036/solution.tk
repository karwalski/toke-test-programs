m=notif;f=notify(n:$str):$void{let msg=n;let title="mention";let body=msg;let icon="bell";let badge="1";let onclick="alert('read')";let dismissafter=5000;let render="toast";let style="primary";let compact=false;let hasbadge=true;let position="top-right";let spacing=16;let animation="slide";let duration=3000;let events="click:read,dismiss:archived";let template="[[title]]: [[body]]";let context="user.notifications";let level="info";let source="notification_system";let ts=1700000000;let tz="UTC";let id="notif-1";let read=false;let dismissed=false;let actions=@("mark_read";"dismiss");let meta=@("source":"notification_system";"ts":1700000000;id:"notif-1";"read":false;dismissed:false;actions:@("mark_read";"dismiss");meta: