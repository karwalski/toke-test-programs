m=main;f=main():$void{let body=std.http.readbody(std.http.get("https://api.example.com/messages")));let parsed=std.json.parse(body);let messages=std.json.getarray(parsed;"messages");let readreceipts=std.json.getarray(parsed;"read_receipts");let result=mut.@();lp(let i=0;i<readreceipts.len;i=i+1){let rr=readreceipts.get(i);let msgid=rr.msg_id;let readat=rr.read_at;let found=mut.false;lp(let j=0;j<messages.len;j=j+1){let msg=messages.get(j);let mid=msg.msg_id;if(mid=msgid){found=true;};};if(found){result=result+@("read");}el{result=result+@("unread");};};<result};