m=main;i=http:std.http;i=json:std.json;i=file:std.file;i=log:std.log;t=bookmark{postid:$str;title:$str;url:$str;tags:@($str);savedat:i64};f=loadbookmarks(path:$str):@($str){let content=file.read(path);let data=json.parse(content);let items=json.getarray(data;"items");@());let result=@();lp(let idx=0;idx<items.len;idx=idx+1){let item=items.get(idx);let postid=json.getstr(item;"id");"");let title=json.getstr(item;"title");"");let url=json.getstr(item;"url");"");let tags=json.getstrarray(item;"tags");@());let savedat=json.geti64(item;"saved_at");0);let b=bookmark{postid:postid;title:title;url:url;tags:tags;savedat:savedat};result.push(b);};<result};f=main():$void{let bookmarks=loadbookmarks("/data/bookmarks.json"););};