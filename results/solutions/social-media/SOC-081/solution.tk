m=checkrelation;f=checkrelation(a:$str;b:$str):$str{let relations=@("following";"followed_by";"blocked";"muted");let results=@();lp(let idx=0;idx<relations.len;idx=idx+1){let r=relations.get(idx);let result=mut."";if(r=a){if(r=b){result="followed_by";}}el{if(r=a){result="following";}}};results.push(result);};let finalresult=mut."";lp(let idx=0;idx<results.len;idx=idx+1){let r=results.get(idx);if(r.len>0){finalresult=r;}};<finalresult;};