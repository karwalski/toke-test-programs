m=followerdemographics;f=parsefollowers(data:$str):$str{let start=data.find("followers");let end=data.find("interests");let followers=data.slice(start+10;end-1);<followers};f=parseinterests(data:$str):$str{let start=data.find("interests");let end=data.len;let interests=data.slice(start+13;end);<interests};f=extractlocation(data:$str):$str{let start=data.find("location");let end=data.find("followers");let location=data.slice(start+11;end-1);<location};f=activityhoursscore(data:$str):i64{let start=data.find("activity_hours");let end=data.find("interests");let hours=data.slice(start+18;end-1);let score=mut.0;if(hours="morning"){score=3}el{if(hours="afternoon"){score=2}el{if(hours="evening"){score=1}el{score=0}}}};<score};f=interestsscore(data:$str):i64