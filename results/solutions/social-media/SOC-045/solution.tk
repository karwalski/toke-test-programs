m=main;i=http:std.http;i=json:std.json;i=io:std.io;t=page{items:@($str);next:$str};f=fetchpage(url:$str):$page{let resp=http.get(url);let body=resp.body;let parsed=json.parse(body);let items=json.getarray(parsed;"items");let nexturl=json.getstr(parsed;"next");let result=page{items:items;next:nexturl};<result};f=main():$void{let url="https://api.example.com/likes?page=1";let page=fetchpage(url);let items=page.items;let count=items.len;lp(let idx=0;idx<count;idx=idx+1){let item=items.get(idx);let name=json.getstr(item;"name");let avatar=json.getstr(item;"avatar");let msg="liked by "+name+" avatar="+avatar;io.println(msg);};let next=page.next;if(next.len>0){io.println(s.concat("more: ";next));};};