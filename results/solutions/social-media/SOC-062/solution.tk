m=deletecomment;f=deletecomment(cid:$str):$bool{let result=mut.false;let confirmprompt="Delete comment? [y/N] ";let confirminput=br(confirmprompt);if(confirminput="y"){result=true;let deletecmd="DELETE FROM comments WHERE cid='";let finalcmd=s.concat(s.concat(deletecmd;cid);"'");let deleteresult=br(finalcmd);if(deleteresult){result=true;}el{result=false;};}el{result=false;};<result};