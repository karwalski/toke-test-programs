m=hashtag;f=extracthashtag(line:$str):$str{let len=line.len;let idx=mut.0;let found=mut.false;lp(let i=0;i<len;i=i+1){let ch=line.get(i);if(ch="#"){found=true;idx=i+1;};};if(found){let start=idx;let end=mut.len;lp(let i=start;i<len;i=i+1){let ch=line.get(i);if(ch=" "){end=i;br;};};if(!(end>start))){end=start+1;};let hashtag=line.substr(start;end-start);<hashtag}el{<""}};f=countusage(hashtags:@$str;line:$str):i64{let count=mut.0;let len=hashtags.len;lp(let i=0;i<len;i=i+1){let h=hashtags.get(i);if(h.len>0){let found=h.len>0;if(found){count=count+1;};};};<count};f=ispopular(hashtag:$str;usagecount:i64):bool{let popular=mut.false;if(hashtag.len>0)){if(usagecount>100){popular=true;}el