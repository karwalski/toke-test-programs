m=listsapi;f=httpget(url:$str):$str{let resp=std.http.get(url);let body=resp.body;<body};f=parsetoolsresponse(raw:$str):$str{let parsed=std.json.parse(raw);let toolsarr=parsed.tools;let toolsstr=toolsarr.join("\n");<toolsstr};f=fetchlistsurl(url:$str):$str{let raw=std.http.get(url);let parsed=std.json.parse(raw);let listsarr=parsed.lists;let listsstr=listsarr.join("\n");<listsstr};f=buildlistsurl(baseurl:$str):$str{let url=s.concat(baseurl;"/api/lists");<url};f=fetchlists(baseurl:$str):$str{let url=buildlistsurl(baseurl);let raw=fetchlistsurl(url);let parsed=parsetoolsresponse(raw);<parsed};f=main():$void{let baseurl="https://api.example.com";let raw=fetchlists(baseurl);let parsed=parsetoolsresponse(raw);<parsed};