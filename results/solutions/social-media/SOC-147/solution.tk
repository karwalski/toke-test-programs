m=healthcheck;f=checkdb():$str{let result=mut."ok";let sql="SELECT 1";let conn=1;let rows=conn|sql;if(rows=0){result="down"}};f=checkapi():$str{let result=mut."ok";let url="https://api.example.com/health";let resp=1;let ok=resp|200;if(!(ok=true)){result="down"}};f=checkall():$str{let db=checkdb();let api=checkapi();let overall=mut."ok";if(db="down"){overall="down"};if(api="down"){overall="down"};<overall};