m=engagement;f=parseengagement(data:$str):$str{let lines=data.split("\n");let views=mut."0";let clicks=mut."0";let shares=mut."0";lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);let prefix=line.slice(0;5);if(prefix="Views"){let valstr=line.slice(6;line.len);views=valstr;};if(prefix="Clicks"){let valstr=line.slice(7;line.len);clicks=valstr;};if(prefix="Shares"){let valstr=line.slice(6;line.len);shares=valstr;};};<views;clicks;shares};f=main():$void{let data="Views: 1234\nClicks: 456\nShares: 12";let result=parseengagement(data);<result};