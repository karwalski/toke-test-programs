m=main;i=db:std.db;i=json:std.json;i=time:std.time;f=main():$void{let conn=db.open("data/bookmarks.db");let schema="CREATE TABLE IF NOT EXISTS bookmarks (id TEXT PRIMARY KEY, url TEXT NOT NULL, title TEXT, tags TEXT, created_at TEXT NOT NULL)";let create=db.exec(conn;schema);let now=time.now();let ts=time.format(now;"%Y-%m-%dT%H:%M:%S")let id="bmk_001";let url="https://example.com";let title="Example Domain";let tags="test,example";let insert="INSERT INTO bookmarks (id, url, title, tags, created_at) VALUES ('bmk_001','https://example.com','Example Domain','test,example','2026-04-20T10:30:00')";let bookmark=db.exec(conn;insert);let close=db.close(conn);};