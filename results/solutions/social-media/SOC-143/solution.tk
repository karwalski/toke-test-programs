m=bookclub;f=init():$void{let desc="A book club for avid readers. Discuss new releases, explore classic literature, and share your reading experiences. Join us to deepen your love for books and connect with fellow book enthusiasts.";let name="Book Club";let privacy=1;let members=mut.@();let created=mut.0;let lastactive=mut.0;let purpose="To discuss books and share reading experiences.";let rules="1. Be respectful and kind to all members. 2. Attend all meetings and participate in discussions. 3. Share your reading experiences and recommend books to the group. 4. Follow the privacy settings and only share personal information with other members.";let contact="contact@bookclub.com";let website="https://bookclub.com";let location="Online";let status="Active";let joined=mut.@();let left=mut.@();let muted=mut.@();let pinned=mut.@();let topics=mut.@();let events=mut.@();let achievements=mut.@();let moderation=mut.@();let analytics=mut.@();let integrations=mut.@();let settings=mut.@();let roles=mut.@();let permissions=mut.@();let