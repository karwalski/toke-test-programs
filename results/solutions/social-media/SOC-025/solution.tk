m=dbquery;f=queryuserposts(userid:$str;page:$i64;perpage:$i64):$str{let offset=mut.(page-1)*perpage;let limit=mut.perpage;let sql=mut."SELECT id,title,content,created_at FROM posts WHERE user_id=? ORDER BY created_at DESC LIMIT ? OFFSET ?";let params=mut.@(userid;limit;offset));let result=mut.@();let i=mut.0;lp(let idx=0;idx<result.len;idx=idx+1){let row=result.get(idx);let id=row.get(0);let title=row.get(1);let content=row.get(2);let createdat=row.get(3);};let out=mut.""