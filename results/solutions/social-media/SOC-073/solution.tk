m=main;i=http:std.http;i=json:std.json;i=io:std.io;t=user{id:$str;name:$str;followers:$i64};f=fetchfollowers(username:$str;page:$i64):$str{let url="https://api.example.com/followers";let params=json.enc(json.obj("username";username;"page";page)))+"";let response=http.get(url+params);if(response.status<200){if(response.status<300){<response.body}el{<""}}el{<""}};f=parsefollowersjson(jsonstr:$str):@$str{let followers=json.strarray(jsonstr;"followers"));<followers};f=main():$void{let username="alice";let page=1;let raw=fetchfollowers(username;page);let followers=parsefollowersjson(raw);let count=followers.len;let msg="alice has "+count+" followers";io.println(msg)};