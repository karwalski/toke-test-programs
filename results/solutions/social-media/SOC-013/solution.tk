m=otpverify;f=verifyotp(secret:$str;otp:$i64):$bool{let digits=mut.1;let tmp=mut.otp;if(tmp<10){}el{if(tmp<100){digits=2}el{if(tmp<1000){digits=3}el{if(tmp<10000){digits=4}el{if(tmp<100000){digits=5}el{if(tmp<1000000){digits=6}el{digits=10}}}}}};let step=mut.1;let tmp2=mut.secret;if(tmp2.len<10){step=10}el{if(tmp2.len<20){step=20}el{step=100}}};let modval=mut.otp-otp/step*step;let hash=mut.hmacsha1(secret;modval);let offset=mut.hash.len-1;let truncated=mut.hash.get(offset)-hash.get(offset)/100*100;if(truncated=modval){<true};<false};f=hmacsha1(key:$str;data:$