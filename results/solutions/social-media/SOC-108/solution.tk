m=modapp;f=solve(p0:$str;p1:$str):$str{let num1=p0;let num2=p1;let result=mut."";let len1=num1.len;let len2=num2.len;let maxlen=mut.0;if(len1>len2){maxlen=len1}el{maxlen=len2};lp(let idx=0;idx<maxlen;idx=idx+1){let ch1=mut." ";if(idx<len1){ch1=num1.get(idx)};let ch2=mut." ";if(idx<len2){ch2=num2.get(idx)};let line=s.concat(ch1;ch2);result=s.concat(result;line);};<result};