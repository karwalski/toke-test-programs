m=query;f=query(p:$str;q:$str):$str{let result=mut."";result=s.concat(result;p);result=s.concat(result;" ");result=s.concat(result;q);<result};f=notify(n:$str):$void{let msg=mut."Query executed: ";msg=s.concat(msg;n);<msg};f=main():$void{let querystr="SELECT * FROM users";let filter="WHERE age > 18";let fullquery=query(querystr;filter);let notification=notify(fullquery);<notification};