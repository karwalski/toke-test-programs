m=markallread;f=markallread(store:$str):$str{let items=mut.@();let idx=mut.0;lp(let i=0;i<store.len;i=i+1){let ch=store.get(i);if(ch=","){let item=store.slice(idx;i);items=items+@(item);idx=i+1;};};let lastitem=store.slice(idx;store.len);items=items+@(lastitem);let n=items.len;lp(let i=0;i<n;i=i+1){let item=items.get(i);let id=mut.0;let len=mut.0;lp(let j=0;j<item.len;j=j+1){let ch=item.get(j);if(ch=":"){len=j;};};id=item.slice(0;len);let readpart=mut."false";lp(let k=len+1;k<item.len;k=k+1){let ch=item.get(k);readpart=readpart+ch;};let newitem=id+":true";items.get(i)=newitem;};<store};