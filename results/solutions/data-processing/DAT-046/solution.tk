m=md5hash;f=hashline(line:$str):$str{let chars=line.chars();let total=mut.0;lp(let i=0;i<chars.len;i=i+1){let c=chars.get(i);total=total+c as i64;};let modval=total-total/128*128;<modval as$str;};f=processinput(input:$str):$str{let lines=input.split("\n");let results=mut.@();lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);let hashed=hashline(line);results=results+@(hashed);};let finaloutput=mut."";lp(let i=0;i<results.len;i=i+1){let result=results.get(i);finaloutput=finaloutput+result+"\n";};<finaloutput;};f=main():$void{let input="hello\nworld\n";let output=processinput(input);<output;};