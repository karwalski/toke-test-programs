m=csvmerge;f=solve(left:$str;right:$str):$str{let llines=left.split("\n");let rlines=right.split("\n");let lheaders=llines.get(0);let rheaders=rlines.get(0);let lkeys=lheaders.split(",");let rkeys=rheaders.split(",");let mergedkeys=mut.@();lp(let li=0;li<lkeys.len;li=li+1){let lkey=lkeys.get(li);let found=mut.false;lp(let ri=0;ri<rkeys.len;ri=ri+1){let rkey=rkeys.get(ri);if(rkey=lkey){found=true};};if(!(found)){mergedkeys=mergedkeys+@($str;lkey));};};lp(let ri=0;ri<rkeys.len;ri=ri+1){let rkey=rkeys.get(ri);let found=mut.false