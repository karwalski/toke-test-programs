m=quicksort;f=partition(arr:@$i64;low:$i64;high:$i64):$i64{let pivot=arr.get(high);let i=mut.low;lp(let j=low;j<high;j=j+1){if(arr.get(j)<pivot){let tmp=arr.get(i);arr.get(i)=arr.get(j);arr.get(j)=tmp;i=i+1;};};let tmp=arr.get(i);arr.get(i)=arr.get(high);arr.get(high)=tmp;<i};f=quicksort(arr:@$i64;low:$i64;high:$i64):@$i64{if(low<high){let pi=partition(arr;low;high);let left=quicksort(arr;low;pi-1);let right=quicksort(arr;pi+1;high);<arr}el{<arr}};f=sort(arr:@$i64):@$i64{<quicksort(arr;0;arr.len-1))};