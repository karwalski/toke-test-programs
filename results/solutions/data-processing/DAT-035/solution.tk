let mapb=parsecsvdata(csvbdata);
let allkeys=set[$str]();
for(key;val in mapa){allkeys.add(key)};
for(key;val in mapb){allkeys.add(key)};
for(key in allkeys){
let inold=mapa.has(key);
let innew=mapb.has(key);
if(inold and innew){
let oldval=mapa.get(key);
let newval=mapb.get(key);
if(oldval!=newval){
io.println("~ "+key+": "+oldval+" -> "+newval)
}
}else if(inold and not innew){
