m=csvdiff;
i=io:std.io;
i=s:std.str;
f=csvparse(line:$str;delimiter:$str):$str{let parts=line.split(delimiter);if(parts.len=0){<""};<parts.get(0)};
f=csvcolcount(line:$str;delimiter:$str):$i64{let parts=line.split(delimiter);<parts.len};
f=parsecsvdata(lines:$str):$map[$str;$str]{let result=map[$str;$str]();let linelist=lines.split("\n");if(linelist.len<2){<result};let header=linelist.get(0);for(let j=1;j<linelist.len;j=j+1){let line=linelist.get(j);if(line.len>0){let parts=line.split(",");if(parts.len>=2){let key=parts.get(0);let value=parts.get(1);result.put(key;value)}}};<result};
f=main():$i64{
let csvadata="";
let line=io.readln();
while(line.len>0){
csvadata=s.concat(s.concat(csvadata;line);"\n");
line=io.readln()
};
let csvbdata="";
