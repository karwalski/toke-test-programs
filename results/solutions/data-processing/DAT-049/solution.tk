m=jsonvalidator;f=validatefield(val:$str;rules:@$str):bool{let result=mut.true;lp(let i=0;i<rules.len;i=i+1){let rule=rules.get(i);if(rule="required"){if(val.len=0){result=false}}el{if(rule="min"){let minval=rule.split("=").get(1);if(!(val.len>minval)){result=false}}el{if(rule="max"){let maxval=rule.split("=").get(1);if(!(val.len<maxval)){result=false}}el{if(rule="pattern"){let pattern=rule.split("=").get(1);if(!(val.matches(pattern))){result=false}}}}};<result};f=validatejson(obj:$str;schema:@$str):bool{let result=mut.true;lp(let i=0;i<schema.len;i=i+1){let rule=schema.get(i);let field=rule.split("=").get(0);let expectedtype=rule.split("=").get(1);let valstr=obj.get(field);let valtype=valstr.split("=").get(0);if(!(valtype=expectedtype)){result=false}};<result};