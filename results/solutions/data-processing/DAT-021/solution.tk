m=mergesort;f=merge(x:@$i64;y:@$i64):@$i64{let result=mut.@();let i=mut.0;let j=mut.0;lp(let k=0;k<x.len+y.len;k=k+1){if(i<x.len){if(j<y.len){if(x.get(i)<y.get(j)){result=result+@(x.get(i));i=i+1;}el{result=result+@(y.get(j));j=j+1;};}el{result=result+@(x.get(i));i=i+1;);};}el{if(j<y.len){result=result+@(y.get(j));j=j+1;);};};};<result};f=mergesort(arr:@$i64):@$i64{if(arr.len<2){<arr};let mid=arr.len/2;let left=mut.@();let right=mut.@();lp(let i=0;i<mid;i=i+1){left=left+@(arr.get(i)));};lp(let j=mid;j<arr.len;j=j+1){right=right+@(arr.get(j)));};let sortedleft=mergesort