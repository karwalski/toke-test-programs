m=transpose;f=solve(p0:$str):$str{let lines=p0.split("\n");let n=lines.len;let ncols=mut.0;let firstline=lines.get(0);let firstparts=firstline.split(",");ncols=firstparts.len;let result=mut."";lp(let r=0;r<ncols;r=r+1){let col=mut."";lp(let l=0;l<n;l=l+1){let cell=lines.get(l).split(",").get(r);if(col.len>0){col=s.concat(col;"\n")};col=col+cell};if(result.len>0){result=s.concat(result;"\n")};result=s.concat(result;col)};<result};