m=csvselect;f=main(args:@$str):i64{if(args.len<3){<1};let n=args.get(1);let m=args.get(2);let out=mut."";lp(let i=0;i<n;i=i+1){let line=mut.args.get(i);let parts=mut.@();let part=mut."";lp(let j=0;j<line.len;j=j+1){let ch=line.get(j);if(ch=","){parts=parts+@(part);part="";}el{part=part+ch;};};parts=parts+@(part);let result=mut."";lp(let k=0;k<parts.len;k=k+1){let col=parts.get(k);if(k>0){result=result+m};result=result+col;};out=result;<0};