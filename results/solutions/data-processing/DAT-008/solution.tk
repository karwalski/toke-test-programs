m=app;f=solve(p0:$str):$str{let result=mut."";let i=mut.0;let len=p0.len;lp(let idx=0;idx<len;idx=idx+1){let ch=p0.get(idx);if(ch="["){let j=mut.idx+1;lp(let k=j;k<len;k=k+1){let c=p0.get(k);if(c="]"){j=k+1;idx=j-1;k=j-1;br;};};};}el{if(ch="]"){let j=mut.idx+1;lp(let k=j;k<len;k=k+1){let c=p0.get(k);if(c="["){j=k+1;idx=j-1;k=j-1;br;};};};}el{if(ch="="){let j=mut.idx+1;lp(let k=j;k<len;k=k+1){let c=p0.get(k);if(c="["){j=k+1;idx=j-1;k=j-1;br;};};};}el{