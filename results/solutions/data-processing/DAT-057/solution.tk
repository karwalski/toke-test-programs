m=descstats;f=parsefloat(s:$str):$f64{<s as$f64}};f=count(vals:@$f64):$i64{<vals.len as$i64}};f=sum(vals:@$f64):$f64{let acc=mut.0.0;lp(let i=0;i<vals.len;i=i+1){acc=acc+vals.get(i);};<acc}};f=mean(vals:@$f64):$f64{if(vals.len=0 as u64)){<0.0};<sum(vals)/count(vals)}};f=median(vals:@$f64):$f64{let sorted=mut.vals;lp(let i=0;i<sorted.len;i=i+1){lp(let j=i+1;j<sorted.len;j=j+1){if(sorted.get(i)>sorted.get(j)){let tmp=sorted.get(i);sorted.get(i)=sorted.get(j);sorted.get(j)=tmp;};};};let len=sorted.len;let half=len/2;if(len=0){<0.0};if(len=1){<sorted.get(0)}};f=