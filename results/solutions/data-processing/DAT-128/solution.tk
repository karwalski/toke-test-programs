m=store;f=hash(s:$str):i64{let hash=mut.0;let prime=31;lp(let i=0;i<s.len;i=i+1){let charcode=s.get(i)as i64;hash=hash*prime+charcode;hash=hash-hash/100000007*100000007;};<hash};f=storeentry(key:$str;value:$str):$str{let keyhash=hash(key);let entry=keyhash as$str+s.concat(":";value);let stored=mut."";stored=stored+entry;<stored};f=rangequery(stored:$str;lokey:$str;hikey:$str):$str{let lowhash=hash(lokey);let hihash=hash(hikey);let result=mut."";let i=mut.0;lp(let idx=0;idx<stored.len;idx=idx+1){let char=stored.get(idx);if(char=10 as$str){i=i+1;};if(!(i<lowhash)){if(!(i>hihash)){if(!(char=10 as$str)){result=result+char;};