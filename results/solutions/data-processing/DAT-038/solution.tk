m=logparse;i=io:std.io;i=s:std.str;f=extractlevel(line:$str):$str{let idx=mut.0;let found=mut.false;let j=mut.0;lp(j<line.len()){let ch=s.slice(line;j;j+1);if(ch=" "){if(found=false){idx=j;found=true}};j=j+1};if(found=false){<line};<s.slice(line;0;idx)};f=keepit(lev:$str;filter:$str):$bool{if(lev=filter){<true};if(filter="WARN"){if(lev="WARN"){<true};if(lev="ERROR"){<true}};if(filter="ERROR"){if(lev="ERROR"){<true};if(lev="FATAL"){<true}};<false};f=main():$i64{let filter=s.trim(io.readln());let all=mut.@();let cont=mut.true;lp(cont=true){let raw=io.readln();if(raw=""){cont=false}el{all=all+@(s.trim(raw))}};let matched=mut.@();let k=mut.0;lp(k<all.len()){let ln=all.get(k);let lev=extractlevel(ln);if(keepit(lev;filter)=true){matched=matched+@(ln)};k=k+1};let out=mut."";let n2=mut.0;lp(n2<matched.len()){if(n2>0){out=out+"\n"};out=out+matched.get(n2);n2=n2+1};out=out+"\n---";let labels=mut.@();if(filter="WARN"){labels=@("WARN";"ERROR")}el{if(filter="ERROR"){labels=@("ERROR";"FATAL")}el{labels=@(filter)}};let p=mut.0;lp(p<labels.len()){let lbl=labels.get(p);let c=mut.0;let q=mut.0;lp(q<matched.len()){let lv=extractlevel(matched.get(q));if(lv=lbl){c=c+1};q=q+1};out=out+"\n"+lbl+": "+s.fromint(c);p=p+1};io.println(out);<0}