m=ma;f=simplemovingavg(vals:@$f64;n:$i64):$f64{let sum=mut.0.0;lp(let i=0;i<n;i=i+1){sum=sum+vals.get(i as u64));};<sum/(n as$f64))};f=exponentialmovingavg(vals:@$f64;n:$i64):$f64{let alpha=1.0/(n as$f64));let result=mut.0.0;lp(let i=0;i<vals.len;i=i+1){let currentval=vals.get(i);let oldresult=result;if(i=0){result=currentval}el{result=oldresult+(currentval-oldresult)*alpha);};};<result};f=weightedmovingavg(vals:@$f64;weights:@$f64):$f64{let n=vals.len;if(n=0){<0.0};let sum=mut.0.0;let weightedsum=mut.0.0;lp(let i=0;i<n;i=i+1){let val=vals.get(i);let weight=weights.get(i);sum=sum+val