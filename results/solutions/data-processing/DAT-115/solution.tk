m=dedupreport;f=countunique(arr:@$str):i64{let seen=mut.@();let n=arr.len;lp(let i=0;i<n;i=i+1){let current=arr.get(i);let isnew=mut.true;let m=seen.len;lp(let j=0;j<m;j=j+1){if(seen.get(j)=current)){isnew=false;};};if(isnew){seen=seen+@(current);};};<seen.len as i64};f=buildreport(original:@$str):$str{let unique=countunique(original);let total=original.len;let ratio=mut.0.0;if(total>0){ratio=unique as f64/total as f64;};let report=mut."Deduplication Report\n";report=s.concat(report;"-----------------------------\n");report=s.concat(report;"Original count: ");report=s.concat(report;total) as$str;report=s.concat(report;"\n");report=s.concat(report;"Unique count: ");report=s.concat(report;unique) as$str;report=s.concat(report;"\n");report=s.concat(report;"Deduplication ratio: ");report=s.concat(report;ratio) as$str;report=s.concat(report;"%\n");report=s.concat(report;")