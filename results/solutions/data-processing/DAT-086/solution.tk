m=sparse;f=issparse(mat:$i64;n:$i64):$bool{let count=mut.0;lp(let i=0;i<n;i=i+1){if(mat.get(i)>0)){count=count+1;};};if(count<(n as i64)/2)){<true}el{<false}};f=compress(mat:$i64;n:$i64):$i64{let sparse=issparse(mat;n);if(sparse){<mat}el{let nn=n;let vals=mut.@();let rows=mut.@();let cols=mut.@();lp(let i=0;i<nn;i=i+1){let val=mat.get(i);if(val>0){vals=vals+@(val);rows=rows+@(i);cols=cols+@(0);};};let result=mut.@();lp(let i=0;i<vals.len;i=i+1){result=result+@(vals.get(i)));};lp(let i=0;i<rows.len;i=i+1){result=result+@(rows.get(i)));};lp(let i=0;i<cols.len;i=i+1){result=result+@(cols.get(i)));};