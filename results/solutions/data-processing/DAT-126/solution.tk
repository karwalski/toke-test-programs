m=hyperloglog;f=hash(s:$str):$i64{let h=mut.0;lp(let i=0;i<s.len;i=i+1){let c=s.get(i);let sum=h+c;let mod=sum-sum/2*2;h=mod;};<h};f=countbits(n:$i64):$i64{let count=mut.0;let num=mut.n;lp(let i=0;i<64;i=i+1){let bit=num-num/2*2;if(bit=1){count=count+1};num=num/2;if(num=0){br};};<count};f=hyperloglog(n:$i64;m:$i64):$i64{let hashes=mut.@();lp(let i=0;i<n;i=i+1){let s=s.concat("val";i) as$str;let h=hash(s);hashes=hashes+@(h);};let maxbits=mut.0;lp(let i=0;i<hashes.len;i=i+1){let h=hashes.get(i);let bits=countbits(h);if(bits>maxbits){maxbits=bits};};<maxbits