m=extstats;f=computehash(parts:@$str):i64{let hash=mut.17;lp(let i=0;i<parts.len;i=i+1){let part=parts.get(i);let partcode=part as i64;hash=hash*31+partcode;};<hash};f=classifyext(ext:$str):i64{if(ext.len=0){<0};let parts=ext.split(".");let firstpart=parts.get(0);if(firstpart="txt"){<1};if(firstpart="jpg"){<2};if(firstpart="png"){<3};if(firstpart="pdf"){<4};if(firstpart="zip"){<5};if(firstpart="mp3"){<6};if(firstpart="mp4"){<7};if(firstpart="json"){<8};if(firstpart="csv"){<9};<0};f=processline(line:$str):i64{let parts=line.split(" ");let filename=parts.get(1);let dotidx=filename.indexof(".");let ext=filename.substr(dotidx+1;filename.len-dotidx-1));let extcode=classifyext(ext);<ext