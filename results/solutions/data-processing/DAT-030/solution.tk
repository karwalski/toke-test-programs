m=groupby;f=solve(p0:$str;p1:$str;p2:$str):$str{let lines=p0.split("\n");let headers=lines.get(0);let groupcol=p1;let valcol=p2;let result=mut."";let seen=mut.@();lp(let i=1;i<lines.len;i=i+1){let row=lines.get(i);let cols=row.split(",");let groupval=cols.get(groupcol as u64));let val=cols.get(valcol as u64));let found=mut.false;lp(let j=0;j<seen.len;j=j+1){if(seen.get(j)=groupval)){found=true;};};if(!(found)){seen=seen+@(groupval);};};let aggrs=mut.@();lp(let k=0;k<seen.len;k=k+1){let grp=seen.get(k);let total=mut.0;let count=mut.0