m=histogram;i=io:std.io;i=s:std.str;i=math:std.math;f=pad(val:$str;width:$i64):$str{let r=mut."";r=val;lp(s.len(r)<width){r=s.concat(" ";r)};<r};f=main():$i64{let bincount=s.toint(s.trim(io.readln()));let line=s.trim(io.readln());let parts=s.split(line;" ");let n=parts.len();let minval=mut.0.0;let maxval=mut.0.0;lp(let i=0;i<n;i=i+1){let v=s.tofloat(parts.get(i));if(i=0){minval=v;maxval=v}el{if(v<minval){minval=v};if(v>maxval){maxval=v}}};let range=maxval-minval;let binwidth=range/s.tofloat(s.fromint(bincount));let counts=mut.@();lp(let i=0;i<bincount;i=i+1){counts=counts+@(0)};lp(let i=0;i<n;i=i+1){let v=s.tofloat(parts.get(i));let fbi=mut.0;lp(let j=0;j<bincount;j=j+1){let lo=minval+binwidth*s.tofloat(s.fromint(j));let hi=minval+binwidth*s.tofloat(s.fromint(j+1));if(v>=lo){if(j=bincount-1){fbi=j}el{if(v<hi){fbi=j}}}};let cur=counts.get(fbi);let newcounts=mut.@();lp(let k=0;k<bincount;k=k+1){if(k=fbi){newcounts=newcounts+@(cur+1)}el{newcounts=newcounts+@(counts.get(k))}};counts=newcounts};let result=mut."";lp(let i=0;i<bincount;i=i+1){let lo=minval+binwidth*s.tofloat(s.fromint(i));let hi=minval+binwidth*s.tofloat(s.fromint(i+1));let loStr=pad(s.format(lo;"%.1f");4);let hiStr=pad(s.format(hi;"%.1f");4);let c=counts.get(i);let bars=mut."";lp(let j=0;j<c;j=j+1){bars=bars+"#"};let row=s.concat(loStr;"-");let row2=s.concat(row;hiStr);let row3=s.concat(row2;": ");let row4=s.concat(row3;bars);let row5=s.concat(row4;" (");let row6=s.concat(row5;s.fromint(c));let row7=s.concat(row6;")");if(i>0){result=s.concat(result;"\n")};result=s.concat(result;row7)};io.println(result);<0}