m=splitcol;f=splitcol(df:$dataframe;col:$str;delim:$str):$dataframe{let n=mut.df.shape;let cidx=df.colnames.indexof(col);let oldvals=df.getcol(cidx);let newcols=mut.@();lp(let i=0;i<oldvals.len;i=i+1){let oldval=oldvals.get(i);let parts=oldval.split(delim);let newrows=mut.@();lp(let j=0;j<parts.len;j=j+1){let part=parts.get(j);let newrow=mut.@();lp(let k=0;k<df.colnames.len;k=k+1){if(k=cidx){newrow=newrow+@(part)}el{newrow=newrow+@(df.get(i;k)))}};newrows=newrows+@(newrow);}