m=heap;f=buildheap(arr:@$i64):@$i64{let n=arr.len;let heap=mut.@();lp(let i=0;i<n;i=i+1){heap=heap+@(arr.get(i)));};lp(let i=n/2-1;!(i<0);i=i-1){let val=heap.get(i);let j=mut.i;lp(let k=0;k<1;k=k+1){let left=2*j+1;let right=2*j+2;let shouldswap=mut.false;if(left<n){let v=heap.get(left);if(v>val){shouldswap=true;};};if(right<n){let v=heap.get(right);if(v>val){shouldswap=true;};};if(shouldswap){let tmp=heap.get(j);heap.get(j)=heap.get(left);heap.get(left)=tmp;};};};<heap};f=heapsort(arr:@$i64):@$i64{let n=arr.len;let sorted=mut.@();lp(let i=0;i<n;i=i+1){sorted=sorted+@(arr.get(i));};let h=buildheap(sorted);lp