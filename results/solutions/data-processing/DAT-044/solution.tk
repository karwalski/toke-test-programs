m=huffman;f=buildtree(freqs:@$i64):$str{let n=freqs.len;let nodes=mut.@();lp(let i=0;i<n;i=i+1){let node=$str{symbol:freqs.get(i);freq:freqs.get(i)};nodes=nodes+@(node)};lp(let m=n;m>1;m=m-1){let merged=mut.@();lp(let i=0;i<m/2;i=i+1){let a=nodes.get(i*2);let b=nodes.get(i*2+1);let mergednode=$str{symbol:a.symbol+b.symbol;freq:a.freq+b.freq};merged=merged+@(mergednode)};nodes=merged;};<nodes.get(0)};f=decodebitstring(tree:$str;bitstring:$str):$str{let n=bitstring.len;let current=mut.tree;lp(let i=0;i<n;i=i+1){let bit=bitstring.get(i);if(bit="0"){current=current.symbol+"0"}el{current=current.symbol+"1"};};<current.symbol};f=huffmandecode(freqs:@$i64;bitstring:$str