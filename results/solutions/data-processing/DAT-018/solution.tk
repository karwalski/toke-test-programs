m=csvgroup;f=csvparse(row:$str):$str{let fields=row.split(",");let name=fields.get(0);<name};f=levdist(a:$str;b:$str):$i64{let alen=a.len;let blen=b.len;let rows=alen+1;let cols=blen+1;let dp=mut.@();lp(let i=0;i<rows;i=i+1){let row=mut.@();lp(let j=0;j<cols;j=j+1){let cell=mut.0;if(i=0){if(j=0){cell=0}el{cell=j-1}}el{if(j=0){cell=i-1}el{let a=dp.get(i-1);let b=dp.get(i);let c=dp.get(i);let ac=a.get(j-1);let bc=b.get(j);let cc=c.get(j);if(ac<bc){if(ac<cc){cell=ac}el{cell=cc}}el{if(bc<cc){cell=bc}el{cell=cc}}}};row.push(cell);};dp.push(row);};<dp};f=groupby(arr:@