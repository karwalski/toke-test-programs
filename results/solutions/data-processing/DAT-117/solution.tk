m=solve;f=solve(p0:$str):@$str{let lines=p0.split("\n");let result=mut.@();lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);let trimmed=line.trim();let iscomment=trimmed.len>0;let c=trimmed.get(0);if(iscomment){if(c=47){<result};};let isfield=trimmed.len>0;let firstchar=trimmed.get(0);if(isfield){if(!(firstchar=64))){let parts=trimmed.split(" ");let name=parts.get(0);let typ=parts.get(1);let entry=name+"="+typ;result=result+@(entry);};};<result};