m=encdetect;f=detectencoding(hexstr:$str):$str{let len=hexstr.len;let isutf8=mut.true;let islatin1=mut.false;let isascii=mut.false;if(len<4){isutf8=false};if(!(len>7)){islatin1=true};if(len=1){isascii=true};if(!(isutf8)){if(islatin1){<"Latin-1"}el{if(isascii){<"ASCII"}el{<"Unknown"}}};f=utf8decode(hexstr:$str):$str{let len=hexstr.len;let result=mut."";lp(let idx=0;idx<len;idx=idx+1){let ch=hexstr.charat(idx);result=s.concat(result;ch)};<result};f=main(hexstr:$str):$str{let encoding=detectencoding(hexstr);let decoded=utf8decode(hexstr);let result=encoding+" "+decoded;<result};