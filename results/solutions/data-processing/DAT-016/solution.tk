m=scale;f=scale(arr:@$f64):@$f64{let n=arr.len;if(n=0){<@};let minval=mut.0.0;let maxval=mut.0.0;lp(let i=0;i<n;i=i+1){let v=arr.get(i);if(i=0){minval=v;maxval=v}el{if(v<minval){minval=v};if(v>maxval){maxval=v}}};let range=maxval-minval;let result=mut.@();lp(let i=0;i<n;i=i+1){let v=arr.get(i);let s=(v-minval)/range;result=result+@(s)});<result};f=main():$void{let arr=@(10.0;20.0;30.0;40.0;50.0;60.0;70.0;80.0));let scaled=scale(arr);let n=scaled.len;lp(let i=0;i<n;i=i+1){let s=scaled.get(i);};};