m=sort;
i=io:std.io;
i=s:std.str;
f=arrtostr(arr:@$i64):$str{let res=mut."[";let alen=arr.len as $i64;lp(let i=0;i<alen;i=i+1){res=res+s.fromint(arr.get(i));if(i<alen-1){res=res+",";};};res=res+"]";<res};
f=reversearr(arr:@$i64):@$i64{let res=mut.@();let alen=arr.len as $i64;lp(let i=alen-1;i>=0;i=i-1){res=res+@(arr.get(i));};<res};
f=mergeruns(left:@$i64;right:@$i64):@$i64{let result=mut.@();let i=mut.0;let j=mut.0;let llen=left.len as $i64;let rlen=right.len as $i64;lp(i<llen&&j<rlen){if(left.get(i)<=right.get(j)){result=result+@(left.get(i));i=i+1;}el{result=result+@(right.get(j));j=j+1;};};lp(i<llen){result=result+@(left.get(i));i=i+1;};lp(j<rlen){result=result+@(right.get(j));j=j+1;};<result};
f=main():$i64{let line=io.readln();let parts=s.split(line;" ");let arr=mut.@();let plen=parts.len as $i64;lp(let i=0;i<plen;i=i+1){let num=s.toint(parts.get(i));arr=arr+@(num);};let n=arr.len as $i64;let runs=mut.@();let start=mut.0;lp(let i=1;i<=n;i=i+1){let isend=mut.false;if(i=n){isend=true;}el{let prev=arr.get(i-1);let cur=arr.get(i);if(prev>cur){isend=true;};};if(isend){let run=mut.@();lp(let j=start;j<i;j=j+1){run=run+@(arr.get(j));};runs=runs+@(run);start=i;};};let runcount=runs.len as $i64;let processed=mut.@();let runnum=mut.1;lp(let r=0;r<runcount;r=r+1){let run=runs.get(r);let rlen=run.len as $i64;let isdesc=mut.false;if(rlen>1){let allreversed=mut.true;lp(let k=1;k<rlen;k=k+1){if(run.get(k-1)<=run.get(k)){allreversed=false;br;};};if(allreversed){isdesc=true;};};if(isdesc){let rev=reversearr(run);io.println("Run "+s.fromint(runnum)+": "+arrtostr(run)+" reversed to "+arrtostr(rev));processed=processed+@(rev);}el{io.println("Run "+s.fromint(runnum)+": "+arrtostr(run));processed=processed+@(run);};runnum=runnum+1;};let pcount=processed.len as $i64;let merged=mut.@();let mlabel=mut.1;let idx=mut.0;lp(idx<pcount){if(idx+1<pcount){let left=processed.get(idx);let right=processed.get(idx+1);let mg=mergeruns(left;right);io.println("Merge Run"+s.fromint(mlabel)+"+Run"+s.fromint(mlabel+1)+": "+arrtostr(mg));merged=merged+@(mg);idx=idx+2;mlabel=mlabel+2;}el{merged=merged+@(processed.get(idx));idx=idx+1;mlabel=mlabel+1;};};lp((merged.len as $i64)>1){let next=mut.@();let mi=mut.0;let mlen=merged.len as $i64;lp(mi<mlen){if(mi+1<mlen){let left=merged.get(mi);let right=merged.get(mi+1);let mg=mergeruns(left;right);io.println("Merge: "+arrtostr(mg));next=next+@(mg);mi=mi+2;}el{next=next+@(merged.get(mi));mi=mi+1;};};merged=next;};let final=mut.@();if((merged.len as $i64)>0){final=merged.get(0);};let flen=final.len as $i64;let out=mut."Sorted: ";lp(let i=0;i<flen;i=i+1){out=out+s.fromint(final.get(i));if(i<flen-1){out=out+" ";};};io.println(out);<0};