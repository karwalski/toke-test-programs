m=extmergesort;f=sortarray(arr:@$i64):@$i64{let n=arr.len;let sorted=mut.@();lp(let i=0;i<n;i=i+1){sorted=sorted+@(arr.get(i));};lp(let pass=0;pass<n;pass=pass+1){lp(let j=0;j<n-pass-1;j=j+1){if(sorted.get(j)>sorted.get(j+1))){let tmp=sorted.get(j);sorted.get(j)=sorted.get(j+1);sorted.get(j+1)=tmp;};};};<sorted};f=merge(a:@$i64;b:@$i64):@$i64{let result=mut.@();let i=mut.0;let j=mut.0;lp(let k=0;k<a.len+b.len;k=k+1){if(i<a.len){if(j<b.len){if(a.get(i)<b.get(j)){result=result+@(a.get(i));i=i+1;}el{result=result+@(b.get(j));j=j+1;};}el{result=result+@(a.get(i));i=i+1;};};};<result};