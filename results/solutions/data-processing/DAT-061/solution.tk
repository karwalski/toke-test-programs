m=csvtop;f=csvtop(n:$i64;fname:$str;cname:$str):$str{let lines=br.fname;let result=mut."";let found=mut.false;let i=mut.0;lp(let idx=0;idx<lines.len;idx=idx+1){let line=lines.get(idx);if(!(found)){if(i=0){let header=line;let cnameidx=mut.0;lp(let jdx=0;jdx<header.len;jdx=jdx+1){let ch=header.get(jdx);if(ch=cname){cnameidx=jdx;};};let startidx=mut.0;lp(let kdx=0;kdx<header.len;kdx=kdx+1){let hc=header.get(kdx);if(hc="$"){startidx=kdx+1;};};let ncols=mut.0;lp(let mdx=0;mdx<header.len;mdx=mdx+1){let hc=header.get(mdx);if(!(hc="$")){ncols=ncols+1;};};let rowstart=mut.0;lp(let ndx=0;ndx<lines.len;ndx=ndx+1