m=needleman;f=scoreof(a:$str;b:$str;match:$i64;mismatch:$i64;gap:$i64):$i64{let alen=a.len;let blen=b.len;let dp=mut.@(0;alen+1));lp(let i=0;i<alen+1;i=i+1){dp.get(i)=mut.@(0;blen+1));};lp(let i=0;i<alen+1;i=i+1){lp(let j=0;j<blen+1;j=j+1){if(i=0){if(j=0){dp.get(i).get(j)=0;}el{dp.get(i).get(j)=dp.get(i).get(j-1)-gap;};}el{if(j=0){dp.get(i).get(j)=dp.get(i-1).get(j)-gap;}el{let matchscore=mut.0;if(a.get(i-1)=b.get(j-1))){matchscore=match;}el{matchscore=mismatch;};let diag=dp.get(i-1).get(j-1));let left=dp.get(i).get(j-1));let up=dp.get(i-1).get(j);let best=mut.0;if(matchscore>0){best=diag+matchscore;}el{best=diag-matchscore;};if(best>diag){if(best>left){if(best>up){best=diag;}el{best=up;};}el{best=left;};}el{best=diag;};dp.get(i).get(j)=best;};};let result=mut.dp.get(alen).get(blen);lp(let i=alen;i>0;i=i-1){lp(let j=blen;j>0;j=j-1){let v=dp.get(i).get(j);let diag=dp.get(i-1).get(j-1));let left=dp.get(i).get(j-1));let up=dp.get(i-1).get(j);if(v=diag){if(a.get(i-1)=b.get(j-1))){result=result+match;}el{result=result+mismatch;};}el{if(v=left){result=result-gap;}el{if(v=up){result=result-gap;}el{result=result;};};};};};<result};f=align