m=topsort;f=sortbydeg(arr:@$str;deg:@$i64):@$str{let n=arr.len;let res=mut.@();lp(let i=0;i<n;i=i+1){let idx=mut.0;lp(let j=0;j<n;j=j+1){if(arr.get(j)=arr.get(i))){idx=j};};res=res+@(arr.get(idx))};<res};f=sortdeps(arr:@$str;deps:@@$str):@$str{let n=arr.len;let deg=mut.@(0);lp(let i=0;i<n;i=i+1){deg=deg+@(0);};lp(let i=0;i<n;i=i+1){let d=deps.get(i);let m=d.len;lp(let j=0;j<m;j=j+1){let dd=d.get(j);let idx=mut.0;lp(let k=0;k<n;k=k+1){if(arr.get(k)=dd)){idx=k};};deg.get(idx)=deg.get(idx)+1;};};let res=sortbydeg(arr;deg);<res};f=hascycle(arr:@$str;deps:@@$str):bool