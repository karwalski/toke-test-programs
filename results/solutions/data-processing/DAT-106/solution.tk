m=datatrans;f=transformstep(name:$str;inputcol:$str;outputcol:$str;transformationtype:$str):$str{let step=s.concat(s.concat(s.concat(s.concat(s.concat(s.concat(name;": ");transformationtype);"(");inputcol);") -> ");outputcol);<step};f=buildprovenancegraph(steps:$str):$str{let graph="digraph DataTransformation {";let i=0;let n=steps.len;lp(let idx=0;idx<n;idx=idx+1){let step=steps.get(idx);let label=s.concat(s.concat(s.concat(step;": [");step);"]");let node=label;<graph+node}