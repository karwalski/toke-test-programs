m=diff;f=diff(a:$str;b:$str):$str{let result=mut."";let aobj=std.json.parse(a);let bobj=std.json.parse(b);let akeys=aobj.keys();let bkeys=bobj.keys();let added=bkeys-akeys;let removed=akeys-bkeys;let changed=mut.@();lp(let i=0;i<akeys.len();i=i+1){let key=akeys.get(i);if(bobj.has(key)){let aval=aobj.get(key);let bval=bobj.get(key);if(!(aval=bval)){changed=changed+@(key)}}}};lp(let i=0;i<added.len();i=i+1){let key=added.get(i);let val=bobj.get(key);result=s.concat(result;"+ ")+key+": "+val+"\n";};lp(let i=0;i<removed.len();i=i+1){let key=removed.get(i);let val=aobj.get(key);result=s.concat(result;"- ")+key+": "+val+"\n";};lp(let i=0;i<changed.len();i=i+1){let key=changed.get(i);let aval=aobj.get(key);let bval=bobj.get(key);result=s.concat(result;"~ ")+key+": "+aval+" -> "+bval+"\n";};<result};f=main():$void{let a=std.io.read();let b=std.io.read();let diffresult=diff(a;b);std.io.write(diffresult);};