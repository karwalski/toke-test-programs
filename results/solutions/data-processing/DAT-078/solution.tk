m=invindex;f=buildindex(docs:@$str):$str{let idx=mut."";lp(let i=0;i<docs.len;i=i+1){let d=docs.get(i);let words=d.split(" ");lp(let j=0;j<words.len;j=j+1){let w=words.get(j);let found=mut.false;let k=mut.0;lp(let zz=0;zz<idx.len;zz=zz+1){let ch=idx.get(zz);if(ch=w){found=true;k=zz};};if(!(found)){idx=idx+w;};};};<idx};f=main():$void{let docs=@("hello world";"hello there";"world hello"));let idx=buildindex(docs);let searchword="hello";let result=idx;let found=mut.false;let k=mut.0;lp(let zz=0;zz<result.len;zz=zz+1){let ch=result.get(zz);if(ch=searchword){found=true;k=zz};};if(found){<result};<result};