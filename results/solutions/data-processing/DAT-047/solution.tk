m=hashstdin;f=hashline(line:$str):$str{let len=line.len;let mut hash=mut.0;lp(let idx=0;idx<len;idx=idx+1){let ch=line.get(idx);hash=hash+ch as$i64;hash=hash-hash/256*256;};<hash as$str};f=processstdin():$void{let reader=io.stdinreader();let line=reader.readline();if(line.len=0){<};let h=hashline(line);<};f=main():$i64{processstdin();<0};