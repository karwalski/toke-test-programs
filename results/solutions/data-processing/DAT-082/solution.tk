m=funnel;i=io:std.io;i=s:std.str;f=countusers(events:$str;eventtype:$str):$i64{let count=mut.0;let lines=s.split(events;"\n");lp(let idx=0;idx<lines.len();idx=idx+1){let line=lines.get(idx);if(s.len(line)>0){let parts=s.split(line;",");if(parts.len()>=2){let evt=parts.get(1);if(evt=eventtype){count=count+1}}}};<count};f=pct(num:$i64;den:$i64):$str{if(den=0){<"0.00"};let r=num as$f64;let d=den as$f64;let val=r*100.0/d;<s.format(val;"%.2f")};f=main():$i64{let steps=mut.@();lp(true){let cur=io.readln();if(s.len(cur)=0){br};steps=steps+@(cur)};let body=mut."";lp(true){let bl=io.readln();if(s.len(bl)=0){br};body=s.concat(body;bl);body=s.concat(body;"\n")};let topcount=mut.0;lp(let idx=0;idx<steps.len();idx=idx+1){let st=steps.get(idx);let cnt=countusers(body;st);if(idx=0){topcount=cnt;let line=mut.st;line=s.concat(line;": ");line=s.concat(line;s.fromint(cnt));line=s.concat(line;" users (");line=s.concat(line;pct(cnt;topcount));line=s.concat(line;"% from top)");io.println(line)}el{let prevst=steps.get(idx-1);let prevcnt=countusers(body;prevst);let line=mut.st;line=s.concat(line;": ");line=s.concat(line;s.fromint(cnt));line=s.concat(line;" users (");line=s.concat(line;pct(cnt;prevcnt));line=s.concat(line;"% from prev, ");line=s.concat(line;pct(cnt;topcount));line=s.concat(line;"% from top)");io.println(line)}};<0}