m=semver;f=compareversion(a:$str;b:$str):$i64{let aparts=a.split(".");let bparts=b.split(".");let amajor=aparts.get(0)as:i64;let bmajor=bparts.get(0)as:i64;if(amajor>bmajor){<1};if(amajor<bmajor){<-1};let aminor=aparts.get(1)as:i64;let bminor=bparts.get(1)as:i64;if(amajor=bmajor){if(aminor>bminor){<1};if(aminor<bminor){<-1};};let apatch=aparts.get(2)as:i64;let bpatch=bparts.get(2)as:i64;if(amajor=bmajor){if(aminor=bminor){if(apatch>bpatch){<1};if(apatch<bpatch){<-1};};};<-1};f=sortversions(lst:@$str):@$str{let n=lst.len;let sorted=mut.lst;lp(let i=0;i<n;i=i+1){lp(let j=0;j+1<n;j=j+1