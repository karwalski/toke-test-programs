m=jsonmask;f=maskemail(email:$str):$str{let atidx=email.indexof("@");if(atidx<0){<email};let prefix=email.substring(0;atidx);<prefix+"@masked.com"};f=maskphone(phone:$str):$str{let len=phone.len;if(len=0){<phone};if(len=10){let masked="XXX-XXX-";<s.concat(masked;phone.substring(9;10))}el{<phone}};f=maskssn(ssn:$str):$str{let len=ssn.len;if(len=0){<ssn};if(len=9){let masked="XXX-XX-";<s.concat(masked;ssn.substring(8;9))}el{<ssn}};f=maskcreditcard(ccn:$str):$str{let len=ccn.len;if(len=0){<ccn};if(len=16){let masked="XXXX-XXXX-XXXX-";<s.concat(masked;ccn.substring(15;16))}el{<ccn}};f=maskfield(val:$str;fieldtype:$str):$str{if(fieldtype="email"){<maskemail(val)}el