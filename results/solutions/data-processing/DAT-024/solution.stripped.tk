m=radixsort;i=io:std.io;i=s:std.str;f=digitat(val:$i64;exp:$i64):$i64{<(val/exp)-((val/exp)/10)*10};f=maxof(arr:@$i64):$i64{let n=arr.len;let mx=mut.0;lp(let k=0;k<n;k=k+1){let v=arr.get(k);if(v>mx){mx=v}};<mx};f=main():$i64{let line=s.trim(io.readln());let parts=s.split(line;"_");let n=parts.len;let res=mut.@();lp(let k=0;k<n;k=k+1){res=res+@(s.toint(parts.get(k)))};let mx=maxof(res);let passnum=mut.0;let names=@("_";"_";"_";"_";"_");lp(let exp=1;exp<mx+1;exp=exp*10){passnum=passnum+1;let buckets=mut.@();lp(let b=0;b<10;b=b+1){buckets=buckets+@(@())};lp(let k=0;k<n;k=k+1){let val=res.get(k);let digit=digitat(val;exp);let newbuckets=mut.@();lp(let b=0;b<10;b=b+1){let bk=mut.buckets.get(b);if(b=digit){bk=bk+@(val)};newbuckets=newbuckets+@(bk)};buckets=newbuckets};let outline=mut.s.concat("_";s.fromint(passnum));outline=s.concat(outline;"_");outline=s.concat(outline;names.get(passnum-1));outline=s.concat(outline;"_");lp(let b=0;b<10;b=b+1){let bk=buckets.get(b);let bl=bk.len;if(bl>0){outline=s.concat(outline;"_");outline=s.concat(outline;s.fromint(b));outline=s.concat(outline;"_");lp(let j=0;j<bl;j=j+1){if(j>0){outline=s.concat(outline;"_")};outline=s.concat(outline;s.fromint(bk.get(j)))};outline=s.concat(outline;"_")}};io.println(outline);let sorted=mut.@();lp(let b=0;b<10;b=b+1){let bk=buckets.get(b);let bl=bk.len;lp(let j=0;j<bl;j=j+1){sorted=sorted+@(bk.get(j))}};res=sorted};let sortedline=mut.s.concat("_";"_");lp(let k=0;k<n;k=k+1){sortedline=s.concat(sortedline;"_");sortedline=s.concat(sortedline;s.fromint(res.get(k)))};io.println(sortedline);<0}