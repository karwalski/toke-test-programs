m=report;f=buildreport(data:$str;title:$str):$str{let out=mut."";let lines=data.split("\n");let n=lines.len;lp(let i=0;i<n;i=i+1){let line=lines.get(i);let prefix=title;prefix=prefix+": ";prefix=prefix+"Line ";let idx=i+1;let idxstr=idx as$str;prefix=prefix+idxstr;prefix=prefix+": ";out=out+prefix;out=out+line;out=s.concat(out;"\n");};<out};f=main():$void{let data="apple 100\nbanana 20\ncherry 5\n";let title="Fruit Inventory";let report=buildreport(data;title);<;};