m=avg;f=solve(p0:$str):$str{let data=mut.@();let lines=p0.split("\n");let headers=lines.get(0);let idxname=headers.indexof("name");let idxage=headers.indexof("age");lp(let i=1;i<lines.len;i=i+1){let line=lines.get(i);let cols=line.split(",");let name=cols.get(idxname);let age=cols.get(idxage);data=data+@(name);};let total=mut.0;lp(let i=0;i<data.len;i=i+1){let name=data.get(i);if(name="alice"){total=total+1};};<total as$str};