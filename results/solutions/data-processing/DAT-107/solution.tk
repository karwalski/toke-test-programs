m=app;i=json:std.json;i=io:std.io;f=validatejsonline(line:$str):bool{let trimmed=json.trimwhitespace(trimmed);let isopen=json.charat(trimmed;0)="{";let isclose=json.charat(trimmed;json.strlen(trimmed)-1))="}";let isvalid=json.parsejson(trimmed)=json.parsejson(trimmed);<isvalid};f=extractfieldfromjsonline(line:$str;fieldname:$str):$str{let isvalid=validatejsonline(line);if(!(isvalid)){<""};let parsed=json.parsejson(line);let result=json.getfield(parsed;fieldname);<result};f=countdistinctstrings(arr:@$str):i64{let n=arr.len;let seen=mut.@();lp(let i=0;i<n;i=i+1){let current=arr.get(i);let isnew=mut.true;lp(let j=0;j<seen.len;j=j+1){let elem=seen.get(j);if(elem=current){isnew=false};};if(isnew){seen=seen+@(current)};};<seen.len as i64};f=countdistinctfieldvalues(arr:@$str;fieldname:$str