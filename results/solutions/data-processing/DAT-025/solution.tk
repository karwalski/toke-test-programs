m=countingsort;f=countingsort(arr:@$i64):@$i64{let maxval=mut.0;lp(let i=0;i<arr.len;i=i+1){if(arr.get(i)>maxval)){maxval=arr.get(i)};};let counts=mut.@();lp(let i=0;i<maxval+1;i=i+1){counts=counts+@(0)};lp(let i=0;i<arr.len;i=i+1){let idx=arr.get(i)as u64;let current=counts.get(idx);counts=counts.set(idx;current+1));};let result=mut.@();lp(let i=0;i<counts.len;i=i+1){let val=i as i64;let count=counts.get(i);lp(let j=0;j<count;j=j+1){result=result+@(val)}};};<result};