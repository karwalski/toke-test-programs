m=crt;i=io:std.io;i=s:std.str;f=gcd(a:$i64;b:$i64):$i64{if(b=0){<a};<gcd(b;a-(a/b)*b)};f=extgcd(a:$i64;b:$i64):@($i64){let x=mut.1;let y=mut.0;let oldx=mut.0;let oldy=mut.1;let ma=mut.a;let mb=mut.b;lp(mb!=0){let q=ma/mb;let temp=mb;mb=ma-q*mb;ma=temp;let tempx=x;x=oldx-q*x;oldx=tempx;let tempy=y;y=oldy-q*y;oldy=tempy};<@(ma;oldx;oldy)};f=modinv(a:$i64;m:$i64):$i64{let result=extgcd(a;m);let gcdval=result.get(0);let x=mut.result.get(1);if(gcdval!=1){<0-1};lp(x<0){x=x+m};<x};f=solvecrt(r1:$i64;m1:$i64;r2:$i64;m2:$i64):@($i64){let g=gcd(m1;m2);if((r2-r1)-(((r2-r1)/g)*g)!=0){<@(0-1;0)};let lcm=m1*m2/g;let inv=modinv(m1/g;m2/g);if(inv=0-1){<@(0-1;0)};let diff=r2-r1;let k=diff/g;let result=mut.r1+k*inv*m1;let mod=result/lcm;result=result-mod*lcm;lp(result<0){result=result+lcm};<@(result;lcm)};f=main():$i64{let line1=io.readln();let parts1=s.split(line1;" ");let r1=s.toint(parts1.get(0));let m1=s.toint(parts1.get(1));let line2=io.readln();let parts2=s.split(line2;" ");let r2=s.toint(parts2.get(0));let m2=s.toint(parts2.get(1));let line3=io.readln();let parts3=s.split(line3;" ");let r3=s.toint(parts3.get(0));let m3=s.toint(parts3.get(1));let tempresult=solvecrt(r1;m1;r2;m2);let tempr=tempresult.get(0);let tempm=tempresult.get(1);let finalresult=solvecrt(tempr;tempm;r3;m3);let answer=finalresult.get(0);io.println(s.fromint(answer));<0}