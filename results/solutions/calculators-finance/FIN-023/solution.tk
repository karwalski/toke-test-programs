m=netpay;i=io:std.io;i=s:std.str;f=netpay(gross:$f64;taxrate:$f64;superrate:$f64;mcl:$f64):$void{let tax=gross*taxrate;let super=gross*superrate;let medicare=gross*mcl;let net=gross-tax-super-medicare;io.println(s.format(tax;"%.2f"));io.println(s.format(super;"%.2f"));io.println(s.format(net;"%.2f"))};f=main():$i64{let line=io.readln();let parts=s.split(line;" ");if(parts.len()>=4){let gross=s.tofloat(parts.get(0));let taxrate=s.tofloat(parts.get(1));let superrate=s.tofloat(parts.get(2));let mcl=s.tofloat(parts.get(3));netpay(gross;taxrate;superrate;mcl)};<0}