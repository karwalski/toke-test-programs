m=tip;i=io:std.io;i=s:std.str;f=main():$i64{let line=io.readln();let parts=s.split(line;" ");if(parts.len()>=3){let bill=s.tofloat(parts.get(0));let tiprate=s.tofloat(parts.get(1));let people=s.tofloat(parts.get(2));let tipamt=bill*tiprate/100.0;let total=bill+tipamt;let perper=total/people;io.println(s.format(tipamt;"%.2f"));io.println(s.format(total;"%.2f"));io.println(s.format(perper;"%.2f"))};<0}