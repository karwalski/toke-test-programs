m=emi;i=io:std.io;i=s:std.str;i=math:std.math;f=main():$i64{let line=io.readln();let parts=s.split(line;" ");if(parts.len()>=3){let principal=s.tofloat(parts.get(0));let annualrate=s.tofloat(parts.get(1));let months=s.tofloat(parts.get(2));let monthlyrate=annualrate/12.0;if(monthlyrate>0.0){let oneplusr=1.0+monthlyrate;let temp=math.pow(oneplusr;months);let emi=(principal*monthlyrate*temp)/(temp-1.0);let total=emi*months;let interest=total-principal;io.println(s.format(emi;"%.2f"));io.println(s.format(total;"%.2f"));io.println(s.format(interest;"%.2f"))}el{let emi=principal/months;let total=principal;let interest=0.0;io.println(s.format(emi;"%.2f"));io.println(s.format(total;"%.2f"));io.println(s.format(interest;"%.2f"))}};<0}