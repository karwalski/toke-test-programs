m=modinv;i=io:std.io;i=s:std.str;t=$triple{gcd:$i64;x:$i64;y:$i64};f=extgcd(a:$i64;b:$i64):$triple{if(b=0){<$triple{gcd:a;x:1;y:0}};let q=a/b;let r=a-q*b;let result=extgcd(b;r);<$triple{gcd:result.gcd;x:result.y;y:result.x-q*result.y}};f=modinv(a:$i64;m:$i64):$i64{let result=extgcd(a;m);if(result.gcd!=1){<-1};if(result.x<0){<result.x+m};<result.x};f=main():$i64{let line=io.readln();let parts=s.split(line;" ");let a=s.toint(parts.get(0));let m=s.toint(parts.get(1));let result=modinv(a;m);if(result=-1){io.println("NO_INVERSE")}el{io.println(s.fromint(result))};<0}