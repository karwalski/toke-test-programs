m=modinv;i=io:std.io;i=s:std.str;f=extgcd(a:$i64;b:$i64;x:$i64;y:$i64):$i64{if(b=0){<a};let q=a/b;let r=a-q*b;let nx=y;let ny=x-q*y;<extgcd(b;r;nx;ny)};f=modinv(a:$i64;m:$i64):$i64{let x=mut.0;let y=mut.1;let g=extgcd(a;m;x;y);if(g!=1){<-1};if(x<0){x=x+m};<x};f=main():$i64{let line=io.readln();let parts=s.split(line;" ");let a=s.toint(parts.get(0));let m=s.toint(parts.get(1));let result=modinv(a;m);io.println(s.fromint(result));<0}