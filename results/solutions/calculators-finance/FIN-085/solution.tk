m=annuity;i=io:std.io;i=s:std.str;f=presentvalue(payment:$f64;rate:$f64;periods:$i64):$f64{let sum=mut.0.0;lp(let idx=0;idx<periods;idx=idx+1){let term=rate/100.0;let exponent=idx as$f64;let factor=(1.0+term)**exponent;sum=sum+payment/factor;};<sum};f=main():$i64{let line=io.readln();let parts=s.split(line;" ");let payment=s.tofloat(parts[0]);let rate=s.tofloat(parts[1]);let periods=s.toint(parts[2]);let result=presentvalue(payment;rate;periods);io.println(s.fromfloat(result;2));<0};