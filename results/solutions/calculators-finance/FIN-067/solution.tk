m=weightcalc;f=calcweight(sd:$f64;mu:$f64):$f64{let vol=sd;let mean=mu;let absmean=mut.0;if(mean<0.0){absmean=-mean}el{absmean=mean};let risk=vol*absmean;let invrisk=mut.1.0/risk;if(!(invrisk>0.0))){<0.0};let weight=invrisk;let clamped=mut.0.0;if(weight<0.0){clamped=0.0}el{if(weight>1.0){clamped=1.0}el{clamped=weight}};<clamped>;};f=main():$i64{let sd=1.5;let mu=0.8;let w=calcweight(sd;mu);<0};