m=movavg;i=io:std.io;i=s:std.str;f=main():$i64{let window=s.toint(io.readln());let line=io.readln();let parts=s.split(line;",");let values=mut.@();let idx=mut.0;lp(idx<parts.len()){let val=s.tofloat(parts.get(idx));values=values+@(val);idx=idx+1};let results=mut.@();let i=mut.0;lp(i<=values.len()-window){let sum=mut.0.0;let j=mut.0;lp(j<window){sum=sum+values.get(i+j);j=j+1};let avg=sum/s.tofloat(s.fromint(window));results=results+@(s.format(avg;"%.2f"));i=i+1};let output=mut."";let k=mut.0;lp(k<results.len()){if(k>0){output=s.concat(output;",")};output=output+results.get(k);k=k+1};io.println(output);<0}