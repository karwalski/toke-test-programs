m=budget;i=io:std.io;i=s:std.str;f=main():$i64{let income=s.tofloat(io.readln());let names=mut.@();let percentages=mut.@();let allocated=mut.@();let spent=mut.@();lp(1){let line=io.readln();if(s.contains(line;"SPEND")){br};let parts=s.split(line;" ");if(parts.len()>=2){names=names+@(parts.get(0));let pct=s.tofloat(parts.get(1))/100.0;percentages=percentages+@(pct);allocated=allocated+@(income*pct);spent=spent+@(0.0)}};lp(1){let line=io.readln();if(s.trim(line)=""){br};let parts=s.split(line;" ");if(parts.len()>=3){if(parts.get(0)="SPEND"){let name=parts.get(1);let amount=s.tofloat(parts.get(2));let idx=mut.0;lp(idx<names.len()){if(names.get(idx)=name){spent=spent.set(idx;spent.get(idx)+amount);br};idx=idx+1}}}};let idx=mut.0;lp(idx<names.len()){let alloc=allocated.get(idx);let spentamt=spent.get(idx);let remaining=alloc-spentamt;io.println(s.concat(s.concat(s.concat(s.concat(s.concat(s.concat(names.get(idx);" ");s.format(alloc;"%.2f"));" ");s.format(spentamt;"%.2f"));" ");s.format(remaining;"%.2f")));idx=idx+1};<0}