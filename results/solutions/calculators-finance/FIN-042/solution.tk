m=median;f=median(arr:@$i64):$i64{let n=arr.len;let sorted=mut.@();lp(let i=0;i<n;i=i+1){sorted=sorted+@(arr.get(i));};lp(let i=0;i<n;i=i+1){lp(let j=0;j<n-i-1;j=j+1){if(sorted.get(j)>sorted.get(j+1))){let tmp=sorted.get(j);sorted.get(j)=sorted.get(j+1);sorted.get(j+1)=tmp;};};};let mid=n/2;let iseven=mut.false;if(n-mid*2=0){iseven=true};if(iseven){let a=sorted.get(mid-1);let b=sorted.get(mid);let c=a+b;let d=c/2;<d;}el{let idx=mid;<sorted.get(idx);};};