m=fastexp;i=io:std.io;i=s:std.str;f=modpow(base:$i64;exp:$i64;mod:$i64):$i64{let result=mut.1;let b=mut.(base%mod);let e=mut.exp;lp(e>0){if((e%2)=1){result=(result*b)%mod};b=(b*b)%mod;e=e/2};<result};f=main():$i64{let line=io.readln();let parts=s.split(line;" ");if(parts.len()>=3){let base=s.toint(parts.get(0));let exp=s.toint(parts.get(1));let modval=s.toint(parts.get(2));let result=modpow(base;exp;modval);io.println(s.fromint(result))};<0}