m=payoff;f=buildschedule(principal:$f64;interestrate:$f64;monthlypayment:$f64):@$f64{let remaining=mut.principal;let paid=mut.0;let schedule=mut.@();lp(let i=0;i<100;i=i+1){if(remaining<0.01){br};let interest=remaining*interestrate/12;let payment=monthlypayment;let principalpart=payment-interest;remaining=remaining-principalpart;paid=paid+principalpart;schedule=schedule+@(paid)};<schedule>;};f=payoff