m=convert;i=io:std.io;i=s:std.str;f=main():$i64{let line=io.readln();let parts=s.split(line;" ");if(parts.len()>=3){let temp=s.tofloat(parts.get(0));let from=parts.get(1);let to=parts.get(2);let celsius=mut.0.0;if(from="C"){celsius=temp}el{if(from="F"){celsius=(temp-32.0)*5.0/9.0}el{celsius=temp-273.15}};let result=mut.0.0;if(to="C"){result=celsius}el{if(to="F"){result=celsius*9.0/5.0+32.0}el{result=celsius+273.15}};io.println(s.format(result;"%.2f"))};<0}