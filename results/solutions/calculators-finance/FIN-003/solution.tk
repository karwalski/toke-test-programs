m=calc;i=io:std.io;i=s:std.str;i=math:std.math;f=main():$i64{let line=io.readln();let parts=s.split(line;" ");if(parts.len()>=2){let op=parts.get(0);let val=s.tofloat(parts.get(1));let result=mut.0.0;if(op="sin"){result=math.sin(val)}el{if(op="cos"){result=math.cos(val)}el{if(op="sqrt"){result=math.sqrt(val)}el{if(op="ln"){result=math.ln(val)}el{if(op="log"){result=math.log10(val)}el{result=0.0}}}}};io.println(s.format(result;"%.6f"))};<0}