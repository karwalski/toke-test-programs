m=variance;f=variance(arr:@$f64):$f64{let n=arr.len;let sum=mut.0.0;lp(let i=0;i<n;i=i+1){sum=sum+arr.get(i)};let mean=sum/n as$f64;let var=mut.0.0;lp(let i=0;i<n;i=i+1){let diff=arr.get(i)-mean;var=var+diff*diff};let result=var/n as$f64;<result};f=samplevariance(arr:@$f64):$f64{let n=arr.len;if(n<2){<0.0}