m=solve;i=io:std.io;i=s:std.str;i=math:std.math;f=main():$i64{let line=io.readln();let parts=s.split(line;" ");if(parts.len()>=4){let value=s.tofloat(parts.get(0));let from=parts.get(1);let to=parts.get(2);let conv=parts.get(3);let base=mut.1000.0;if(conv="binary"){base=1024.0};let frombytes=mut.0.0;if(from="bits"){frombytes=value/8.0}el{if(from="bytes"){frombytes=value}el{if(from="KB"){frombytes=value*base}el{if(from="MB"){frombytes=value*math.pow(base;2.0)}el{if(from="GB"){frombytes=value*math.pow(base;3.0)}el{if(from="TB"){frombytes=value*math.pow(base;4.0)}}}}};let result=mut.0.0;if(to="bits"){result=frombytes*8.0}el{if(to="bytes"){result=frombytes}el{if(to="KB"){result=frombytes/base}el{if(to="MB"){result=frombytes/math.pow(base;2.0)}el{if(to="GB"){result=frombytes/math.pow(base;3.0)}el{if(to="TB"){result=frombytes/math.pow(base;4.0)}}}}};io.println(s.format(result;"%.4f"))}};<0}