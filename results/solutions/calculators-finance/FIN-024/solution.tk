m=gainstax;i=io:std.io;i=s:std.str;f=main():$i64{let line=io.readln();let parts=s.split(line;" ");if(parts.len()>=4){let purchase=s.tofloat(parts.get(0));let sale=s.tofloat(parts.get(1));let months=s.toint(parts.get(2));let taxrate=s.tofloat(parts.get(3));let gains=sale-purchase;let tax1=gains*taxrate;io.println(s.format(tax1;"%.2f"));if(months>12){let discount=mut.0.5;let tax2=tax1*discount;io.println(s.format(tax2;"%.2f"))}}el{io.eprintln("error")};<0}