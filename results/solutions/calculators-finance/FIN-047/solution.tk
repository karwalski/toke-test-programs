m=pearson;f=pearson(x:$str;y:$str):$str{let xvals=x.split(",");let yvals=y.split(",");let n=xvals.len;let sumx=mut.0;let sumy=mut.0;let sumxy=mut.0;let sumx2=mut.0;let sumy2=mut.0;lp(let i=0;i<n;i=i+1){let xi=xvals.get(i).parsef64();let yi=yvals.get(i).parsef64();sumx=sumx+xi;sumy=sumy+yi;sumxy=sumxy+xi*yi;sumx2=sumx2+xi*xi;sumy2=sumy2+yi*yi};let meanx=sumx/n as f64;let meany=sumy/n as f64;let num=mut.0;let den