m=margin;i=io:std.io;i=s:std.str;f=main():$i64{let line=io.readln();let parts=s.split(line;" ");if(parts.len()>=4){let revenue=s.tofloat(parts.get(0));let cogs=s.tofloat(parts.get(1));let opex=s.tofloat(parts.get(2));let tax=s.tofloat(parts.get(3));let gross=revenue-cogs;let operating=gross-opex;let net=operating-tax;let grossmargin=gross/revenue*100.0;let opmargin=operating/revenue*100.0;let netmargin=net/revenue*100.0;io.println(s.concat(s.format(grossmargin;"%.2f");"%"));io.println(s.concat(s.format(opmargin;"%.2f");"%"));io.println(s.concat(s.format(netmargin;"%.2f");"%"))}el{io.eprintln("error")};<0}