m=europeancall;i=io:std.io;i=s:std.str;i=math:std.math;f=erf(x:$f64):$f64{let a1=0.254829592;let a2=-0.284496736;let a3=1.421413741;let a4=-1.453152027;let a5=1.061405429;let p=0.3275911;let sign=mut.1.0;let ax=mut.x;if(x<0.0){sign=0.0-1.0;ax=0.0-x};let t=1.0/(1.0+p*ax);let poly=((((a5*t+a4)*t+a3)*t+a2)*t+a1)*t;let y=1.0-poly*math.exp(0.0-ax*ax);<sign*y};f=normcdf(x:$f64):$f64{<0.5*(1.0+erf(x/math.sqrt(2.0)))};f=bsc(spot:$f64;k:$f64;t:$f64;r:$f64;sigma:$f64):$f64{let d1=(math.ln(spot/k)+(r+0.5*sigma*sigma)*t)/(sigma*math.sqrt(t));let d2=d1-sigma*math.sqrt(t);let result=spot*normcdf(d1)-k*math.exp(0.0-r*t)*normcdf(d2);<result};f=main():$i64{let line=io.readln();let parts=s.split(line;" ");let spotprice=s.tofloat(parts.get(0));let strike=s.tofloat(parts.get(1));let timetoexp=s.tofloat(parts.get(2));let rate=s.tofloat(parts.get(3));let vol=s.tofloat(parts.get(4));let price=bsc(spotprice;strike;timetoexp;rate;vol);io.println(s.format(price;"%.4f"));<0}
