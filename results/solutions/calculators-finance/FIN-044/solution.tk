m=stats;i=io:std.io;i=s:std.str;i=math:std.math;f=main():$i64{let line=s.trim(io.readln());let parts=s.split(line;",");let n=s.tofloat(s.fromint(parts.len()));let sum=mut.0.0;let idx=mut.0;lp(idx<parts.len()){let val=s.tofloat(s.trim(parts.get(idx)));sum=sum+val;idx=idx+1};let mean=sum/n;let varsum=mut.0.0;let idx2=mut.0;lp(idx2<parts.len()){let val=s.tofloat(s.trim(parts.get(idx2)));let diff=val-mean;varsum=varsum+(diff*diff);idx2=idx2+1};let popvar=varsum/n;let sampvar=varsum/(n-1.0);let popstd=math.sqrt(popvar);let sampstd=math.sqrt(sampvar);io.println(s.format(popstd;"%.4f"));io.println(s.format(sampstd;"%.4f"));<0}