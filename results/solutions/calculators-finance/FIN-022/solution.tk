m=gstcalc;i=io:std.io;i=s:std.str;f=main():$i64{let line=io.readln();let parts=s.split(line;" ");if(parts.len()>=3){let mode=parts.get(0);let amt=s.tofloat(parts.get(1));let rate=s.tofloat(parts.get(2));if(s.trim(mode)="exclusive"){let exclusive=amt;let gst=amt*rate;io.println(s.format(exclusive;"%.2f"));io.println(s.format(gst;"%.2f"))}el{let inclusive=amt;let exclusive=amt/(1.0+rate);let gst=inclusive-exclusive;io.println(s.format(exclusive;"%.2f"));io.println(s.format(gst;"%.2f"))}};<0}