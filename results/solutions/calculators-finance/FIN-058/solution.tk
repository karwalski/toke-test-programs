m=expsummary;f=parseentry(line:$str):$str{let parts=line.split(",");if(parts.len<2){<""};<parts.get(1)};f=compute(line:$str):$str{let entry=parseentry(line);if(entry.len=0){<""};let amt=entry.trim().parsef32();if(amt<0.0){<""};<entry};f=summarise(lines:@$str):$str{let total=mut.0.0;let count=mut.0;lp(let i=0;i<lines.len;i=i+1){let amt=parseentry(lines.get(i))).trim().parsef32();if(amt<0.0){<""};total=total+amt;count=count+1;};let avg=mut.0.0;if(count>0){avg=total/count};<total as$str};f=main():$str{let lines=@("rent,500";"food,100";"transport,50";"entertainment,30";"groceries,150"));let result=summarise(lines);<result};