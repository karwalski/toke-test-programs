m=taxcalc;i=io:std.io;i=s:std.str;f=main():$i64{let subtotal=mut.0.0;let taxtotal=mut.0.0;let line=io.readln();lp(s.len(line)>0){let parts=s.split(line;" ");if(parts.len()>=4){let qty=s.toint(parts.get(1));let price=s.tofloat(parts.get(2));let taxrate=s.tofloat(parts.get(3));let qtyf=s.tofloat(s.fromint(qty));let itemprice=qtyf*price;let itemtax=itemprice*taxrate;subtotal=subtotal+itemprice;taxtotal=taxtotal+itemtax};line=io.readln()};io.println(s.format(subtotal;"%.2f"));io.println(s.format(taxtotal;"%.2f"));io.println(s.format(subtotal+taxtotal;"%.2f"));<0}