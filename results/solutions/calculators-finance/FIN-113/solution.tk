m=binomial;i=io:std.io;i=s:std.str;i=math:std.math;f=factorial(n:$i64):$f64{if(n<=1){<1.0};<(n as $f64)*factorial(n-1)};f=combination(n:$i64;k:$i64):$f64{<factorial(n)/(factorial(k)*factorial(n-k))};f=main():$i64{let line=io.readln();let parts=s.split(line;" ");if(parts.len()>=3){let n=s.toint(parts.get(0));let k=s.toint(parts.get(1));let p=s.tofloat(parts.get(2));let c=combination(n;k);let prob=c*math.pow(p;k as $f64)*math.pow(1.0-p;(n-k) as $f64);let formatted=s.format(prob;"%.6f");io.println(formatted)};<0}