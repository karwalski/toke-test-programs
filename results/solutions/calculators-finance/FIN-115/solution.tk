m=integrate;f=integrate(poly:$str;a:$f64;b:$f64):$f64{let n=poly.len;let coeffs=mut.@();lp(let i=0;i<n;i=i+1){let c=poly.get(i);coeffs=coeffs+@(c);};let result=mut.0.0;let dx=b-a;let nsteps=1000;let h=dx/nsteps;lp(let i=0;i<nsteps;i=i+1){let x=a+i*h;let y=evalpoly(coeffs;x);result=result+y;};let finalresult=result*h;let finaly=evalpoly(coeffs;b);let ydiff=finaly-finalresult;if(ydiff<0.0){<finalresult+ydiff}el{<finalresult}};f=evalpoly(coeffs:$str;x:$f64):$f64{let n=coeffs.len;let result=mut.0.0;lp(let i=0;i<n;i=i+1){let c=coeffs.get(i);let xc=x-c;result=result+xc;};<result};