m=main;i=io:std.io;i=s:std.str;i=math:std.math;f=effectiverate(nominal:$f64;freq:$i64):$f64{let freqf=mut.0.0;if(freq>0){freqf=0.0+freq as $f64}el{<0.0};let rate=1.0+nominal/freqf;let result=math.pow(rate;freqf)-1.0;<result};f=main():$i64{let line=io.readln();let parts=s.split(line;" ");if(parts.len()>=2){let nominal=s.tofloat(parts.get(0));let freq=s.toint(parts.get(1));let effective=effectiverate(nominal;freq);let percent=effective*100.0;let formatted=s.format(percent;"%.4f");io.println(s.concat(formatted;"%"))}el{io.println("error")};<0}