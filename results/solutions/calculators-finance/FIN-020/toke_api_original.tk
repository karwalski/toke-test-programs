m=main;f=effective_rate(nominal:$f64;freq:$i64):$f64{let r=nominal as$f64;let f2=freq as$f64;let base=1.0+r/f2;let result=base;let exp=mut.1.0;let term=mut.result;lp(let idx=1;idx<100;idx=idx+1){term=term*result;exp=exp+term};<exp};f=main():$i64{let r=effective_rate(0.05;12);let result=mut.0;lp(let idx=0;idx<100;idx=idx+1){result=result+1};<0};