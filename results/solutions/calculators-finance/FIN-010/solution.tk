m=evaluator;i=io:std.io;i=s:std.str;f=main():$i64{let vars=mut.@();lp(1=1){let line=io.readln();if(s.contains(line;"=")){let parts=s.split(line;" ");if(parts.len()>=3){let varname=parts.get(0);let value=s.toint(parts.get(2));vars=vars+@(varname);vars=vars+@(value)}}el{let tokens=s.split(line;" ");if(tokens.len()>=5){let val1=mut.0;let val2=mut.0;let idx=mut.0;lp(idx<vars.len()){if(idx+1<vars.len()){let varname=vars.get(idx);let varval=vars.get(idx+1);if(varname=tokens.get(0)){val1=varval};if(varname=tokens.get(2)){val2=varval}};idx=idx+2};let result=mut.0;if(tokens.get(1)="*"){result=val1*val2};if(tokens.get(3)="+"){result=result+s.toint(tokens.get(4))};io.println(s.fromint(result))};br}};<0}