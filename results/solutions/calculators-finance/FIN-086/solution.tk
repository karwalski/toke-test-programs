m=annuity;i=io:std.io;i=s:std.str;i=math:std.math;f=main():$i64{let line=io.readln();let parts=s.split(line;" ");if(parts.len()>=3){let pmt=s.tofloat(parts.get(0));let rate=s.tofloat(parts.get(1));let periods=s.tofloat(parts.get(2));let one=1.0;let fv=pmt*((math.pow(one+rate;periods)-one)/rate);let formatted=s.format(fv;"%.2f");io.println(formatted)};<0}