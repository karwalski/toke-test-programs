m=crypto;i=io:std.io;i=s:std.str;f=main():$i64{let totalprofit=mut.0.0;let holdings=mut.@();lp(1=1){let line=io.readln();if(s.len(line)=0){br};let trimmed=s.trim(line);if(s.len(trimmed)=0){br};let parts=s.split(trimmed;" ");if(parts.len()>=3){let action=parts.get(0);let amount=s.tofloat(parts.get(1));let price=s.tofloat(parts.get(2));if(s.contains(action;"BUY")){let newheld=mut.@();let idx=mut.0;lp(idx<holdings.len()){newheld=newheld+@(holdings.get(idx));idx=idx+1};newheld=newheld+@(@(amount;price));holdings=newheld}el{if(s.contains(action;"SELL")){let remaining=mut.amount;let newheld=mut.@();let idx=mut.0;lp(idx<holdings.len()){let holding=holdings.get(idx);let buyamount=holding.get(0);let buyprice=holding.get(1);if(remaining>0.0){if(buyamount<=remaining){totalprofit=totalprofit+buyamount*(price-buyprice);remaining=remaining-buyamount}el{totalprofit=totalprofit+remaining*(price-buyprice);newheld=newheld+@(@(buyamount-remaining;buyprice));remaining=0.0}}el{newheld=newheld+@(holding)};idx=idx+1};holdings=newheld}}}};io.println(s.format(totalprofit;"%.2f"));<0}