m=baseconv;f=baseconv(n:$i64;basefrom:$i64;baseto:$i64):$str{if(basefrom=baseto){<n as$str};let digits=mut."0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ";let val=mut.n;let otherbase=mut.baseto;let result=mut."";if(val=0){<"0"};if(val<0){val=0-val;};lp(let dummy=0;val>0;val=val/otherbase){let r=val-val/otherbase*otherbase;result=digits.get(r as u64)+result};if(n<0){result="-"+result};<result};