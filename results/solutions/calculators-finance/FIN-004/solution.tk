m=addstr;i=io:std.io;i=s:std.str;f=addstr(a:$str;b:$str):$str{let numa=s.trim(a);let numb=s.trim(b);let lena=s.len(numa);let lenb=s.len(numb);let maxlen=mut.lena;if(lenb>lena){maxlen=lenb};let result=mut."";let carry=mut.0;let i=mut.0;lp(i<maxlen){let da=mut.0;if(i<lena){let pos=lena-1-i;da=s.toint(s.slice(numa;pos;pos+1))};let db=mut.0;if(i<lenb){let pos=lenb-1-i;db=s.toint(s.slice(numb;pos;pos+1))};let sum=da+db+carry;carry=sum/10;let digit=sum-(carry*10);result=s.concat(s.fromint(digit);result);i=i+1};if(carry>0){result=s.concat(s.fromint(carry);result)};<result};f=main():$i64{let a=s.trim(io.readln());let b=s.trim(io.readln());io.println(addstr(a;b));<0}