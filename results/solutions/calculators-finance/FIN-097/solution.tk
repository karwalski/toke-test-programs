m=gcd;i=io:std.io;i=s:std.str;f=gcd(a:$i64;b:$i64):$i64{let x=mut.a;let y=mut.b;lp(let i=0;!(y=0);i=i+1){let tmp=y;y=x-x/y*y;x=tmp};<x};f=lcm(a:$i64;b:$i64):$i64{let g=gcd(a;b);let res=mut.0;res=a/g*b;<res};f=main():$i64{let line=io.readln();let parts=s.split(line;",");let nums=mut.s.toint(parts[0]);let result=mut.nums;let idx=mut.1;lp(let j=0;idx<len(parts);j=j+1){nums=s.toint(parts[idx]);result=lcm(result;nums);idx=idx+1};io.println(s.fromint(result));<0};