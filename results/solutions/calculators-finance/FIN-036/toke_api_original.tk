m=convert;f=convert(val:$f64;from:$str;to:$str):$f64{if(from=to){<val};let frommps=mut.false;let tomps=mut.false;if(from="m/s"){frommps=true};if(to="m/s"){tommps=true};let result=mut.val;if(frommps){result=val*3.6};if(from="km/h"){result=val/3.6};if(from="mph"){result=val*1.60934};if(from="knots"){result=val/1.85200};if(tomps){result=val/3.6};if(to="km/h"){result=val*3.6};if(to="mph"){result=val/1.60934};if(to="knots"){result=val*1.85200};<result};f=main():$i64{<0};