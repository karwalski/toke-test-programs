m=percentile;i=io:std.io;i=s:std.str;i=math:std.math;f=main():$i64{let p=s.tofloat(io.readln());let line=io.readln();let parts=s.split(line;",");let n=parts.len();let data=mut.@();let idx=mut.0;lp(idx<n){let val=s.tofloat(parts.get(idx));data=data+@(val);idx=idx+1};let i=mut.0;lp(i<n-1){let j=mut.i+1;lp(j<n){if(data.get(i)>data.get(j)){let temp=data.get(i);let tempj=data.get(j);let newdata=mut.@();let k=mut.0;lp(k<n){if(k=i){newdata=newdata+@(tempj)}el{if(k=j){newdata=newdata+@(temp)}el{newdata=newdata+@(data.get(k))}};k=k+1};data=newdata};j=j+1};i=i+1};let pos=(p/100.0)*(s.tofloat(s.fromint(n-1)));let lower=s.toint(s.fromfloat(pos));let upper=lower+1;if(upper>=n){let result=data.get(n-1);io.println(s.format(result;"%.4f"))}el{let frac=pos-s.tofloat(s.fromint(lower));let result=data.get(lower)*(1.0-frac)+data.get(upper)*frac;io.println(s.format(result;"%.4f"))};<0}