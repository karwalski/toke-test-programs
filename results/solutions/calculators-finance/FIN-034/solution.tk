m=lengthconv;i=io:std.io;i=s:std.str;f=tometers(val:$f64;unit:$str):$f64{if(unit="mm"){<val*0.001};if(unit="cm"){<val*0.01};if(unit="m"){<val*1.0};if(unit="km"){<val*1000.0};if(unit="in"){<val*0.0254};if(unit="ft"){<val*0.3048};if(unit="yd"){<val*0.9144};if(unit="mi"){<val*1609.344};<0.0};f=frommeters(val:$f64;unit:$str):$f64{if(unit="mm"){<val*1000.0};if(unit="cm"){<val*100.0};if(unit="m"){<val*1.0};if(unit="km"){<val*0.001};if(unit="in"){<val*39.3701};if(unit="ft"){<val*3.28084};if(unit="yd"){<val*1.09361};if(unit="mi"){<val*0.000621371};<0.0};f=main():$i64{let line=io.readln();let parts=s.split(line;" ");if(parts.len()>=3){let val=s.tofloat(parts.get(0));let fromunit=parts.get(1);let tounit=parts.get(2);let meters=tometers(val;fromunit);let result=frommeters(meters;tounit);let formatted=s.format(result;"%.4f");io.println(formatted)};<0}