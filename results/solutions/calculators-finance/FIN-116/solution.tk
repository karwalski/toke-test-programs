m=newton;i=io:std.io;i=s:std.str;i=math:std.math;f=eval(coeffs:@($str);x:$f64):$f64{let result=mut.0.0;let power=mut.1.0;let idx=mut.0;lp(idx<coeffs.len()){let coeff=s.tofloat(coeffs.get(idx));result=result+coeff*power;power=power*x;idx=idx+1};<result};f=deriv(coeffs:@($str);x:$f64):$f64{let result=mut.0.0;let power=mut.1.0;let idx=mut.1;lp(idx<coeffs.len()){let coeff=s.tofloat(coeffs.get(idx));result=result+coeff*s.tofloat(s.fromint(idx))*power;power=power*x;idx=idx+1};<result};f=main():$i64{let line1=io.readln();let params=s.split(line1;" ");if(params.len()>=3){let x0=s.tofloat(params.get(0));let eps=s.tofloat(params.get(1));let maxiter=s.toint(params.get(2));let line2=io.readln();let coeffs=s.split(line2;" ");let x=mut.x0;let iter=mut.0;lp(iter<maxiter){let fx=eval(coeffs;x);let fpx=deriv(coeffs;x);let absfx=mut.fx;if(fx<0.0){absfx=0.0-fx};if(absfx<eps){br};if(fpx=0.0){br};x=x-fx/fpx;iter=iter+1};io.println(s.format(x;"%.6f"));io.println(s.concat(s.concat(s.fromint(iter);" ");"iterations"))}el{io.eprintln("Invalid input")};<0}