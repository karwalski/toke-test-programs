m=mortgage;i=io:std.io;i=s:std.str;i=math:std.math;f=payment(principal:$f64;rate:$f64;years:$i64):$f64{let r=rate/12.0;let n=s.tofloat(s.fromint(years*12));let tmp=math.pow(1.0+r;n);let monthly=principal*r*tmp/(tmp-1.0);<monthly};f=main():$i64{let line=io.readln();let parts=s.split(line;"_");if(parts.len()>=3){let p=s.tofloat(parts.get(0));let apr=s.tofloat(parts.get(1));let y=s.toint(parts.get(2));let result=payment(p;apr;y);io.println(s.format(result;"_"))};<0}