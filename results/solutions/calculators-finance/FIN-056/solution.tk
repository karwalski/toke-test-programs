m=ema;i=io:std.io;i=s:std.str;f=ema(arr:@$f64;alpha:$f64):$f64{let n=arr.len;let m=mut.0;lp(let i=0;i<n;i=i+1){let v=arr.get(i);let diff=v-m;let delta=alpha*diff;let next=m+delta;let zz=mut.0;if(i=0){zz=v}el{zz=next};m=zz};<m};f=main():$i64{let alpha=s.tofloat(io.readln());let line=io.readln();let parts=s.split(line;",");let values=@$f64{};lp(let j=0;j<parts.len;j=j+1){let val=s.tofloat(parts.get(j));values.add(val)};let results=@$str{};let current=mut.0;lp(let k=0;k<values.len;k=k+1){let val=values.get(k);if(k=0){current=val}el{let diff=val-current;current=current+alpha*diff};let formatted=s.fromfloat(current;2);results.add(formatted)};let output=s.join(results;",");io.println(output);<0}