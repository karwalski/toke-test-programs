m=bond;i=io:std.io;i=s:std.str;i=math:std.math;f=main():$i64{let line=io.readln();let parts=s.split(line;" ");if(parts.len()>=4){let fv=s.tofloat(parts.get(0));let cr=s.tofloat(parts.get(1));let ytm=s.tofloat(parts.get(2));let n=s.tofloat(parts.get(3));let c=fv*cr;let pv=mut.0.0;let idx=mut.1.0;lp(idx<=n){pv=pv+c/math.pow(1.0+ytm;idx);idx=idx+1.0};pv=pv+fv/math.pow(1.0+ytm;n);io.println(s.format(pv;"%.2f"))}el{io.println("0.00")};<0}