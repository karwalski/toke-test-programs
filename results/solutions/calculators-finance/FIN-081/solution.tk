m=duty;i=io:std.io;i=s:std.str;f=main():$i64{let price=s.tofloat(io.readln());let total=mut.0.0;let remaining=mut.price;let line1=io.readln();let parts1=s.split(line1;" ");if(parts1.len()>=2){let bracket1=s.tofloat(parts1.get(0));let rate1=s.tofloat(parts1.get(1));let line2=io.readln();let parts2=s.split(line2;" ");if(parts2.len()>=2){let bracket2=s.tofloat(parts2.get(0));let rate2=s.tofloat(parts2.get(1));let line3=io.readln();let parts3=s.split(line3;" ");if(parts3.len()>=2){let bracket3=s.tofloat(parts3.get(0));let rate3=s.tofloat(parts3.get(1));if(remaining>0.0){let taxable=mut.remaining;if(taxable>bracket1){taxable=bracket1};total=total+taxable*rate1;remaining=remaining-taxable};if(remaining>0.0){let taxable=mut.remaining;if(taxable>bracket2-bracket1){taxable=bracket2-bracket1};total=total+taxable*rate2;remaining=remaining-taxable};if(remaining>0.0){let taxable=mut.remaining;if(taxable>bracket3-bracket2){taxable=bracket3-bracket2};total=total+taxable*rate3;remaining=remaining-taxable};if(remaining>0.0){total=total+remaining*rate3};io.println(s.format(total;"%.2f"))}}};<0}