m=zscore;i=io:std.io;i=s:std.str;f=zscore(arr:@f64):@f64{let n=arr.len;let m=mut.0;lp(let i=0;i<n;i=i+1){m=m+arr.get(i);};let avg=m/n as f64;let s=mut.0;lp(let i=0;i<n;i=i+1){let diff=arr.get(i)-avg;s=s+diff*diff;};let sd=sqrt(s/n as f64);let result=mut.@();lp(let i=0;i<n;i=i+1){let diff=arr.get(i)-avg;let z=diff/sd;result=result+@(z);};<result};f=sqrt(x:f64):f64{let guess=mut.x;lp(let i=0;i<10;i=i+1){let next=(guess+x/guess)/2;guess=next;};<guess};f=main():$i64{let line=io.readln();let parts=s.split(line;",");let arr=mut.@();lp(let j=0;j<parts.len;j=j+1){let num=s.tofloat(parts.get(j));arr=arr+@(num);};let zscores=zscore(arr);let output=mut."";lp(let k=0;k<zscores.len;k=k+1){let formatted=s.fromfloat(zscores.get(k);4);if(k>0){output=s.concat(output;",");};output=s.concat(output;formatted);};io.println(output);<0};