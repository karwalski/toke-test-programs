m=investment;i=io:std.io;i=s:std.str;i=math:std.math;f=main():$i64{let rate=s.tofloat(io.readln());let rateDec=rate/100.0;let years=mut.0.0;let balance=mut.1.0;lp(balance<2.0){years=years+1.0;balance=balance*(1.0+rateDec)};let exactYears=math.ln(2.0)/math.ln(1.0+rateDec);io.println(s.format(years;"%.2f"));io.println(s.format(exactYears;"%.2f"));<0}