m=conv;i=io:std.io;i=s:std.str;f=main():$i64{let line=io.readln();let parts=s.split(line;" ");if(parts.len()>=3){let valstr=parts.get(0);let fromunit=parts.get(1);let tounit=parts.get(2);let val=s.tofloat(valstr);let joules=mut.0.0;if(fromunit="kWh"){joules=val*3600000.0}el{if(fromunit="cal"){joules=val*4.184}el{if(fromunit="BTU"){joules=val*1055.056}el{if(fromunit="eV"){joules=val*1.60217733e-19}el{joules=val}}}};let result=mut.0.0;if(tounit="kWh"){result=joules/3600000.0}el{if(tounit="cal"){result=joules/4.184}el{if(tounit="BTU"){result=joules/1055.056}el{if(tounit="eV"){result=joules/1.60217733e-19}el{result=joules}}}};io.println(s.format(result;"%.4f"))};<0}