m=npv;i=io:std.io;i=s:std.str;i=math:std.math;f=calcnpv(rate:$f64;flows:@($str)):$f64{let npv=mut.0.0;let n=flows.len();let idx=mut.0;lp(idx<n){let cf=s.tofloat(flows.get(idx));let disc=math.pow(1.0+rate;s.tofloat(s.fromint(idx)));npv=npv+cf/disc;idx=idx+1};<npv};f=main():$i64{let r=s.tofloat(io.readln());let line=io.readln();let parts=s.split(line;",");let result=calcnpv(r;parts);io.println(s.format(result;"%.2f"));<0}