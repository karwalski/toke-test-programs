m=rental;i=io:std.io;i=s:std.str;f=main():$i64{let line=s.trim(io.readln());let parts=s.split(line;" ");let pv=s.tofloat(parts.get(0));let rent=s.tofloat(parts.get(1));let exp=s.tofloat(parts.get(2));let pc=s.tofloat(parts.get(3));let gross=(rent/pv)*100.0;let net=((rent-exp)/(pv+pc))*100.0;io.println(s.concat(s.format(gross;"%.2f");"%"));io.println(s.concat(s.format(net;"%.2f");"%"));<0}
