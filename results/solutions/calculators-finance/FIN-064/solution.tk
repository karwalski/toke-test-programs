m=sharpe;i=io:std.io;i=s:std.str;i=math:std.math;f=main():$i64{let rfrate=s.tofloat(s.trim(io.readln()));let line=s.trim(io.readln());let parts=s.split(line;",");let sum=mut.0.0;let idx=mut.0;lp(idx<parts.len()){let ret=s.tofloat(s.trim(parts.get(idx)));sum=sum+ret;idx=idx+1};let n=s.tofloat(s.fromint(parts.len()));let mean=sum/n;let sumsq=mut.0.0;idx=0;lp(idx<parts.len()){let ret=s.tofloat(s.trim(parts.get(idx)));let diff=ret-mean;sumsq=sumsq+(diff*diff);idx=idx+1};let variance=sumsq/n;let stdev=math.sqrt(variance);let sharpe=(mean-rfrate)/stdev;io.println(s.format(sharpe;"%.4f"));<0}