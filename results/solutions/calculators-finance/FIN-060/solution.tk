m=monthlysaving;f=monthlysaving(p:$i64;q:$i64;rate:$f64):$f64{let r=rate/100.0;let interest=mut.0.0;let principal=mut.p as$f64;let monthlyrate=r/12.0;let payment=mut.0.0;if(!(r=0.0))el{let numerator=principal*monthlyrate;let denominator=1.0-monthlyrate;let annuity=mut.numerator/denominator;if(!(annuity=0.0))el{payment=annuity;};};let saved=mut.0.0;if(!(payment=0.0))el{saved=principal-payment;principal=saved;};if(!(q=0))el{let i=mut.0.0;lp(let idx=0;idx<q;idx=idx+1){i=i+monthlyrate;};interest=i*principal;};let total=mut.0.0;if(!(q=0))el{total=payment+interest;}el{total=payment;};<total};