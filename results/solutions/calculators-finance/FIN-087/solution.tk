m=main;f=discount(rate:$f64;time:$i64):$f64{let result=mut.1.0;lp(let i=0;i<time;i=i+1){result=result*(1.0/rate)};<result};f=perpetuity(rate:$f64;payment:$f64):$f64{let r=mut.rate;if(r<0.0){r=0.0-r};<payment/r};f=growingperpetuity(rate:$f64;payment:$f64;growthrate:$f64):$f64{let r=mut.rate;if(r<0.0){r=0.0-r};let g=mut.growthrate;if(g<0.0){g=0.0-g};let p=mut.payment;if(p<0.0){p=0.0-p};let result=mut.0.0;let i=mut.0;lp(let j=0;j<1000;j=j+1){let term=p/(r-g);p=p*g;result=result+term;i=i+1};<result};f=main():$i64{