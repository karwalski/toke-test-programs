m=irr;i=io:std.io;i=s:std.str;i=math:std.math;f=npv(cashflows:@($f64);n:$i64;rate:$f64):$f64{let result=mut.0.0;let idx=mut.0;lp(idx<n){let cf=cashflows.get(idx);let power=math.pow(1.0+rate;s.tofloat(s.fromint(idx)));result=result+cf/power;idx=idx+1};<result};f=npvderiv(cashflows:@($f64);n:$i64;rate:$f64):$f64{let result=mut.0.0;let idx=mut.1;lp(idx<n){let cf=cashflows.get(idx);let if64=s.tofloat(s.fromint(idx));let denom=math.pow(1.0+rate;if64+1.0);result=result-cf*if64/denom;idx=idx+1};<result};f=irrcalc(cashflows:@($f64);n:$i64):$f64{let x=mut.0.1;let tolerance=0.00001;let maxiter=100;let iter=mut.0;lp(iter<maxiter){let fval=npv(cashflows;n;x);let deriv=npvderiv(cashflows;n;x);if(math.abs(deriv)>tolerance){x=x-fval/deriv};if(math.abs(fval)<tolerance){<x};iter=iter+1};<x};f=main():$i64{let line=s.trim(io.readln());let parts=s.split(line;",");let n=parts.len();let cashflows=mut.@();let idx=mut.0;lp(idx<n){let cf=s.tofloat(parts.get(idx));cashflows=cashflows+@(cf);idx=idx+1};let rate=irrcalc(cashflows;n);let percent=rate*100.0;io.println(s.concat(s.format(percent;"%.2f");"%"));<0}