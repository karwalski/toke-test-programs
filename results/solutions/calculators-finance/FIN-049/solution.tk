m=chisq;i=io:std.io;i=s:std.str;f=chisq(obs:$i64;exp:$i64):$f64{let sum=mut.0.0;lp(let i=0;i<obs.len;i=i+1){let o=obs.get(i);let e=exp.get(i);let diff=o-e;let sq=diff*diff;sum=sum+sq as$f64/e as$f64};<sum};f=main():$i64{let obsline=io.readln();let expline=io.readln();let obsparts=s.split(obsline;",");let expparts=s.split(expline;",");let obs=mut$i64[];let exp=mut$i64[];lp(let i=0;i<obsparts.len;i=i+1){obs.push(s.toint(obsparts.get(i)));exp.push(s.toint(expparts.get(i)))};let result=chisq(obs;exp);io.println(s.fromf64(result;4));<0};