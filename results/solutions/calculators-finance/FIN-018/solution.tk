m=interest;i=io:std.io;i=s:std.str;f=simpleinterest(principal:$f64;rate:$f64;time:$f64):$f64{let interest=principal*rate*time;<interest};f=totalamount(principal:$f64;interest:$f64):$f64{<principal+interest};f=main():$i64{let line=io.readln();let parts=s.split(line;" ");if(parts.len()>=3){let principal=s.tofloat(parts.get(0));let rate=s.tofloat(parts.get(1));let time=s.tofloat(parts.get(2));let interest=simpleinterest(principal;rate;time);let total=totalamount(principal;interest);io.println(s.format(interest;"%.2f"));io.println(s.format(total;"%.2f"))};<0}