m=retirement;f=required_corpus(age:$i64;expected_life:$i64;annual_income:$i64):$i64{let inflation_rate=mut.3;let years_until_retirement=mut.65-age;let projected_income=mut.annual_income*(1+inflation_rate/100));let corpus=mut.0;lp(let idx=0;idx<years_until_retirement;idx=idx+1){corpus=corpus+projected_income*(1+inflation_rate/100));};<corpus};f=monthly_savings_needed(corpus:$i64;years_until_retirement:$i64):$i64{let monthly_savings=mut.0;let total_months=years_until_retirement*12;lp(let idx=0;idx<total_months;idx=idx+1){monthly_savings=monthly_savings+corpus/total_months;};<monthly_savings};f=main():$i64{let age=30;let expected_life=100;let annual_income=50000;let corpus=required_corpus(age;expected_life;annual_income));let