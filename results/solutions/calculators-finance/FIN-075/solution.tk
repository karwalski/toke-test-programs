m=insurance;i=io:std.io;i=s:std.str;f=main():$i64{let line=io.readln();let parts=s.split(line;" ");if(parts.len()>=3){let base=s.tofloat(parts.get(0));let age=s.toint(parts.get(1));let multipliers=s.split(parts.get(2);",");let agefactor=mut.1.0;if(age<25){agefactor=1.5}el{if(age>60){agefactor=1.3}};let premium=mut.base;premium=premium*agefactor;let idx=mut.0;lp(idx<multipliers.len()){let mult=s.tofloat(multipliers.get(idx));premium=premium*mult;idx=idx+1};io.println(s.format(premium;"%.2f"))}el{io.println("0.00")};<0}