m=scorecalc;f=scorecalc(age:$i64;bp:$i64;cho:$i64;glu:$i64;ht:$i64):$i64{let ageage=age as$f64;let agefact=1.0+ageage/10.0;let bpbp=bp as$f64;let bpfact=1.0+bpbp/100.0;let chcho=cho as$f64;let chfact=1.0+chcho/100.0;let gluglu=glu as$f64;let glufact=1.0+gluglu/100.0;let htht=ht as$f64;let htfact=1.0+htht/100.0;let scores=@(agefact;bpfact;chfact;glufact;htfact));let totalscore=mut.0;lp(let idx=0;idx<scores.len;idx=idx+1){totalscore=totalscore+scores.get(idx as u64))};let finalscore=mut.0;if(tot