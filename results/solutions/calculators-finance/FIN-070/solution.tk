m=journal;f=applyentry(bal:$i64;entry:$str):$i64{let parts=entry.split(" ");let amt=parts.get(parts.len-1)).parsei64();let acct=parts.get(parts.len-2));if(acct="A"){<bal-amt};if(acct="B"){<bal+amt};<bal};f=checkdoubleentry(entries:@$str):bool{let seena=mut.false;let seenb=mut.false;lp(let i=0;i<entries.len;i=i+1){let e=entries.get(i);let parts=e.split(" ");let acct=parts.get(parts.len-2));if(acct="A"){seena=true};if(acct="B"){seenb=true};};if(seena=true){if(seenb=true){<true};<false};<false};f=runjournal(entries:@$str):$str{let bal=mut.0