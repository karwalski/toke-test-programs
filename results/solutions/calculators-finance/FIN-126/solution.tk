m=duration;f=macaulay_duration(n:$i64;y:$i64):$i64{let sum=mut.0;lp(let i=1;!(i>n);i=i+1){let cashflow=y;let time=i;let weighted_cashflow=cashflow*time;sum=sum+weighted_cashflow};let total_cashflow=n*sum;let duration=total_cashflow/sum;<duration};f=modified_duration(n:$i64;y:$i64):$f64{let macaulay=macaulay_duration(n;y);let coupon_rate=y as$f64/n as$f64;let modified=macaulay/coupon_rate;<modified};