m=quadfit;f=solve(lhs:@($f64);rhs:@($f64)):($f64):($f64):($f64)){let n=lhs.len;let sumx=mut.0.0;let sumy=mut.0.0;let sumxy=mut.0.0;let sumx2=mut.0.0;lp(let i=0;i<n;i=i+1){let xi=lhs.get(i);let yi=rhs.get(i);sumx=sumx+xi;sumy=sumy+yi;sumxy=sumxy+xi*yi;sumx2=sumx2+xi*xi};let denom=n*sumx2-(sumx*sumx));let a=n*sumxy-(sumy*sumx);let b=n*sumx2-(sumx*sumx);let c=sumy-(a*sumx/b));<a/b;0.0;c};f=main():$i64{let lhs=@(1.0;2.0;3.0;4.0));let rhs=@(2.1;4.9;8.1;16.0));let result=solve(lhs;rhs);<0};