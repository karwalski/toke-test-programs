m=gcd;i=io:std.io;i=s:std.str;f=gcd(n:$i64;m:$i64):$i64{let a=mut.n;let b=mut.m;lp(let idx=0;!(b=0);idx=idx+1){let tmp=a;a=b;b=tmp-tmp/b*b};<a};f=main():$i64{let line=io.readln();let parts=s.split(line;",");let nums=mut.[];idx=0;lp(idx=0;idx<s.len(parts);idx=idx+1){nums=s.push(nums;s.toint(parts[idx]))};let result=nums[0];idx=1;lp(idx=1;idx<s.len(nums);idx=idx+1){result=gcd(result;nums[idx])};io.println(s.fromint(result));<0}