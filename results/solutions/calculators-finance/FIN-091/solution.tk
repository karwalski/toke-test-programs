m=determinant;f=determinant(mat:$i64;n:$i64):$i64{if(n=1){<mat};let result=mut.0;let sign=mut.1;lp(let i=0;i<n;i=i+1){let nexti=i+1;if(nexti<n){let submat=mut.0;let subidx=mut.0;lp(let row=0;row<n;row=row+1){if(row=nexti){subidx=subidx+1}el{if(row=i){subidx=subidx+1}el{submat=submat+1}}}};let subdeterminant=determinant(submat;n-1);result=result+sign*subdeterminant;sign=sign*-1};<result};