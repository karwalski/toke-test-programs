m=perc;i=io:std.io;i=s:std.str;f=percent(pct:$i64;num:$i64):$f64{let tmp=mut.0.0;tmp=(pct as $f64);tmp=tmp*0.01;tmp=tmp*(num as $f64);<tmp};f=percchange(old:$i64;new:$i64):$f64{let diff=new-old;let tmp=mut.0.0;tmp=(diff as $f64);tmp=tmp/(old as $f64);tmp=tmp*100.0;<tmp};f=whatperc(part:$i64;whole:$i64):$f64{let tmp=mut.0.0;tmp=(part as $f64);tmp=tmp/(whole as $f64);tmp=tmp*100.0;<tmp};f=main():$i64{let line=io.readln();let parts=s.split(line;" ");if(parts.len()>=3){let cmd=parts.get(0);let a=s.toint(parts.get(1));let b=s.toint(parts.get(2));if(cmd="of"){let result=percent(a;b);let intresult=(result as $i64);io.println(s.fromint(intresult))}el{if(cmd="change"){let result=percchange(a;b);let intresult=(result as $i64);io.println(s.concat(s.fromint(intresult);"%"))}el{if(cmd="is"){let result=whatperc(a;b);let intresult=(result as $i64);io.println(s.concat(s.fromint(intresult);"%"))}el{io.println("error")}}}}el{if(parts.len()=2){let a=s.toint(parts.get(0));let b=s.toint(parts.get(1));let result=whatperc(a;b);let intresult=(result as $i64);io.println(s.concat(s.fromint(intresult);"%"))}el{io.println("error")}};<0}