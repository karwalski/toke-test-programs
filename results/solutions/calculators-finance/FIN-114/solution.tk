m=sumgeo;i=io:std.io;i=s:std.str;f=sumgeo(first:$f64;ratio:$f64;n:$i64):$f64{if(n<1){<0.0};let sum=mut.0.0;let term=mut.first;lp(let i=0;i<n;i=i+1){sum=sum+term;term=term*ratio};<sum};f=main():$i64{let line=io.readln();let parts=s.split(line;" ");let first=s.tofloat(parts.0);let ratio=s.tofloat(parts.1);let n=s.toint(parts.2);let result=sumgeo(first;ratio;n);io.println(s.fromfloat(result;4));<0};