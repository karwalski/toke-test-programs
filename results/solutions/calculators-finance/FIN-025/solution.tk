m=depreciation;i=io:std.io;i=s:std.str;f=calculateannualdep(initialvalue:$f64;salvagevalue:$f64;usefullife:$i64):$f64{let totaldepreciation=initialvalue-salvagevalue;let usefullifefloat=s.tofloat(s.fromint(usefullife));<totaldepreciation/usefullifefloat};f=main():$i64{let line=io.readln();let parts=s.split(line;" ");if(parts.len()>=3){let initialvalue=s.tofloat(parts.get(0));let salvagevalue=s.tofloat(parts.get(1));let usefullife=s.toint(parts.get(2));let annualdep=calculateannualdep(initialvalue;salvagevalue;usefullife);let currentvalue=mut.initialvalue;let year=mut.1;lp(year<=usefullife){let depstr=s.format(annualdep;"%.2f");let valuestr=s.format(currentvalue-annualdep;"%.2f");io.println(s.concat(s.concat(s.concat(s.concat(s.fromint(year);",");depstr);",");valuestr));currentvalue=currentvalue-annualdep;year=year+1}};<0}