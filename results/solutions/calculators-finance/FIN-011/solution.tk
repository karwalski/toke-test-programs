m=compoundinterest;i=io:std.io;i=s:std.str;i=math:std.math;f=compoundinterest(principal:$f64;rate:$f64;compfreq:$i64;time:$i64):$f64{let t=time as $f64;let n=compfreq as $f64;let base=1.0+rate/n;let exponent=n*t;let result=principal*math.pow(base;exponent);<result};f=main():$i64{let line=io.readln();let parts=s.split(line;" ");if(parts.len()>=4){let principal=s.tofloat(parts.get(0));let rate=s.tofloat(parts.get(1));let compfreq=s.toint(parts.get(2));let time=s.toint(parts.get(3));let result=compoundinterest(principal;rate;compfreq;time);io.println(s.format(result;"%.2f"))};<0}