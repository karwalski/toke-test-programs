m=lists;f=solve(p0:$str):$str{let result=mut."";let lines=p0.split("\n");let n=lines.len;lp(let i=0;i<n;i=i+1){let line=lines.get(i);let isunordered=line.startswith("- ");let isordered=line.startswith("1. ");let isbullet=mut.false;if(isunordered){isbullet=true};if(isordered){isbullet=true};if(isbullet){let num1=mut.0;let num2=mut.0;if(isunordered){num1=1;num2=1};if(isordered){num1=1;num2=1};let out=mut."";if(isunordered){out="unordered: "};if(isordered){out="ordered: "};out=s.concat(out;num1) as$str;result=s.concat(result;out);};<result};