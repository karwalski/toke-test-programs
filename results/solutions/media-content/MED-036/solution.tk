m=extractcode;f=extractcode(md:$str):@$str{let result=mut.@();let len=md.len;let i=mut.0;let incode=mut.false;let currentcode=mut."";lp(let idx=0;idx<len;idx=idx+1){let ch=md.get(idx);if(!(incode)){if(ch="["){let nextidx=idx+1;if(nextidx<len){let ch2=md.get(nextidx);if(ch2="("){let endidx=mut.idx+2;lp(let j=idx+2;j<len;j=j+1){let ch3=md.get(j);if(ch3=")"){endidx=j;br};};let block=md.slice(idx+2;endidx);result=result+@(block);idx=endidx;};};};}el{if(ch="]"){incode=false;};if(incode){currentcode=currentcode+ch;};};};};<result};