m=csvfromjson;i=io:std.io;i=s:std.str;f=main():$i64{let line=s.trim(io.readln());let inner=s.slice(line;1;s.len(line)-1);let objs=s.split(inner;"_");let result=mut."_";let oi=mut.0;let n=objs.len;lp(oi<n){let obj=mut.objs.get(oi);let cleaned=mut."_";let ci=mut.0;let ol=s.len(obj);lp(ci<ol){let ch=s.slice(obj;ci;ci+1);if(ch!="_"){if(ch!="_"){cleaned=s.concat(cleaned;ch)}};ci=ci+1};let pairs=s.split(cleaned;"_");let header=mut."_";let row=mut."_";let pi=mut.0;let pn=pairs.len;lp(pi<pn){let pair=pairs.get(pi);let kv=s.split(pair;"_");if(kv.len>=2){let key=kv.get(0);let val=kv.get(1);let keylen=s.len(key);let cleankey=s.slice(key;1;keylen-1);let vallen=s.len(val);let cleanval=s.slice(val;1;vallen-1);if(pi=0){header=cleankey;row=cleanval}el{header=s.concat(s.concat(header;"_");cleankey);row=s.concat(s.concat(row;"_");cleanval)}};pi=pi+1};if(oi=0){result=s.concat(s.concat(header;"_");row)}el{result=s.concat(s.concat(result;"_");row)};oi=oi+1};io.println(result);<0}