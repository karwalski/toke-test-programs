m=trigram;f=counttrigrams(text:$str):$str{let trigrams=mut.@();let words=text.split(" ");let n=words.len;lp(let i=0;i<n-2;i=i+1){let w1=words.get(i);let w2=words.get(i+1);let w3=words.get(i+2);let trigram=w1+" "+w2+" "+w3;trigrams=trigrams+@(trigram);};let counts=mut.@();lp(let i=0;i<trigrams.len;i=i+1){let t=trigrams.get(i);let found=mut.false;let j=mut.0;lp(let k=0;k<counts.len;k=k+1){let c=counts.get(k);if(c.trigram=t){found=true;j=k;};};if(found){let c=counts.get(j);c.count=c.count+1;counts.get(j)=c;}el{let newcount=$count{trigram:trigrams.get(i);count:1};counts=counts+@(newcount);};};let result=mut."";lp(let i=0;i<counts.len;i=i+1){let c=counts.get(i