m=extractheadings;f=extractheadings(s:$str):$str{let lines=s.split("\n");let result=mut."";lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);let isheader=mut.false;let headerlevel=mut.0;if(line.len>0){let firstchar=line.get(0);if(firstchar="#"){isheader=true;let j=mut.0;lp(let k=0;k<line.len;k=k+1){let ch=line.get(k);if(ch="#"){j=j+1}el{br}};headerlevel=j}}};if(isheader){let numstr=mut."";lp(let idx=0;idx<headerlevel;idx=idx+1){numstr=s.concat(numstr;"1");};let headingtext=line.slice(headerlevel;line.len));let outputline=s.concat("h";headerlevel) as$str+s.concat(s.concat(" ";headingtext);"\n");result=s.concat(result;outputline)}};result};f=main():$void{let input="## Section 1\n\n### Subsection 1.1\n\n## Section 2\n\n### Subsection 2.1\n\n";let headings=extractheadings(input);<