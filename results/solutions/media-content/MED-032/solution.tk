m=csvtfx;f=csvtfx(lines:@$str):$str{let result=mut."";let n=lines.len;lp(let i=0;i<n;i=i+1){let line=lines.get(i);let cols=mut.@();let col=mut."";lp(let j=0;j<line.len;j=j+1){let ch=line.get(j);if(ch=","){cols=cols+@(col);col="";}el{col=col+ch;};};cols=cols+@(col);let m=cols.len;lp(let k=0;k<m;k=k+1){let c=cols.get(k);let clen=c.len;let pad=mut.0;if(k=0){pad=8-clen;if(pad<0){pad=0};}el{pad=4-clen;if(pad<0){pad=0};};let spaces=mut."";lp(let s=0;s<pad;s=s+1){spaces=s.concat(spaces;" ")};result=result+c+spaces;};<result};