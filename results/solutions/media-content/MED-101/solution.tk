m=csvtojson;f=csvtojson(csv:$str):$str{let lines=csv.split("\n");let header=lines.get(0);let idxmap=mut.@();let i=0;lp(let j=0;j<header.len;j=j+1){let ch=header.get(j);if(ch=","){idxmap=idxmap+@(-1);i=i+1;}el{if(ch="\n"){idxmap=idxmap+@(-1);i=i+1;}el{let idx=j;idxmap=idxmap+@(idx);i=i+1;};};};};let jsonarr=mut."[";let n=lines.len;lp(let k=1;k<n;k=k+1){let line=lines.get(k);let obj=mut."{}";let m=idxmap.len;lp(let s=0;s<m;s=s+1){let idx=idxmap.get(s);if(!(idx<0)){let ch=line.get(idx);let key=mut."\"";let t=mut.0;lp(let u=0;u<idx;u=u+1){let c=line.get(u);key=key+c;};key=s.concat(key;"\"");let