m=fmtcols;f=fmtcols(items:@$str;n:$i64):$str{let itemcount=items.len;let itemspercol=itemcount/n;let remainder=itemcount-itemspercol*n;let result=mut."";lp(let i=0;i<itemspercol;i=i+1){lp(let j=0;j<n;j=j+1){let idx=j*itemspercol+i;if(!(idx<itemcount)){br};let item=items.get(idx);if(!(j=0)){result=s.concat(result;" ")};result=result+item};result=s.concat(result;"\n")};if(!(remainder=0)){lp(let k=0;k<remainder;k=k+1){lp(let j=0;j<n;j=j+1){let idx=j*itemspercol+k