m=wordbigram;f=extractbigrams(text:$str):@$str{let words=text.split(" ");let n=words.len;let bigrams=mut.@();lp(let i=0;i<n-1;i=i+1){let w1=words.get(i);let w2=words.get(i+1);let bg=w1+"_"+w2;bigrams=bigrams.push(bg)};<bigrams>};f=countbigramfreq(bigrams:@$str):$str{let freq=mut."";lp(let i=0;i<bigrams.len;i=i+1){let bg=bigrams.get(i);let found=mut.false;let j=mut.0;lp(let k=0;k<freq.len;k=k+1){let ch=freq.get(k);if(ch=bg){found=true;j=k};};if(found){j=j+1;freq=freq+bg}el{freq=freq+bg}};<freq>};f=wordbigram(text:$str):$str{let bigrams=extractbigrams(text);let freq=countbigramfreq(bigrams);<freq>};