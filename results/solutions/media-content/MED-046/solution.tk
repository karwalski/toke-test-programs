m=removeduplines;f=removeduplines(lines:@$str):@$str{let seen=mut.@($str);let result=mut.@($str);lp(let i=0;i<lines.len;i=i+1){let current=lines.get(i);let isduplicate=mut.false;lp(let j=0;j<seen.len;j=j+1){if(seen.get(j)=current)){isduplicate=true;};};if(!(isduplicate)){result=result+@(current);seen=seen+@(current);};};<result};