m=extract;f=extractimgs(html:$str):$str{let result=mut."";let i=mut.0;let len=html.len;lp(let idx=0;idx<len;idx=idx+1){let ch=html.get(idx);if(ch=">"){let start=idx+1;let end=mut.len;lp(let j=start;j<end;j=j+1){let c=html.get(j);if(c=" "){end=j;br};if(c="<"){end=j;br}};let tag=html.slice(start;end);let isimg=mut.false;let attrstart=mut.0;let attrend=mut.0;let lookingforattr=mut.true;lp(let k=0;k<tag.len;k=k+1){let ch2=tag.get(k);if(lookingforattr){if(ch2=" "){lookingforattr=false;attrstart=k+1;}el{if(ch2="/"){lookingforattr=false;attrstart=k+1;}el{if(ch2=">"){lookingforattr=false;attrstart=k+1;}el{}}}}}}