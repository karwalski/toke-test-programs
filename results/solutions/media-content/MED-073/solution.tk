m=breadcrumb;i=io:std.io;i=s:std.str;f=main():$i64{let line=s.trim(io.readln());let parts=s.split(line;"/");let n=parts.len;let result=mut."<nav><a href=\"/\">Home</a>";let acc=mut."";let idx=mut.1;lp(idx<n){let part=parts.get(idx);if(s.len(part)>0){acc=acc+"/"+part;if(idx<n-1){result=result+" / <a href=\""+acc+"\">"+part+"</a>"}el{result=result+" / "+part}};idx=idx+1};result=result+"</nav>";io.println(result);<0}