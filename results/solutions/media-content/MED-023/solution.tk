m=wordrank;f=rankword(text:$str):$i64{let words=text.split(" ");let freq=mut.@();lp(let i=0;i<words.len;i=i+1){let w=words.get(i);let found=mut.false;let idx=mut.0;lp(let j=0;j<freq.len;j=j+1){let entry=freq.get(j);if(entry.word=w){found=true;idx=j};};if(found){let entry=freq.get(idx);entry.count=entry.count+1;freq.set(idx;entry);}el{let entry=mut.$str{word:w;count:1};freq=freq+@(entry);};};let total=mut.0;lp(let i=0;i<freq.len;i=i+1){let entry=freq.get(i);total=total+entry.count;};let rank=mut.1