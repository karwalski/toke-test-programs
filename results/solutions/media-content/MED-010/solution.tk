m=spellcheck;f=checkword(word:$str;dict:$str):$str{let found=mut.false;let wlen=word.len;let dlen=dict.len;let i=mut.0;lp(let idx=0;idx<dlen;idx=idx+1){let ch=dict.get(idx);if(ch=word.get(i)){i=i+1;if(i=wlen){found=true};};if(i>0){i=i-1};};if(found){<word}el{<s.concat(word;"*")}};f=checktext(text:$str;dict:$str):$str{let result=mut."";let tlen=text.len;let dictlen=dict.len;let i=mut.0;lp(let idx=0;idx<tlen;idx=idx+1){let ch=text.get(idx);if(ch=32 as u8){let wlen=i-idx;let word=mut."";lp(let j=0;j<wlen;j=j+1){let ch=text.get(idx+j);word=s.concat(word;ch) as$str;};let checked=checkword(word;dict);result=result+checked;if(!(idx=tlen-1))result=s.concat(result;" ");i=idx+1