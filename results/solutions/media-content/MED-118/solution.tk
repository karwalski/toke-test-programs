m=icsparse;f=solve(p0:$str):$str{let lines=p0.split("\n");let events=mut.@();lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);let isdtstart=mut.false;let isdtend=mut.false;let issummary=mut.false;if(line.startswith("DTSTART:"))){isdtstart=true};if(line.startswith("DTEND:"))){isdtend=true};if(line.startswith("SUMMARY:"))){issummary=true};if(isdtstart){let start=line.slice(12);events=events+@(start)};if(isdtend){let end=line.slice(10);events=events+@(end)};if(issummary){let summary=line.slice(10);events=events+@(summary)}};let result=mut."";lp(let i=0;i<events.len;i=i+1){let event=events.get(i);result=result+event;if(!(i=(events.len-1)))){result=s.concat(result;"\n")}};<result};