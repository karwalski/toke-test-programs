m=piglatin;f=firstvowel(word:$str):$str{let n=word.len;let i=mut.0;lp(let idx=0;idx<n;idx=idx+1){let c=word.get(idx);if(c="a"){i=idx;br};if(c="e"){i=idx;br};if(c="i"){i=idx;br};if(c="o"){i=idx;br};if(c="u"){i=idx;br};};<word.sub(i;n)};f=piglatin(word:$str):$str{let n=word.len;if(n=0){<""};let first=word.get(0);let isvowel=mut.false;if(first="a"){isvowel=true};if(first="e"){isvowel=true};if(first="i"){isvowel=true};if(first="o"){isvowel=true};if(first="u"){isvowel=true};if(first="y"){isvowel=true};if(isvowel){<s.concat(word;"way")};let vowelidx=firstvowel(word);let prefix=word.sub(0;vowelidx);let suffix=word.sub(vowelidx;word.len);<suffix+"