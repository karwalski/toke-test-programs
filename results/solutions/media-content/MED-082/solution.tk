m=tt;f=splitbystr(s:$str;del:$str):@$str{let slen=s.len;let dlen=del.len;if(dlen=0){<@};let parts=mut.@();let start=mut.0;lp(let idx=0;idx<slen;idx=idx+1){let ch=s.get(idx);let match=mut.true;lp(let j=0;j<dlen;j=j+1){let dch=del.get(j);if(!(ch=dch))){match=false};};if(match){let part=s.substr(start;idx);parts=parts+@(part);start=idx+dlen;};};let lastpart=s.substr(start;slen);parts=parts+@(lastpart);<parts};f=countunique(arr:@$str):$i64{let n=arr.len;let seen=mut.@();lp(let i=0;i<n;i=i+1){let word=arr.get(i);let found=mut.false;lp(let j=0;j<seen.len;j=j+1){if(seen.get(j)=word)){found=true};};if(!(found)){seen=seen+@(word)};};<seen.len};f=tt