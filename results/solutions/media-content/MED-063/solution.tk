m=normlist;f=normlist(lhs:$str):$str{let n=lhs.len;let result=mut."";let i=mut.0;lp(let idx=0;idx<n;idx=idx+1){let ch=lhs.get(idx);if(ch="\n"){result=result+ch;i=0;}el{if(i=0){if(ch="*"){result=s.concat(result;"-");i=1;}el{if(ch="-"){result=s.concat(result;"-");i=1;}el{if(ch="+"){result=s.concat(result;"-");i=1;}el{result=result+ch;};};};};};};};};};};};};};};};};};};};};};};};};}