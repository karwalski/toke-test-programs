m=wordcount;f=solve(p0:$str):$i64{let words=mut.@();let n=p0.len;let i=mut.0;let word=mut."";lp(let j=0;j<n;j=j+1){let ch=p0.get(j);if(ch=32){if(word.len>0){words=words+word;word=""}}el{word=word+ch}};if(word.len>0){words=words+word}};let seen=mut.@();let m=words.len;lp(let k=0;k<m;k=k+1){let w=words.get(k);let found=mut.false;let s=seen.len;lp(let idx=0;idx<s;idx=idx+1){let v=seen.get(idx);if(v=w){found=true}}};if(!found){seen=seen+w}}};<seen.len>;};