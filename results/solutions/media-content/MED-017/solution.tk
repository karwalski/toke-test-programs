m=mdheadcheck;i=std.str:stdio;i=std.io:stdio;f=checkheads(lines:@$str):@$str{let result=mut.@();let i=mut.0;let n=lines.len as i64;lp(let lv=0;lv<n;lv=lv+1){let line=lines.get(lv);let isheader=mut.false;let headerlevel=mut.0;if(line.len>0){let firstchar=line.get(0);if(firstchar="#"){isheader=true;let idx=mut.1;lp(let lv2=0;lv2<line.len;lv2=lv2+1){let ch=line.get(lv2);if(!(ch="#")){idx=lv2;br;};};headerlevel=idx;};};};if(isheader){let currentlevel=headerlevel;if(!(currentlevel>0)){result=result+@(line);}el{if(!(currentlevel>1)){result=result+@(line);}el{if(!(currentlevel>2)){result=result+@(line);}el{if(!(currentlevel>3)){result=result+@(line);}el{result=result+@(line);};};};};}el{result=result+@(line);};};};<result};f=validate(lines:@$str):bool{let violations=checkheads(lines);let result=mut.true;if(!(violations.len=0 as u64)){}el{result=false;};<result};f=main():i64{let lines=mut.@();let i=mut.0;let n=mut.0;let c=mut.std.io.stdin.read(1000);let len=c.len;if(!(len=0)){lines=lines+@(c);};let result=validate(lines);if(result){std.io.stdout.write("PASS\n");}el{std.io.stdout.write("FAIL\n");};<0;};