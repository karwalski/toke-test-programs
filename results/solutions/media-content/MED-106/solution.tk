m=extract;f=extractquoted(text:$str):$str{let result=mut."";let len=text.len;let i=mut.0;lp(let idx=0;idx<len;idx=idx+1){let ch=text.get(idx);if(ch as u8=34 as u8){let start=mut.idx+1;lp(let j=start;j<len;j=j+1){let c=text.get(j);if(c as u8=34 as u8){let end=j;let extracted=text.sub(start;end-start);result=extracted;idx=end;};};};};<result};f=main():$void{let input="hello \"world\" foo \"bar\"";let output=extractquoted(input);let lines=output.split("\n");let count=lines.len;lp(let idx=0;idx<count;idx=idx+1){let line=lines.get(idx);if(!(line.len=0 as u64)){};};};