m=extractlinks;f=solve(p0:$str):$str{let result=mut."";let len=p0.len;let i=mut.0;lp(let idx=0;idx<len;idx=idx+1){let ch=p0.get(idx);if(ch="["){let j=mut.idx+1;lp(let k=j;k<len;k=k+1){let c=p0.get(k);if(c="]"){let m=mut.k+1;lp(let n=m;n<len;n=n+1){let bc=p0.get(n);if(bc="("){let o=mut.n+1;lp(let p=o;p<len;p=p+1){let cc=p0.get(p);if(cc=")"){let found=true;let linktext=p0.slice(j;k);let linkurl=p0.slice(o;p);if(result.len=0){result=s.concat(s.concat(s.concat(s.concat("1. [";linktext);"](");linkurl);")");i=1;}el{let nextidx=i+1;result=s.concat(result;"\n")+nextidx+s.concat(s.concat(s.concat(s.concat(". [";linktext);"](");linkurl);")");i=nextidx;};};};};};};};};};};};};};};};};};};};};};};};};}