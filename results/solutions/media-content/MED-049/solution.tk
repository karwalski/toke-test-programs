m=docstats;i=io:std.io;i=str:std.str;f=countchars(s:$str):i64{let n=str.len(s);<n};f=countwords(s:$str):i64{let n=str.len(s);let words=mut.0;let inword=mut.false;lp(let i=0;i<n;i=i+1){let c=str.charat(s;i);if(!(inword)){if(!(c=" ")){words=words+1;inword=true;};}el{if(c=" "){inword=false;}el{inword=true;};};};<words};f=countsentences(s:$str):i64{let n=str.len(s);let sentences=mut.0;let inword=mut.false;lp(let i=0;i<n;i=i+1){let c=str.charat(s;i);if(c="."){sentences=sentences+1;inword=false;}el{inword=true;};};<sentences};f=countparagraphs(s:$str):i64{let n=str.len(s);let paragraphs=mut.0;let inword=mut.false;lp(let i=0;i<n;i=i+1){let c=str.charat(s;i);if(c="\n"){paragraphs=paragraphs+1;inword=false;}el{inword=true;};};<paragraphs};f=avgwordlength(s:$str):f