m=worddiff;f=splitwords(text:$str):@$str{let words=mut.@();let current=mut."";let i=mut.0;lp(let idx=0;idx<text.len;idx=idx+1){let ch=text.get(idx);if(ch=" "){if(!(current="")){words=words+@(current);current="";};}el{current=current+ch;};};if(!(current="")){words=words+@(current);};<words};f=worddiff(a:$str;b:$str):$str{let wa=splitwords(a);let wb=splitwords(b);let result=mut."";let i=mut.0;let j=mut.0;lp(let idx=0;idx<wa.len;idx=idx+1){let waidx=wa.get(idx);let found=mut.false;let jval=mut.0;lp(let jidx=0;jidx<wb.len;jidx=jidx+1){let wbidx=wb.get(jidx);if(waidx=wbidx){found=true;jval=jidx;j=jidx;};};if(found){result=result+waidx+" ";j=j+1;}