m=template;f=render(template:$str;name:$str;value:$str):$str{let result=mut.template;let replacements=@(name;value);lp(let idx=0;idx<replacements.len;idx=idx+1){let key=replacements.get(idx);let val=replacements.get(idx+1);let pattern=key+"="+val;let result=mut.result;if(result.contains(pattern)){result=result.replace(pattern;"")}};<result};f=main():$void{let template="Hello, {{name}}! Your balance is {{value}}.";let result=render(template;"Alice";"100.00");<result;};