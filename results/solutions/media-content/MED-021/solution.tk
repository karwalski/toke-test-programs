m=bibsort;f=sortbyauthor(b:$str):$str{let lines=b.split("\n");let n=lines.len;let sorted=mut.@();lp(let i=0;i<n;i=i+1){let line=lines.get(i);let lastcomma=line.lastIndexOf(",");let lastname=line.substring(lastcomma+1;line.len);let trimmedname=lastname.trim();sorted=sorted+@(s.concat(trimmedname;" ")+line));};let result=mut."";lp(let i=0;i<sorted.len;i=i+1){let entry=sorted.get(i);let islast=i=sorted.len-1;if(!(islast)){result=result+entry+"\n";}el{result=result+entry;};};<result};