m=pack;f=solve(p0:$str;p1:$str):$str{let dir=p0;let outpath=p1;let files=std.file.list(dir);let count=files.len;let added=mut."";lp(let i=0;i<count;i=i+1){let f=files.get(i);let path=std.path.join(dir;f);let size=std.file.size(path);let line="added: "+path+" (size: "+size+" bytes)";added=s.concat(s.concat(added;line);"\n");};let final="Archive created: "+outpath+"\n";let result=s.concat(added;final);<result};