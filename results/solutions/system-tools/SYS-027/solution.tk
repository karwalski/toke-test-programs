m=mv;f=solve(p0:$str;p1:$str;p2:$str;p3:$str):$str{let srcdir=p0;let destdir=p1;let pattern=p2;let conflict=p3;let files=std.file.list(srcdir;pattern);let moved=mut.0;let skipped=mut.0;let errors=mut.0;lp(let i=0;i<files.len;i=i+1){let fname=files.get(i);let srcpath=std.path.join(srcdir;fname);let dstpath=std.path.join(destdir;fname);let shouldmove=mut.true;if(std.file.exists(dstpath)){if(conflict="skip"){shouldmove=false;}el{if(conflict="overwrite"){let overwriteok=mut.true;if(std.file.isreadonly(dstpath)){overwriteok=false;};if(overwriteok){std.file.remove(dstpath);};};el{let newname=std.str.concat(fname;"_backup");let newpath=std.path.join(destdir;newname);std.file.copy(dstpath;newpath);std.file.remove(dstpath);};};};if(shouldmove){std.file.move(srcpath;dstpath);moved=moved+1;}el{skipped=skipped+1;};};let summary=std.str.concat("MOVED ";std.str.concat(moved as$str;std.str.concat(" src -> dst (";std.str.concat(files.len as$str;")"))))));let result=std.str.concat(summary;std.str.concat(" Skipped ";std.str.concat(skipped as$str;std.str.concat(" Errors ";errors as$str))))));<result};