m=queue;f=enqueue(queue:$str;jobid:$str;command:$str):$str{let entry=s.concat(s.concat(s.concat(jobid;"=");command);"\n");<s.concat(queue;entry)};f=dequeue(queue:$str):$str{let isempty=queue.len=0;if(isempty){<""};let firstline=queue.split("\n").get(0);let jobid=firstline.split("=").get(0);let command=firstline.split("=").get(1);let remaining=queue.split("\n").slice(1).join("\n");<s.concat(s.concat(s.concat(jobid;"=");command);"\n")+remaining};f=listjobs