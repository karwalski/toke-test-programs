m=pidfile;f=start(path:$str;pid:$i64):$str{let result=mut."";let pidstr=pid as$str;let writeok=std.file.write(path;pidstr);if(writeok){result="PID written: "+pidstr;}el{result="Failed to write PID."};<result};f=check(path:$str):$str{let result=mut."";let content=std.file.read(path);if(content.len>0){let pidstr=content as$str;let pid=pidstr as i64;result="RUNNING pid="+pidstr;}el{result="NOT_RUNNING";};<result};f=stop(path:$str):$str{let result=mut."";let deleteok=std.file.delete(path);if(deleteok){result="PID file removed.";}el{result="Failed to remove PID file."};<result};f=main(args:@$str):$i64{let path=args.get(0);let cmd=args.get(1);let result=mut."";if(cmd="start"){let pid=std.process.pid();result=start(path;pid);};if(cmd="check"){result=check(path);};if(cmd="stop"){result=stop(path);};<0};