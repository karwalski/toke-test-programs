m=systemdstatus;f=processline(line:$str):$str{let parts=line.split(" ");let pid=parts.get(1);let state=parts.get(2);let sub=parts.get(3);let result=pid+":"+state+" sub="+sub;<result};f=main():$void{let reader=std.process.spawn("systemctl";@("list-units";"--type=service";"--state=active,loading"))));let out=reader.stdout;let lines=out.split("\n");let n=lines.len;lp(let i=0;i<n;i=i+1){let line=lines.get(i);let result=processline(line);let printline=result;<printline};};