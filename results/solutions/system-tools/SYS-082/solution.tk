m=merge;f=mergesortedfiles(n:$str;m:$str):$str{let a=mut.@();let b=mut.@();let i=mut.0;let j=mut.0;let linea=mut."";let lineb=mut."";let filea=mut.std.file.open(n);let fileb=mut.std.file.open(m);lp(let k=0;k<1000;k=k+1){linea=std.file.readline(filea);lineb=std.file.readline(fileb);if(linea=""){i=1000};if(lineb=""){j=1000};if(i<1000){if(j<1000){if(linea<lineb){a=a+@(linea);i=i+1;}el{a=a+@(lineb);j=j+1;};}el{a=a+@(linea);i=i+1;};};};let result=mut."";lp(let idx=0;idx<a.len;idx=idx+1){result=result+a.get(idx);};<result};