m=filechecksum;f=hashfile(filepath:$str):$str{let data=std.io:readfile(filepath);let hash=std.crypto:sha256(data);<hash};f=verifysum(filepath:$str;expectedsum:$str):$bool{let computedsum=hashfile(filepath);let verificationresult=mut.false;if(computedsum=expectedsum){verificationresult=true}el{verificationresult=false};<verificationresult};f=main(args:@$str):$i64{let mode=mut."";let filepath=mut."";let expectedsum=mut."";let i=mut.1;lp(let idx=0;idx<args.len;idx=idx+1){let arg=args.get(idx);if(i=1){mode=arg;i=i+1;}el{if(i=2){filepath=arg;i=i+1;}el{if(i=3){expectedsum=arg;i=i+1;}el{}}}}};if(mode="verify"){let verificationresult=verifysum(filepath;expectedsum);if(verificationresult=true){<0}el{<1}}el{<2}}};