m=textstats;f=charfreq(text:$str):$str{let freq=mut."";let i=mut.0;lp(let idx=0;idx<text.len;idx=idx+1){let ch=text.get(idx);let found=mut.false;lp(let jdx=0;jdx<freq.len;jdx=jdx+1){let pair=freq.get(jdx);if(pair.get(0)=ch){found=true};};if(!(found)){freq=freq+ch+"1";}el{lp(let jdx=0;jdx<freq.len;jdx=jdx+1){let pair=freq.get(jdx);if(pair.get(0)=ch){let count=pair.get(1);freq=freq+ch+count+1;};};};<freq};f=topwords(text:$str;n:$i64):$str{let words