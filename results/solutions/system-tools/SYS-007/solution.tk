m=syncdirs;f=usage():$str{<"Usage: toke syncdirs <source> <dest>"}};f=syncdirs(sourcepath:$str;destpath:$str):$i64{let sourcedir=sourcepath;let destdir=destpath;let files=std.file.list(sourcedir);let skipped=mut.0;let copied=mut.0;let errors=mut.0;lp(let i=0;i<files.len;i=i+1){let file=files.get(i);let sourcefile=sourcedir+"/"+file;let destfile=destdir+"/"+file;let destexists=std.file.exists(destfile);let sourceinfo=std.file.info(sourcefile);let destinfo=std.file.info(destfile);let shouldcopy=mut.false;if(!(destexists)){shouldcopy=true;}el{if(destinfo.mtime<sourceinfo.mtime)){shouldcopy=true;}el{if(destinfo.size<sourceinfo.size)){shouldcopy=true;}el{shouldcopy=false;};};};if(shouldcopy){let result=std.file.copy(sourcefile;destfile);if(result){copied=copied+1;}el{errors=errors+1;};}el{skipped=skipped+1;};};let summary="Copied: "+copied+" files\nSkipped: "+skipped+" files\nErrors: "+errors+" files";<summary};f=main():$i64{let args=std.file.args();let sourcepath=args.get(1);let destpath=args.get(2);let result=syncdirs(sourcepath;destpath);<0;};f=cleanpath(path:$str):$str{let result=mut.path;if(result.len>0){if(result.get(0)as u8=47 as u8)){result=result.slice(1;result.len);};};<result};