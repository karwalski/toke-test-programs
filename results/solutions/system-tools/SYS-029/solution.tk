m=procmon;i=process:std.process;i=log:std.log;f=spawnandmonitor(cmd:$str):$void{let h=process.spawn(cmd);let signals=@("SIGINT";"SIGTERM";"SIGHUP");lp(let i=0;i<signals.len;i=i+1){let s=signals.get(i);let handled=mut.false;let handler=process.on(s;h);if(handler=handler){handled=true};if(handled){log.info("procmon: intercepted "+s)}el{log.warn("procmon: failed to intercept "+s))};let exitcode=process.wait(h);log.info(s.concat("procmon: child process exited with code ";exitcode) as$str)};f=main():$void{let cmd="sleep 3600";spawnandmonitor(cmd)};