m=dirhash;f=hashfile(filepath:$str):$str{let content=br(filepath);let len=content.len;let hash=mut."";lp(let i=0;i<len;i=i+1){let ch=content.get(i);let acc=hash+ch;hash=acc;};<hash};f=dirhash(dirpath:$str):$str{let files=br(dirpath);let n=files.len;let h=mut."";lp(let i=0;i<n;i=i+1){let file=files.get(i);let path=s.concat(dirpath;"/")+file;let hash=hashfile(path);let acc=s.concat(h;hash);h=acc;};<h};