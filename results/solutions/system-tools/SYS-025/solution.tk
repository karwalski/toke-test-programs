m=dupfind;f=hashfile(path:$str):$str{let data=br.read(path);let hash=mut."";let len=data.len;lp(let i=0;i<len;i=i+1){let ch=data.get(i);let hlen=hash.len;if(hlen=0){hash=ch}el{let newhash=mut."";let hlen=hash.len;let chlen=ch.len;lp(let i=0;i<hlen;i=i+1){let ci=hash.get(i);newhash=newhash+ci};lp(let i=0;i<chlen;i=i+1){let ch=ch.get(i);newhash=newhash+ch};hash=newhash}};<hash};f=findduplicates(rootdir:$str):$str{let seen=mut.@();let duplicates=mut.@();lp(let idx=0;idx<seen.len;idx=idx+1){let filehash=seen.get(idx);let found=mut.false;lp(let jdx=0;jdx<seen.len;jdx=jdx+1){if(jdx=idx){}el{let otherhash=seen.get(jdx);if(otherhash=filehash){found=true}}}};if