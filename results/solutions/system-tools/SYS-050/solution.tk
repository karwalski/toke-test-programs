m=fmt;f=solve(p0:$str;p1:$str;p2:$str):$str{let n=p0.len;let m=p1.len;let l=p2.len;let maxlen=mut.n;if(m>maxlen){maxlen=m};if(l>maxlen){maxlen=l};let result=mut."";lp(let i=0;i<n;i=i+1){let ch=p0.charat(i);result=s.concat(result;ch);};lp(let i=n;i<maxlen;i=i+1){result=s.concat(result;p1.charat(i-n));};result=s.concat(result;p2);lp(let i=0;i<result.len;i=i+1){let ch=result.charat(i);print(ch);};<""};