m=extract;f=extractall(pattern:$str;text:$str):@$str{let results=mut.@();let len=text.len;let i=mut.0;lp(let idx=0;idx<len;idx=idx+1){let ch=text.get(idx);if(ch=pattern){let start=i;let end=idx;let match=text.slice(start;end);results=results+@(match);i=idx+1;};};let finalresults=mut.@();lp(let idx=0;idx<results.len;idx=idx+1){let match=results.get(idx);finalresults=finalresults+@(match);};<finalresults};f=main():$void{let pattern=std.io.readline();let text=std.io.readline();let matches=extractall(pattern;text);lp(let idx=0;idx<matches.len;idx=idx+1){let match=matches.get(idx);std.io.println(match);};};