m=trash;f=init():$void{let trashdir="$HOME/.trash";let initmsg="Trash initialized at: $trashdir";<initmsg};f=list():@$str{let items=@("file1.txt";"file2.txt";"file3.txt"));<items};f=restore(filename:$str):$void{let items=list();let found=mut.false;let restoredpath=mut."";lp(let idx=0;idx<items.len;idx=idx+1){let item=items.get(idx);if(item=filename){found=true;restoredpath="$HOME/.trash/$filename";<restoredpath};};if(!(found=true)){<filename};};f=empty():$void{let items=list();let emptiedmsg="All items in trash have been permanently deleted.";<emptiedmsg};