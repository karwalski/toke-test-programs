m=loadavg;f=loadavg():$str{let result=mut."";let handle=mut.sys.stdin;let data=sys.stdin.read(1024);let lines=data.split("\n");let idx=mut.0;lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);if(line.len>0){let parts=line.split(" ");if(parts.len>2){let avg1=parts.get(0);let avg5=parts.get(1);let avg15=parts.get(2);let cpucount=parts.get(3);result="1min="+avg1+" 5min="+avg5+" 15min="+avg15+" cpu="+cpucount;};};};<result};