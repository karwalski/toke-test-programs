m=sorter;f=sortbyfield(lines:@$str;n:$i64):@$str{let count=lines.len;let result=mut.@();lp(let i=0;i<count;i=i+1){let line=lines.get(i);let fields=line.split(" ");let fieldcount=fields.len;let idx=mut.0;if(n<fieldcount){idx=n}el{idx=0};let key=fields.get(idx);let inserted=mut.false;let newresult=mut.@();lp(let j=0;j<result.len;j=j+1){let r=result.get(j);let rkey=fields.get(idx);if(key<rkey){newresult=newresult+@(key);newresult=newresult+@(r);inserted=true;}el{newresult=newresult+@(r);};};if(!(inserted)){newresult=newresult+@(key);};result=newresult;};<result};f=sortbyfielddesc(lines:@$str;n:$i64):@$str{let sorted=sortbyfield(lines;n);let count=sorted