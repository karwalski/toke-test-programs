m=memstat;f=parsebytes(s:$str):$i64{let n=s.len;let v=mut.0;let i=mut.0;lp(let j=0;j<n;j=j+1){let c=s.get(j);if(c>47){if(c<58){let d=c-48;v=v*10+d;i=j+1;}}}};if(i<n){let c=s.get(i);if(c>64){if(c<91){let d=c+32;v=v*10+d;i=i+1;}}}};};<v};f=totalbytes(p:$i64;q:$i64):$i64{let b=mut.0;lp(let i=0;i<q;i=i+1){b=b+p;};<b};f=avgbytes(arr:@$i64):$i64{let n=arr.len;let m=mut.0;lp(let i=0;i<n;i=i+1){m=m+arr.get(i);};<m/n};f=maxbytes(arr:@$i64):$i64{let n=arr.len