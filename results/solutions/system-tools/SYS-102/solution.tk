m=filecrypt;f=solve(p0:$str;p1:$str;p2:$str;p3:$str):$str{let mode=p0;let infile=p1;let outfile=p2;let passphrase=p3;let result=mut."";if(mode="encrypt"){let cmd="openssl enc -aes-256-cbc -salt -in ";let tail=" -out ";let fullcmd=cmd+infile+passphrase+tail+outfile;let r=std.process.run(fullcmd);if(r.exitcode=0){result="Encrypted: "+outfile}el{result="Encryption failed"}}el{if(mode="decrypt"){let cmd="openssl enc -d