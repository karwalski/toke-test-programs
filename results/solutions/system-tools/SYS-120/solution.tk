m=extract;f=solve(p0:$str):$str{let lhs=mut."";let rhs=mut."";let sepfound=mut.false;lp(let i=0;i<p0.len;i=i+1){let c=p0.get(i);if(!(sepfound)){if(c=58){sepfound=true}el{lhs=lhs+c}}el{rhs=rhs+c}}};<lhs>;};f=extractbytes(s:$str):$str{let parts=s.split(58);if(parts.len=0){<""};let lhs=parts.get(0);let rhs=parts.get(1);<s.concat(s.concat(lhs;":");rhs)};f=main():$str{let input="text:hello world";let step1=solve(input);let step2=extractbytes(step1);<step2>};