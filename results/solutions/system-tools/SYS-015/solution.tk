m=lockmgr;f=lockfile(path:$str):$str{<path};f=lockname(path:$str):$str{let fname=mut."";let i=mut.0;lp(let idx=0;idx<path.len;idx=idx+1){let ch=path.get(idx);if(ch="/"){i=0}el{i=i+1}};fname=path.substr(0;i);<fname};f=lockext(path:$str):$str{let fname=lockname(path);let dotpos=mut.-1;lp(let idx=0;idx<fname.len;idx=idx+1){let ch=fname.get(idx);if(ch="."){dotpos=idx}};if(dotpos<0){<""};let ext=fname.substr(dotpos+1;fname.len));<ext};f=lockdir(path:$str):$str{let fname=lockname(path);let dir=fname.substr(0;fname.len-4));<dir};f=lockhash(path:$str):$str{let fname=lockname(path);let hash=fname.substr(fname.len-4;fname.len));<hash};f=lockextcheck(path:$str):$str{