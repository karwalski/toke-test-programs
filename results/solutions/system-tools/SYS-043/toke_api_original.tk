m=crontab;f=parsefield(field:$str):$str{let result=mut."";let parts=field.split("/");let base=parts.get(0);let step=parts.len>1?parts.get(1):"1";let num=base as i64;let stepval=step as i64;let rem=num-num/stepval*stepval;if(rem=0){result=base}el{result="1"};<result};f=parsecronline(line:$str):$str{let parts=line.split(" ");let minute=parts.get(0);let hour=parts.get(1);let day=parts.get(2);let month=parts.get(3);let weekday=parts.get(4);let result=mut."";let minpart=parsefield(minute);let hourpart=parsefield(hour);let daypart=parsefield(day);let monthpart=parsefield(month);let weekdaypart=parsefield(weekday);result=minpart+" "+hourpart+" "+daypart+" "+monthpart+" "+weekdaypart;<result};f=main():$i64{let lines=@("0 12 * * *";"0 1