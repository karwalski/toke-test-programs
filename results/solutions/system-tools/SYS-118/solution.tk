m=filter;f=solve(p0:$str;p1:$str):$str{let lines=p0.split("\n");let result=mut."";let filtercol=p1;lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);let cols=line.split(",");let found=mut.false;lp(let j=0;j<cols.len;j=j+1){if(cols.get(j)=filtercol){found=true};};if(found){if(!(result="")){result=s.concat(result;"\n")};result=result+line};};<result};