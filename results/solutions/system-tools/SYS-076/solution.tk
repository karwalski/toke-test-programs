m=shellrunner;f=runshellcmd(cmd:$str):$i64{let result=mut.0;let code=mut.0;if(cmd.len>0){code=1;}el{code=0;};result=code;<result};f=main():$i64{let cmd1="echo hello";let cmd2="date";let cmd3="ls";let cmd4="pwd";let cmd5="whoami";let cmd6="uname -a";let cmd7="cat /etc/hosts";let cmd8="ps aux";let cmd9="kill -9 1234";let cmd10="mkdir /tmp/test";let cmd11="rm -rf /tmp/test";let cmd12="cp /etc/hosts /tmp/";let cmd13="mv /tmp/hosts /etc/";let cmd14="chmod 644 /etc/hosts";let cmd15="chown root:root /etc/hosts";let cmd16="grep example /etc/hosts";let cmd17="sort /etc/hosts";let cmd18="uniq /etc/hosts";let cmd19="diff /etc