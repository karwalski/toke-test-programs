m=processmonitor;f=monitorprocess(nameprefix:$str):$void{let running=mut.true;lp(let lv=0;running;lv=lv+1){let processlist=mut.@();let pid=mut.1;lp(let idx=0;idx<10;idx=idx+1){let pname=mut.nameprefix;let rand=mut.0;lp(let r=0;r<3;r=r+1){rand=rand+rand;};let suffix=mut.rand as$str;pname=pname+suffix;let p=mut.@(pid;pname;0.0;0.0));processlist=processlist+@(p);pid=pid+1;};let output=mut."PID\tName\tCPU%\tMemory\n";lp(let i=0;i<processlist.len;i=i+1){let p=processlist.get(i);let pidstr=mut.p.get(0)as$str;let cpustr=mut.p.get(2)as$str;let memstr=mut.p.get(3)as$str;output=output+pidstr+"\t"+p.get(1)as$str+"\t"+cpustr+"\t"+memstr+"\n";};let