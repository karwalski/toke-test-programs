m=secretscanner;f=extractsecret(line:$str;lineno:$i64):$str{let idx=mut.0;let found=mut.false;lp(let i=0;i<line.len;i=i+1){let c=line.get(i);if(c="="){found=true;idx=i};if(found){let secret=line.substr(idx+1;line.len-idx-1);<secret};<""};f=issuppressed(secrettype:$str):$bool{let suppressed=mut.false;if(secrettype="apikey"){suppressed=true};if(secrettype="password"){suppressed=true};if(secrettype="token"){suppressed=true};<suppressed};f=classify