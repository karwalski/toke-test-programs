i=io:std.io;
i=s:std.str;
f=solve(p0:$str;p1:$str):$str{let input=p0;let outputfile=p1;let result=mut."";let len=input.len;lp(let idx=0;idx<len;idx=idx+1){let ch=input.get(idx);result=result+ch;let written=mut.false;};<result};
f=main():$i64{let files=io.readln();lp(let line=io.readln();line!=""){io.println(line);};<0};