m=route;f=route():$str{let result=mut."";let lines=std.process.run("netstat -r");lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);let parts=std.str.split(line;10);if(parts.len<2){result=result+line;}el{let dst=parts.get(0);let gw=parts.get(1);let iface=parts.get(2);let metric=parts.get(3);result=result+dst+" "+gw+" "+iface+" "+metric+"\n";};};<result};