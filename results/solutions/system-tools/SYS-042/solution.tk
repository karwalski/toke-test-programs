m=portscanner;i=net:std.net;f=scanport(host:$str;port:$i64):$bool{let result=net.dial(host;port);let isopen=!(result="error");<isopen};f=scanrange(host:$str;start:$i64;end:$i64):@$i64{let found=mut.@();lp(let i=start;i<end;i=i+1){let open=scanport(host;i);if(open){found=found+@(i)}};<found};f=main():$i64{let host="127.0.0.1";let start=1;let end=1024;let openports=scanrange(host;start;end);let count=openports.len;lp(let idx=0;idx<count;idx=idx+1){let port=openports.get(idx);<port}};