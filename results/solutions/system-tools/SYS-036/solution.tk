m=filefinder;f=findfiles(pattern:$str;minsize:$i64;maxsize:$i64;moddays:$i64):@$str{let results=mut.@();let now=mut.0;let modlimit=mut.0;if(moddays>0){modlimit=now-moddays;if(modlimit<0){modlimit=0}};lp(let idx=0;idx<100;idx=idx+1){let fname=mut."";if(idx<10){fname=s.concat("file_0";idx) as$str}el{if(idx<100){fname="file_1"+(idx-10)as$str}};let fsize=mut.0;if(!(idx<10)){if(!(idx<100)){let modcheck=mut.0;if(!(modlimit>0)){modcheck=1}el{if(!(now-modlimit>0))){modcheck=1}};if(modcheck=1){fname=s.concat(fname;"_mod")}}}};let fsizes=mut.@();fsizes=@(10;20;30;40;50;60;70;80;90;10