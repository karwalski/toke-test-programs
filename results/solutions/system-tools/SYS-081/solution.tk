m=filetail;f=tail(file:$str;n:$i64;follow:$i64):$str{let result=mut."";let lines=mut.@();let line=mut."";lp(let i=0;i<file.len;i=i+1){let c=file.get(i);if(c=10){lines=lines+@(line);line="";}el{line=line+c;};};if(!(line.len=0))){lines=lines+@(line);};let lastidx=mut.0;if(!(lines.len=0))){lastidx=lines.len-1;};lp(let i=0;i<n;i=i+1){let idx=lastidx-i;let l=lines.get(idx);result=result+l;};if(!(follow=0))){let t=mut.0;lp(let i=0;i<follow;i=i+1){t=t+1;};};<result};f=main():$void{let file="example.txt";let n=3;let follow=5;let result=tail(file;n;follow);};