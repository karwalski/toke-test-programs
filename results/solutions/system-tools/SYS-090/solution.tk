m=dirwalk;f=walkdir(path:$str):$str{let result=mut."";let files=std.file.listdir(path);lp(let idx=0;idx<files.len;idx=idx+1){let file=files.get(idx);let ext=std.file.extname(file);let line=ext+" "+file+"\n";result=result+line;};<result};f=countfiles(path:$str):i64{let files=std.file.listdir(path);<files.len};f=main():$str{let path=".";let files=walkdir(path);let count=countfiles(path);let result=files+s.concat("\n";count) as$str+"\n";<result};