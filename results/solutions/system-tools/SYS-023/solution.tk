m=solve;
i=io:std.io;
i=s:std.str;
f=solve(p0:$str):$str{let p=mut.p0;let q=mut."";let found=mut.false;lp(let idx=0;idx<p.len;idx=idx+1){let ch=p.get(idx);if(ch="/"){found=true};if(!(found)){q=q+ch};};if(found){<q};<p};
f=main():$i64{let line=io.readln();let result=solve(line);io.println(result);<0};