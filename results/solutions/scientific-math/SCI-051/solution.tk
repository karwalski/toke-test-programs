m=convexhull;f=convexhull(points:@($i64;$i64)):@($i64;$i64)){let n=points.len;if(n<3){<points};let result=mut.@($i64;$i64));let p0=mut.0;let miny=mut.points.get(0).y;lp(let i=1;i<n;i=i+1){let y=points.get(i).y;if(y<miny){miny=y;p0=i};};result=result+@(points.get(p0)));let q=mut.0;lp(let i=0;i<n;i=i+1){if(i=p0){<i};let dx=points.get(i).x-points.get(p0).x;let dy=points.get(i).y-points.get(p0).y;if(dy<0){q=i};if(dy=0){if(dx<0){q=i}}};}