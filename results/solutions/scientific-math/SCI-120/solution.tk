m=hamiltonian;f=hamiltonian(g:$str):$str{let n=g.len;let m=mut.0;let edges=mut.@();lp(let i=0;i<n;i=i+1){let line=g.split(i);let parts=line.split(" ");lp(let j=0;j<parts.len-1;j=j+1){let from=parts.get(j);let to=parts.get(j+1);let found=mut.false;lp(let k=0;k<edges.len;k=k+1){let e=edges.get(k);if(e.from=from){if(e.to=to){found=true}}}};if(!(found=true)){let e=$str{from:from;to:to};edges=edges+@(e)};};};let start=g.split(0);let s=start.split(" ");let startvertex=s.get(1);let visited=mut.@();lp(let i=0;i<n;i=i+1){visited=visited+@(false)};let path=mut.@();lp(let i=0;i<n;i=i+1){path=path+@(-1)};let result=mut.@();lp(let i=0;i<n;i=i+1){result