m=dkpoly;f=evalpoly(coeffs:@$cpx;val:$cpx):$cpx{let res=mut.0;lp(let i=0;i<coeffs.len;i=i+1){let lhs=res;let rhs=coeffs.get(i);res=lhs+rhs*val;};<res};f=dkpoly(coeffs:@$cpx):@$cpx{let n=coeffs.len;let guess=mut.@$cpx;lp(let i=0;i<n;i=i+1){guess=guess+@($cpx{re:0;im:0})};let res=mut.@$cpx;lp(let i=0;i<n;i=i+1){let g=guess.get(i);let eg=evalpoly(coeffs;g);let next=mut.g-eg/(1+eg*eg));res=res+@(next);}