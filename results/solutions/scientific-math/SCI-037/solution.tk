m=lcs;f=lcslen(a:$str;b:$str):$i64{let m=a.len;let n=b.len;let dp=mut.@(0);lp(let i=0;i<m+1;i=i+1){lp(let j=0;j<n+1;j=j+1){if(i=0){if(j=0){dp=@(0);}el{dp=dp+@(0);};};}el{if(j=0){dp=dp+@(0);}el{if(a.get(i-1))=b.get(j-1)){dp=dp+@(dp.get(i-1).get(j-1))+1);}el{let x=dp.get(i-1).get(j));let y=dp.get(i).get(j-1));if(x>y){dp=dp+@(x);}el{dp=dp+@(y);};};};};};};};};};};};};};};};};};};};};};};};};}