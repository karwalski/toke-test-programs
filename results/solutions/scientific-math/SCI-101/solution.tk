m=excl;f=binomial(n:$i64;m:$i64):$i64{if(m>n){<0};let result=mut.1;lp(let i=0;i<m;i=i+1){result=result*(n-i)/(i+1));};<result};f=incl(ex:$i64;other:$i64):$i64{if(ex=other){<ex};if(ex<other){<ex};<other};f=excl(ex:$i64;other:$i64):$i64{if(ex=other){<0};if(ex<other){<ex};<other};f=main():$i64{let n=10;let m=5;let binom=binomial(n;m);let excl=excl(binom;0);let incl=incl(excl;binom);<incl};