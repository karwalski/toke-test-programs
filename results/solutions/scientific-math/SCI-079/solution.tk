m=sudoku;f=solve(p:$i64;q:$i64):$i64{let result=mut.p;let n=result.len;lp(let i=0;i<n;i=i+1){if(result.get(i)=0){let j=mut.0;lp(let k=0;k<n;k=k+1){let cell=result.get(k);if(cell=j){j=j+1};};let found=mut.false;lp(let idx=0;idx<n;idx=idx+1){let cell=result.get(idx);if(cell=0){result.get(idx)=j;found=true;j=j+1;if(j>n){j=1};};};if(found){solve(result;q;q)}el{<result};}f=validatenine(arr:$i64):bool{let n=arr.len;let valid=mut.true;lp(let i=0;i<n;i=i+1){let cell=arr.get(i);if(cell<1){valid=false};if(cell>9){valid=false};};let seen=mut.@(false;false;false;false;false;false;false;false);lp(let idx=0;idx<n;idx=idx+1){let cell=arr.get(idx);let cellidx=cell-1;if(seen.get(cellidx)){valid=false};seen.get(cellidx)=true;};<valid};f=validat