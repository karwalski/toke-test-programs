m=bezier;f=bernstein(n:$i64;m:$i64):$f64{let result=mut.1.0;let k=mut.0;lp(let idx=0;idx<m;idx=idx+1){k=k+1;result=result*(n-k)as$f64;result=result/k as$f64;};<result};f=beziereval(points:@$f64;t:$f64):$f64{let n=points.len;let m=mut.0;lp(let idx=0;idx<n;idx=idx+1){let cond=mut.false;if(idx=0){cond=true};if(cond){m=m+bernstein(n-1;idx as$i64)*points.get(idx)*(1.0-t));}el{m=m+bernstein(n-1;idx as$i64)*points.get(idx)*t;};};<m};