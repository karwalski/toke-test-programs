m=binomial;i=io:std.io;i=s:std.str;f=binomial(n:$i64;k:$i64):$i64{if(k<0){<0};if(k>n){<0};let result=mut.1;lp(let i=0;i<k;i=i+1){result=result*(n-i);result=result/(i+1)};<result};f=main():$i64{let n=s.toint(io.readln());lp(let row=0;row<n;row=row+1){let output=mut."";lp(let col=0;col<=row;col=col+1){if(col>0){output=s.concat(output;" ")};output=s.concat(output;s.fromint(binomial(row;col)))};io.println(output)};let line=io.readln();if(s.length(line)>0){let parts=s.split(line;" ");let queryN=s.toint(parts[0]);let queryK=s.toint(parts[1]);let result=binomial(queryN;queryK);io.println(s.concat(s.concat(s.concat(s.concat(s.concat("C(";s.fromint(queryN));",");s.fromint(queryK));") = ");s.fromint(result)))};< 0}