m=fibonacci;i=io:std.io;i=s:std.str;f=fibiter(n:$i64):$str{let output=mut."";if(n>=0){output="0"};if(n>=1){output=s.concat(output;" 1")};if(n>=2){let a=mut.1;let b=mut.1;let idx=mut.2;lp(idx<=n){let next=a+b;output=s.concat(s.concat(output;" ");s.fromint(next));b=a;a=next;idx=idx+1}};<output};f=main():$i64{let n=s.toint(io.readln());let method=s.trim(io.readln());if(method="iterative"){io.println(fibiter(n))};<0}