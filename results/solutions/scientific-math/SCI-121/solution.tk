m=graph;i=io:std.io;i=s:std.str;f=main():$i64{let line=io.readln();let parts=s.split(line;" ");if(parts.len()>=2){let n=s.toint(parts.get(0));let edges=s.toint(parts.get(1));let adj=mut.@();let idx=mut.0;lp(idx<n){adj=adj+@();idx=idx+1};let e=mut.0;lp(e<edges){let edgeline=io.readln();let edgeparts=s.split(edgeline;" ");if(edgeparts.len()>=2){let u=s.toint(edgeparts.get(0));let v=s.toint(edgeparts.get(1));let uadj=mut.adj.get(u);uadj=uadj+@(v);let newadj=mut.@();let k=mut.0;lp(k<adj.len){if(k=u){newadj=newadj+uadj}el{newadj=newadj+adj.get(k)};k=k+1};adj=newadj;let vadj=mut.adj.get(v);vadj=vadj+@(u);let newadj2=mut.@();k=0;lp(k<adj.len){if(k=v){newadj2=newadj2+vadj}el{newadj2=newadj2+adj.get(k)};k=k+1};adj=newadj2};e=e+1};let colors=mut.@();let c=mut.0;lp(c<n){colors=colors+@(-1);c=c+1};let node=mut.0;lp(node<n){let used=mut.@();let neighs=adj.get(node);let j=mut.0;lp(j<neighs.len){let neigh=neighs.get(j);let neighcolor=colors.get(neigh);if(neighcolor!=-1){used=used+@(neighcolor)};j=j+1};let color=mut.0;let found=mut.0;lp(found=0){let k=mut.0;let present=mut.0;lp(k<used.len){if(used.get(k)=color){present=1};k=k+1};if(present=0){found=1}el{color=color+1}};let newcolors=mut.@();let z=mut.0;lp(z<colors.len){if(z=node){newcolors=newcolors+@(color)}el{newcolors=newcolors+colors.get(z)};z=z+1};colors=newcolors;node=node+1};let output=mut."Colouring: ";let p=mut.0;lp(p<n){output=s.concat(output;s.concat(s.fromint(p);s.concat("=";s.fromint(colors.get(p)))));if(p<n-1){output=s.concat(output;" ")};p=p+1};io.println(output);let maxcolor=mut.0;let q=mut.0;lp(q<n){if(colors.get(q)>maxcolor){maxcolor=colors.get(q)};q=q+1};io.println(s.concat("Colours used: ";s.fromint(maxcolor+1)))};<0}