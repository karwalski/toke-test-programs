m=convexhull;f=sortbyangle(points:@($i64;$i64))):@$i64{let n=points.len;let sorted=mut.@();lp(let i=0;i<n;i=i+1){sorted=sorted+@(i)};lp(let i=0;i<n;i=i+1){lp(let j=i+1;j<n;j=j+1){let dx1=points.get(sorted.get(i))).x-points.get(sorted.get(j))).x;let dy1=points.get(sorted.get(i))).y-points.get(sorted.get(j))).y;let dx2=points.get(sorted.get(j))).x-points.get(sorted.get(i))).x;let dy2=points.get(sorted.get(j))).y-points.get(sorted.get(i))).y;let cross1=dx1*dy2;let cross2=dx2*dy1;if(cross1<cross2){let tmp=sorted.get(i);sorted.get(i)=sorted.get(j);sorted.get(j)=tmp;};};};<sorted};f=orientation(p:$i64;q:$i64;r:$i64):$i64{let val=p*q-r*p;let other=p*other-r*p;if(val