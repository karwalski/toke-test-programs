m=simpson;i=io:std.io;i=s:std.str;i=math:std.math;f=poly(x:$f64;coeffs:@($f64)):$f64{let result=mut.0.0;let idx=mut.0;lp(idx<coeffs.len()){result=result+coeffs.get(idx)*math.pow(x;s.tofloat(s.fromint(idx)));idx=idx+1};<result};f=main():$i64{let a=s.tofloat(io.readln());let b=s.tofloat(io.readln());let n=s.toint(io.readln());let line=s.trim(io.readln());let parts=s.split(line;" ");let coeffs=mut.@();let idx=mut.0;lp(idx<parts.len()){let part=s.trim(parts.get(idx));if(s.len(part)>0){coeffs=coeffs+@(s.tofloat(part))};idx=idx+1};let h=(b-a)/s.tofloat(s.fromint(n));let sum=mut.(poly(a;coeffs)+poly(b;coeffs));let j=mut.1;lp(j<n){let x=a+s.tofloat(s.fromint(j))*h;if(j%2=1){sum=sum+4.0*poly(x;coeffs)}el{sum=sum+2.0*poly(x;coeffs)};j=j+1};let result=sum*h/3.0;let formatted=s.format(result;"%.6f");io.println(s.concat("Integral: ";formatted));<0}