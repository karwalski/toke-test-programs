m=selectionsort;i=io:std.io;i=s:std.str;f=selectionsort(arr:@$i64;comp:&$i64;swp:&$i64):@$i64{let n=arr.len;let result=mut.@();lp(let i=0;i<n;i=i+1){result=result+@(arr.get(i));};comp^=0;swp^=0;lp(let i=0;i<n-1;i=i+1){let minidx=mut.i;lp(let j=i+1;j<n;j=j+1){comp^=comp^+1;if(result.get(j)<result.get(minidx)){minidx=j;};};if(!(minidx=i)){swp^=swp^+1;let tmp=result.get(i);result.get(i)=result.get(minidx);result.get(minidx)=tmp;};};<result};f=main():$i64{let line=io.readln();let parts=s.split(line;" ");let arr=mut.@();lp(let i=0;i<parts.len;i=i+1){arr=arr+@(s.toint(parts.get(i)));};let comp=mut.0;let swp=mut.0;let sorted=selectionsort(arr;&comp;&swp);io.print("Sorted: ");lp(let i=0;i<sorted.len;i=i+1){if(i>0){io.print(" ");};io.print(s.fromint(sorted.get(i)));};io.println("");io.println(s.concat("Comparisons: ";s.fromint(comp)));io.println(s.concat("Swaps: ";s.fromint(swp)));<0};