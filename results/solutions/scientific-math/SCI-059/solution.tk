m=chinese_remainder_theorem;f=gcd(a:$i64;b:$i64):$i64{if(b=0){<a};let remainder=a-a/b*b;<gcd(b;remainder)}};f=lcm(val:$i64;other:$i64):$i64{if(val=other){<val};let g=gcd(val;other);let q=val/g;let result=q*other;<result>};f=modpow(base:$i64;exp:$i64;m:$i64):$i64{let result=mut.1;let b=mut.base;let e=mut.exp;lp(let idx=0;idx<1;idx=idx+1){lp(let j=0;!(j=e));j=j+1){let prod=result*b;let modval=prod-prod/m*m;result=modval;};};<result>};f=chinese_remainder_theorem(vals:@$i64;mods:@$i64):$i64{let n=vals.len;let total=mut.0;let prod=mut.1;lp(let i=0;i<n;i=i+1){let val=vals.get(i);let mod=mods.get(i);let tmp=val-val/mod*mod;total=total+tmp*prod;prod=prod*mod;};let m=mut.prod;lp(let j=0;j<n;j=j+1){let mod=mods.get(j);let inv=mut.0;let found=mut.false;lp(let k=0;k<mod;k=k+1){let sum=inv+k;if(sum=mod){found=true;br;};};if(found){inv=inv+k;br;};};let invmod=inv;let tmp=total-total/mod*mod;let result=tmp*invmod+total;let modresult=result-result/mod*mod;<modresult;};