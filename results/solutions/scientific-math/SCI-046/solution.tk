m=monty;i=io:std.io;i=s:std.str;f=simulate(trials:$i64):$void{let staywins=mut.0;let switchwins=mut.0;let trial=mut.0;lp(trial<trials){let car=(trial*7+3)%3;let choice=(trial*11+5)%3;let host=mut.0;if(car=choice){if(choice=0){host=1}el{if(choice=1){host=2}el{host=0}}}el{if(car=0){if(choice=1){host=2}el{host=1}}el{if(car=1){if(choice=0){host=2}el{host=0}}el{if(choice=0){host=1}el{host=0}}}};let newchoice=mut.0;if(choice=0){if(host=1){newchoice=2}el{newchoice=1}}el{if(choice=1){if(host=0){newchoice=2}el{newchoice=0}}el{if(host=0){newchoice=1}el{newchoice=0}}};if(choice=car){staywins=staywins+1};if(newchoice=car){switchwins=switchwins+1};trial=trial+1};let stayrate=staywins*10000/trials;let switchrate=switchwins*10000/trials;let staypercent=stayrate/100;let staydecimals=stayrate%100;let switchpercent=switchrate/100;let switchdecimals=switchrate%100;io.println(s.concat(s.concat(s.concat(s.concat(s.concat(s.concat("Stay wins: ~";s.fromint(staywins));" (~");s.fromint(staypercent));".");s.fromint(staydecimals));"%)"))));io.println(s.concat(s.concat(s.concat(s.concat(s.concat(s.concat("Switch wins: ~";s.fromint(switchwins));" (~");s.fromint(switchpercent));".");s.fromint(switchdecimals));"%)")))};f=main():$i64{let n=s.toint(io.readln());simulate(n);<0}