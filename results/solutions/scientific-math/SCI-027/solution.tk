m=mergesort;f=merge(lhs:@$i64;rhs:@$i64):@$i64{let result=mut.@();let i=mut.0;let j=mut.0;lp(let k=0;k<lhs.len+rhs.len;k=k+1){if(i<lhs.len){if(j<rhs.len){if(lhs.get(i)<rhs.get(j)){result=result+@(lhs.get(i));i=i+1;}el{result=result+@(rhs.get(j));j=j+1;};}el{result=result+@(lhs.get(i));i=i+1;);};}el{if(j<rhs.len){result=result+@(rhs.get(j));j=j+1;);};};};<result};f=mergesort(arr:@$i64):@$i64{if(arr.len<2){<arr};let mid=arr.len/2;let left=mut.@();lp(let i=0;i<mid;i=i+1){left=left+@(arr.get(i)));};let right=mut.@();lp(let i=mid;i<arr.len;i=i+1){right=right+@(arr.get(i)));};let