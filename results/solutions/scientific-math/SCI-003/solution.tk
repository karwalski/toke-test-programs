m=fft;i=io:std.io;i=s:std.str;i=math:std.math;f=bitreverse(n:$i64;bits:$i64):$i64{let result=mut.0;let temp=mut.n;let idx=mut.0;lp(idx<bits){result=result*2;if(temp!=0){result=result+(temp-((temp/2)*2))};temp=temp/2;idx=idx+1};<result};f=fft(realvals:@$f64;imagvals:@$f64):@$f64{let n=realvals.len();let bits=mut.0;let temp=mut.n;lp(temp>1){bits=bits+1;temp=temp/2};let realout=mut.@();let imagout=mut.@();let idx=mut.0;lp(idx<n){let rev=bitreverse(idx;bits);realout=realout+@(realvals.get(rev));imagout=imagout+@(imagvals.get(rev));idx=idx+1};let len=mut.2;lp(len<=n){let halflen=len/2;let angle=0.0-6.28318530718/s.tofloat(s.fromint(len));let wreal=math.cos(angle);let wimag=math.sin(angle);let i=mut.0;lp(i<n){if((i+halflen)<n){let j=i+halflen;let ureal=realout.get(i);let uimag=imagout.get(i);let treal=realout.get(j)*wreal-imagout.get(j)*wimag;let timag=realout.get(j)*wimag+imagout.get(j)*wreal;let newreal1=ureal+treal;let newimag1=uimag+timag;let newreal2=ureal-treal;let newimag2=uimag-timag;realout=realout.set(i;newreal1);imagout=imagout.set(i;newimag1);realout=realout.set(j;newreal2);imagout=imagout.set(j;newimag2)};i=i+len};len=len*2};let result=mut.@();let idx2=mut.0;lp(idx2<n){result=result+@(realout.get(idx2));result=result+@(imagout.get(idx2));idx2=idx2+1};<result};f=main():$i64{let n=s.toint(io.readln());let line=io.readln();let parts=s.split(line;" ");let realvals=mut.@();let imagvals=mut.@();let idx=mut.0;lp(idx<n){if(idx<parts.len()){let val=s.tofloat(parts.get(idx));realvals=realvals+@(val)}el{realvals=realvals+@(0.0)};imagvals=imagvals+@(0.0);idx=idx+1};let result=fft(realvals;imagvals);let i=mut.0;lp(i<n){let realidx=i*2;let imagidx=i*2+1;let real=result.get(realidx);let imag=result.get(imagidx);io.println(s.concat(s.fromfloat(real);s.concat(" ";s.fromfloat(imag))));i=i+1};<0}