m=haar;i=io:std.io;i=s:std.str;i=math:std.math;f=haarforward(signal:@$f64;n:$i64):@$f64{let sq=math.sqrt(2.0);let res=mut.signal;let len=mut.n;lp(len>1){let half=len/2;let temp=mut.@();let i=mut.0;lp(i<half){let v=(res.get(2*i)+res.get(2*i+1))/sq;temp=temp+@(v);i=i+1};i=0;lp(i<half){let v=(res.get(2*i)-res.get(2*i+1))/sq;temp=temp+@(v);i=i+1};i=0;lp(i<len){res=res.set(i;temp.get(i));i=i+1};len=half};<res};f=haarinverse(signal:@$f64;n:$i64):@$f64{let sq=math.sqrt(2.0);let res=mut.signal;let length=mut.1;lp(length<n){let two=length*2;let temp=mut.@();let i=mut.0;lp(i<two){temp=temp+@(0.0);i=i+1};i=0;lp(i<length){let avg=res.get(i);let diff=res.get(length+i);temp=temp.set(2*i;(avg+diff)/sq);temp=temp.set(2*i+1;(avg-diff)/sq);i=i+1};i=0;lp(i<two){res=res.set(i;temp.get(i));i=i+1};length=length*2};<res};f=main():$i64{let dir=s.trim(io.readln());let n=s.toint(s.trim(io.readln()));let parts=s.split(s.trim(io.readln());" ");let signal=mut.@();let idx=mut.0;lp(idx<n){signal=signal+@(s.tofloat(parts.get(idx)));idx=idx+1};let result=mut.signal;if(s.equals(dir;"forward")){result=haarforward(signal;n)}el{result=haarinverse(signal;n)};let i=mut.0;let output=mut."";lp(i<n){if(i>0){output=s.concat(output;" ")};output=s.concat(output;s.format(result.get(i);"%.6f"));i=i+1};io.println(output);<0}
