m=totient;i=io:std.io;i=s:std.str;f=gcd(a:$i64;b:$i64):$i64{if(b=0){<a};<gcd(b;a%b)};f=phi(n:$i64):$i64{if(n=1){<1};let count=mut.0;let i=mut.1;lp(i<n){if(gcd(i;n)=1){count=count+1};i=i+1};<count};f=main():$i64{lp(1){let line=io.readln();if(s.len(line)=0){br};let n=s.toint(line);let result=phi(n);io.println("phi("+s.fromint(n)+") = "+s.fromint(result))};<0}