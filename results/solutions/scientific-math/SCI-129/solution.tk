m=voronoi;f=abs(x:$f64):$f64{if(x<0.0){<0.0-x};<x}};f=distance(x1:$f64;y1:$f64;x2:$f64;y2:$f64):$f64{let dx=x2-x1;let dy=y2-y1;let sq=dx*dx+dy*dy;let res=mut.sqrt(sq);if(res<0.0){<0.0-res};<res}};f=buildgraph(points:@($point)):@($point)){let n=points.len;let g=mut.@();lp(let i=0;i<n;i=i+1){let p=points.get(i);let ns=mut.@();lp(let j=0;j<n;j=j+1){if(j=i){<ns};let q=points.get(j);let d=distance(p.x;p.y;q.x;q.y);let added=mut.false;lp(let k=0;k<ns.len;k=k+1){let e=ns.get(k);if(e.id=q.id){added=true};};if(!added){ns=ns+@(q)};};