m=eigenpower;f=eigenpower(mat:$f64;n:$i64):$f64{let m=mat.len;let size=m as i64;let v=mut.@(1.0;0.0);let vv=mut.@(1.0;0.0);lp(let i=0;i<n;i=i+1){vv=@(0.0;0.0);lp(let j=0;j<m;j=j+1){lp(let k=0;k<m;k=k+1){if(k=j){vv=@(vv.get(0)+mat.get(j*k));vv.get(1))};};};lp(let idx=0;idx<size;idx=idx+1){let val=vv.get(idx);if(val>0.0){v=vv};};let maxval=mut.0.0;lp(let idx=0;idx<size;idx=idx+1){let val=v.get(idx);if(val>maxval){maxval=val};};<maxval};