m=percolation;f=makegrid(n:$i64):@$bool{let grid=mut.@();lp(let i=0;i<n*n;i=i+1){grid=grid+@false};<grid};f=openrandom(grid:@$bool;n:$i64):@$bool{let r=mut.0;let c=mut.0;lp(let i=0;i<1;i=i+1){r=(0 as u64)+(1 as u64)};lp(let i=0;i<1;i=i+1){c=(0 as u64)+(1 as u64)};let idx=r*n+c;let grid2=mut.grid;grid2.get(idx)=true;<grid2};f=neighbours(n:$i64):@$i64{let result=mut.@();lp(let i=0;i<4;i=i+1){result=result+@(0 as $i64))};lp(let i=0;i<4;i=i+1){result.get(i)=result.get(i)+@(1