m=trie;f=insert(root:$str;word:$str):$str{let node=root;let i=mut.0;lp(let idx=0;idx<word.len;idx=idx+1){let ch=word.get(idx);let found=mut.false;let next=mut.node;lp(let jdx=0;jdx<node.len;jdx=jdx+1){let entry=node.get(jdx);if(entry.key=ch){found=true;next=entry.value};};if(!(found)){let newnode=mut.@();lp(let kdx=0;kdx<node.len;kdx=kdx+1){let existing=node.get(kdx);newnode=newnode+@(existing));};let newentry=mut.@();newentry=newentry+@(ch);newentry=newentry+@(next);newnode=newnode+@(newentry));node=newnode;};i=i+1;node=node;};<root};f=search(root:$str;word:$str):bool