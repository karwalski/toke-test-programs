m=levdist;f=levdist(a:$str;b:$str):$i64{let m=a.len;let n=b.len;let dp=mut.@();lp(let i=0;i<m+1;i=i+1){let row=mut.@();lp(let j=0;j<n+1;j=j+1){let val=mut.0;if(i=0){val=j}el{if(j=0){val=i}el{let cost=mut.1;if(a.get(i-1)=b.get(j-1))){cost=0};let del=i;let ins=j;let minval=mut.cost;if(del<minval){minval=del};if(ins<minval){minval=ins};val=minval}};row=row+@(val);};dp=dp+@(row);};lp(let i=1