m=bubblesort;f=bubblesort(arr:@$i64):@$i64{let n=arr.len;let sortedarr=mut.@();lp(let idx=0;idx<n;idx=idx+1){sortedarr=sortedarr+@(arr.get(idx));};let cmp=mut.0;let swp=mut.0;lp(let pass=0;pass<n;pass=pass+1){lp(let idx=0;idx<n-pass-1;idx=idx+1){cmp=cmp+1;if(sortedarr.get(idx)>sortedarr.get(idx+1))){swp=swp+1;let tmp=sortedarr.get(idx);sortedarr.get(idx)=sortedarr.get(idx+1);sortedarr.get(idx+1)=tmp;};};};<sortedarr};