m=horner;i=io:std.io;i=s:std.str;f=horner(coeffs:@$f64;x:$f64):$f64{let n=coeffs.len();if(n=0){<0.0};let result=mut.coeffs.get(n-1);let idx=mut.n-2;lp(idx>=0){result=result*x+coeffs.get(idx);idx=idx-1};<result};f=main():$i64{let line=io.readln();let parts=s.split(line;" ");let coeffs=mut.@();let idx=mut.0;lp(idx<parts.len()){let coeff=s.tofloat(parts.get(idx));coeffs=coeffs+@(coeff);idx=idx+1};lp(1){let xline=io.readln();let trimmed=s.trim(xline);if(s.len(trimmed)=0){br};let x=s.tofloat(trimmed);let result=horner(coeffs;x);io.println(s.concat(s.concat(s.concat("p(";s.format(x;"%.0f"));") = ");s.format(result;"%.6f")))};<0}