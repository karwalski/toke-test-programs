m=bitops;i=io:std.io;i=s:std.str;f=popcount(n:$i64):$i64{let count=mut.0;let num=mut.n;lp(num>0){if(num%2=1){count=count+1};num=num/2};<count};f=lowestbit(n:$i64):$i64{if(n=0){<0};let pos=mut.1;let num=mut.n;lp(num%2=0){num=num/2;pos=pos*2};<pos};f=highestbit(n:$i64):$i64{if(n=0){<0};let pos=mut.1;let num=mut.n;lp(num>1){num=num/2;pos=pos*2};<pos};f=ispow2(n:$i64):$bool{if(n<=0){<false};<popcount(n)=1};f=main():$i64{let line=mut.io.readln();lp(s.len(line)>0){let parts=s.split(line;" ");if(parts.len()>=2){let op=parts.get(0);let arg=s.toint(parts.get(1));if(op="popcount"){io.println(s.fromint(popcount(arg)))};if(op="lowest_bit"){io.println(s.fromint(lowestbit(arg)))};if(op="highest_bit"){io.println(s.fromint(highestbit(arg)))};if(op="is_pow2"){if(ispow2(arg)){io.println("true")}el{io.println("false")}}};line=io.readln()};<0}