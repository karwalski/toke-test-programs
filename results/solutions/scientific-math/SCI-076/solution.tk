m=editdist;f=editdist(p:$str;q:$str):$i64{let m=p.len;let n=q.len;let dp=mut.@();lp(let i=0;i<m+1;i=i+1){let row=mut.@();lp(let j=0;j<n+1;j=j+1){let val=mut.0;if(i=0){val=j}el{if(j=0){val=i}el{let cpi=p.get(i-1);let cqj=q.get(j-1);if(cpi=cqj){val=dp.get(i-1).get(j-1)}el{let del=dp.get(i-1).get(j);let ins=dp.get(i).get(j-1);let sub=dp.get(i-1).get(j-1);let minval=mut.del;if(ins<minval){minval=ins};if(sub<minval){minval=sub};val=minval}}}};row=row+@(val);};dp=dp+@(row);};let result=mut.dp.get(m).get(n);<result};f=editdistops(p:$str;q:$str):$str{let m=p.len