m=bucketsort;i=io:std.io;i=s:std.str;i=math:std.math;f=main():$i64{let n=s.toint(io.readln());let line=io.readln();let parts=s.split(line;" ");let nums=@();let idx=mut.0;lp(idx<parts.len()){let val=s.tofloat(parts.get(idx));nums=nums.push(val);idx=idx+1};let buckets=@();let j=mut.0;lp(j<n){buckets=buckets.push(@());j=j+1};let k=mut.0;lp(k<nums.len()){let val=nums.get(k);let nf=s.tofloat(s.fromint(n));let bidx=math.floor(val*nf);if(bidx>=nf){bidx=nf-1.0};let bucketidx=s.toint(s.fromfloat(bidx));let bucket=buckets.get(bucketidx);bucket=bucket.push(val);buckets=buckets.set(bucketidx;bucket);k=k+1};let m=mut.0;lp(m<buckets.len()){let bucket=buckets.get(m);let p=mut.0;lp(p<bucket.len()-1){let q=mut.p+1;lp(q<bucket.len()){if(bucket.get(p)>bucket.get(q)){let temp=bucket.get(p);bucket=bucket.set(p;bucket.get(q));bucket=bucket.set(q;temp)};q=q+1};p=p+1};buckets=buckets.set(m;bucket);m=m+1};let sorted=@();let r=mut.0;lp(r<buckets.len()){let bucket=buckets.get(r);let t=mut.0;lp(t<bucket.len()){sorted=sorted.push(bucket.get(t));t=t+1};r=r+1};let output=mut."Sorted:";let u=mut.0;lp(u<sorted.len()){output=s.concat(s.concat(output;" ");s.format(sorted.get(u);"%.4f"));u=u+1};io.println(output);let sizes=mut."Bucket sizes:";let v=mut.0;lp(v<buckets.len()){sizes=s.concat(s.concat(sizes;" ");s.fromint(buckets.get(v).len()));v=v+1};io.println(sizes);<0}