m=optimal;f=optimal(n:$i64):$i64{if(n<2){<0};let m=mut.@(0;0;0);lp(let i=0;i<n;i=i+1){m=m+@(0;0;0));};lp(let len=2;len<n;len=len+1){lp(let i=0;i<n-len;i=i+1){let j=i+len-1;let minval=mut.922337203685477580;let minidx=mut.0;lp(let k=i;k<j;k=k+1){let val=m.get(i as u64).get(k as u64))+m.get(k as u64).get(j as u64))+m.get(i as u64).get(j as u64);if(val<minval){minval=val;minidx=k;};};m.get(i as u64).get(j as u64)=minval;};};<m.get(0 as u64).get(n-1 as u64))};