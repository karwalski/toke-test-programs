m=segintersect;f=segintersect(ax:$f64;ay:$f64;bx:$f64;by:$f64):$f64{let dx1=bx-ax;let dx2=by-ay;let det=dx1*dx2;let px=ax+bx;let py=ay+by;let midx=px/2.0;let midy=py/2.0;let result=mut.0.0;if(det=0.0){<0.0};let xcross=mut.0.0;let ycross=mut.0.0;let dx=bx-ax;let dy=by-ay;let ppx=ax+dx/2.0;let ppy=ay+dy/2.0;let dx2=ppx-midx;let dy2=ppy-midy;let dot=dx2*dx+dy2*dy;if(dot<0.0){<0.0};let len=dx*dx+dy*dy;let t=dot/len;let ix=ax+t*dx;let iy=ay+t*dy;let ix2=ix-midx;let iy2=iy