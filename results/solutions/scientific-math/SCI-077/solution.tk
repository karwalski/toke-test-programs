m=josephus;i=io:std.io;i=s:std.str;f=josephus(n:$i64;k:$i64):$i64{let result=mut.0;let current=mut.0;lp(let i=1;i<n;i=i+1){let next=(current+k-1)/n;result=result+next*power(n;i-1);current=next;};<result};f=power(base:$i64;exp:$i64):$i64{let result=mut.1;lp(let i=0;i<exp;i=i+1){result=result*base};<result};f=main():$i64{let n=s.toint(io.readln());let k=s.toint(io.readln());let order=mut.[];let people=mut.[];lp(let i=1;i<=n;i=i+1){people=people+[i]};let pos=mut.0;lp(let i=0;i<n;i=i+1){pos=(pos+k-1)%(n-i);let eliminated=people[pos];order=order+[eliminated];people=people[0:pos]+people[pos+1:]};let output=mut."Elimination order: ";lp(let i=0;i<n;i=i+1){output=s.concat(output;s.fromint(order[i]));if(i<n-1){output=s.concat(output;" ")}};io.println(output);io.println(s.concat("Survivor: ";s.fromint(order[n-1])));<0}