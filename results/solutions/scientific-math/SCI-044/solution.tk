m=bisection;i=io:std.io;i=s:std.str;i=math:std.math;f=poly(x:$f64;coeffs:@($str)):$f64{let result=mut.0.0;let idx=mut.0;lp(idx<coeffs.len()){let coeff=s.tofloat(coeffs.get(idx));let power=coeffs.len()-idx-1;result=result+coeff*math.pow(x;s.tofloat(s.fromint(power)));idx=idx+1};<result};f=main():$i64{let line1=io.readln();let coeffs=s.split(line1;" ");let line2=io.readln();let bounds=s.split(line2;" ");let a=mut.s.tofloat(bounds.get(0));let b=mut.s.tofloat(bounds.get(1));let tol=s.tofloat(io.readln());let maxiter=s.toint(io.readln());let fa=mut.poly(a;coeffs);let fb=poly(b;coeffs);if(fa*fb>0.0){io.println("ERROR: f(a) and f(b) must have opposite signs");<0};let iter=mut.0;lp(iter<maxiter){let c=(a+b)/2.0;let fc=poly(c;coeffs);if(math.abs(fc)<tol){io.println(s.concat(s.concat(s.concat("Root: ";s.format(c;"%.6f"));" (");s.fromint(iter+1))t(iter+1);" iterations)"));<0};if(fa*fc<0.0){b=c}el{a=c;fa=fc};iter=iter+1};io.println(s.concat("Root: ";s.format((a+b)/2.0;"%.6f"))(s.format((a+b)/2.0;"%.6f");" (");s.fromint(iter));" iterations)"));<0}