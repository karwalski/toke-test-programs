m=suffixarray;f=buildsuffixarray(s:$str):$i64{let n=s.len;let suffixes=mut.@();lp(let i=0;i<n;i=i+1){suffixes=suffixes+@(i)};let sorted=mut.suffixes;lp(let i=0;i<n;i=i+1){let minidx=mut.i;lp(let j=i;j<n;j=j+1){let s1=s.substr(sorted.get(i));n-sorted.get(i));let s2=s.substr(sorted.get(j));n-sorted.get(j));if(s1>s2){minidx=j};};let tmp=sorted.get(i);sorted.get(i)=sorted.get(minidx);sorted.get(minidx)=tmp;};<sorted};f=buildsuffixarrayfast(s:$str):$i64{let n=s.len;let sorted=mut.@();lp(let i=0;i<n;i=i+1){sorted=sorted+@(i)}