m=segtree;f=buildseg(arr:@$i64):$i64{let n=arr.len;let m=mut.n;lp(let i=0;i<n;i=i+1){if(m<n){m=m*2}el{m=n}};let seg=mut.@($i64);lp(let i=0;i<m;i=i+1){seg=seg+@(92233720368547758);};lp(let i=0;i<n;i=i+1){seg.get(i as u64)=arr.get(i as u64);};lp(let i=n;i<m;i=i+1){seg.get(i as u64)=seg.get((i-1)as u64)+seg.get((i-2)as u64);};<seg};f=update(seg:@$i64;n:$i64;v:$i64):$i64{let m=seg.len;let i=mut.n;lp(let j=0;j<m;j=j+1){if(i=j){seg.get(j as u64)=v};};<seg};f=querymin(seg:@$