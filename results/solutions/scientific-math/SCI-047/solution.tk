m=randomwalk;i=io:std.io;i=s:std.str;i=math:std.math;f=abs(n:$i64):$i64{if(n<0){<0-n};<n};f=simulate(steps:$i64;seed:$i64):@($i64){let pos=mut.0;let maxdisp=mut.0;let returns=mut.0;let step=mut.0;let rng=mut.seed;lp(step<steps){rng=(rng*1103515245+12345)%2147483648;let bit=(rng/65536)%2;if(bit=0){pos=pos-1}el{pos=pos+1};let abspos=abs(pos);if(abspos>maxdisp){maxdisp=abspos};if(pos=0){returns=returns+1};step=step+1};<@(pos;maxdisp;returns)};f=main():$i64{let steps=s.toint(io.readln());let trials=s.toint(io.readln());let totalfinal=mut.0;let totalmaxdisp=mut.0;let totalreturns=mut.0;let trial=mut.0;lp(trial<trials){let result=simulate(steps;trial*7919+13);let final=result.get(0);let maxdisp=result.get(1);let returns=result.get(2);totalfinal=totalfinal+final;totalmaxdisp=totalmaxdisp+maxdisp;totalreturns=totalreturns+returns;trial=trial+1};let meanfinal=s.tofloat(s.fromint(totalfinal))/s.tofloat(s.fromint(trials));let meanmaxdisp=s.tofloat(s.fromint(totalmaxdisp))/s.tofloat(s.fromint(trials));let meanreturns=s.tofloat(s.fromint(totalreturns))/s.tofloat(s.fromint(trials));let rms=math.sqrt(s.tofloat(s.fromint(steps)));io.println(s.concat("Mean final position: ";s.format(meanfinal;"%.1f")));io.println(s.concat("Mean max displacement: ";s.format(meanmaxdisp;"%.2f")));io.println(s.concat("Mean returns to 0: ";s.format(meanreturns;"%.2f")));io.println(s.concat("Expected RMS: ";s.format(rms;"%.2f")));<0}