m=polynomialroot;f=evalpoly(coeffs:@$f64;x:$f64):$f64{let n=coeffs.len;let res=mut.0.0;lp(let i=0;i<n;i=i+1){let lhs=res;let rhs=coeffs.get(i);if(i=0){res=rhs}el{res=lhs+rhs}}};f=derivative(coeffs:@$f64):@$f64{let n=coeffs.len;let result=mut.@();lp(let i=0;i<n;i=i+1){let lhs=coeffs.get(i);let rhs=i;if(!(lhs=0.0))){result=result+@(lhs*rhs))}};<result>};f=newtonraphson(coeffs:@$f64;x0:$f64;tolerance:$f64;maxiter:$i64):$f64{let n=coeffs.len;let x=mut.x0;let i=mut.0;lp(let idx=0;idx<maxiter;idx=idx+1){let fx=evalpoly(coeffs;x);let dfx=evalpoly(derivative(coeffs);x);