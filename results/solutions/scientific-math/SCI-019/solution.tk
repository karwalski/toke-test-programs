m=floyd;i=io:std.io;i=s:std.str;f=main():$i64{let n=s.toint(io.readln());let dist=mut.@();let row=mut.0;lp(row<n){let line=io.readln();let parts=s.split(line;" ");let rowdata=mut.@();let col=mut.0;lp(col<n){let val=parts.get(col);if(s.contains(val;"INF")){rowdata=rowdata+@(999999)}el{rowdata=rowdata+@(s.toint(val))};col=col+1};dist=dist+@(rowdata);row=row+1};let k=mut.0;lp(k<n){let i=mut.0;lp(i<n){let j=mut.0;lp(j<n){let ik=dist.get(i).get(k);let kj=dist.get(k).get(j);let newval=ik+kj;let oldval=dist.get(i).get(j);if(newval<oldval){let newrow=mut.@();let c=mut.0;lp(c<n){if(c=j){newrow=newrow+@(newval)}el{newrow=newrow+@(dist.get(i).get(c))};c=c+1};let newdist=mut.@();let r=mut.0;lp(r<n){if(r=i){newdist=newdist+@(newrow)}el{newdist=newdist+@(dist.get(r))};r=r+1};dist=newdist};j=j+1};i=i+1};k=k+1};let outi=mut.0;lp(outi<n){let outj=mut.0;let outline=mut."";lp(outj<n){let val=dist.get(outi).get(outj);if(val>=999999){outline=s.concat(outline;"INF")}el{outline=s.concat(outline;s.fromint(val))};if(outj<n-1){outline=s.concat(outline;" ")};outj=outj+1};io.println(outline);outi=outi+1};<0}