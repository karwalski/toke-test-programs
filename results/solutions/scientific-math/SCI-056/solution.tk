m=gcdlcm;i=io:std.io;i=s:std.str;f=gcd(a:$i64;b:$i64):$i64{if(b=0){<a};<gcd(b;a%b)};f=gcdsteps(a:$i64;b:$i64):$void{io.print("gcd(");io.print(s.fromint(a));io.print(",");io.print(s.fromint(b));io.print(")");if(b!=0){io.print(" ");gcdsteps(b;a%b)}el{io.print("=");io.print(s.fromint(a))}};f=lcm(a:$i64;b:$i64):$i64{<(a*b)/gcd(a;b)};f=main():$i64{let mode=io.readln();let line=io.readln();let parts=s.split(line;" ");if(parts.len()>=2){let a=s.toint(parts.get(0));let b=s.toint(parts.get(1));let g=gcd(a;b);let l=lcm(a;b);io.print("GCD: ");io.print(s.fromint(g));io.print(" LCM: ");io.println(s.fromint(l));io.print("Steps: ");gcdsteps(a;b);io.println("")};<0}