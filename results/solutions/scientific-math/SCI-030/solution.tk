m=radixsort;f=sort(arr:@$i64):@$i64{let n=arr.len;let m=mut.0;lp(let i=0;i<n;i=i+1){let v=arr.get(i);if(v>m){m=v};};let res=mut.@();lp(let i=0;i<n;i=i+1){res=res+@(arr.get(i));};lp(let exp=1;exp<m+1;exp=exp*10){let count=mut.@(0;0;0;0;0;0;0;0;0));lp(let i=0;i<n;i=i+1){let v=res.get(i);let d=(v/exp)-(v/exp/10)*10)as i64;count.get(d)=count.get(d)+1;};let output=mut.@(