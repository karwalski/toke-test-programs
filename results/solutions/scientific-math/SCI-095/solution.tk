m=armstrong;f=power(base:$i64;exp:$i64):$i64{let result=mut.1;lp(let i=0;i<exp;i=i+1){result=result*base};<result};f=sumofdigits(n:$i64):$i64{let absn=mut.n;if(n<0){absn=0-n};let sum=mut.0;lp(let temp=absn;temp>0;temp=temp/10){let digit=temp-temp/10*10;sum=sum+digit};<sum};f=checkarmstrong(n:$i64):$bool{if(n<0){<false};let digits=mut.0;let temp=mut.n;lp(let i=0;i<20;i=i+1){if(temp=0){digits=i;br};temp=temp/10};let sum=mut.0;lp(let temp2=n;temp2>0;temp2=temp2/10){let digit=temp2-temp2/10*10;sum=sum+power(digit;digits);if(sum>n){br}};<sum=n}};f=findallarmstrong