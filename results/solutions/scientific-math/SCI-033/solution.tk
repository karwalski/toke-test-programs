m=shellsort;i=io:std.io;i=s:std.str;f=main():$i64{let line=io.readln();let parts=s.split(line;" ");let n=parts.len();let arr=mut.@();let idx=mut.0;lp(idx<n){let val=s.toint(parts.get(idx));arr=arr+@(val);idx=idx+1};let gaps=mut.@();let gap=mut.1;lp(gap<n){gaps=gaps+@(gap);gap=gap*3+1};let gapidx=mut.0;if(gaps.len()>0){gapidx=gaps.len()-1};let usedgaps=mut.@();let comparisons=mut.0;lp(gapidx>=0){let g=mut.0;if(gapidx<gaps.len()){g=gaps.get(gapidx)};if(g<n){if(g>0){usedgaps=usedgaps+@(g);let i=mut.g;lp(i<n){let temp=arr.get(i);let j=mut.i;lp(j>=g){let leftval=arr.get(j-g);comparisons=comparisons+1;if(leftval<=temp){br};let newarr=mut.@();let k=mut.0;lp(k<arr.len()){if(k=j){newarr=newarr+@(leftval)}el{if(k=j-g){newarr=newarr+@(arr.get(j))}el{newarr=newarr+@(arr.get(k))}};k=k+1};arr=newarr;j=j-g};i=i+1}}};gapidx=gapidx-1};let result=mut."Sorted: ";let i=mut.0;lp(i<arr.len()){if(i>0){result=s.concat(result;" ")};result=s.concat(result;s.fromint(arr.get(i)));i=i+1};io.println(result);let gapstr=mut."Gaps used: ";let i=mut.0;lp(i<usedgaps.len()){if(i>0){gapstr=s.concat(gapstr;" ")};gapstr=s.concat(gapstr;s.fromint(usedgaps.get(i)));i=i+1};io.println(gapstr);io.println(s.concat("Comparisons: ";s.fromint(comparisons)));<0}