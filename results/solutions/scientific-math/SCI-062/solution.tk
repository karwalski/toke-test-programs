m=histogram;f=buildhistogram(bins:$i64;data:$str):$str{let bincount=bins;let datalines=data.split("\n");let datalength=datalines.len;let minval=mut.0;let maxval=mut.0;let firstline=datalines.get(0);let firstparts=firstline.split(" ");let firstnum=firstparts.get(0);minval=firstnum;maxval=firstnum;lp(let i=1;i<datalength;i=i+1){let lin=datalines.get(i);let parts=lin.split(" ");let num=parts.get(0);if(num<minval){minval=num};if(num>maxval){maxval=num}};let binrange=(maxval-minval)/bincount;let counts=mut.@();lp(let i=0;i<bincount;i=i+1){counts=counts+@(0)};lp(let i=0