m=gradesc;i=io:std.io;i=s:std.str;i=math:std.math;f=poly(x:$f64;a:$f64;b:$f64;c:$f64):$f64{<a*x*x+b*x+c};f=polyder(x:$f64;a:$f64;b:$f64):$f64{<2.0*a*x+b};f=absf(x:$f64):$f64{if(x<0.0){<0.0-x};<x};f=main():$i64{let line1=io.readln();let parts1=s.split(line1;" ");let a=s.tofloat(parts1.get(0));let b=s.tofloat(parts1.get(1));let c=s.tofloat(parts1.get(2));let x=mut.s.tofloat(io.readln());let lr=s.tofloat(io.readln());let tol=s.tofloat(io.readln());let maxiter=s.toint(io.readln());let iter=mut.0;lp(iter<maxiter){let grad=polyder(x;a;b);let newx=x-lr*grad;let fx=poly(newx;a;b;c);io.println(s.concat("Iteration ";s.concat(s.fromint(iter+1);s.concat(": x=";s.concat(s.format(newx;"%.6f");s.concat(" f(x)=";s.format(fx;"%.6f")))))));let diff=absf(newx-x);x=newx;if(diff<tol){br};iter=iter+1};let fx=poly(x;a;b;c);io.println(s.concat("Minimum: x=";s.concat(s.format(x;"%.6f");s.concat(" f(x)=";s.format(fx;"%.6f")))));<0}