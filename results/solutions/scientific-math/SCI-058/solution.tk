m=powmod;i=io:std.io;i=s:std.str;f=modpow(base:$i64;exp:$i64;mod:$i64):$i64{if(mod=1){<0};let result=mut.1;let b=mut.base;let e=mut.exp;b=b%mod;lp(e>0){if(e%2=1){result=(result*b)%mod};e=e/2;b=(b*b)%mod};<result};f=gcd(a:$i64;b:$i64):$i64{let a2=mut.a;let b2=mut.b;lp(b2!=0){let temp=b2;b2=a2%b2;a2=temp};<a2};f=extgcd(a:$i64;b:$i64):$i64{let oldr=mut.a;let r=mut.b;let olds=mut.1;let s=mut.0;lp(r!=0){let quotient=oldr/r;let temp=r;r=oldr-quotient*r;oldr=temp;temp=s;s=olds-quotient*s;olds=temp};<olds};f=modinv(a:$i64;m:$i64):$i64{if(gcd(a;m)!=1){<-1};let x=extgcd(a;m);if(x<0){<x+m};<x};f=main():$i64{let line=io.readln();let parts=s.split(line;" ");if(parts.len()>=1){let op=parts.get(0);if(s.contains(op;"powmod")){if(parts.len()>=4){let a=s.toint(parts.get(1));let b=s.toint(parts.get(2));let mod=s.toint(parts.get(3));io.println(s.fromint(modpow(a;b;mod)))}el{io.println("error")}}el{if(s.contains(op;"modinv")){if(parts.len()>=3){let a=s.toint(parts.get(1));let mod=s.toint(parts.get(2));let inv=modinv(a;mod);if(inv=-1){io.println("error")}el{io.println(s.fromint(inv))}}el{io.println("error")}}el{io.println("error")}}}el{io.println("error")};<0}