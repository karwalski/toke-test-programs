m=chain;f=chain(keylen:$i64):$str{let k=mut."";lp(let i=0;i<keylen;i=i+1){k=s.concat(k;"a")};<k};f=symmetricratchet(step:$i64;keylen:$i64):$str{let current=chain(keylen);let result=mut."";lp(let i=0;i<step;i=i+1){let next=mut."";lp(let j=0;j<current.len;j=j+1){let ch=current.get(j);let code=ch as i64;let newcode=code+1;let newch=newcode as$str;next=next+newch;};current=next;};result=current;<result};