m=hashchain;f=hashfn(msg:$str):$i64{let hash=mut.0;let len=msg.len;lp(let i=0;i<len;i=i+1){let charcode=msg.get(i)as:i64;hash=hash+charcode;hash=hash-hash/1000*1000;};<hash};f=verifychain(msg:$str;expectedhash:$i64):$bool{let computed=hashfn(msg);let valid=mut.false;if(computed=expectedhash){valid=true};<valid};f=main():$i64{let message="hello world";let expected=hashfn("hello world");let result=verifychain(message;expected);if(result){<0}el{<1}};