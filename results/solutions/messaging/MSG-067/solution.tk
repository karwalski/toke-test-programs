m=summarise;f=summarise(msgs:@$str):$str{let mcount=msgs.len;let byname=@();lp(let i=0;i<mcount;i=i+1){let name=mut."unknown";let msg=msgs.get(i);if(msg.len>10){name=msg.sub(0;10)};let found=mut.false;lp(let j=0;j<byname.len;j=j+1){if(byname.get(j)=name)){found=true;br};};if(!found){byname.push(name)};};let mtypes=@($str);lp(let i=0;i<mcount;i=i+1){let msg=msgs.get(i);let found=mut.false;lp(let j=0;j<mtypes.len;j=j+1){if(mtypes.get(j)=msg)){found=true;br};};if(!found){mtypes.push(msg)};};let summary=mut."";summary=s.concat(summary;"");summary=s.concat(summary;"");summary=summary+