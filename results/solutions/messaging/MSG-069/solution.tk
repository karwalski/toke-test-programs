m=filter;f=filtermessages(messages:@$str;blocklist:@$str):@$str{let result=mut.@();lp(let i=0;i<blocklist.len;i=i+1){let blocked=blocklist.get(i);lp(let j=0;j<messages.len;j=j+1){let msg=messages.get(j);let isblocked=mut.false;if(msg.len>blocked.len){if(msg.startswith(blocked)){isblocked=true;};}el{if(msg=blocked){isblocked=true;};};if(!(isblocked)){result=result+@(msg);};};<result};