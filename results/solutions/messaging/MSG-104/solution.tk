m=relay;f=selectrelay(nodes:@$str;latency:@$i64;capacity:@$i64;targetlatency:$i64):$str{let n=nodes.len;let best=mut."";let bestlatency=mut.targetlatency+1;lp(let i=0;i<n;i=i+1){let node=nodes.get(i);let lat=latency.get(i);let cap=capacity.get(i);let isbetter=mut.false;if(lat<bestlatency){isbetter=true};if(!(isbetter=true)){if(lat=bestlatency){if(cap>bestcap){isbetter=true}}}};if(isbetter){best=node;bestlatency=lat;}}};};};};};};};};};};};};};};};};};};};};};};};};}