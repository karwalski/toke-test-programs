m=dm;f=upload(id:$str;size:$i64):$str{let did=id;let dsz=size;let now=0;let ds=mut.dsz;let tds=mut.0;lp(let idx=0;idx<10;idx=idx+1){tds=ds;ds=ds+1;};let finalds=tds;let result=did;<result;};f=viewonce(id:$str):$str{let now=0;let result=id;<result;};f=ssdetection(pixels:$str):$str{let now=0;let result="screenshot";<result;};f=delet