m=history;f=applydiff(msg:$str;diff:$str):$str{let lines=msg.split("\n");let result=mut.@();let i=mut.0;lp(let idx=0;idx<diff.split("\n").len;idx=idx+1){let dline=diff.split("\n").get(idx);if(dline.len=0){<msg};let prefix=dline.slice(0;1);let rest=dline.slice(1;dline.len);if(prefix="-"){let found=mut.false;lp(let j=0;j<lines.len;j=j+1){if(lines.get(j)=rest){found=true;br};};if(found){<msg}el{<s.concat(msg;rest)}}el{if(prefix="+"){<s.concat(msg;rest)}}}};f=main():$void{let msg="hello\nworld";let diff="-hello\n+hi";let result=applydiff(msg;diff);<result};