m=hashchain;f=hashfn(msg:$str):$i64{let hash=mut.0;let len=msg.len;lp(let i=0;i<len;i=i+1){let char=msg.get(i);let code=char.code;hash=hash*31+code;};<hash};f=verifychain(msgs:@$str):$bool{let n=msgs.len;if(n<2){<false};lp(let i=1;i<n;i=i+1){let msg1=msgs.get(i-1);let msg2=msgs.get(i);let h1=hashfn(msg1);let h2=hashfn(msg2);if(h2=h1){<false};};<true};f=main():$i64{let msgs=@("hello";"world";"hash"));let result=verifychain(msgs);if(result){<0}el{<1}};