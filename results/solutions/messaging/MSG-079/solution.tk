m=contactdiscovery;f=hashcontact(contact:$str):$str{let n=contact.len;let hash=mut."";lp(let i=0;i<n;i=i+1){let c=contact.get(i);let cval=c as i64;let hashval=hash as i64;let nextval=hashval+cval;let modval=nextval-nextval/32*32;hash=modval as$str;};<hash};f=comparecontacts(contact1:$str;contact2:$str):$bool{let hash1=hashcontact(contact1);let hash2=hashcontact(contact2);let eq=hash1=hash2;<eq};f=findcommoncontacts(contacts1:@$str;contacts2:@$str):@$str{let results=mut.@();lp(let i=0;i<contacts1.len;i=i+1){let c1=contacts1.get(i);let found=mut.false;lp(let j=0;j<contacts2.len;j=j+1){let c2=contacts2.get(j);let eq=comparecontacts(c1;c2);if(eq){found=true;};};if(found){results=results+@(c1