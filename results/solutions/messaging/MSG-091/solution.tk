m=priority;f=solve(p:$str;q:$str):$str{let keywords=mut.@("urgent";"critical";"now";"immediately"));let found=mut.false;lp(let i=0;i<keywords.len;i=i+1){if(p.contains(keywords.get(i)))){found=true}};if(found){<"high"};let timeindicators=mut.@("tomorrow";"next week";"later"));let timefound=mut.false;lp(let i=0;i<timeindicators.len;i=i+1){if(p.contains(timeindicators.get(i)))){timefound=true}};if(timefound){<"medium"};<"low"};