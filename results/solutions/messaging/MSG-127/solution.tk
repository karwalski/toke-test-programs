m=enc;f=simpleencode(n:$i64):$i64{if(n<0){<n};let mod2=n-n/2*2;if(mod2=0){<n+1};<n-1};f=rotateleft(arr:@$i64;n:$i64):@$i64{let len=arr.len;let m=n-n/len*len;let result=mut.@();lp(let i=0;i<len;i=i+1){let newidx=i+m;let newidx2=newidx-newidx/len*len;result=result+@(arr.get(newidx2)));};<result};f=encryptround(key:@$i64;val:$i64):$i64{let idx=val-val/4*4;let pass1=key.get(idx)+val;let pass2=pass1+key.get(idx);let m=pass2-pass2/4*4;<m};f=encrypt(key:@$i64;val:$i64):$i64{let r=mut.val;lp(let i=0;i<4;i=i+1){r=encryptround(key;r);};<r};f