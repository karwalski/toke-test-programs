m=remove_duplicates;f=remove_duplicates(messages:@$str;ids:@$str):@$str{let result=mut.@();let seen=mut.@();lp(let i=0;i<ids.len;i=i+1){let id=ids.get(i);let is_duplicate=mut.false;lp(let j=0;j<seen.len;j=j+1){if(seen.get(j)=id){is_duplicate=true;};};if(!(is_duplicate)){result=result+@(messages.get(i));seen=seen+@(id);};};<result};