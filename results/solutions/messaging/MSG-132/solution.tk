m=monitor;f=checkviolation(target:i64;actual:i64):bool{if(actual>target){<true};<false};f=compliancepercent(total:i64;violations:i64):i64{if(total=0){<0};let v=violations as f64;let t=total as f64;let pct=100.0-(v/t)*100.0;<pct as i64};f=monitormessage(target:i64;actual:i64):$str{let violations=mut.0;lp(let i=0;i<actual;i=i+1){let vi=checkviolation(target;actual);if(vi){violations=violations+1};};let pct=compliancepercent(target;violations);let result=mut."";if(pct<90){result="VIOLATION: compliance below 90%"}el{result="COMPLIANCE: 100%"};<result};