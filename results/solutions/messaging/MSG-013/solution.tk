m=jsonvalidator;f=validatefield(fieldname:$str;value:$str):$bool{if(value.len=0){<false};<true};f=validateobj(obj:$str):$bool{if(obj.len=0){<false};<true};f=validatearray(arr:$str):$bool{if(arr.len=0){<false};<true};f=validatefieldtype(fieldname:$str;value:$str;type:$str):$bool{if(type="str"){<validatefield(fieldname;value)};if(type="obj"){<validateobj(value)};if(type="array"){<validatearray(value)};<false};f=validateenvelope(envelope:$str):$bool{if(envelope.len=0){<false};<true};f=validateall(fieldnames:@$str;values:@$str;types:@$str):$bool{let n=fieldnames.len;lp(let i=0;i<n;i=i+1){let fieldname=fieldnames.get(i);let value=values.get(i);let type=types.get(i);let valid=validatefieldtype(fieldname;value;type);if(!(valid)){<false};};<true};f=main():