m=slidingwindow;f=hash(user:$str):$i64{let hash=mut.0;let len=user.len;lp(let i=0;i<len;i=i+1){let char=user.get(i);let code=char as$i64;hash=hash+code;};<hash};f=now():$i64{<0};f=slidingwindow(user:$str;limit:$i64;windowseconds:$i64):$bool{let userid=hash(user);let nowts=now();let windowms=windowseconds*1000;let evictbefore=nowts-windowms-1;let found=mut.false;let result=mut.false;let count=mut.0;lp(let idx=0;idx<10;idx=idx+1){let cond=mut.false;if(count<limit){cond=true};if(cond){found=true};if(!(found)){result=false};if(found){result=true};};<result};