m=enclog;f=encrypt(key:$str;plaintext:$str):$str{let result=mut."";lp(let i=0;i<plaintext.len;i=i+1){let ch=plaintext.get(i);let kidx=i-i/2*2;let shift=key.get(kidx)as i64;let basech=ch as i64;let shifted=basech+shift;let wrapped=shifted-shifted/128*128;let finalch=wrapped as$str;result=result+finalch;};<result};f=logencrypt(keylen:$i64;plaintextlen:$i64):$str{let msg=mut."encrypt: keylen=";msg=s.concat(msg;keylen) as$str;msg=s.concat(msg;" plaintextlen=");msg=s.concat(msg;plaintextlen) as$str;<msg};f=main():$str{let key="secretkey";let pt="confidential";let result=encrypt(key;pt);let logmsg=logencrypt(key.len;pt.len);<logmsg};