m=chatexport;
i=io:std.io;
i=s:std.str;
f=exportchat(sessionid:$str;messages:@$str):$str{let header="Chat Session Export\nSession ID: ";let footer="\nEnd of session.\n";let body=mut."";lp(let i=0;i<messages.len;i=i+1){let msg=messages.get(i);let isuser=i=0;let prefix=mut."";if(isuser){prefix="[User] ";}el{prefix="[Assistant] ";};body=s.concat(body;prefix)+msg+"\n";};let result=s.concat(s.concat(s.concat(s.concat(header;sessionid);"\n\n");body);footer);<result;};
f=parsejson(line:$str):$str{let parts=s.split(line;":\"");if(parts.len>=2){let value=parts.get(1);let endpos=value.find("\"");if(endpos>=0){<value.substr(0;endpos);};};< "";};
f=formattime(isotime:$str):$str{let parts=s.split(isotime;"T");if(parts.len>=2){let datepart=parts.get(0);let timepart=parts.get(1);let timeclean=s.split(timepart;"Z").get(0);<datepart+" "+timeclean;};< isotime;};
f=main():$i64{let metadataline=io.readln();let roomname=parsejson(metadataline.replace("\"room\"";"")); let exporttime=parsejson(metadataline.replace("\"exported_at\"";"")); let formattedtime=formattime(exporttime);io.println("Chat Export: "+roomname);io.println("Exported: "+formattedtime+" UTC");io.println("================================");let messagecount=0;lp(t){let line=io.readln();if(line.len=0){br;};let sender=parsejson(line.replace("\"sender\"";"")); let time=parsejson(line.replace("\"time\"";"")); let text=parsejson(line.replace("\"text\"";"")); let formattedmsgtime=formattime(time);io.println("["+formattedmsgtime+"] "+sender+": "+text);messagecount=messagecount+1;};io.println("================================");io.println(s.concat(s.fromint(messagecount);" messages exported"));<0;};