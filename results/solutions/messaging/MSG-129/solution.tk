m=channelbinding;f=safeproto(proto:$str):$str{if(proto="https")){<proto};if(proto="ssh")){<proto};if(proto="sftp")){<proto};<""};f=extracttransport(info:$str):$str{let idx=mut.0;let len=info.len;lp(let i=0;i<len;i=i+1){let ch=info.get(i);if(ch=":"){idx=i}};if(idx=0){<""};<info.sub(0;idx)>};f=bindchannel(proto:$str;transport:$str):$str{let safe=safeproto(proto);if(safe=""){<""};let trans=extracttransport(transport);if(trans=""){<""};<safe+"://"+trans>;};f=main():$void{let channel=bindchannel("https";"unix:/var/run/myapp.sock");<channel;};