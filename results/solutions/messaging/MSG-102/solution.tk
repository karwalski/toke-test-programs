m=notif;f=soundtype(msgtype:$str;relation:$str;prefs:$str):$str{if(msgtype="critical"){<"critical"};if(msgtype="warning"){<"warning"};if(msgtype="info"){if(relation="colleague"){<"colleague"};if(relation="friend"){<"friend"};if(relation="acquaintance"){<"acquaintance"};if(relation="stranger"){<"stranger"};<"info"};<"unknown"};f=selectsound(prefs:$str;msgtype:$str;relation:$str):$str{if(prefs="dark"){<"dark"}