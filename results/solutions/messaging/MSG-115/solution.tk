m=encryptkey;f=passwordhash(password:$str):$str{let salt=mut."salt_";let result=mut."";lp(let i=0;i<password.len;i=i+1){let ch=password.get(i);let tmp=salt+ch;result=tmp;};<result};f=encryptkey(key:$str;password:$str):$str{let hash=passwordhash(password);let xor=mut."";lp(let i=0;i<key.len;i=i+1){let ch=key.get(i);let hch=hash.get(i);let tmp=ch as i64+hch as i64;let modval=tmp-tmp/256*256;let ch2=modval as u8;xor=xor+ch2;};<xor};