m=conversation;i=io:std.io;i=s:std.str;i=json:std.json;f=parsestatemap(def:$str):$map{let parsed=json.parse(def);let states=parsed["states"];let transitions=parsed["transitions"];let statemap=map.new();for t in transitions{let key=t["from"]+"|"+t["event"];statemap[key]=t["to"]};< statemap};f=main():$i64{let def=io.readln();let statemap=parsestatemap(def);let state=io.readln();io.println(s.concat(state;" (initial)"));while true{let event=io.readln();if event==""{break};let key=s.concat(s.concat(state;"|");event);if statemap.has(key){let newstate=statemap[key];io.println(s.concat(state;" -> ")+newstate+s.concat(s.concat(" (";event);")"));state=newstate}else{io.println("INVALID TRANSITION")}};< 0};