m=broker;f=subscribe(state:$str;client:$str;topic:$str):$str{let entry=s.concat(s.concat(client;"=");topic);let current=state;if(current.len=0){<entry};let result=mut.current;result=s.concat(result;entry);<result};f=publish(state:$str;topic:$str;message:$str):$str{let found=mut.false;let clients=mut.@();let topics=mut.@();lp(let idx=0;idx<state.len;idx=idx+1){let ch=state.get(idx);if(ch="+"){found=true;let client=mut."";let t=mut.topics.len;lp(let j=0;j<t;j=j+1){let tc=topics.get(j);if(tc=topic){let c=clients.get(j);client=c;};};let clientlen=client.len;if(clientlen>0){let clientidx=mut.0;lp(let k=0;k<clientlen;k=k+1){let cc=client.get(k);if(cc="+"){clientidx=k+1;};};let clientpart=client.get(clientidx);if(clientpart.len>0){clients=clients+clientpart;};};};if(found){let client=clients;let topic=topic;let message=message;let result=mut."";result=s.concat(result;client);result=s.concat(result;"=");result=s.concat(result;topic);result=s.concat(result;"=");result=s.concat(result;message);<result};};f=un