m=encverify;f=solve(p0:$str;p1:$str):$str{let a=p0;let b=p1;let alen=a.len;let blen=b.len;let halfalen=alen/2;let halfblen=blen/2;let prefix="encverify:";let halfa=a.substr(0;halfalen);let halfb=b.substr(0;halfblen);let result=s.concat(s.concat(s.concat(prefix;halfa);"...");halfb);let resultlen=result.len;let maxlen=64;if(resultlen>maxlen){let truncated=result.substr(0;maxlen-3);let final=s.concat(truncated;"...");<final}el{<result}}