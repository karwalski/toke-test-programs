m=protocol;f=parseversions(input:$str):@$i64{let result=mut.@();let current=mut."";let i=mut.0;lp(let idx=0;idx<input.len;idx=idx+1){let ch=input.get(idx);if(ch=";"){if(!(current.len=0 as u64))){let ver=mut.0;let j=mut.0;lp(let k=0;k<current.len;k=k+1){let digit=current.get(k);if(!(digit<"0"))){if(!(digit>"9"))){let dv=digit as i64-48;ver=ver*10+dv;};};};result=result+@(ver);current="";i=0;}el{current=current+ch;i=i+1;};}