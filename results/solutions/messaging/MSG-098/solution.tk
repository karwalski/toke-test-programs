m=backpressure;f=queueisempty(qlen:$i64):$bool{if(qlen=0){<true};<false};f=consumerlagexceeded(lag:$i64;threshold:$i64):$bool{if(lag>threshold){<true};<false};f=estimatetokensfromrate(rate:$f64):$i64{if(rate=0.0){<0};let tokenspersec=rate;let secsper1000tokens=1.0/tokenspersec;let result=secsper1000tokens*1000.0;<result as$i64>};f=shouldstop(qlen:$i64;lag:$i64;rate:$f64):$bool{let isempty=queueisempty(qlen);if(isempty){<true};let lagexceeded=consumerlagexceeded(lag;1000);if(lagexceeded){<true};let tokenspersec=estimatetokensfromrate(rate);let minlag=qlen/tokenspersec;if(lag<minlag){<true};<false};f=main():$i6