m=solve;i=s:std.str;f=solve(p0:$str;p1:$str):$str{let schema=p0;let hex=p1;let jsonout=mut."";let keys=mut.@();let vals=mut.@();let i=mut.0;let n=schema.len;lp(let idx=0;idx<n;idx=idx+1){let ch=schema.get(idx);if(ch=":"){let start=i;let end=idx;let key=schema.slice(start;end);keys=keys+@(key);i=idx+1;};};let nkeys=keys.len;lp(let idx=0;idx<nkeys;idx=idx+1){let key=keys.get(idx);let start=i;let end=hex.len;let val=hex.slice(start;end);vals=vals+@(val);i=hex.len;};let nvals=vals.len;lp(let idx=0;idx<nvals;idx=idx+1){let key=keys.get(idx);let val=vals.get(idx);let pair=s.concat(s.concat(key;":");val);let sep=mut."";if(idx=0){sep="";}el{sep="\n"};jsonout=s.concat(s.concat(jsonout;sep);pair);};<jsonout};