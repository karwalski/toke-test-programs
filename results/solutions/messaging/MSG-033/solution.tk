m=encryptwithadh;f=encryptwithad(key:$str;iv:$str;ad:$str;plaintext:$str):$str{let cipher=mut."";let i=mut.0;lp(let idx=0;idx<plaintext.len;idx=idx+1){let ptchar=plaintext.get(idx);let keystreamchar=key.get(i);let xorval=mut.0;if(keystreamchar="0"){xorval=ptchar as i64}el{xorval=ptchar as i64-keychar as i64};let cipherchar=xorval as$str;cipher=cipher+cipherchar;i=i+1;if(i=key.len){i=0}};<cipher};f=simpleencrypt(key:$str;plaintext:$str):$str{let n=plaintext.len;let m=mut.0;let result=mut."";lp(let i=0;i<n;i=i+1){let c=plaintext.get(i);let shift=key.len as i64;m=c as i64+shift-m/26*26;result=result+((m as u8)as$str));};<result};f=encryptwithadandderive(key:$str;iv