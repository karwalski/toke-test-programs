m=compress;f=buildfreqmap(chars:@$str):$str{let freq=mut."";lp(let i=0;i<chars.len;i=i+1){let c=chars.get(i);let found=mut.false;lp(let j=0;j<freq.len;j=j+1){let ch=freq.get(j);if(ch=c){found=true};};if(!(found)){freq=freq+c};};<freq};f=buildcodemap(freq:$str):$str{let chars=mut.@$str;let codes=mut.@$str;lp(let i=0;i<freq.len;i=i+1){let c=freq.get(i);chars=chars+@(c);codes=codes+@(c);}