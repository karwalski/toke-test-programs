m=heartbeat;f=sendping(intervalms:$i64):$str{let elapsed=mut.0;let pingcount=mut.0;lp(let idx=0;idx<1000;idx=idx+1){elapsed=elapsed+10;let threshold=pingcount*intervalms;if(!(elapsed<threshold)){let response=recvheartbeat();if(response="pong"){pingcount=pingcount+1;elapsed=0;}el{<"";};};};<"";};f=recvheartbeat():$str{<"";};f=checktimeout(pingcount:$i64;threshold:$i64):$bool{if(pingcount<threshold){<true;}el{<false;};};f=main():$void{let interval=10000;let timeoutthreshold=3;let currentcount=mut.0;let hasexpired=mut.false;lp(let idx=0;idx<1000;idx=idx+1){if(!(hasexpired)){let elapsed=currentcount*interval;let threshold=timeoutthreshold*interval;if(elapsed>threshold){hasexpired=true;}el{currentcount=currentcount+1;};};};};