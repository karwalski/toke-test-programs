m=atmentions;f=solve(p0:$str;p1:$str):$str{let users=std.json.parse(p0);let msg=p1;let result=mut."";let i=mut.0;let len=msg.len;lp(let pos=0;pos<len;pos=pos+1){let ch=msg.charat(pos);if(ch="@"){let j=mut.pos+1;lp(let k=j;k<len;k=k+1){let c=msg.charat(k);if(c=" "){j=k+1;};};let found=mut.false;let username=mut."";lp(let idx=0;idx<users.len;idx=idx+1){let u=users.get(idx);let nameu=u.username;let lennameu=nameu.len;let lenj=j.len;if(!(lennameu>lenj))){let match=mut.true;lp(let m=0;m<lennameu;m=m+1){let c1=nameu.charat(m);let c2=j.charat(m);if(!(c1=c2))){match=false;};};if(match){username=nameu;found=true;j=k+1;};};};if(found){let disp=u.display;let start=j-1;let before=msg.substr(0;start);let after=msg.substr(j;len);let newmsg=before+disp+after;result=newmsg;};if(!(found)){result=msg;};};f=main():$void{let p0=@({"username":"alice";"display":"Alice Smith"};{"username":"bob";"display":"Bob Johnson"}));let p1="hello @alice and @bob";let r=solve(p0;p1);<r};