m=arrowmaze;f=solve(arr:@$str;n:$i64;m:$i64):$str{let dirs=arr;let startx=n;let starty=m;let x=mut.startx;let y=mut.starty;let result=mut."";let found=mut.false;lp(let i=0;i<1000;i=i+1){let dir=dirs.get(y);let ch=dir.get(x);if(ch="N"){y=y-1}el{if(ch="S"){y=y+1}el{if(ch="E"){x=x+1}el{if(ch="W"){x=x-1}el{}}}}};if(!(x<0)){if(!(y<0)){if(!(x>n)){if(!(y>m)){result="Found";found=true}}}}};if(found){<result}el{<""}};