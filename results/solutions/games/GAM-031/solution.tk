m=gameoflife;f=neighbours(x:$i64;y:$i64):@$i64{let result=mut.@();lp(let dx=-1;dx<2;dx=dx+1){if(dx=0){}el{let nx=x+dx;result=result+@(nx);};};lp(let dy=-1;dy<2;dy=dy+1){if(dy=0){}el{let ny=y+dy;result=result+@(ny);};};<result};f=cellstate(cells:@$bool;x:$i64;y:$i64):$bool{let live=mut.false;let n=neighbours(x;y);lp(let i=0;i<n.len;i=i+1){let nx=n.get(i);if(cells.get(nx)=true)){live=true;};};<live};f=applyrule(cells:@$bool;x:$i64;y:$i64):$bool{let current=cells.get(x);let live=cellstate(cells;x;y);if(current=true){if(live=false){<false};<true};if(current=false){if(live=true){<true};<false};<false};f=nextgeneration