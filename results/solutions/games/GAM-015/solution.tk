m=wordle;i=io:std.io;i=s:std.str;f=feedback(target:$str;guess:$str):$str{let result=mut."";let n=target.len;let i=mut.0;lp(let idx=0;idx<n;idx=idx+1){let tchar=target.get(idx);let gchar=guess.get(idx);if(tchar=gchar){result=s.concat(result;"G");}el{let found=mut.false;lp(let jdx=0;jdx<n;jdx=jdx+1){let jchar=guess.get(jdx);if(tchar=jchar){found=true;};};if(found){result=s.concat(result;"Y");}el{result=s.concat(result;"B");};};};<result};f=main():$i64{let target=io.readln();let guess=io.readln();let result=feedback(target;guess);io.println(result);<0};