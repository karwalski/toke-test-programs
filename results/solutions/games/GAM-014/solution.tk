m=hangman;f=playhangman(word:$str;guesses:@$str):$str{let lives=mut.6;let masked=mut.word;let i=mut.0;lp(let idx=0;idx<guesses.len;idx=idx+1){let guess=guesses.get(idx);let found=mut.false;let j=mut.0;lp(let k=0;k<word.len;k=k+1){let ch=word.get(k);if(ch=guess){if(!(found)){masked=masked.sub(0;k)+guess+masked.sub(k+1;word.len);found=true;};};};if(found){lives=lives;}el{if(!(lives=0))){lives=lives-1;};};};<masked+s.concat(" lives: ";lives) as$str;};