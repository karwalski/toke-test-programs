m=skyscraper;f=solve(n:$i64;m:$i64):$str{let grid=mut.@();lp(let i=0;i<n;i=i+1){let row=mut.@();lp(let j=0;j<n;j=j+1){row=row+@(0)};grid=grid+@(row)};let top=mut.@();lp(let i=0;i<n;i=i+1){top=top+@(0)};lp(let i=0;i<n;i=i+1){let row=grid.get(i);let visible=mut.0;lp(let j=0;j<n;j=j+1){let height=row.get(j);if(height>visible){visible=height}};top.get(i)=visible}};let result=mut."";lp(let i=0;i<n;i=i+1){let row=grid.get(i);lp(let j=0;j<n;j=j+1){let cell=row.get(j);if(cell=0){result=s.concat(result;" ")}el{result=s.concat(result;cell) as$str}};if(!(i=n-1)){result=s.concat(result;"\n")}};<result};