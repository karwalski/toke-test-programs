m=mastermind;f=solve(p:$str;q:$str):$str{let code=p;let guess=q;let result=mut."";let codearr=mut.@();let guessarr=mut.@();let i=mut.0;lp(let idx=0;idx<code.len;idx=idx+1){let ch=code.get(idx);codearr=codearr+@(ch);};lp(let idx=0;idx<guess.len;idx=idx+1){let ch=guess.get(idx);guessarr=guessarr+@(ch);};let black=mut.0;let white=mut.0;lp(let idx=0;idx<codearr.len;idx=idx+1){let c=codearr.get(idx);let g=guessarr.get(idx);if(c=g){black=black+1;};}