m=main;i=io:std.io;i=str:std.str;f=evaluatescore(target:$str;response:$str):$i64{let targetarr=str.split(target;" ");let responsearr=str.split(response;" ");let n=targetarr.len;let m=responsearr.len;let minlen=mut.0;if(n<m){minlen=n}el{minlen=m};let score=mut.0;lp(let idx=0;idx<minlen;idx=idx+1){if(targetarr.get(idx)=responsearr.get(idx))){score=score+1}};let result=mut.0;if(score=minlen){result=score}el{result=0}};f=main():$i64{let target=io.readline();let response=io.readline();let score=evaluatescore(target;response);<score};