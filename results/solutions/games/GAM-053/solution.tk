m=pegjump;f=canjump(board:@$bool;fromidx:$i64;toidx:$i64):$bool{let frompos=fromidx as u64;let topos=toidx as u64;let boardlen=board.len;if(!(frompos<boardlen)){<false};if(!(topos<boardlen)){<false};let fromval=board.get(frompos);let toval=board.get(topos);let isempty=mut.false;if(fromval=false){isempty=true};if(toval=false){isempty=true};if(!(isempty=true)){<false};let jumpidx=frompos+(topos-frompos)/2);let jumppos=jumpidx as u64;let jumpval=board.get(jumppos);let isjumpable=mut.false;if(jumpval=false){isjumpable=true};if(!(isjumpable=true)){<false};<true};f=apply