m=roulette;f=spin(seed:$i64):$i64{let result=seed-(seed/37)*37;if(result=0){<37};<result};f=playround(seed:$i64;bets:$i64):$i64{let spinresult=spin(seed);let pay=mut.0;if(spinresult=bets){pay=36*bets};if(!(pay>0))){if(spinresult=1){pay=100};if(spinresult=2){pay=50};if(spinresult=3){pay=25};if(spinresult=4){pay=10};if(spinresult=5){pay=5};if(spinresult=6){pay=2};if(spinresult=7){pay=1};};<pay};f=main():$i64{let seed=1;let bets=18;let balance=mut.1000;let spins=mut.0;lp(let idx=0;idx<10;idx=idx+1){let pay=playround(seed+spins;bets);balance=balance+pay;sp