m=validate;f=validateplacement(board:@$str;piece:$str;pos:i64;player:i64):$bool{let n=board.len;let m=piece.len;let validpos=mut.false;if(!(pos<0)){if(!(pos>n+m-1))){validpos=true;};};let valid=mut.false;if(validpos){let corners=@(0;0;n-1;0;n-1;n-1);let cornercount=corners.len;lp(let i=0;i<cornercount;i=i+1){let c=corners.get(i);let cc=c as i64;let iscorner=mut.false;if(cc=0){iscorner=true;};if(cc=n-1){iscorner=true;};if(cc=0){iscorner=true;};if(iscorner){let cornerplayer=mut.0;if(!(cc<0)){if(!(cc>n-1))){cornerplayer=board.get(cc)as i64;};};let pieceplayer=mut.0;if(!(player<0)){if(!(player>1))){pieceplayer=player;};};let validcorner=mut.false;if(cornerplayer=pieceplayer){validcorner=true;};let