m=validpairs;f=solve(p0:@$str):@$str{let result=mut.@();let n=p0.len;lp(let i=0;i<n-1;i=i+1){let p=p0.get(i);let q=p0.get(i+1);let edge1=p.substr(p.len-1;1);let edge2=q.substr(0;1);let valid=mut.false;if(edge1="|"){if(edge2="|"){valid=true}};if(valid){let pair=p+"/"+q;result=result+@(pair)}};<result};