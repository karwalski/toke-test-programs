m=ecosys;f=solve(p0:$i64;p1:$i64;n:$i64):$str{let x=mut.p0;let y=mut.p1;let result=mut."";lp(let i=0;i<n;i=i+1){let tmpx=x;let tmpy=y;let dx=tmpx*0.1-tmpx*0.01-tmpy*0.01;let dy=tmpy*0.1-tmpy*0.01-tmpx*0.01;let nx=tmpx+dx;let ny=tmpy+dy;result=s.concat(s.concat(result;"step ");i) as$str+s.concat(": x=";nx) as$str+s.concat(" y=";ny) as$str+"\n";x=nx;y=ny;};<result};f=main():$void{let out=solve(50;20;10));<};