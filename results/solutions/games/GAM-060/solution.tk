m=othello;f=validatemove(board:@$i64;x:$i64;y:$i64):bool{let n=8;let dx=@(0;1;1;1;0;-1;-1;-1);let dy=@(0;0;1;0;-1;0;1;0);let result=mut.false;lp(let i=0;i<16;i=i+1){let cx=x+dx.get(i);let cy=y+dy.get(i);let valid=mut.false;if(cx>0){if(cx<n){if(cy>0){if(cy<n){valid=true;};};};};if(valid){let found=mut.false;lp(let j=i+1;j<16;j=j+1){let nx=x+dx.get(j);let ny=y+dy.get(j);if(nx=cx){if(ny=cy){found=true;};};if(found){result=true;};};};};};};};};};};};};};};};};};};};};};};};};}