m=seqgen;f=solve(p0:$str;p1:$i64):$str{let seq=p0;let n=p1;let len=seq.len;let lastidx=len-1;let lastval=seq.get(lastidx);let result=mut."";lp(let i=0;i<n;i=i+1){let modval=i-i/2*2;if(modval=0){result=s.concat(result;lastval) as$str}el{let idx=i-i/2*2;let val=seq.get(idx);result=s.concat(result;val) as$str}};<result};