m=eval;f=evalpos(fen:$str):$i64{let pieces=mut.@();let ranks=mut.@();let i=mut.0;lp(let idx=0;idx<fen.len;idx=idx+1){let ch=fen.get(idx);if(ch="/"){ranks=ranks+@(i);i=0;}el{i=i+1;};};ranks=ranks+@(i);let board=mut.@();lp(let ridx=0;ridx<ranks.len;ridx=ridx+1){let rank=ranks.get(ridx);lp(let pidx=0;pidx<rank;pidx=pidx+1){let ch=fen.get(rank+pidx));if(!(ch=" ")){board=board+@(ch);};};};let wp=mut.0;let bp=mut.0;lp(let idx=0;idx<board.len;idx=idx+1){let ch=board.get(idx);if(ch="P"){wp=wp+1;}el{if(ch="p"){bp=bp+1;}el{};};};let score=wp-bp;<score;};