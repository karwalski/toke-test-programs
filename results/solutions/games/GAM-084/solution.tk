m=shuffle;f=shuffle(n:$i64;m:$i64):$i64{let r=mut.0;let s=mut.0;lp(let i=0;i<m;i=i+1){let j=i+i/2;let tmp=n.get(i);n.get(i)=n.get(j);n.get(j)=tmp;};<n};f=deal(hands:$i64;cardsperhand:$i64;totalcards:$i64):$i64{let result=mut.@();lp(let i=0;i<hands;i=i+1){let hand=mut.@();lp(let j=0;j<cardsperhand;j=j+1){if((i*cardsperhand+j)<totalcards)){hand=hand+@((i*cardsperhand+j)<totalcards));};};result=result+@(hand);};<result};f=main(args:@$str):i64{let seed=args.get(0);let hands=args.get(1);let cardsperhand=args.get(2);let totalcards=args.get(3);let shuffled=shuffle(seed;totalcards);let dealt=deal(shuffled;hands;cardsperhand;totalcards);lp(let i=0;i<dealt.len;i=i+1){let hand=dealt.get(i);let output=mut."";lp(let j=0;j<hand.len;j=j+1){let card=hand.get(j);output=output+card;if(!(j=hand.len-1))){output=s.concat(output;" ");};};<output;};