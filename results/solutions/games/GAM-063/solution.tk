m=chessclock;f=chessclock(startwhite:$i64;startblack:$i64;movesequence:$str;elapsedtimes:$i64):$str{let white=mut.startwhite;let black=mut.startblack;let moves=movesequence.split(" ");let times=elapsedtimes;lp(let i=0;i<moves.len;i=i+1){let m=moves.get(i);if(i=0){let w=mut.white;let b=mut.black;lp(let j=0;j<times;j=j+1){let wtmp=w-1;if(wtmp<0){let btmp=b-1;if(btmp<0){w=0;b=0;}el{b=btmp;};}el{w=wtmp;};};if(w=0){let result="White time expired. Black wins.";<result;}el{let btmp=b-1;if(btmp<0){b=0;}el{b=btmp;};};}el