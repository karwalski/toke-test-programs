m=kalah;f=evalboard(board:$str):$i64{let score=mut.0;let i=mut.0;lp(let idx=0;idx<6;idx=idx+1){let val=board.get(idx);if(val>0){score=score+val};};let j=mut.0;lp(let idx=6;idx<12;idx=idx+1){let val=board.get(idx);if(val>0){score=score-val};};<score};f=generatemoves(board:$str):@$str{let moves=mut.@()