m=dungeon;f=solve(left:$str;right:$str):$str{let lines=left.split("\n");let result=mut."";lp(let i=0;i<lines.len;i=i+1){let line=lines.get(i);let parts=line.split(" ");let num1=parts.get(0).parsei64();let num2=parts.get(1).parsei64();let diff=num2-num1;let avg=diff/2;let offset=avg;let newx=num1+offset;let newy=num2-offset;let newline=newx.str+" "+newy.str;let newresult=result+newline;if(!(i=(lines.len-1)))){newresult=newresult+"\n"};result=newresult;};<result};f=main():$void{let left="10 5\n15 10\n20 5\n25 10\n30 5";let right="5 10\n10 15\n15 20\n20 25\n25 30";let result=solve(left;right);<result};