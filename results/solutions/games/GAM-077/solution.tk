m=knapsack;i=io:std.io;i=s:std.str;f=main():$i64{let cap=s.toint(s.trim(io.readln()));let names=mut.@();let weights=mut.@();let values=mut.@();let count=mut.0;let reading=mut.1;lp(reading=1){let line=io.readln();if(s.len(s.trim(line))<1){reading=0}el{let parts=s.split(s.trim(line);" ");if(parts.len()>=3){names=names+@(parts.get(0));weights=weights+@(s.toint(parts.get(1)));values=values+@(s.toint(parts.get(2)));count=count+1}el{reading=0}}};let best=mut.0;let bestmask=mut.0;let total=mut.1;let p=mut.0;lp(p<count){total=total*2;p=p+1};let mask=mut.0;lp(mask<total){let w=mut.0;let v=mut.0;let b=mut.0;lp(b<count){let bit=mask/pow2(b);if(bit-(bit/2)*2=1){w=w+weights.get(b);v=v+values.get(b)};b=b+1};if(w<=cap){if(v>best){best=v;bestmask=mask}};mask=mask+1};let chosen=mut."";let b2=mut.0;lp(b2<count){let bit=bestmask/pow2(b2);if(bit-(bit/2)*2=1){if(s.len(chosen)>0){chosen=chosen+" "};chosen=chosen+names.get(b2)};b2=b2+1};io.println(chosen);io.println(s.concat("Total value: ";s.fromint(best)));<0};f=pow2(n:$i64):$i64{let r=mut.1;let k=mut.0;lp(k<n){r=r*2;k=k+1};<r}