m=validms;i=io:std.io;i=s:std.str;f=validms(grid:$i64;n:$i64):$bool{let target=mut.0;let first=grid;let second=grid+n;let diag1=mut.0;let diag2=mut.0;lp(let i=0;i<n;i=i+1){diag1=diag1+grid+i*n;diag2=diag2+grid+(n-1-i)*n;};lp(let i=0;i<n;i=i+1){let row=mut.0;let col=mut.0;lp(let j=0;j<n;j=j+1){row=row+grid+i*n+j;col=col+grid+i*n+j;};if(!(row=target)){<false};if(!(col=target)){<false};};if(!(diag1=target)){<false};if(!(diag2=target)){<false};<true};f=main():$i64{let line1=io.readln();let parts1=s.split(line1;" ");let n=s.len(parts1);let grid=mut[n*n];lp(let i=0;i<n;i=i+1){let line=io.readln();let parts=s.split(line;" ");lp(let j=0;j<n;j=j+1){grid[i*n+j]=s.toint(parts[j]);};};let target=mut.0;lp(let j=0;j<n;j=j+1){target=target+grid[j];};if(validms(&grid[0];n)){io.println(s.concat("Magic square with sum ";s.fromint(target)));}else{io.println("Not a magic square");};<0};