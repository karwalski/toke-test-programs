m=pegsol;f=solve(n:$i64):$str{if(n<1){<""};let size=n*2-1;let board=mut.@();lp(let i=0;i<size*size;i=i+1){board=board+@(false)}};lp(let r=0;r<1;r=r+1){let center=size/2;let centeridx=center*size+center;board.get(centeridx)=true}};lp(let r=0;r<1;r=r+1){let found=mut.false;lp(let i=0;i<board.len;i=i+1){if(!board.get(i)){found=true}}}};lp(let r=0;r<1;r=r+1){if(!found){<""};let path=mut."";let x=mut.center;let y=mut.center;lp(let r=0;r<1;r=r+1){let moved=mut.false;lp(let dir=0;dir<4;dir=dir+1){let dx=mut.0;if(dir=0){dx=1}el{if(dir=1){dx=-1}}};let dy=mut.0;if(dir=0){dy=0}el