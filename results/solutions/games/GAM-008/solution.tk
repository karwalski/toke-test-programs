m=chess;f=solve(p:$str;q:$str):$str{let result=mut."";let piece=p;let pos=q;let x=pos.substr(0;1);let y=pos.substr(1;1);let xval=x as i64;let yval=y as i64;let knightmoves=@(1;2;2;1;-1;-2;-2;-1);let knightidx=mut.0;let knightx=xval;let knightr=mut.0;let knighty=yval;let knightfound=mut.false;lp(let idx=0;idx<knightmoves.len;idx=idx+1){let move=knightmoves.get(idx);let modenum=move as i64;let newx=knightx+modenum;let newy=knighty+modenum;let newpos=newx as$str+newy as$str;let newposval=newpos as i64;if(!(newposval<0))){if(!(newposval>8))){result=result+newpos;}}};<result};