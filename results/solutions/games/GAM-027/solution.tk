m=ast;f=heuristic(a:$str;b:$str):$i64{let ax=a.charat(0)as.i64-97;let ay=a.charat(1)as.i64-49;let bx=b.charat(0)as.i64-97;let by=b.charat(1)as.i64-49;let dx=bx-ax;let dy=by-ay;if(dx<0){dx=-dx};if(dy<0){dy=-dy};<dx+dy};f=astsearch(grid:$str;start:$str;goal:$str):$str{let rows=grid.split("\n");let rowcount=rows.len;let cols=rows.get(0).split(" ");let colcount=cols.len;let startpos=start.split(" ");let startX=startpos.get(0).as.i64;let startY=startpos.get(1).as.i64;let goalpos=goal.split(" ");let goalX=goalpos.get(0).as.i64;let goalY=goalpos.get(1).as.i64;let openlist=mut.@();let closedlist=mut.@