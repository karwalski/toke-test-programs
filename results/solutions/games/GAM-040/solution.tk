m=ladder;i=io:std.io;i=s:std.str;f=diffone(a:$str;b:$str):$bool{let la=s.len(a);let lb=s.len(b);if(la!=lb){<false};let diff=mut.0;lp(let k=0;k<la;k=k+1){let ca=s.slice(a;k;k+1);let cb=s.slice(b;k;k+1);if(ca!=cb){diff=diff+1}};if(diff=1){<true};<false};f=setat(arr:@$i64;idx:$i64;val:$i64):@$i64{let res=mut.@();let len=arr.len();lp(let k=0;k<len;k=k+1){if(k=idx){res=res+@(val)}el{res=res+@(arr.get(k))}};<res};f=main():$i64{let start=s.trim(io.readln());let end=s.trim(io.readln());let words=mut.@();let reading=mut.true;lp(reading){let raw=io.readln();let line=s.trim(raw);if(s.len(line)>0){words=words+@(line)}el{reading=false}};let n=words.len();let prev=mut.@();let dist=mut.@();lp(let k=0;k<n;k=k+1){prev=prev+@(0-1);dist=dist+@(0-1)};let startidx=mut.(0-1);let endidx=mut.(0-1);lp(let k=0;k<n;k=k+1){let w=words.get(k);if(w=start){startidx=k};if(w=end){endidx=k}};if(startidx<0){io.println("No ladder");<0};if(endidx<0){io.println("No ladder");<0};let queue=mut.@(startidx);dist=setat(dist;startidx;0);let head=mut.0;lp(head<queue.len()){let cur=queue.get(head);head=head+1;let cw=words.get(cur);let dcur=dist.get(cur);lp(let j=0;j<n;j=j+1){if(dist.get(j)<0){let nw=words.get(j);if(diffone(cw;nw)){dist=setat(dist;j;dcur+1);prev=setat(prev;j;cur);queue=queue+@(j)}}}};if(dist.get(endidx)<0){io.println("No ladder");<0};let path=mut."";let node=mut.endidx;lp(node>=0){let w=words.get(node);if(s.len(path)=0){path=w}el{path=s.concat(s.concat(w;" ");path)};node=prev.get(node)};io.println(path);<0}