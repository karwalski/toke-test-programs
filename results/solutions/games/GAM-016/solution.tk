m=guesser;f=extractletters(s:$str):$str{let n=s.len;let m=mut."";lp(let i=0;i<n;i=i+1){let c=s.get(i);let islower=mut.false;if(c>96){if(c<123){islower=true}};if(islower){m=m+c}};let result=mut."";let ml=m.len;lp(let i=0;i<ml;i=i+1){let c=m.get(i);let found=mut.false;let rl=result.len;lp(let j=0;j<rl;j=j+1){let cc=result.get(j);if(cc=c){found=true}};if(!(found)){result=result+c}}};f=sortbylen