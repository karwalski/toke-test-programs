m=hexwin;f=checkwin(board:$str;n:$i64;player:$str):$str{let directions=@("up";"down";"left";"right";"upright";"upleft");lp(let di=0;di<directions.len;di=di+1){let dir=directions.get(di);let count=mut.1;let x=mut.0;let y=mut.0;if(dir="up"){x=0;y=1;}el{if(dir="down"){x=0;y=0;}el{if(dir="left"){x=1;y=0;}el{if(dir="right"){x=0;y=0;}el{if(dir="upright"){x=0;y=1;}el{if(dir="upleft"){x=1;y=1;}el{}}}}}}};lp(let xi=0;xi<n;xi=xi+1){lp(let yi=0;yi<n;yi=yi+1){let cell=board.get(xi*n+yi);if(cell=player){let dx=mut.0;let dy=mut.0;if(dir="up"){dx=0;dy=1;}el{if(dir="down"){dx=0;dy=0;}el{if(dir="left"){dx=1;dy=0;}el{if(dir="right"){dx=0;dy=0;}el{if(dir="upright"){dx=0;dy=1;}el{if(dir="upleft"){dx=1;dy=1;}el{}}}}}}};let nx=xi+dx;let ny=yi+dy;if(nx<n){if(ny<n){let ncell=board.get(nx*n+ny);if(ncell=player){count=count+1;xi=nx;yi=ny;nx=xi+dx