m=guessinggame;f=checkguess(secret:$i64;guess:$i64):$str{if(guess=secret){<"correct"};if(guess<secret){<"lower"};if(guess>secret){<"higher"}};f=playgame(secret:$i64):$str{let guess=mut.0;let result=mut."";lp(let idx=0;idx<10;idx=idx+1){guess=guess+1;result=checkguess(secret;guess);if(result="correct"){<result}};<"incorrect"}};f=main():$i64{let secret=mut.42;let result=mut."";result=playgame(secret);<0};