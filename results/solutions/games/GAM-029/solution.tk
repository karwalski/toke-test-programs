m=clear;f=clearlines(board:$str):$str{let lines=mut.0;let rows=board.split("\n");let result=mut."";lp(let i=0;i<rows.len;i=i+1){let r=rows.get(i);let isfull=mut.true;lp(let j=0;j<r.len;j=j+1){let c=r.get(j);if(c="."){isfull=false};};if(isfull){lines=lines+1}el{result=result+r+"\n"};};<result};f=score(lines:$i64):$i64{let s=mut.0;lp(let i=0;i<lines;i=i+1){let base=mut.100;lp(let j=0;j<i;j=j+1){base=base+base/2;};s=s+base;};<s};f=main():$i64{let board=".......\n......X.\n......X.\n......X.\n......X.\n......X