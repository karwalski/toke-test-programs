m=liarsdice;
i=io:std.io;
i=s:std.str;
f=evaluatebid(allhidden:$str;bid:$str):$bool{let allarr=allhidden.split(" ");let bidarr=bid.split(" ");let num1=bidarr.get(0);let num2=bidarr.get(1);let count1=mut.0;let count2=mut.0;lp(let i=0;i<allarr.len;i=i+1){let dice=allarr.get(i);if(dice=num1){count1=count1+1};if(dice=num2){count2=count2+1}};let total=count1+count2;let bidval=num1 as i64;if(bidval<total){<true};<false};
f=main():$i64{let bidline=io.readln();let bidarr=bidline.split(" ");let bidcount=s.toint(bidarr.get(0));let bidface=bidarr.get(1);let allhidden="";let line1=io.readln();let line2=io.readln();let line3=io.readln();let dice1=line1.split(" ");let dice2=line2.split(" ");let dice3=line3.split(" ");lp(let i=0;i<dice1.len;i=i+1){allhidden=s.concat(allhidden;" ")+dice1.get(i)};lp(let i=0;i<dice2.len;i=i+1){allhidden=s.concat(allhidden;" ")+dice2.get(i)};lp(let i=0;i<dice3.len;i=i+1){allhidden=s.concat(allhidden;" ")+dice3.get(i)};let actualcount=0;let allarr=allhidden.split(" ");lp(let i=0;i<allarr.len;i=i+1){let dice=allarr.get(i);if(dice=bidface){actualcount=actualcount+1};if(dice="1"){actualcount=actualcount+1}};if(actualcount>=bidcount){io.println(s.concat("Bid stands: actual count ";s.fromint(actualcount)))}else{io.println(s.concat("Liar! actual count ";s.fromint(actualcount)))};< 0}