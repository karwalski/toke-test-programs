m=suggest;f=suggestnext(state:$str;letters:@$str):$str{let known=state;let wrongs=letters;let best=mut."";let score=mut.0;lp(let i=0;i<26;i=i+1){let c=(i+97)as u8;let ch=c as$str;let found=mut.false;lp(let j=0;j<wrongs.len;j=j+1){if(wrongs.get(j)=ch)){found=true};};if(!(found=true))){let inknown=mut.false;lp(let k=0;k<known.len;k=k+1){if(known.get(k)=ch)){inknown=true};};if(!(inknown=true))){let newscore=score+1;if(newscore>score)){best=ch;score=newscore};};};<best};