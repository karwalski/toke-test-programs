m=wordsearch;f=solve(p0:$str;p1:i64;p2:i64;p3:i64):$str{let words=p0.split(",");let rows=p1;let cols=p2;let seed=p3;let grid=mut."";lp(let i=0;i<rows;i=i+1){let row=mut."";lp(let j=0;j<cols;j=j+1){let idx=i*cols+j;let char=mut." ";if(!(idx<seed)){char=words.get(idx-seed));};row=s.concat(row;char);};grid=s.concat(s.concat(grid;row);"\n");};let result=mut."";lp(let i=0;i<rows;i=i+1){let line=grid.split("\n").get(i);let spaces=mut."";lp(let j=0;j<cols;j=j+1){spaces=s.concat(spaces;" ");};let combined=line+spaces;result=result+combined+"\n";};<result};