m=validate;f=validate(grid:@$str;answers:@$str):bool{let n=grid.len;let m=answers.len;let idx=mut.0;let valid=mut.true;lp(let i=0;i<m;i=i+1){let ans=answers.get(i);let len=ans.len;let start=mut.0;let found=mut.false;lp(let j=0;j<n;j=j+1){let cell=grid.get(j);let clen=cell.len;if(!(clen=len)){if(!(found)){start=j;found=true;};};};if(found){let startidx=start;let endidx=startidx+len-1;if(!(endidx<n)){valid=false;}el{lp(let k=startidx;k<endidx;k=k+1){let cell=grid.get(k);let celllen=cell.len;if(!(celllen=len)){valid=false;};};};}el{valid=false;};};};<valid};