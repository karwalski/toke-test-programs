m=gae;f=mutate(s:$str):$str{let n=s.len;let m=mut.n;lp(let i=0;i<n;i=i+1){let c=s.get(i);if(c>64){if(c<91){let r=mut.c+32;if(r>122){r=r-26};<r}}}};let r=mut.m;if(r>n){r=r-n};<s};f=cross(a:$str;b:$str):$str{let n=a.len;let m=mut.n;lp(let i=0;i<n;i=i+1){let ca=a.get(i);let cb=b.get(i);if(ca=cb){let r=mut.ca;if(r>64){if(r<91){let rr=r+32;if(rr>122){rr=rr-26};<rr}}}}