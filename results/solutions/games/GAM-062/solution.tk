m=dice;f=evaldice(expr:$str):$i64{let parts=expr.split("+");let total=mut.0;lp(let i=0;i<parts.len;i=i+1){let part=parts.get(i);let dpos=part.find("d");if(dpos<0){let num=part.parseint();total=total+num;}el{let num1=part.substr(0;dpos).parseint();let num2=part.substr(dpos+1;part.len).parseint();let roll=mut.0;lp(let j=0;j<num1;j=j+1){let r=mt(num2+1);roll=roll+r;};total=total+roll;};};<total};f=mt(n:$i64):$i64{let m=mut.0;lp(let i=0;i<n;i=i+1){m=m+1;};<m};