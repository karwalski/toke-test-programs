m=stockgame;f=playgame(prices:@$i64;cmds:@$str):$i64{let n=prices.len;let m=cmds.len;let bal=mut.1000;let pos=mut.0;lp(let i=0;i<m;i=i+1){let cmd=cmds.get(i);if(cmd="b"){let canbuy=mut.true;if(pos>0){canbuy=false};if(canbuy){let p=prices.get(i);if(p<bal){bal=bal-p;pos=pos+1;}el{bal=bal;pos=pos;};};};if(cmd="s"){let cansell=mut.true;if(pos=0){cansell=false};if(cansell){let p=prices.get(i);bal=bal+p;pos=pos-1;};};};};<bal>};