m=numbrix;i=io:std.io;i=s:std.str;f=pad(val:$str;w:$i64):$str{let res=mut.val;lp(s.len(res)<w){res=s.concat(" ";res)};<res};f=main():$i64{let first=io.readln();let fp=s.split(first;" ");let dim=fp.len();let cells=mut.@();let r=mut.0;lp(r<dim){let cur=mut."";if(r=0){cur=first}el{cur=io.readln()};let cp=s.split(cur;" ");let c=mut.0;lp(c<dim){cells=cells.push(s.toint(cp.get(c)));c=c+1};r=r+1};let total=dim*dim;let path=mut.@();let pr=mut.0;lp(pr<dim){if(pr%2=0){let cc=mut.0;lp(cc<dim){path=path.push(pr*dim+cc);cc=cc+1}}el{let cc2=mut.0;lp(cc2<dim){path=path.push(pr*dim+(dim-1-cc2));cc2=cc2+1}};pr=pr+1};let sol=mut.@();let g=mut.0;lp(g<total){sol=sol.push(0);g=g+1};let out=mut.0;lp(out<total){let pos=path.get(out);sol=sol.set(pos;out+1);out=out+1};let ok=mut.1;let k=mut.0;lp(k<total){let av=cells.get(k);if(av!=0){if(av!=sol.get(k)){ok=0}};k=k+1};let fin=mut.@();let fk=mut.0;lp(fk<total){if(ok=1){fin=fin.push(sol.get(fk))}el{fin=fin.push(cells.get(fk))};fk=fk+1};let maxv=mut.0;let mk=mut.0;lp(mk<total){if(fin.get(mk)>maxv){maxv=fin.get(mk)};mk=mk+1};let w=s.len(s.fromint(maxv));let ro=mut.0;lp(ro<dim){let lineout=mut."";let co=mut.0;lp(co<dim){if(co>0){lineout=s.concat(lineout;" ")};lineout=s.concat(lineout;pad(s.fromint(fin.get(ro*dim+co));w));co=co+1};io.println(lineout);ro=ro+1};<0}