m=wordfind;f=solve(p:$str;q:$i64):$str{let result=mut."";let len=p.len;let found=mut.false;lp(let idx=0;idx<len;idx=idx+1){let ch=p.get(idx);if(ch=" "){if(idx-q>0){let word=mut."";lp(let j=idx-q;j<idx;j=j+1){word=s.concat(word;p.get(j))};if(word=result){found=true}}};result=word}}};if(found){<result};<""};f=main():$void{let clue="seven-letter word for a person who is a member of a political party";let len=7;let result=solve(clue;len);if(result=""){<0};<1};